// AXIOM Standard Library — std::os::linux_sys
//
// Raw Linux x86-64 direct system calls.

pub const SYS_READ:  u64 = 0 as u64
pub const SYS_WRITE: u64 = 1 as u64
pub const SYS_OPEN:  u64 = 2 as u64
pub const SYS_CLOSE: u64 = 3 as u64
pub const SYS_MMAP:  u64 = 9 as u64
pub const SYS_MUNMAP: u64 = 11 as u64
pub const SYS_EXIT:  u64 = 60 as u64

extern "C" fn syscall(num: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64, a6: u64) -> i64
