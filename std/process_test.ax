// AXIOM Standard Library — std.process_test

import std.string

extern "C" fn GetStdHandle(nStdHandle: u32) -> ptr[void]
extern "C" fn WriteFile(hFile: ptr[void], lpBuffer: ptr[void], nNumberOfBytesToWrite: u32, lpNumberOfBytesWritten: ptr[void], lpOverlapped: ptr[void]) -> i32
extern "C" fn syscall(num: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64, a6: u64) -> i64

fn test_print_str(s: str):
    if @compiler_intrinsic("is_windows"):
        let h = GetStdHandle(0xFFFFFFF5 as u32)
        mut written := 0 as u32
        WriteFile(h, s as ptr[void], std.string.len(s) as u32, (&written) as ptr[void], null as ptr[void])
    else:
        syscall(1 as u64, 1 as u64, s as ptr[u8] as u64, std.string.len(s) as u64, 0 as u64, 0 as u64, 0 as u64)

fn test_process_spawn():
    mut cmd := new_command("cmd.exe")
    if not @compiler_intrinsic("is_windows"):
        cmd = new_command("/bin/echo")

    if @compiler_intrinsic("is_windows"):
        cmd.arg("/c")
        cmd.arg("echo")
        cmd.arg("Process_Test_Successful")
    else:
        cmd.arg("Process_Test_Successful")

    match cmd.output():
        Ok(output):
            assert(output.status.success() == true)
            assert(output.status.code == 0)
        Err(e):
            test_print_str("Error: ")
            test_print_str(e)
            test_print_str("\n")
            assert(false)
    test_print_str("  PASS: test_process_spawn\n")

pub fn main():
    test_print_str("Running AXIOM-native process unit tests...\n")
    test_process_spawn()
    test_print_str("All AXIOM-native process tests passed!\n")
