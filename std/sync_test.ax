// AXIOM Standard Library — std::sync_test
//
// Standalone unit tests for AXIOM-native synchronization primitives.

import std.string

extern "C" fn GetStdHandle(nStdHandle: u32) -> ptr[void]
extern "C" fn WriteFile(hFile: ptr[void], lpBuffer: ptr[u8], nNumberOfBytesToWrite: u32, lpNumberOfBytesWritten: ptr[void], lpOverlapped: ptr[void]) -> i32
extern "C" fn syscall(num: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64, a6: u64) -> i64

fn test_print_str(s: str):
    if @compiler_intrinsic("is_windows"):
        let h = GetStdHandle(0xFFFFFFF5 as u32)
        mut written := 0 as u32
        WriteFile(h, s as ptr[u8], std.string.len(s) as u32, (&written) as ptr[void], null as ptr[void])
    else:
        syscall(1 as u64, 1 as u64, s as ptr[u8] as u64, std.string.len(s) as u64, 0 as u64, 0 as u64, 0 as u64)

fn test_atomic_operations():
    mut at := atomic_new[i32](10 as i32)
    assert(at.load() == 10)

    at.store(20 as i32)
    assert(at.load() == 20)

    let old = at.swap(30 as i32)
    assert(old == 20)
    assert(at.load() == 30)

    let swapped = at.compare_and_swap(30 as i32, 40 as i32)
    assert(swapped == true)
    assert(at.load() == 40)

    let not_swapped = at.compare_and_swap(30 as i32, 50 as i32)
    assert(not_swapped == false)
    assert(at.load() == 40)
    test_print_str("  PASS: test_atomic_operations\n")

fn test_mutex_operations():
    mut m := mutex_new[i32](100 as i32)
    
    // Test lock & unlock
    let guard = m.lock()
    assert(guard.get() == 100)
    guard.set(200 as i32)
    assert(guard.get() == 200)
    guard.unlock()

    // Test try_lock
    let guard_opt = m.try_lock()
    assert(guard_opt.is_some())
    let g = guard_opt.unwrap()
    assert(g.get() == 200)
    g.unlock()
    test_print_str("  PASS: test_mutex_operations\n")

fn test_rwlock_operations():
    mut l := rwlock_new[i32](500 as i32)

    // Test read lock
    let r1 = l.read()
    assert(r1.get() == 500)
    let r2 = l.read()
    assert(r2.get() == 500)
    r1.unlock()
    r2.unlock()

    // Test write lock
    let w = l.write()
    assert(w.get() == 500)
    w.set(1000 as i32)
    assert(w.get() == 1000)
    w.unlock()
    test_print_str("  PASS: test_rwlock_operations\n")

pub fn main():
    test_print_str("Running AXIOM-native synchronization unit tests...\n")
    test_atomic_operations()
    test_mutex_operations()
    test_rwlock_operations()
    test_print_str("All AXIOM-native synchronization tests passed!\n")
