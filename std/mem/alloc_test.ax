// AXIOM Standard Library — std.mem.alloc_test
//
// Standalone unit tests for AXIOM-native allocator.

import std.string

extern "C" fn GetStdHandle(nStdHandle: u32) -> ptr[void]
extern "C" fn WriteFile(hFile: ptr[void], lpBuffer: ptr[void], nNumberOfBytesToWrite: u32, lpNumberOfBytesWritten: ptr[void], lpOverlapped: ptr[void]) -> i32
extern "C" fn syscall(num: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64, a6: u64) -> i64

fn test_print_str(s: str):
    if @compiler_intrinsic("is_windows"):
        let h = GetStdHandle(0xFFFFFFF5 as u32)
        mut written := 0 as u32
        WriteFile(h, s as ptr[void], std.string.len(s) as u32, (&written) as ptr[void], null as ptr[void])
    else:
        syscall(1 as u64, 1 as u64, s as ptr[u8] as u64, std.string.len(s) as u64, 0 as u64, 0 as u64, 0 as u64)

fn test_size_class_for():
    assert(ax_size_class_for(0) == 0)
    assert(ax_size_class_for(1) == 1) // user_size 1 + header 8 = 9 (<= 16) -> sc 1
    assert(ax_size_class_for(8) == 1) // 8 + 8 = 16 (<= 16) -> sc 1
    assert(ax_size_class_for(9) == 2) // 9 + 8 = 17 (<= 32) -> sc 2
    assert(ax_size_class_for(56) == 3) // 56 + 8 = 64 (<= 64) -> sc 3
    assert(ax_size_class_for(57) == 4) // 57 + 8 = 65 (<= 128) -> sc 4
    assert(ax_size_class_for(4088) == 9) // 4088 + 8 = 4096 (<= 4096) -> sc 9
    assert(ax_size_class_for(4089) == 10) // 4089 + 8 = 4097 (> 4096) -> sc 10
    test_print_str("  PASS: test_size_class_for\n")

fn test_free_list_push_pop():
    // Allocate a buffer on the OS stack/heap for raw blocks
    let raw = ax_os_alloc(256) as ptr[u8]
    assert(raw != null as ptr[u8])
    
    let block0 = raw
    let block1 = (raw as i64 + 32) as ptr[u8]
    let block2 = (raw as i64 + 64) as ptr[u8]
    
    mut list := FreeList(head: null as ptr[FreeSlot], count: 0)
    
    ax_free_list_push(&list, block0)
    ax_free_list_push(&list, block1)
    ax_free_list_push(&list, block2)
    assert(list.count == 3)
    
    let b2 = ax_free_list_pop(&list)
    let b1 = ax_free_list_pop(&list)
    let b0 = ax_free_list_pop(&list)
    
    assert(b2 == block2)
    assert(b1 == block1)
    assert(b0 == block0)
    assert(list.count == 0)
    
    let b_null = ax_free_list_pop(&list)
    assert(b_null == null as ptr[u8])
    
    ax_os_free(raw as ptr[void], 256)
    test_print_str("  PASS: test_free_list_push_pop\n")

fn test_segment_bump_alloc():
    ax_segment_manager_init()
    
    let seg = ax_segment_acquire(2) // SIZE_CLASS_32
    assert(seg != null as ptr[Segment])
    
    let b1 = ax_segment_bump_alloc(seg, 2)
    assert(b1 != null as ptr[u8])
    
    let b2 = ax_segment_bump_alloc(seg, 2)
    assert(b2 != null as ptr[u8])
    assert((b2 as i64 - b1 as i64) == 32)
    
    ax_segment_release(seg)
    ax_segment_manager_shutdown()
    test_print_str("  PASS: test_segment_bump_alloc\n")

fn test_actor_heap_lifecycle_and_alloc():
    ax_segment_manager_init()
    
    let heap = ax_actor_heap_create(42 as u64)
    assert(heap != null as ptr[ActorHeap])
    assert(heap.actor_id == 42 as u64)
    assert(heap.magic == ACTOR_HEAP_MAGIC)
    
    // Allocate different size classes
    let p1 = ax_actor_alloc(heap, 4) // 4 + 8 = 12 -> sc 1 (16 bytes)
    assert(p1 != null as ptr[u8])
    
    let p2 = ax_actor_alloc(heap, 20) // 20 + 8 = 28 -> sc 2 (32 bytes)
    assert(p2 != null as ptr[u8])
    
    let p3 = ax_actor_alloc(heap, 5000) // sc 10 (large alloc)
    assert(p3 != null as ptr[u8])
    
    // Check total allocation stats
    // sc 1 = 16, sc 2 = 32, sc 10 = 5000
    // total allocated metadata should reflect sc sizes (16 + 32) and large alloc (5000)
    assert(heap.total_allocated == (16 as u64 + 32 as u64 + 5000 as u64))
    assert(heap.alloc_count == 3 as u64)
    
    ax_actor_free(heap, p1)
    ax_actor_free(heap, p2)
    ax_actor_free(heap, p3)
    
    // Check that gen_id is invalidated (0)
    let hdr1 = (p1 as i64 - 8) as ptr[AxHeader]
    assert(hdr1.gen_id == 0 as u32)
    
    let hdr2 = (p2 as i64 - 8) as ptr[AxHeader]
    assert(hdr2.gen_id == 0 as u32)
    
    ax_actor_heap_destroy(heap)
    ax_segment_manager_shutdown()
    test_print_str("  PASS: test_actor_heap_lifecycle_and_alloc\n")

pub fn main():
    test_print_str("Running AXIOM-native Allocator unit tests...\n")
    test_size_class_for()
    test_free_list_push_pop()
    test_segment_bump_alloc()
    test_actor_heap_lifecycle_and_alloc()
    test_print_str("All AXIOM-native Allocator tests passed!\n")
