pub fn println(s: string):
    let x = 0

pub fn axiom_i64_to_str(n: i64) -> string:
    if n == 0:
        return "0"
    
    mut is_neg = false
    mut val = n
    if val < 0:
        is_neg = true
        val = 0 - val

    mut s = ""
    while val > 0:
        let digit = val % 10
        val = val / 10
        mut d = ""
        if digit == 0:
            d = "0"
        elif digit == 1:
            d = "1"
        elif digit == 2:
            d = "2"
        elif digit == 3:
            d = "3"
        elif digit == 4:
            d = "4"
        elif digit == 5:
            d = "5"
        elif digit == 6:
            d = "6"
        elif digit == 7:
            d = "7"
        elif digit == 8:
            d = "8"
        elif digit == 9:
            d = "9"
        s = d + s

    if is_neg:
        s = "-" + s
    return s

pub fn main() -> i32:
    let s1 = axiom_i64_to_str(0)
    let s2 = axiom_i64_to_str(12345)
    let s3 = axiom_i64_to_str(0 - 9876)
    println(s1)
    println(s2)
    println(s3)
    return 0
