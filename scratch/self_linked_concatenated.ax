        return "fadd"
    if op == OP_FSUB:
        return "fsub"
    if op == OP_FMUL:
        return "fmul"
    if op == OP_FDIV:
        return "fdiv"
    if op == OP_EQ:
        return "eq"
    if op == OP_NE:
        return "ne"
    if op == OP_LT:
        return "lt"
    if op == OP_LE:
        return "le"
    if op == OP_GT:
        return "gt"
    if op == OP_GE:
        return "ge"
    if op == OP_AND:
        return "and"
    if op == OP_OR:
        return "or"
    if op == OP_XOR:
        return "xor"
    if op == OP_SHL:
        return "shl"
    if op == OP_SHR:
        return "shr"
    if op == OP_NOT:
        return "not"
    if op == OP_NEG:
