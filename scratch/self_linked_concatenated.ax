            out_insts.push(MachInst(op: MACH_MOV_IMM, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_mask, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 255 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
            out_insts.push(MachInst(op: MACH_AND, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.dest, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_mask, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
        elif type_size == 2 as u32:
            let tmp_mask = next_vreg(sel)
            out_insts.push(MachInst(op: MACH_MOV_IMM, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_mask, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 65535 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
            out_insts.push(MachInst(op: MACH_AND, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.dest, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_mask, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
        elif type_size == 4 as u32:
            let tmp_mask = next_vreg(sel)
            out_insts.push(MachInst(op: MACH_MOV_IMM, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_mask, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 4294967295 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
            out_insts.push(MachInst(op: MACH_AND, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.dest, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_mask, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))

    else:
        out_insts.push(MachInst(op: MACH_NOP, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))

pub fn select_all(f: ptr[AirFunc], abi: str, table: TypeTable, symbols: SymbolTable, pool: InternPool) -> MachInstVec:
    mut actual_max_vreg := 0 as u32
    mut vi := 0 as i64
    while vi < f.insts.len:
        let inst = &f.insts.data[vi]
        if inst.dest > actual_max_vreg:
            actual_max_vreg = inst.dest
        vi = vi + 1

    mut actual_max_label := 0 as u32
    mut bi_init := 0 as i64
    while bi_init < f.blocks.len:
        let bb = &f.blocks.data[bi_init]
        if bb.id > actual_max_label:
            actual_max_label = bb.id
        bi_init = bi_init + 1

    if actual_max_label < 1000000 as u32:
        actual_max_label = 1000000 as u32

    mut sel := InstructionSelector(
        fn_ptr: f,
        abi_name: abi,
        table: table,
        param_idx_processed: 0,
        symbols: symbols,
        pool: pool,
        max_vreg: actual_max_vreg,
        max_label: actual_max_label
    )
    mut result := new_mach_inst_vec()

    let fn_name = pool.get(f.name)
    let is_main = (fn_name == "main")

    if f.blocks.len > 0:
        mut bi := 0 as i64
        while bi < f.blocks.len:
            let bb = &f.blocks.data[bi]
            result.push(MachInst(op: MACH_LABEL, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_LABEL, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: bb.id, imm: 0 as i64), src1: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
            
            if is_main and bi == 0 as i64:
                if abi == "win64":
                    result.push(MachInst(op: MACH_SUB, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_PHYS, phys: REG_RSP, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 32 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
                result.push(MachInst(op: MACH_CALL, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: -4 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
                if abi == "win64":
                    result.push(MachInst(op: MACH_ADD, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_PHYS, phys: REG_RSP, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 32 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
            
            mut i := 0 as i64
            while i < bb.instrs_len as i64:
                let inst_idx = f.block_instrs.data[bb.instrs_start as i64 + i]
                if inst_idx < f.insts.len as u32:
                    let inst = &f.insts.data[inst_idx as i64]
                    select_inst(&sel, inst, &result)
                i = i + 1
            bi = bi + 1
    else:
        mut i := 0 as i64
        while i < f.insts.len:
            let inst = &f.insts.data[i]
            select_inst(&sel, inst, &result)
            i = i + 1

    return result
// bootstrap/stage1/x86_regalloc.ax
// Liveness Analysis and Graph-Coloring Register Allocation for x86-64 in self-hosted AXIOM.


pub struct LiveInterval:
    pub vreg: u32
    pub start: i32
    pub end: i32

pub struct LiveIntervalVec:
    pub data: ptr[LiveInterval]
    pub len: i64
    pub cap: i64

pub fn new_live_interval_vec() -> LiveIntervalVec:
    return LiveIntervalVec(data: null as ptr[LiveInterval], len: 0, cap: 0)

pub fn push(mut self: LiveIntervalVec, iv: LiveInterval) -> u32:
    if self.len == self.cap:
        mut new_cap := 16 as i64
        if self.cap != 0:
            new_cap = self.cap * 2
        let new_data = @alloc(new_cap * 12) as ptr[LiveInterval]
        if self.data != null as ptr[LiveInterval]:
            @memcpy(new_data as ptr[u8], self.data as ptr[u8], self.len * 12)
            @free(self.data as ptr[u8])
        self.data = new_data
        self.cap = new_cap
    let idx = self.len as u32
    self.data[self.len] = iv
    self.len = self.len + 1
    return idx

pub fn is_two_operand_read(op: u16) -> bool:
    if op == MACH_ADD or op == MACH_SUB or op == MACH_IMUL or op == MACH_AND or op == MACH_OR or op == MACH_XOR or op == MACH_SHL or op == MACH_SAR or op == MACH_NEG or op == MACH_NOT:
        return true
    if op == MACH_CMP or op == MACH_TEST or op == MACH_STORE:
        return true
    return false

pub fn compute_liveness(insts: ptr[MachInst], insts_len: i64) -> LiveIntervalVec:
    mut max_vreg := 0 as u32
    mut i := 0 as i64
    while i < insts_len:
        let inst = &insts[i]
        if inst.dst.kind == OPND_VREG and inst.dst.vreg > max_vreg:
            max_vreg = inst.dst.vreg
        if inst.src1.kind == OPND_VREG and inst.src1.vreg > max_vreg:
            max_vreg = inst.src1.vreg
        if inst.src2.kind == OPND_VREG and inst.src2.vreg > max_vreg:
            max_vreg = inst.src2.vreg
        i = i + 1

    let map_size = (max_vreg + 1 as u32) as i64
    let interval_map = @alloc(map_size * 8) as ptr[ptr[LiveInterval]]
    @memset(interval_map as ptr[u8], 0 as u8, map_size * 8)

    i = 0 as i64
    while i < insts_len:
        let inst = &insts[i]

        if inst.dst.kind == OPND_VREG and inst.dst.vreg != 0 as u32:
            let v = inst.dst.vreg
            if interval_map[v] == null as ptr[LiveInterval]:
                let iv = @alloc(12) as ptr[LiveInterval]
                iv.vreg = v
                iv.start = i as i32
                mut is_param := false
                if inst.op == MACH_MOV and inst.src1.kind == OPND_PHYS:
                    let phys = inst.src1.phys
                    if phys == REG_RCX or phys == REG_RDX or phys == REG_R8 or phys == REG_R9 or phys == REG_RDI or phys == REG_RSI:
                        is_param = true
                if is_param:
                    iv.end = (insts_len - 1) as i32
                else:
                    iv.end = i as i32
                interval_map[v] = iv

        if inst.src1.kind == OPND_VREG and inst.src1.vreg != 0 as u32:
            let v = inst.src1.vreg
            mut iv = interval_map[v]
            if iv == null as ptr[LiveInterval]:
                iv = @alloc(12) as ptr[LiveInterval]
                iv.vreg = v
                iv.start = 0 as i32
                iv.end = i as i32
                interval_map[v] = iv
            elif (i as i32) > iv.end:
                iv.end = i as i32

        if inst.src2.kind == OPND_VREG and inst.src2.vreg != 0 as u32:
            let v = inst.src2.vreg
            mut iv = interval_map[v]
            if iv == null as ptr[LiveInterval]:
                iv = @alloc(12) as ptr[LiveInterval]
                iv.vreg = v
                iv.start = 0 as i32
                iv.end = i as i32
                interval_map[v] = iv
            elif (i as i32) > iv.end:
                iv.end = i as i32

        if is_two_operand_read(inst.op):
            if inst.dst.kind == OPND_VREG and inst.dst.vreg != 0 as u32:
                let v = inst.dst.vreg
                mut iv = interval_map[v]
                if iv == null as ptr[LiveInterval]:
                    iv = @alloc(12) as ptr[LiveInterval]
                    iv.vreg = v
                    iv.start = 0 as i32
                    iv.end = i as i32
                    interval_map[v] = iv
                elif (i as i32) > iv.end:
                    iv.end = i as i32
        i = i + 1

    // Scan for back-edges and extend lifetimes
    i = 0 as i64
    while i < insts_len:
        let inst = &insts[i]
        if inst.op == MACH_JMP or inst.op == MACH_JCC:
            if inst.dst.kind == OPND_LABEL:
                let target_label = inst.dst.label
                // Find the target instruction index
                mut target_idx := -1 as i64
                mut search_idx := 0 as i64
                while search_idx < insts_len:
                    if insts[search_idx].op == MACH_LABEL and insts[search_idx].dst.label == target_label:
                        target_idx = search_idx
                        break
                    search_idx = search_idx + 1
                
                // If it is a back-edge (target_idx < i)
                if target_idx != -1 as i64 and target_idx < i:
                    // For any virtual register live at target_idx, extend its end to i
                    mut v_scan := 0 as i64
                    while v_scan < map_size:
                        let iv = interval_map[v_scan]
                        if iv != null as ptr[LiveInterval]:
                            if iv.start <= target_idx as i32 and iv.end >= target_idx as i32:
                                if iv.end < i as i32:
                                    iv.end = i as i32
                        v_scan = v_scan + 1
        i = i + 1

    mut result := new_live_interval_vec()
    mut v := 0 as i64
    while v < map_size:
        let iv = interval_map[v]
        if iv != null as ptr[LiveInterval]:
            result.push(iv[0])
            @free(iv as ptr[u8])
        v = v + 1
    @free(interval_map as ptr[u8])

    mut idx := 1 as i64
    while idx < result.len:
        let key = result.data[idx]
        mut j := idx - 1
        while j >= 0 and result.data[j].start > key.start:
            result.data[j + 1] = result.data[j]
            j = j - 1
        result.data[j + 1] = key
        idx = idx + 1

    return result

pub struct RegAllocation:
    pub vreg: u32
    pub phys: u8
    pub spilled: bool
    pub spill_idx: i32

pub struct RegAllocResult:
    pub allocs: ptr[RegAllocation]
    pub max_vreg: u32
    pub spill_count: i32

pub fn get_allocatable_gprs(out_len: ptr[i64]) -> ptr[u8]:
    let arr = @alloc(12) as ptr[u8]
    arr[0] = REG_RAX
    arr[1] = REG_RCX
    arr[2] = REG_RDX
    arr[3] = REG_RBX
    arr[4] = REG_RSI
    arr[5] = REG_RDI
    arr[6] = REG_R8
    arr[7] = REG_R9
    arr[8] = REG_R12
    arr[9] = REG_R13
    arr[10] = REG_R14
    arr[11] = REG_R15
    out_len[0] = 12
    return arr

pub fn reg_is_caller_saved(abi: str, r: u8) -> bool:
    if abi == "win64":
        if r == REG_RAX or r == REG_RCX or r == REG_RDX or r == REG_R8 or r == REG_R9 or r == REG_R10 or r == REG_R11:
            return true
    else:
        if r == REG_RAX or r == REG_RCX or r == REG_RDX or r == REG_RSI or r == REG_RDI or r == REG_R8 or r == REG_R9 or r == REG_R10 or r == REG_R11:
            return true
    return false

pub fn graph_coloring_alloc(intervals: LiveIntervalVec, avail_regs: ptr[u8], avail_regs_len: i64, insts: ptr[MachInst], insts_len: i64, abi: str) -> RegAllocResult:
    if intervals.len == 0 or avail_regs_len == 0:
        return RegAllocResult(allocs: null as ptr[RegAllocation], max_vreg: 0 as u32, spill_count: 0 as i32)

    mut max_vreg := 0 as u32
    mut i := 0 as i64
    while i < intervals.len:
        if intervals.data[i].vreg > max_vreg:
            max_vreg = intervals.data[i].vreg
        i = i + 1

    let graph_size = (max_vreg + 1 as u32) as i64

    let param_idx_of_vreg = @alloc(graph_size * 4) as ptr[i32]
    mut param_vi := 0 as i64
    while param_vi < graph_size:
        param_idx_of_vreg[param_vi] = -1 as i32
        param_vi = param_vi + 1

    mut inst_idx := 0 as i64
    while inst_idx < insts_len:
        let inst = insts[inst_idx]
        if inst.op == MACH_MOV and inst.dst.kind == OPND_VREG and inst.src1.kind == OPND_PHYS:
            let phys = inst.src1.phys
            mut p_idx := -1 as i32
            if abi == "win64":
                if phys == REG_RCX:
                    p_idx = 0 as i32
                elif phys == REG_RDX:
                    p_idx = 1 as i32
                elif phys == REG_R8:
                    p_idx = 2 as i32
                elif phys == REG_R9:
                    p_idx = 3 as i32
            else:
                if phys == REG_RDI:
                    p_idx = 0 as i32
                elif phys == REG_RSI:
                    p_idx = 1 as i32
                elif phys == REG_RDX:
                    p_idx = 2 as i32
                elif phys == REG_RCX:
                    p_idx = 3 as i32
                elif phys == REG_R8:
                    p_idx = 4 as i32
                elif phys == REG_R9:
                    p_idx = 5 as i32
            
            if p_idx != -1 as i32:
                let vr = inst.dst.vreg
                if vr < max_vreg + 1 as u32:
                    param_idx_of_vreg[vr as i64] = p_idx
        inst_idx = inst_idx + 1

    // Determine for each virtual register if its live interval spans any call instruction
    let spans_call = @alloc(graph_size) as ptr[bool]
    @memset(spans_call as ptr[u8], 0 as u8, graph_size)

    mut iv_idx := 0 as i64
    while iv_idx < intervals.len:
        let vreg = intervals.data[iv_idx].vreg
        let start = intervals.data[iv_idx].start
        let end = intervals.data[iv_idx].end
        
        mut k := start as i64
        while k <= end as i64:
            if k >= 0 and k < insts_len:
                let op = insts[k].op
                if op == MACH_CALL or op == MACH_CALL_INDIRECT:
                    if start < k as i32 and end > k as i32:
                        spans_call[vreg] = true
                        break
            k = k + 1
        iv_idx = iv_idx + 1

    let adj = @alloc(graph_size * 24) as ptr[U32Vec]
    mut vi := 0 as i64
    while vi < graph_size:
        adj[vi] = new_u32_vec()
        vi = vi + 1

    i = 0 as i64
    while i < intervals.len:
        let iv1 = &intervals.data[i]
        mut j := i + 1
        while j < intervals.len:
            let iv2 = &intervals.data[j]
            if iv1.start <= iv2.end and iv2.start <= iv1.end:
                adj[iv1.vreg].append_unique(iv2.vreg)
                adj[iv2.vreg].append_unique(iv1.vreg)
            j = j + 1
        i = i + 1

    let degrees = @alloc(graph_size * 4) as ptr[i32]
    mut di := 0 as i64
    while di < graph_size:
        degrees[di] = adj[di].len as i32
        di = di + 1

    let removed = @alloc(graph_size) as ptr[bool]
    @memset(removed as ptr[u8], 0 as u8, graph_size)

    mut stack := new_u32_vec()
    let K = avail_regs_len as i32
    mut simplified_count := 0 as i64
    let target_count = intervals.len

    while simplified_count < target_count:
        mut found := false
        mut best_node := 0 as u32

        mut iv_idx := 0 as i64
        while iv_idx < intervals.len:
            let vreg = intervals.data[iv_idx].vreg
            if not removed[vreg]:
                if degrees[vreg] < K:
                    best_node = vreg
                    found = true
                    break
            iv_idx = iv_idx + 1

        if found:
            stack.push(best_node)
            removed[best_node] = true
            simplified_count = simplified_count + 1
            mut n_idx := 0 as i64
            while n_idx < adj[best_node].len:
                let neighbor = adj[best_node].data[n_idx]
                if not removed[neighbor]:
                    degrees[neighbor] = degrees[neighbor] - 1
                n_idx = n_idx + 1
        else:
            mut spill_candidate := 0 as u32
            mut max_degree := -1 as i32
            mut has_candidate := false

            iv_idx = 0
            while iv_idx < intervals.len:
                let vreg = intervals.data[iv_idx].vreg
                if not removed[vreg]:
                    if degrees[vreg] > max_degree:
                        max_degree = degrees[vreg]
                        spill_candidate = vreg
                        has_candidate = true
                iv_idx = iv_idx + 1

            if not has_candidate:
                break

            stack.push(spill_candidate)
            removed[spill_candidate] = true
            simplified_count = simplified_count + 1

            mut n_idx := 0 as i64
            while n_idx < adj[spill_candidate].len:
                let neighbor = adj[spill_candidate].data[n_idx]
                if not removed[neighbor]:
                    degrees[neighbor] = degrees[neighbor] - 1
                n_idx = n_idx + 1

    let assigned_colors = @alloc(graph_size) as ptr[u8]
    @memset(assigned_colors, REG_NONE, graph_size)

    let allocs = @alloc(graph_size * 12) as ptr[RegAllocation]
    @memset(allocs as ptr[u8], 0 as u8, graph_size * 12)
    mut spill_count := 0 as i32

    mut st_idx := stack.len - 1
    while st_idx >= 0:
        let vreg = stack.data[st_idx]
        let forbidden = @alloc(256) as ptr[bool]
        @memset(forbidden as ptr[u8], 0 as u8, 256)

        let p_idx = param_idx_of_vreg[vreg as i64]
        if p_idx != -1 as i32:
            mut j := (p_idx + 1) as i64
            while j < 6 as i64:
                let r = abi_int_arg_reg(abi, j)
                if r != REG_NONE:
                    forbidden[r as i64] = true
                j = j + 1

        mut n_idx := 0 as i64
        while n_idx < adj[vreg].len:
            let neighbor = adj[vreg].data[n_idx]
            let color = assigned_colors[neighbor]
            if color != REG_NONE:
                forbidden[color] = true
            n_idx = n_idx + 1

        if spans_call[vreg]:
            mut r := 0 as i64
            while r < 256:
                if reg_is_caller_saved(abi, r as u8):
                    forbidden[r] = true
                r = r + 1

        mut colored := false
        mut c_idx := 0 as i64
        while c_idx < avail_regs_len:
            let color = avail_regs[c_idx]
            if not forbidden[color]:
                assigned_colors[vreg] = color
                allocs[vreg] = RegAllocation(vreg: vreg, phys: color, spilled: false, spill_idx: 0 as i32)
                colored = true
                break
            c_idx = c_idx + 1

        @free(forbidden as ptr[u8])

        if not colored:
            allocs[vreg] = RegAllocation(vreg: vreg, phys: REG_NONE, spilled: true, spill_idx: spill_count)
            spill_count = spill_count + 1

        st_idx = st_idx - 1

    @free(removed as ptr[u8])
    @free(degrees as ptr[u8])
    @free(assigned_colors)
    @free(spans_call as ptr[u8])
    @free(param_idx_of_vreg as ptr[u8])
    if stack.data != null as ptr[u32]:
        @free(stack.data as ptr[u8])

    mut f_idx := 0 as i64
    while f_idx < graph_size:
        if adj[f_idx].data != null as ptr[u32]:
            @free(adj[f_idx].data as ptr[u8])
        f_idx = f_idx + 1
    @free(adj as ptr[u8])

    return RegAllocResult(allocs: allocs, max_vreg: max_vreg, spill_count: spill_count)

pub fn get_used_callee_saved(abi: str, allocs: ptr[RegAllocation], max_vreg: u32, out_len: ptr[i64]) -> ptr[u8]:
    let used = @alloc(16) as ptr[bool]
    @memset(used as ptr[u8], 0 as u8, 16)

    mut i := 0 as i64
    while i <= max_vreg as i64:
        let phys = allocs[i].phys
        if phys != REG_NONE:
            if abi == "win64":
                if reg_is_win64_callee_saved(phys):
                    used[phys] = true
            else:
                if reg_is_sysv_callee_saved(phys):
                    used[phys] = true
        i = i + 1

    mut count := 0 as i64
    mut r := 0 as i64
    while r < 16:
        if used[r]:
            count = count + 1
        r = r + 1

    let result = @alloc(count) as ptr[u8]
    mut idx := 0 as i64
    r = 0
    while r < 16:
        if used[r]:
            result[idx] = r as u8
            idx = idx + 1
        r = r + 1

    @free(used as ptr[u8])
    out_len[0] = count
    return result

pub struct StackFrame:
    pub callee_saved: ptr[u8]
    pub callee_saved_len: i64
    pub spill_slots: i32
    pub local_bytes: i32
    pub align_padding: i32
    pub total_size: i32

pub fn compute_frame(callee_saved: ptr[u8], callee_saved_len: i64, spill_count: i32, local_bytes: i32, abi: str) -> StackFrame:
    mut needed := spill_count * 8 + local_bytes
    if abi == "win64":
        needed = needed + 32
    let pushed_bytes = (callee_saved_len + 2) * 8

    mut total := needed
    mut padding := 0 as i32
    if (pushed_bytes + total as i64) % 16 != 0:
        padding = (16 as i64 - (pushed_bytes + total as i64) % 16) as i32
        total = total + padding

    return StackFrame(
        callee_saved: callee_saved,
        callee_saved_len: callee_saved_len,
        spill_slots: spill_count,
        local_bytes: local_bytes,
        align_padding: padding,
        total_size: total
    )

pub fn emit_prologue(frame: ptr[StackFrame], out_insts: ptr[MachInstVec]):
    out_insts.push(MachInst(op: MACH_PUSH, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_PHYS, phys: REG_RBP, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
    out_insts.push(MachInst(op: MACH_MOV, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_PHYS, phys: REG_RBP, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_PHYS, phys: REG_RSP, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))

    mut i := 0 as i64
    while i < frame.callee_saved_len:
        let reg = frame.callee_saved[i]
        out_insts.push(MachInst(op: MACH_PUSH, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_PHYS, phys: reg, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
        i = i + 1

    if frame.total_size > 0:
        out_insts.push(MachInst(op: MACH_SUB, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_PHYS, phys: REG_RSP, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: frame.total_size as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))

pub fn emit_epilogue(frame: ptr[StackFrame], out_insts: ptr[MachInstVec]):
    if frame.total_size > 0:
        out_insts.push(MachInst(op: MACH_ADD, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_PHYS, phys: REG_RSP, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: frame.total_size as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))

    mut i := frame.callee_saved_len - 1
    while i >= 0:
        let reg = frame.callee_saved[i]
        out_insts.push(MachInst(op: MACH_POP, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_PHYS, phys: reg, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
        i = i - 1

    out_insts.push(MachInst(op: MACH_POP, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_PHYS, phys: REG_RBP, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))

pub const DST_UNUSED: u8 = 0
pub const DST_WRITE_ONLY: u8 = 1
pub const DST_READ_WRITE: u8 = 2
pub const DST_READ_ONLY: u8 = 3

pub fn get_dst_behavior(op: u16) -> u8:
    if op == MACH_MOV or op == MACH_MOV_IMM or op == MACH_XOR_ZERO or op == MACH_SETCC or op == MACH_MOVZX_B or op == MACH_POP or op == MACH_LOAD:
        return DST_WRITE_ONLY
    if op == MACH_ADD or op == MACH_SUB or op == MACH_IMUL or op == MACH_NEG or op == MACH_NOT or op == MACH_AND or op == MACH_OR or op == MACH_XOR or op == MACH_SHL or op == MACH_SAR:
        return DST_READ_WRITE
    if op == MACH_CMP or op == MACH_TEST or op == MACH_STORE:
        return DST_READ_ONLY
    return DST_UNUSED

pub fn insert_spill_code(insts: ptr[MachInst], insts_len: i64, allocs: ptr[RegAllocation], frame: ptr[StackFrame]) -> MachInstVec:
    mut result := new_mach_inst_vec()

    mut i := 0 as i64
    while i < insts_len:
        mut inst := insts[i]

        if inst.src1.kind == OPND_VREG:
            let v = inst.src1.vreg
            let alloc = allocs[v]
            if alloc.spilled:
                let offset = -((frame.callee_saved_len + 1 + alloc.spill_idx as i64) * 8)
                result.push(MachInst(op: MACH_LOAD, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_PHYS, phys: REG_R10, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_PHYS, phys: REG_RBP, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: offset as i64)))
                inst.src1 = MachOperand(kind: OPND_PHYS, phys: REG_R10, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)

        if inst.src2.kind == OPND_VREG:
            let v = inst.src2.vreg
            let alloc = allocs[v]
            if alloc.spilled:
                let offset = -((frame.callee_saved_len + 1 + alloc.spill_idx as i64) * 8)
                result.push(MachInst(op: MACH_LOAD, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_PHYS, phys: REG_R10, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_PHYS, phys: REG_RBP, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: offset as i64)))
                inst.src2 = MachOperand(kind: OPND_PHYS, phys: REG_R10, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)

        mut dst_spilled := false
        mut dst_alloc = RegAllocation(vreg: 0 as u32, phys: 0 as u8, spilled: false, spill_idx: 0 as i32)
        if inst.dst.kind == OPND_VREG:
            let v = inst.dst.vreg
            let alloc = allocs[v]
            if alloc.spilled:
                dst_spilled = true
                dst_alloc = alloc

        if dst_spilled:
            let behavior = get_dst_behavior(inst.op)
            let offset = -((frame.callee_saved_len + 1 + dst_alloc.spill_idx as i64) * 8)

            if behavior == DST_READ_ONLY:
                result.push(MachInst(op: MACH_LOAD, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_PHYS, phys: REG_R11, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_PHYS, phys: REG_RBP, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: offset as i64)))
                inst.dst = MachOperand(kind: OPND_PHYS, phys: REG_R11, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)
                result.push(inst)
            elif behavior == DST_READ_WRITE:
                result.push(MachInst(op: MACH_LOAD, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_PHYS, phys: REG_R11, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_PHYS, phys: REG_RBP, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: offset as i64)))
                inst.dst = MachOperand(kind: OPND_PHYS, phys: REG_R11, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)
                result.push(inst)
                result.push(MachInst(op: MACH_STORE, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_PHYS, phys: REG_RBP, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_PHYS, phys: REG_R11, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: offset as i64)))
            elif behavior == DST_WRITE_ONLY:
                inst.dst = MachOperand(kind: OPND_PHYS, phys: REG_R11, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)
                result.push(inst)
                result.push(MachInst(op: MACH_STORE, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_PHYS, phys: REG_RBP, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_PHYS, phys: REG_R11, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: offset as i64)))
            else:
                result.push(inst)
        else:
            result.push(inst)

        i = i + 1
    return result
// bootstrap/stage1/x86_asm_emitter.ax
// Assembly Text Emitter for NASM, FASM, and WinAsm/MASM in self-hosted AXIOM.


pub fn to_byte_reg(reg: u8) -> str:
    let hw = reg_hw_reg(reg)
    if reg_is_gpr(reg):
        if hw == 0:
            return "al"
        if hw == 1:
            return "cl"
        if hw == 2:
            return "dl"
        if hw == 3:
            return "bl"
        if hw == 4:
            return "spl"
        if hw == 5:
            return "bpl"
        if hw == 6:
            return "sil"
        if hw == 7:
            return "dil"
        if hw == 8:
            return "r8b"
        if hw == 9:
            return "r9b"
        if hw == 10:
            return "r10b"
        if hw == 11:
            return "r11b"
        if hw == 12:
            return "r12b"
        if hw == 13:
            return "r13b"
        if hw == 14:
            return "r14b"
        if hw == 15:
            return "r15b"
    return "al"

pub fn format_operand(op: MachOperand, format: str, allocs: ptr[RegAllocation]) -> str:
    if op.kind == OPND_PHYS:
        return reg_to_str(op.phys)
    elif op.kind == OPND_VREG:
        let r = op.vreg
        let alloc = allocs[r]
        return reg_to_str(alloc.phys)
    elif op.kind == OPND_IMM:
        return format_int(op.imm)
    elif op.kind == OPND_LABEL:
        if format == "winasm":
            return std.string.concat("L_b_", format_int(op.label as i64))
        return std.string.concat(".L_b_", format_int(op.label as i64))
    return "none"

pub fn emit_inst(file: ptr[void], inst: MachInst, fn_name: str, allocs: ptr[RegAllocation], format: str, symbols: SymbolTable, pool: InternPool):
    let op = inst.op
    if op == MACH_NOP:
        ax_fprintf_local(file, "    nop\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == MACH_LABEL:
        let lbl_id = inst.dst.label
        if format == "winasm":
            ax_fprintf_local(file, "L_b_%d:\n", lbl_id as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        else:
            ax_fprintf_local(file, ".L_b_%d:\n", lbl_id as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == MACH_RET:
        ax_fprintf_local(file, "    ret\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == MACH_MOV:
        let dst = format_operand(inst.dst, format, allocs)
        let src = format_operand(inst.src1, format, allocs)
        ax_fprintf_local(file, "    mov %s, %s\n", (get_str_ptr(dst)) as i64, (get_str_ptr(src)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == MACH_MOV_IMM:
        let dst = format_operand(inst.dst, format, allocs)
        if inst.src1.vreg == 1 as u32:
            let sym_name = x86_resolve_sym_name(inst.src1.imm as u32, symbols, pool)
            if format == "winasm":
                ax_fprintf_local(file, "    mov %s, OFFSET %s\n", (get_str_ptr(dst)) as i64, (get_str_ptr(sym_name)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            else:
                ax_fprintf_local(file, "    mov %s, %s\n", (get_str_ptr(dst)) as i64, (get_str_ptr(sym_name)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        else:
            let src = format_operand(inst.src1, format, allocs)
            ax_fprintf_local(file, "    mov %s, %s\n", (get_str_ptr(dst)) as i64, (get_str_ptr(src)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == MACH_XOR_ZERO:
        let dst = format_operand(inst.dst, format, allocs)
        ax_fprintf_local(file, "    xor %s, %s\n", (get_str_ptr(dst)) as i64, (get_str_ptr(dst)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == MACH_ADD:
        let dst = format_operand(inst.dst, format, allocs)
        let src = format_operand(inst.src1, format, allocs)
        ax_fprintf_local(file, "    add %s, %s\n", (get_str_ptr(dst)) as i64, (get_str_ptr(src)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == MACH_SUB:
        let dst = format_operand(inst.dst, format, allocs)
        let src = format_operand(inst.src1, format, allocs)
        ax_fprintf_local(file, "    sub %s, %s\n", (get_str_ptr(dst)) as i64, (get_str_ptr(src)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == MACH_IMUL:
        let dst = format_operand(inst.dst, format, allocs)
        let src = format_operand(inst.src1, format, allocs)
        ax_fprintf_local(file, "    imul %s, %s\n", (get_str_ptr(dst)) as i64, (get_str_ptr(src)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == MACH_IDIV:
        let src = format_operand(inst.src1, format, allocs)
        ax_fprintf_local(file, "    idiv %s\n", (get_str_ptr(src)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == MACH_CQO:
        ax_fprintf_local(file, "    cqo\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == MACH_NEG:
        let dst = format_operand(inst.dst, format, allocs)
        ax_fprintf_local(file, "    neg %s\n", (get_str_ptr(dst)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == MACH_NOT:
        let dst = format_operand(inst.dst, format, allocs)
        ax_fprintf_local(file, "    not %s\n", (get_str_ptr(dst)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == MACH_AND:
        let dst = format_operand(inst.dst, format, allocs)
        let src = format_operand(inst.src1, format, allocs)
        ax_fprintf_local(file, "    and %s, %s\n", (get_str_ptr(dst)) as i64, (get_str_ptr(src)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == MACH_OR:
        let dst = format_operand(inst.dst, format, allocs)
        let src = format_operand(inst.src1, format, allocs)
        ax_fprintf_local(file, "    or %s, %s\n", (get_str_ptr(dst)) as i64, (get_str_ptr(src)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == MACH_XOR:
        let dst = format_operand(inst.dst, format, allocs)
        let src = format_operand(inst.src1, format, allocs)
        ax_fprintf_local(file, "    xor %s, %s\n", (get_str_ptr(dst)) as i64, (get_str_ptr(src)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == MACH_SHL:
        let dst = format_operand(inst.dst, format, allocs)
        if inst.src1.kind == OPND_IMM:
            ax_fprintf_local(file, "    shl %s, %d\n", (get_str_ptr(dst)) as i64, inst.src1.imm, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        else:
            ax_fprintf_local(file, "    shl %s, cl\n", (get_str_ptr(dst)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == MACH_SAR:
        let dst = format_operand(inst.dst, format, allocs)
        if inst.src1.kind == OPND_IMM:
            ax_fprintf_local(file, "    sar %s, %d\n", (get_str_ptr(dst)) as i64, inst.src1.imm, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        else:
            ax_fprintf_local(file, "    sar %s, cl\n", (get_str_ptr(dst)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == MACH_CMP:
        let dst = format_operand(inst.dst, format, allocs)
        let src = format_operand(inst.src1, format, allocs)
        ax_fprintf_local(file, "    cmp %s, %s\n", (get_str_ptr(dst)) as i64, (get_str_ptr(src)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == MACH_TEST:
        let dst = format_operand(inst.dst, format, allocs)
        let src = format_operand(inst.src1, format, allocs)
        ax_fprintf_local(file, "    test %s, %s\n", (get_str_ptr(dst)) as i64, (get_str_ptr(src)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == MACH_SETCC:
        mut dst_reg := REG_NONE
        if inst.dst.kind == OPND_PHYS:
            dst_reg = inst.dst.phys
        elif inst.dst.kind == OPND_VREG:
            dst_reg = allocs[inst.dst.vreg].phys
        let byte_reg = to_byte_reg(dst_reg)
        let cc_str = cond_code_to_str(inst.cc)
        ax_fprintf_local(file, "    set%s %s\n", (get_str_ptr(cc_str)) as i64, (get_str_ptr(byte_reg)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == MACH_MOVZX_B:
        mut src_reg := REG_NONE
        if inst.src1.kind == OPND_PHYS:
            src_reg = inst.src1.phys
        elif inst.src1.kind == OPND_VREG:
            src_reg = allocs[inst.src1.vreg].phys
        let byte_reg = to_byte_reg(src_reg)
        let dst = format_operand(inst.dst, format, allocs)
        ax_fprintf_local(file, "    movzx %s, %s\n", (get_str_ptr(dst)) as i64, (get_str_ptr(byte_reg)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == MACH_PUSH:
        let src = format_operand(inst.src1, format, allocs)
        ax_fprintf_local(file, "    push %s\n", (get_str_ptr(src)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == MACH_POP:
        let dst = format_operand(inst.dst, format, allocs)
        ax_fprintf_local(file, "    pop %s\n", (get_str_ptr(dst)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == MACH_JMP:
        let dst = format_operand(inst.dst, format, allocs)
        ax_fprintf_local(file, "    jmp %s\n", (get_str_ptr(dst)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == MACH_JCC:
        let dst = format_operand(inst.dst, format, allocs)
        let cc_str = cond_code_to_str(inst.cc)
        ax_fprintf_local(file, "    j%s %s\n", (get_str_ptr(cc_str)) as i64, (get_str_ptr(dst)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == MACH_LOAD:
        let base = format_operand(inst.src1, format, allocs)
        mut disp := 0 as i64
        if inst.src2.kind == OPND_IMM:
            disp = inst.src2.imm
        
        mut addr_str := ""
        if disp == 0 as i64:
            addr_str = std.string.concat("[", std.string.concat(base, "]"))
        elif disp > 0 as i64:
            addr_str = std.string.concat("[", std.string.concat(base, std.string.concat(" + ", std.string.concat(format_int(disp), "]"))))
        else:
            addr_str = std.string.concat("[", std.string.concat(base, std.string.concat(" - ", std.string.concat(format_int(0 as i64 - disp), "]"))))
            
        let dst = format_operand(inst.dst, format, allocs)
        if format == "winasm":
            ax_fprintf_local(file, "    mov %s, qword ptr %s\n", (get_str_ptr(dst)) as i64, (get_str_ptr(addr_str)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        else:
            ax_fprintf_local(file, "    mov %s, %s\n", (get_str_ptr(dst)) as i64, (get_str_ptr(addr_str)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            
    elif op == MACH_STORE:
        let base = format_operand(inst.dst, format, allocs)
        mut disp := 0 as i64
        if inst.src2.kind == OPND_IMM:
            disp = inst.src2.imm
            
        mut addr_str := ""
        if disp == 0 as i64:
            addr_str = std.string.concat("[", std.string.concat(base, "]"))
        elif disp > 0 as i64:
            addr_str = std.string.concat("[", std.string.concat(base, std.string.concat(" + ", std.string.concat(format_int(disp), "]"))))
        else:
            addr_str = std.string.concat("[", std.string.concat(base, std.string.concat(" - ", std.string.concat(format_int(0 as i64 - disp), "]"))))
            
        let src = format_operand(inst.src1, format, allocs)
        if format == "winasm":
            ax_fprintf_local(file, "    mov qword ptr %s, %s\n", (get_str_ptr(addr_str)) as i64, (get_str_ptr(src)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        else:
            ax_fprintf_local(file, "    mov %s, %s\n", (get_str_ptr(addr_str)) as i64, (get_str_ptr(src)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            
    elif op == MACH_CALL:
        if inst.src1.imm <= 0 as i64:
            if inst.src1.imm == -1 as i64:
                ax_fprintf_local(file, "    call malloc\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            elif inst.src1.imm == -2 as i64:
                ax_fprintf_local(file, "    call free\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            elif inst.src1.imm == -3 as i64:
                ax_fprintf_local(file, "    call ax_actor_spawn\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            elif inst.src1.imm == -4 as i64:
                ax_fprintf_local(file, "    call __ax_runtime_init\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            elif inst.src1.imm == -5 as i64:
                ax_fprintf_local(file, "    call __ax_runtime_shutdown\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            elif inst.src1.imm == -10 as i64:
                ax_fprintf_local(file, "    call ax_println_str\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            elif inst.src1.imm == -11 as i64:
                ax_fprintf_local(file, "    call ax_println_i64\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            elif inst.src1.imm == -12 as i64:
                ax_fprintf_local(file, "    call ax_println_f64\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            elif inst.src1.imm == -13 as i64:
                ax_fprintf_local(file, "    call ax_println_bool\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            elif inst.src1.imm == -14 as i64:
                ax_fprintf_local(file, "    call ax_print_str\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            elif inst.src1.imm == -15 as i64:
                ax_fprintf_local(file, "    call ax_print_i64\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            elif inst.src1.imm == -16 as i64:
                ax_fprintf_local(file, "    call ax_print_f64\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            elif inst.src1.imm == -17 as i64:
                ax_fprintf_local(file, "    call ax_print_bool\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            elif inst.src1.imm == -20 as i64:
                ax_fprintf_local(file, "    call ExitProcess\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            elif inst.src1.imm == -21 as i64:
                ax_fprintf_local(file, "    call strlen\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            else:
                ax_fprintf_local(file, "    call %s\n", (get_str_ptr(fn_name)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        else:
            mut sym_name := x86_resolve_sym_name(inst.src1.imm as u32, symbols, pool)
            if sym_name == "std.string.len":
                sym_name = "ax_str_len"
            elif sym_name == "std.string.concat":
                sym_name = "ax_str_concat"
            elif sym_name == "std.string.replace":
                sym_name = "ax_str_replace"
            elif sym_name == "std.string.slice":
                sym_name = "ax_str_slice"
            ax_fprintf_local(file, "    call %s\n", (get_str_ptr(sym_name)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

pub fn emit_function(file: ptr[void], fn_name: str, insts: ptr[MachInst], insts_len: i64, allocs: ptr[RegAllocation], frame: ptr[StackFrame], format: str, symbols: SymbolTable, pool: InternPool):
    if format == "winasm":
        ax_fprintf_local(file, "%s PROC\n", (get_str_ptr(fn_name)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    else:
        ax_fprintf_local(file, "%s:\n", (get_str_ptr(fn_name)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    mut prologue := new_mach_inst_vec()
    emit_prologue(frame, &prologue)
    mut i := 0 as i64
    while i < prologue.len:
        emit_inst(file, prologue.data[i], fn_name, allocs, format, symbols, pool)
        i = i + 1
    if prologue.data != null as ptr[MachInst]:
        @free(prologue.data as ptr[u8])

    let is_entry = (fn_name == "main" or fn_name == "_AX_main_main_v_v")
    i = 0 as i64
    while i < insts_len:
        let inst = insts[i]
        if inst.op == MACH_RET:
            mut epilogue := new_mach_inst_vec()
            emit_epilogue(frame, &epilogue)
            mut j := 0 as i64
            while j < epilogue.len:
                emit_inst(file, epilogue.data[j], fn_name, allocs, format, symbols, pool)
                j = j + 1
            if epilogue.data != null as ptr[MachInst]:
                @free(epilogue.data as ptr[u8])
            
            if is_entry:
                if @compiler_intrinsic("is_windows"):
                    ax_fprintf_local(file, "    mov ecx, eax\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                    ax_fprintf_local(file, "    sub rsp, 40\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                    ax_fprintf_local(file, "    call ExitProcess\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                else:
                    ax_fprintf_local(file, "    mov rdi, rax\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                    ax_fprintf_local(file, "    mov rax, 60\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                    ax_fprintf_local(file, "    syscall\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            else:
                emit_inst(file, inst, fn_name, allocs, format, symbols, pool)
        else:
            emit_inst(file, inst, fn_name, allocs, format, symbols, pool)
        i = i + 1

    if format == "winasm":
        ax_fprintf_local(file, "%s ENDP\n", (get_str_ptr(fn_name)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

extern "C" fn fopen(filename: ptr[void], mode: ptr[u8]) -> ptr[void]
extern "C" fn fclose(stream: ptr[void]) -> i32

fn x86_str_to_null_terminated(s: str) -> ptr[u8]:
    let len = std.string.len(s)
    let buf = @alloc(len + 1) as ptr[u8]
    @memcpy(buf, s as ptr[u8], len)
    buf[len] = 0 as u8
    return buf

pub fn compile_native_asm(output_asm_file: str, mod: AirModule, symbols: SymbolTable, pool: InternPool, table: TypeTable, format: str) -> bool:
    let output_asm_file_nt = x86_str_to_null_terminated(output_asm_file)
    let file = fopen(output_asm_file_nt as ptr[void], get_str_ptr("wb"))
    @free(output_asm_file_nt)
    if file == null as ptr[void]:
        return false

    // 1. Emit assembler-specific header
    if format == "fasm":
        ax_fprintf_local(file, "; Generated by AXIOM Compiler (FASM format)\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        ax_fprintf_local(file, "format ELF64 executable\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        ax_fprintf_local(file, "segment readable executable\n\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif format == "winasm":
        ax_fprintf_local(file, "; Generated by AXIOM Compiler (WinAsm / MASM format)\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        ax_fprintf_local(file, ".code\n\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    else:
        // Default to NASM
        ax_fprintf_local(file, "; Generated by AXIOM Compiler (NASM format)\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        ax_fprintf_local(file, "bits 64\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        ax_fprintf_local(file, "section .text\n\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    // 2. Declare external symbols
    mut fi := 0 as i64
    while fi < mod.funcs.len:
        let fn_ptr = &mod.funcs.data[fi]
        if fn_ptr.is_extern:
            let name = x86_resolve_sym_name(fn_ptr.sym_id, symbols, pool)
            if format == "fasm":
                ax_fprintf_local(file, "extrn %s\n", (get_str_ptr(name)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            elif format == "winasm":
                ax_fprintf_local(file, "EXTERN %s:PROC\n", (get_str_ptr(name)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            else:
                ax_fprintf_local(file, "extern %s\n", (get_str_ptr(name)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fi = fi + 1
    if @compiler_intrinsic("is_windows"):
        if format == "fasm":
            ax_fprintf_local(file, "extrn ExitProcess\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        elif format == "winasm":
            ax_fprintf_local(file, "EXTERN ExitProcess:PROC\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        else:
            ax_fprintf_local(file, "extern ExitProcess\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    ax_fprintf_local(file, "\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    // 3. Declare global symbols
    fi = 0
    while fi < mod.funcs.len:
        let fn_ptr = &mod.funcs.data[fi]
        if not fn_ptr.is_extern:
            let name = x86_resolve_sym_name(fn_ptr.sym_id, symbols, pool)
            if format == "fasm":
                ax_fprintf_local(file, "public %s\n", (get_str_ptr(name)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            elif format == "winasm":
                ax_fprintf_local(file, "PUBLIC %s\n", (get_str_ptr(name)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            else:
                ax_fprintf_local(file, "global %s\n", (get_str_ptr(name)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fi = fi + 1
    ax_fprintf_local(file, "\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    // 4. Compile each function to assembly text
    let abi = "win64"
    fi = 0
    while fi < mod.funcs.len:
        let fn_ptr = &mod.funcs.data[fi]
        if not fn_ptr.is_extern:
            let fn_name = x86_resolve_sym_name(fn_ptr.sym_id, symbols, pool)
            
            // Run selection & register allocation
            let mach_insts = select_all(fn_ptr, abi, table, symbols, pool)
            let intervals = compute_liveness(mach_insts.data, mach_insts.len)
            
            mut gpr_len := 0 as i64
            let avail_gprs = get_allocatable_gprs(&gpr_len)
            let alloc_res = graph_coloring_alloc(intervals, avail_gprs, gpr_len, mach_insts.data, mach_insts.len, abi)
            mut num_str_lits := 0 as i32
            mut loop_i := 0 as i64
            while loop_i < mach_insts.len:
                let inst = mach_insts.data[loop_i]
                if inst.op == MACH_MOV_IMM and inst.src1.vreg == 2 as u32:
                    num_str_lits = num_str_lits + 1
                loop_i = loop_i + 1

            mut local_bytes := 0 as i32
            if num_str_lits > 0:
                local_bytes = 16 + num_str_lits * 16

            mut cs_len := 0 as i64
            let cs_regs = get_used_callee_saved(abi, alloc_res.allocs, alloc_res.max_vreg, &cs_len)
            let frame = compute_frame(cs_regs, cs_len, alloc_res.spill_count, local_bytes, abi)
            
            let final_insts = insert_spill_code(mach_insts.data, mach_insts.len, alloc_res.allocs, &frame)
            
            // Emit ASM
            emit_function(file, fn_name, final_insts.data, final_insts.len, alloc_res.allocs, &frame, format, symbols, pool)
            ax_fprintf_local(file, "\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            
            // Free structures
            @free(cs_regs)
            @free(avail_gprs)
            @free(alloc_res.allocs)
            if intervals.data != null as ptr[LiveInterval]:
                @free(intervals.data as ptr[u8])
            if mach_insts.data != null as ptr[MachInst]:
                @free(mach_insts.data as ptr[u8])
            if final_insts.data != null as ptr[MachInst]:
                @free(final_insts.data as ptr[u8])
        fi = fi + 1

    if format == "winasm":
        ax_fprintf_local(file, "END\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    fclose(file)
    return true
// bootstrap/stage1/x86_modrm.ax
// ModRM and SIB byte encoding schemas for x86-64 in self-hosted AXIOM.

pub const MOD_INDIRECT:   u8 = 0b00 // [reg] â€” register indirect
pub const MOD_DISP8:      u8 = 0b01 // [reg + disp8]
pub const MOD_DISP32:     u8 = 0b10 // [reg + disp32]
pub const MOD_REG_DIRECT: u8 = 0b11 // reg â€” register direct

pub const REX_BASE: u8 = 0x40 // 0100xxxx
pub const REX_W:    u8 = 0x08 // W bit: 64-bit operand size
pub const REX_R:    u8 = 0x04 // R bit: extends ModRM.reg
pub const REX_X:    u8 = 0x02 // X bit: extends SIB.index
pub const REX_B:    u8 = 0x01 // B bit: extends ModRM.rm or SIB.base

pub struct ByteVec:
    pub data: ptr[u8]
    pub len: i64
    pub cap: i64

pub fn new_byte_vec() -> ByteVec:
    return ByteVec(data: null as ptr[u8], len: 0, cap: 0)

pub fn push_byte(mut self: ptr[ByteVec], b: u8):
    if self.len == self.cap:
        mut new_cap := 16 as i64
        if self.cap != 0:
            new_cap = self.cap * 2
        let new_data = @alloc(new_cap) as ptr[u8]
        if self.data != null as ptr[u8]:
            @memcpy(new_data, self.data, self.len)
            @free(self.data)
        self.data = new_data
        self.cap = new_cap
    self.data[self.len] = b
    self.len = self.len + 1

pub fn push_bytes(mut self: ptr[ByteVec], bytes: ptr[u8], bytes_len: i64):
    mut i := 0 as i64
    while i < bytes_len:
        push_byte(self, bytes[i])
        i = i + 1

pub fn push_u16_le(mut self: ptr[ByteVec], val: u16):
    push_byte(self, (val & 0xFF as u16) as u8)
    push_byte(self, ((val >> 8 as u16) & 0xFF as u16) as u8)

pub fn push_u32_le(mut self: ptr[ByteVec], val: u32):
    push_byte(self, (val & 0xFF as u32) as u8)
    push_byte(self, ((val >> 8 as u32) & 0xFF as u32) as u8)
    push_byte(self, ((val >> 16 as u32) & 0xFF as u32) as u8)
    push_byte(self, ((val >> 24 as u32) & 0xFF as u32) as u8)

pub fn push_u64_le(mut self: ptr[ByteVec], val: u64):
    push_u32_le(self, (val & 0xFFFFFFFF as u64) as u32)
    push_u32_le(self, ((val >> 32 as u64) & 0xFFFFFFFF as u64) as u32)

pub fn encode_rex(w: bool, r: bool, x: bool, b: bool) -> u8:
    mut rex := REX_BASE
    if w:
        rex = rex | REX_W
    if r:
        rex = rex | REX_R
    if x:
        rex = rex | REX_X
    if b:
        rex = rex | REX_B
    return rex

pub fn x86_encode_modrm_rr(reg: u8, rm: u8, out_modrm: ptr[u8], out_rex: ptr[u8], out_need_rex: ptr[bool]):
    let reg_field = reg_hw_reg(reg)
    let rm_field = reg_hw_reg(rm)
    out_modrm[0] = (MOD_REG_DIRECT << 6 as u8) | (reg_field << 3 as u8) | rm_field
    
    let reg_need = reg_needs_rex(reg)
    let rm_need = reg_needs_rex(rm)
    
    if reg_need or rm_need:
        out_need_rex[0] = true
        mut rex := REX_BASE
        if reg_need:
            rex = rex | REX_R
        if rm_need:
            rex = rex | REX_B
        out_rex[0] = rex
    else:
        out_need_rex[0] = false
        out_rex[0] = 0 as u8

pub fn x86_encode_modrm_rm(reg: u8, base: u8, disp: i32, buf: ptr[ByteVec]):
    let base_field = reg_hw_reg(base)
    let reg_field = reg_hw_reg(reg)
    let rsp_field = reg_hw_reg(REG_RSP)
    let rbp_field = reg_hw_reg(REG_RBP)
    
    let needs_sib = (base_field == rsp_field)
    let needs_disp8_for_rbp = (base_field == rbp_field and disp == 0)
    
    mut mod := MOD_INDIRECT
    if needs_disp8_for_rbp:
        mod = MOD_DISP8
    elif disp == 0:
        mod = MOD_INDIRECT
    elif disp >= -128 and disp <= 127:
        mod = MOD_DISP8
    else:
        mod = MOD_DISP32
        
    mut rex := 0 as u8
    let reg_need = reg_needs_rex(reg)
    let base_need = reg_needs_rex(base)
    if reg_need or base_need:
        rex = REX_BASE
        if reg_need:
            rex = rex | REX_R
        if base_need:
            rex = rex | REX_B
            
    if rex != 0 as u8:
        push_byte(buf, rex)
        
    if needs_sib:
        let modrm = (mod << 6 as u8) | (reg_field << 3 as u8) | 0x04 as u8
        let sib = (0 as u8 << 6 as u8) | (0x04 as u8 << 3 as u8) | base_field
        push_byte(buf, modrm)
        push_byte(buf, sib)
    else:
        let modrm = (mod << 6 as u8) | (reg_field << 3 as u8) | base_field
        push_byte(buf, modrm)
        
    if mod == MOD_DISP8:
        push_byte(buf, disp as u8)
    elif mod == MOD_DISP32:
        push_u32_le(buf, disp as u32)

pub fn x86_encode_modrm_rip(reg: u8, disp32: i32, buf: ptr[ByteVec]):
    mut rex := 0 as u8
    if reg_needs_rex(reg):
        rex = REX_BASE | REX_R
        
    if rex != 0 as u8:
        push_byte(buf, rex)
        
    let reg_field = reg_hw_reg(reg)
    let modrm = (MOD_INDIRECT << 6 as u8) | (reg_field << 3 as u8) | 0x05 as u8
    push_byte(buf, modrm)
    push_u32_le(buf, disp32 as u32)

pub fn x86_encode_modrm_sib(reg: u8, base: u8, index: u8, scale: u8, disp: i32, buf: ptr[ByteVec]):
    mut scale_bits := 0 as u8
    if scale == 1 as u8:
        scale_bits = 0 as u8
    elif scale == 2 as u8:
        scale_bits = 1 as u8
    elif scale == 4 as u8:
        scale_bits = 2 as u8
    elif scale == 8 as u8:
        scale_bits = 3 as u8
    else:
        scale_bits = 0 as u8
        
    let base_field = reg_hw_reg(base)
    let rbp_field = reg_hw_reg(REG_RBP)
    let reg_field = reg_hw_reg(reg)
    let index_field = reg_hw_reg(index)
    
    let needs_disp8_for_rbp = (base_field == rbp_field and disp == 0)
    mut mod := MOD_INDIRECT
    if needs_disp8_for_rbp:
        mod = MOD_DISP8
    elif disp == 0:
        mod = MOD_INDIRECT
    elif disp >= -128 and disp <= 127:
        mod = MOD_DISP8
    else:
        mod = MOD_DISP32
        
    mut rex := 0 as u8
    let reg_need = reg_needs_rex(reg)
    let base_need = reg_needs_rex(base)
    let index_need = reg_needs_rex(index)
    if reg_need or base_need or index_need:
        rex = REX_BASE
        if reg_need:
            rex = rex | REX_R
        if index_need:
            rex = rex | REX_X
        if base_need:
            rex = rex | REX_B
            
    if rex != 0 as u8:
        push_byte(buf, rex)
        
    let modrm = (mod << 6 as u8) | (reg_field << 3 as u8) | 0x04 as u8
    let sib = (scale_bits << 6 as u8) | (index_field << 3 as u8) | base_field
    push_byte(buf, modrm)
    push_byte(buf, sib)
    
    if mod == MOD_DISP8:
        push_byte(buf, disp as u8)
    elif mod == MOD_DISP32:
        push_u32_le(buf, disp as u32)
// bootstrap/stage1/x86_encoding.ax
// x86-64 instruction encoders in self-hosted AXIOM.

pub fn x86_encode_ret(buf: ptr[ByteVec]):
    push_byte(buf, 0xC3 as u8)

pub fn x86_encode_nop(buf: ptr[ByteVec]):
    push_byte(buf, 0x90 as u8)

pub fn x86_encode_int3(buf: ptr[ByteVec]):
    push_byte(buf, 0xCC as u8)

pub fn x86_encode_push(reg: u8, buf: ptr[ByteVec]):
    if reg_needs_rex(reg):
        push_byte(buf, REX_BASE | REX_B)
    push_byte(buf, 0x50 as u8 + reg_hw_reg(reg))

pub fn x86_encode_pop(reg: u8, buf: ptr[ByteVec]):
    if reg_needs_rex(reg):
        push_byte(buf, REX_BASE | REX_B)
    push_byte(buf, 0x58 as u8 + reg_hw_reg(reg))

pub fn x86_encode_mov_rr(dst: u8, src: u8, buf: ptr[ByteVec]):
    mut modrm := 0 as u8
    mut rex := 0 as u8
    mut need_rex := false
    x86_encode_modrm_rr(src, dst, &modrm, &rex, &need_rex)
    if need_rex:
        rex = rex | REX_W
        push_byte(buf, rex)
    else:
        push_byte(buf, encode_rex(true, false, false, false))
    push_byte(buf, 0x89 as u8)
    push_byte(buf, modrm)

pub fn x86_encode_mov_ri(dst: u8, imm: i32, buf: ptr[ByteVec]):
    let rex = encode_rex(true, false, false, reg_needs_rex(dst))
    let modrm = (MOD_REG_DIRECT << 6 as u8) | (0 as u8 << 3 as u8) | reg_hw_reg(dst)
    push_byte(buf, rex)
    push_byte(buf, 0xC7 as u8)
    push_byte(buf, modrm)
    push_u32_le(buf, imm as u32)

pub fn x86_encode_mov_ri64(dst: u8, imm: i64, buf: ptr[ByteVec]):
    let rex = encode_rex(true, false, false, reg_needs_rex(dst))
    push_byte(buf, rex)
    push_byte(buf, 0xB8 as u8 + reg_hw_reg(dst))
    push_u64_le(buf, imm as u64)

pub fn x86_encode_add_rr(dst: u8, src: u8, buf: ptr[ByteVec]):
    mut modrm := 0 as u8
    mut rex := 0 as u8
    mut need_rex := false
    x86_encode_modrm_rr(src, dst, &modrm, &rex, &need_rex)
    if need_rex:
        rex = rex | REX_W
    else:
        rex = encode_rex(true, false, false, false)
    push_byte(buf, rex)
    push_byte(buf, 0x01 as u8)
    push_byte(buf, modrm)

pub fn x86_encode_add_ri(dst: u8, imm: i32, buf: ptr[ByteVec]):
    let rex = encode_rex(true, false, false, reg_needs_rex(dst))
    let modrm = (MOD_REG_DIRECT << 6 as u8) | (0 as u8 << 3 as u8) | reg_hw_reg(dst)
    push_byte(buf, rex)
    push_byte(buf, 0x81 as u8)
    push_byte(buf, modrm)
    push_u32_le(buf, imm as u32)

pub fn x86_encode_sub_rr(dst: u8, src: u8, buf: ptr[ByteVec]):
    mut modrm := 0 as u8
    mut rex := 0 as u8
    mut need_rex := false
    x86_encode_modrm_rr(src, dst, &modrm, &rex, &need_rex)
    if need_rex:
        rex = rex | REX_W
    else:
        rex = encode_rex(true, false, false, false)
    push_byte(buf, rex)
    push_byte(buf, 0x29 as u8)
    push_byte(buf, modrm)

pub fn x86_encode_sub_ri(dst: u8, imm: i32, buf: ptr[ByteVec]):
    let rex = encode_rex(true, false, false, reg_needs_rex(dst))
    let modrm = (MOD_REG_DIRECT << 6 as u8) | (5 as u8 << 3 as u8) | reg_hw_reg(dst)
    push_byte(buf, rex)
    push_byte(buf, 0x81 as u8)
    push_byte(buf, modrm)
    push_u32_le(buf, imm as u32)

pub fn x86_encode_imul_rr(dst: u8, src: u8, buf: ptr[ByteVec]):
    mut modrm := 0 as u8
    mut rex := 0 as u8
    mut need_rex := false
    x86_encode_modrm_rr(dst, src, &modrm, &rex, &need_rex)
    if need_rex:
        rex = rex | REX_W
    else:
        rex = encode_rex(true, false, false, false)
    push_byte(buf, rex)
    push_byte(buf, 0x0F as u8)
    push_byte(buf, 0xAF as u8)
    push_byte(buf, modrm)

pub fn x86_encode_cqo(buf: ptr[ByteVec]):
    push_byte(buf, encode_rex(true, false, false, false))
    push_byte(buf, 0x99 as u8)

pub fn x86_encode_idiv_r(divisor: u8, buf: ptr[ByteVec]):
    let rex = encode_rex(true, false, false, reg_needs_rex(divisor))
    let modrm = (MOD_REG_DIRECT << 6 as u8) | (7 as u8 << 3 as u8) | reg_hw_reg(divisor)
    push_byte(buf, rex)
    push_byte(buf, 0xF7 as u8)
    push_byte(buf, modrm)

pub fn x86_encode_neg_r(reg: u8, buf: ptr[ByteVec]):
    let rex = encode_rex(true, false, false, reg_needs_rex(reg))
    let modrm = (MOD_REG_DIRECT << 6 as u8) | (3 as u8 << 3 as u8) | reg_hw_reg(reg)
    push_byte(buf, rex)
    push_byte(buf, 0xF7 as u8)
    push_byte(buf, modrm)

pub fn x86_encode_not_r(reg: u8, buf: ptr[ByteVec]):
    let rex = encode_rex(true, false, false, reg_needs_rex(reg))
    let modrm = (MOD_REG_DIRECT << 6 as u8) | (2 as u8 << 3 as u8) | reg_hw_reg(reg)
    push_byte(buf, rex)
    push_byte(buf, 0xF7 as u8)
    push_byte(buf, modrm)

pub fn x86_encode_cmp_rr(dst: u8, src: u8, buf: ptr[ByteVec]):
    mut modrm := 0 as u8
    mut rex := 0 as u8
    mut need_rex := false
    x86_encode_modrm_rr(src, dst, &modrm, &rex, &need_rex)
    if need_rex:
        rex = rex | REX_W
    else:
        rex = encode_rex(true, false, false, false)
    push_byte(buf, rex)
    push_byte(buf, 0x39 as u8)
    push_byte(buf, modrm)

pub fn x86_encode_cmp_ri(reg: u8, imm: i32, buf: ptr[ByteVec]):
    let rex = encode_rex(true, false, false, reg_needs_rex(reg))
    let modrm = (MOD_REG_DIRECT << 6 as u8) | (7 as u8 << 3 as u8) | reg_hw_reg(reg)
    push_byte(buf, rex)
    push_byte(buf, 0x81 as u8)
    push_byte(buf, modrm)
    push_u32_le(buf, imm as u32)

pub fn x86_encode_test_rr(dst: u8, src: u8, buf: ptr[ByteVec]):
    mut modrm := 0 as u8
    mut rex := 0 as u8
    mut need_rex := false
    x86_encode_modrm_rr(src, dst, &modrm, &rex, &need_rex)
    if need_rex:
        rex = rex | REX_W
    else:
        rex = encode_rex(true, false, false, false)
    push_byte(buf, rex)
    push_byte(buf, 0x85 as u8)
    push_byte(buf, modrm)

pub fn x86_encode_and_rr(dst: u8, src: u8, buf: ptr[ByteVec]):
    mut modrm := 0 as u8
    mut rex := 0 as u8
    mut need_rex := false
    x86_encode_modrm_rr(src, dst, &modrm, &rex, &need_rex)
    if need_rex:
        rex = rex | REX_W
    else:
        rex = encode_rex(true, false, false, false)
    push_byte(buf, rex)
    push_byte(buf, 0x21 as u8)
    push_byte(buf, modrm)

pub fn x86_encode_or_rr(dst: u8, src: u8, buf: ptr[ByteVec]):
    mut modrm := 0 as u8
    mut rex := 0 as u8
    mut need_rex := false
    x86_encode_modrm_rr(src, dst, &modrm, &rex, &need_rex)
    if need_rex:
        rex = rex | REX_W
    else:
        rex = encode_rex(true, false, false, false)
    push_byte(buf, rex)
    push_byte(buf, 0x09 as u8)
    push_byte(buf, modrm)

pub fn x86_encode_xor_rr(dst: u8, src: u8, buf: ptr[ByteVec]):
    mut modrm := 0 as u8
    mut rex := 0 as u8
    mut need_rex := false
    x86_encode_modrm_rr(src, dst, &modrm, &rex, &need_rex)
    if need_rex:
        rex = rex | REX_W
    else:
        rex = encode_rex(true, false, false, false)
    push_byte(buf, rex)
    push_byte(buf, 0x31 as u8)
    push_byte(buf, modrm)

pub fn x86_encode_shl_cl(reg: u8, buf: ptr[ByteVec]):
    let rex = encode_rex(true, false, false, reg_needs_rex(reg))
    let modrm = (MOD_REG_DIRECT << 6 as u8) | (4 as u8 << 3 as u8) | reg_hw_reg(reg)
    push_byte(buf, rex)
    push_byte(buf, 0xD3 as u8)
    push_byte(buf, modrm)

pub fn x86_encode_sar_cl(reg: u8, buf: ptr[ByteVec]):
    let rex = encode_rex(true, false, false, reg_needs_rex(reg))
    let modrm = (MOD_REG_DIRECT << 6 as u8) | (7 as u8 << 3 as u8) | reg_hw_reg(reg)
    push_byte(buf, rex)
    push_byte(buf, 0xD3 as u8)
    push_byte(buf, modrm)

pub fn x86_encode_xor_zero(reg: u8, buf: ptr[ByteVec]):
    let modrm = (MOD_REG_DIRECT << 6 as u8) | (reg_hw_reg(reg) << 3 as u8) | reg_hw_reg(reg)
    if reg_needs_rex(reg):
        let rex = REX_BASE | REX_R | REX_B
        push_byte(buf, rex)
    push_byte(buf, 0x31 as u8)
    push_byte(buf, modrm)

pub fn x86_encode_setcc(cc: u8, dst: u8, buf: ptr[ByteVec]):
    if reg_needs_rex(dst) or reg_hw_reg(dst) >= 4 as u8:
        mut rex := REX_BASE
        if reg_needs_rex(dst):
            rex = rex | REX_B
        push_byte(buf, rex)
    let modrm = (MOD_REG_DIRECT << 6 as u8) | (0 as u8 << 3 as u8) | reg_hw_reg(dst)
    push_byte(buf, 0x0F as u8)
    push_byte(buf, 0x90 as u8 + cc)
    push_byte(buf, modrm)

pub fn x86_encode_movzx_br(dst: u8, src: u8, buf: ptr[ByteVec]):
    let rex = encode_rex(true, reg_needs_rex(dst), false, reg_needs_rex(src))
    let modrm = (MOD_REG_DIRECT << 6 as u8) | (reg_hw_reg(dst) << 3 as u8) | reg_hw_reg(src)
    push_byte(buf, rex)
    push_byte(buf, 0x0F as u8)
    push_byte(buf, 0xB6 as u8)
    push_byte(buf, modrm)

pub fn x86_encode_jmp_rel32(rel32: i32, buf: ptr[ByteVec]):
    push_byte(buf, 0xE9 as u8)
    push_u32_le(buf, rel32 as u32)

pub fn x86_encode_jcc_rel32(cc: u8, rel32: i32, buf: ptr[ByteVec]):
    push_byte(buf, 0x0F as u8)
    push_byte(buf, 0x80 as u8 + cc)
    push_u32_le(buf, rel32 as u32)

pub fn x86_encode_call_rel32(rel32: i32, buf: ptr[ByteVec]):
    push_byte(buf, 0xE8 as u8)
    push_u32_le(buf, rel32 as u32)

pub fn x86_encode_call_r(reg: u8, buf: ptr[ByteVec]):
    if reg_needs_rex(reg):
        push_byte(buf, REX_BASE | REX_B)
    let modrm = (MOD_REG_DIRECT << 6 as u8) | (2 as u8 << 3 as u8) | reg_hw_reg(reg)
    push_byte(buf, 0xFF as u8)
    push_byte(buf, modrm)

pub fn x86_encode_lea(dst: u8, base: u8, disp: i32, buf: ptr[ByteVec]):
    let rex = encode_rex(true, reg_needs_rex(dst), false, reg_needs_rex(base))
    
    // We construct a temporary byte vector to receive the ModRM byte sequence,
    // merging REX bits if necessary, just like the reference Go emitter.
    mut temp_buf := new_byte_vec()
    x86_encode_modrm_rm(dst, base, disp, &temp_buf)
    
    mut final_rex := rex
    mut start_idx := 0 as i64
    let has_rex := reg_needs_rex(dst) or reg_needs_rex(base)
    if has_rex and temp_buf.len > 0 as i64:
        let first_byte = temp_buf.data[0]
        if (first_byte & 0xF0 as u8) == 0x40 as u8:
            final_rex = final_rex | (first_byte & 0x0F as u8)
            start_idx = 1
            
    push_byte(buf, final_rex)
    push_byte(buf, 0x8D as u8)
    
    mut i := start_idx
    while i < temp_buf.len:
        push_byte(buf, temp_buf.data[i])
        i = i + 1
        
    if temp_buf.data != null as ptr[u8]:
        @free(temp_buf.data)

pub fn x86_encode_mov_load(dst: u8, base: u8, disp: i32, buf: ptr[ByteVec]):
    let rex = encode_rex(true, reg_needs_rex(dst), false, reg_needs_rex(base))
    mut temp_buf := new_byte_vec()
    x86_encode_modrm_rm(dst, base, disp, &temp_buf)
    
    mut final_rex := rex
    mut start_idx := 0 as i64
    let has_rex := reg_needs_rex(dst) or reg_needs_rex(base)
    if has_rex and temp_buf.len > 0 as i64:
        let first_byte = temp_buf.data[0]
        if (first_byte & 0xF0 as u8) == 0x40 as u8:
            final_rex = final_rex | (first_byte & 0x0F as u8)
            start_idx = 1
            
    push_byte(buf, final_rex)
    push_byte(buf, 0x8B as u8)
    
    mut i := start_idx
    while i < temp_buf.len:
        push_byte(buf, temp_buf.data[i])
        i = i + 1
        
    if temp_buf.data != null as ptr[u8]:
        @free(temp_buf.data)

pub fn x86_encode_mov_store(base: u8, disp: i32, src: u8, buf: ptr[ByteVec]):
    let rex = encode_rex(true, reg_needs_rex(src), false, reg_needs_rex(base))
    mut temp_buf := new_byte_vec()
    x86_encode_modrm_rm(src, base, disp, &temp_buf)
    
    mut final_rex := rex
    mut start_idx := 0 as i64
    let has_rex := reg_needs_rex(src) or reg_needs_rex(base)
    if has_rex and temp_buf.len > 0 as i64:
        let first_byte = temp_buf.data[0]
        if (first_byte & 0xF0 as u8) == 0x40 as u8:
            final_rex = final_rex | (first_byte & 0x0F as u8)
            start_idx = 1
            
    push_byte(buf, final_rex)
    push_byte(buf, 0x89 as u8)
    
    mut i := start_idx
    while i < temp_buf.len:
        push_byte(buf, temp_buf.data[i])
        i = i + 1
        
    if temp_buf.data != null as ptr[u8]:
        @free(temp_buf.data)

pub fn x86_encode_syscall(buf: ptr[ByteVec]):
    push_byte(buf, 0x0F as u8)
    push_byte(buf, 0x05 as u8)

pub fn x86_encode_lea_rip(dst: u8, disp32: i32, buf: ptr[ByteVec]):
    mut rex := REX_BASE | REX_W
    if reg_needs_rex(dst):
        rex = rex | REX_R
    push_byte(buf, rex)
    push_byte(buf, 0x8D as u8)
    let reg_field = reg_hw_reg(dst)
    let modrm = (MOD_INDIRECT << 6 as u8) | (reg_field << 3 as u8) | 0x05 as u8
    push_byte(buf, modrm)
    push_u32_le(buf, disp32 as u32)

pub fn x86_encode_shl_imm(reg: u8, imm: u8, buf: ptr[ByteVec]):
    let rex = encode_rex(true, false, false, reg_needs_rex(reg))
    let modrm = (MOD_REG_DIRECT << 6 as u8) | (4 as u8 << 3 as u8) | reg_hw_reg(reg)
    push_byte(buf, rex)
    push_byte(buf, 0xC1 as u8)
    push_byte(buf, modrm)
    push_byte(buf, imm)

pub fn x86_encode_sar_imm(reg: u8, imm: u8, buf: ptr[ByteVec]):
    let rex = encode_rex(true, false, false, reg_needs_rex(reg))
    let modrm = (MOD_REG_DIRECT << 6 as u8) | (7 as u8 << 3 as u8) | reg_hw_reg(reg)
    push_byte(buf, rex)
    push_byte(buf, 0xC1 as u8)
    push_byte(buf, modrm)
    push_byte(buf, imm)

pub fn x86_encode_mov_load_sized(dst: u8, base: u8, disp: i32, size: u8, buf: ptr[ByteVec]):
    mut w_bit := true
    mut op_byte1 := 0x8B as u8
    mut op_byte2 := 0 as u8
    mut is_two_byte_op := false
    
    if size == 1 as u8:
        w_bit = true
        is_two_byte_op = true
        op_byte1 = 0x0F as u8
        op_byte2 = 0xB6 as u8
    elif size == 2 as u8:
        w_bit = true
        is_two_byte_op = true
        op_byte1 = 0x0F as u8
        op_byte2 = 0xB7 as u8
    elif size == 4 as u8:
        w_bit = false
        is_two_byte_op = false
        op_byte1 = 0x8B as u8
    else:
        w_bit = true
        is_two_byte_op = false
        op_byte1 = 0x8B as u8

    let rex = encode_rex(w_bit, reg_needs_rex(dst), false, reg_needs_rex(base))
    mut temp_buf := new_byte_vec()
    x86_encode_modrm_rm(dst, base, disp, &temp_buf)
    
    mut final_rex := rex
    mut start_idx := 0 as i64
    let has_rex := reg_needs_rex(dst) or reg_needs_rex(base)
    if has_rex and temp_buf.len > 0 as i64:
        let first_byte = temp_buf.data[0]
        if (first_byte & 0xF0 as u8) == 0x40 as u8:
            final_rex = final_rex | (first_byte & 0x0F as u8)
            start_idx = 1
            
    let needs_rex_prefix = w_bit or reg_needs_rex(dst) or reg_needs_rex(base)
    if needs_rex_prefix:
        push_byte(buf, final_rex)
        
    if is_two_byte_op:
        push_byte(buf, op_byte1)
        push_byte(buf, op_byte2)
    else:
        push_byte(buf, op_byte1)
        
    mut i := start_idx
    while i < temp_buf.len:
        push_byte(buf, temp_buf.data[i])
        i = i + 1
        
    if temp_buf.data != null as ptr[u8]:
        @free(temp_buf.data)

pub fn x86_encode_mov_store_sized(base: u8, disp: i32, src: u8, size: u8, buf: ptr[ByteVec]):
    mut w_bit := true
    mut op_byte := 0x89 as u8
    
    if size == 1 as u8:
        w_bit = false
        op_byte = 0x88 as u8
    elif size == 2 as u8:
        w_bit = false
        op_byte = 0x89 as u8
        push_byte(buf, 0x66 as u8)
    elif size == 4 as u8:
        w_bit = false
        op_byte = 0x89 as u8
    else:
        w_bit = true
        op_byte = 0x89 as u8

    let rex = encode_rex(w_bit, reg_needs_rex(src), false, reg_needs_rex(base))
    mut temp_buf := new_byte_vec()
    x86_encode_modrm_rm(src, base, disp, &temp_buf)
    
    mut final_rex := rex
    mut start_idx := 0 as i64
    let has_rex := reg_needs_rex(src) or reg_needs_rex(base)
    if has_rex and temp_buf.len > 0 as i64:
        let first_byte = temp_buf.data[0]
        if (first_byte & 0xF0 as u8) == 0x40 as u8:
            final_rex = final_rex | (first_byte & 0x0F as u8)
            start_idx = 1
            
    let needs_rex_prefix = w_bit or reg_needs_rex(src) or reg_needs_rex(base)
    if needs_rex_prefix:
        push_byte(buf, final_rex)
        
    push_byte(buf, op_byte)
    
    mut i := start_idx
    while i < temp_buf.len:
        push_byte(buf, temp_buf.data[i])
        i = i + 1
        
    if temp_buf.data != null as ptr[u8]:
        @free(temp_buf.data)


// bootstrap/stage1/x86_emitter.ax
// Binary machine code emitter for x86-64 in self-hosted AXIOM.

pub const RELOC_PC32:  u8 = 0
pub const RELOC_ABS64: u8 = 1
pub const RELOC_PLT32: u8 = 2

pub struct Relocation:
    pub offset: i64
    pub kind: u8
    pub padding1: u8
    pub padding2: u16
    pub sym_name: u32 // Interned symbol name index
    pub addend: i64

pub struct RelocationVec:
    pub data: ptr[Relocation]
    pub len: i64
    pub cap: i64

pub fn new_relocation_vec() -> RelocationVec:
    return RelocationVec(data: null as ptr[Relocation], len: 0, cap: 0)

pub fn push_reloc(mut self: ptr[RelocationVec], r: Relocation):
    if self.len == self.cap:
        mut new_cap := 16 as i64
        if self.cap != 0:
            new_cap = self.cap * 2
        let new_data = @alloc(new_cap * 24) as ptr[Relocation]
        if self.data != null as ptr[Relocation]:
            @memcpy(new_data as ptr[u8], self.data as ptr[u8], self.len * 24)
            @free(self.data as ptr[u8])
        self.data = new_data
        self.cap = new_cap
    self.data[self.len] = r
    self.len = self.len + 1

pub struct Fixup:
    pub offset: i64
    pub label_id: u32
    pub inst_size: i32

pub struct FixupVec:
    pub data: ptr[Fixup]
    pub len: i64
    pub cap: i64

pub fn new_fixup_vec() -> FixupVec:
    return FixupVec(data: null as ptr[Fixup], len: 0, cap: 0)

pub fn push_fixup(mut self: ptr[FixupVec], f: Fixup):
    if self.len == self.cap:
        mut new_cap := 16 as i64
        if self.cap != 0:
            new_cap = self.cap * 2
        let new_data = @alloc(new_cap * 16) as ptr[Fixup]
        if self.data != null as ptr[Fixup]:
            @memcpy(new_data as ptr[u8], self.data as ptr[u8], self.len * 16)
            @free(self.data as ptr[u8])
        self.data = new_data
        self.cap = new_cap
    self.data[self.len] = f
    self.len = self.len + 1

pub struct LabelMap:
    pub keys: ptr[u32]
    pub values: ptr[i64]
    pub len: i64
    pub cap: i64

pub fn new_label_map() -> LabelMap:
    return LabelMap(keys: null as ptr[u32], values: null as ptr[i64], len: 0, cap: 0)

pub fn label_map_set(mut self: ptr[LabelMap], key: u32, val: i64):
    mut i := 0 as i64
    while i < self.len:
        if self.keys[i] == key:
            self.values[i] = val
            return
        i = i + 1
    if self.len == self.cap:
        mut new_cap := 16 as i64
        if self.cap != 0:
            new_cap = self.cap * 2
        let new_keys = @alloc(new_cap * 4) as ptr[u32]
        let new_values = @alloc(new_cap * 8) as ptr[i64]
        if self.keys != null as ptr[u32]:
            @memcpy(new_keys as ptr[u8], self.keys as ptr[u8], self.len * 4)
            @memcpy(new_values as ptr[u8], self.values as ptr[u8], self.len * 8)
            @free(self.keys as ptr[u8])
            @free(self.values as ptr[u8])
        self.keys = new_keys
        self.values = new_values
        self.cap = new_cap
    self.keys[self.len] = key
    self.values[self.len] = val
    self.len = self.len + 1

pub fn label_map_get(self: ptr[LabelMap], key: u32, out_val: ptr[i64]) -> bool:
    mut i := 0 as i64
    while i < self.len:
        if self.keys[i] == key:
            out_val[0] = self.values[i]
            return true
        i = i + 1
    return false

pub struct MachEmitter:
    pub code: ByteVec
    pub relocs: RelocationVec
    pub labels: LabelMap
    pub fixups: FixupVec

pub fn new_mach_emitter() -> MachEmitter:
    return MachEmitter(
        code: new_byte_vec(),
        relocs: new_relocation_vec(),
        labels: new_label_map(),
        fixups: new_fixup_vec()
    )

pub fn free_mach_emitter(mut self: ptr[MachEmitter]):
    if self.code.data != null as ptr[u8]:
        @free(self.code.data)
    if self.relocs.data != null as ptr[Relocation]:
        @free(self.relocs.data as ptr[u8])
    if self.labels.keys != null as ptr[u32]:
        @free(self.labels.keys as ptr[u8])
    if self.labels.values != null as ptr[i64]:
        @free(self.labels.values as ptr[u8])
    if self.fixups.data != null as ptr[Fixup]:
        @free(self.fixups.data as ptr[u8])

pub fn emitter_resolve_reg(op: MachOperand, allocs: ptr[RegAllocation]) -> u8:
    if op.kind == OPND_PHYS:
        return op.phys
    elif op.kind == OPND_VREG:
        let r = op.vreg
        let alloc = allocs[r]
        return alloc.phys
    return REG_NONE

pub fn emit_mach_inst(mut e: ptr[MachEmitter], inst: MachInst, allocs: ptr[RegAllocation], pool: InternPool, frame: ptr[StackFrame], mut str_lit_counter: ptr[i32]):
    let op = inst.op
    let buf = &e.code
    
    if op == MACH_NOP:
        x86_encode_nop(buf)
    elif op == MACH_LABEL:
        label_map_set(&e.labels, inst.dst.label, buf.len)
    elif op == MACH_RET:
        x86_encode_ret(buf)
    elif op == MACH_MOV:
        let dst = emitter_resolve_reg(inst.dst, allocs)
        let src = emitter_resolve_reg(inst.src1, allocs)
        if dst != REG_NONE and src != REG_NONE:
            x86_encode_mov_rr(dst, src, buf)
    elif op == MACH_MOV_IMM:
        let dst = emitter_resolve_reg(inst.dst, allocs)
        let imm = inst.src1.imm
        ax_printf_local("[Debug emit_mach_inst] MACH_MOV_IMM dst=%d, vreg_flag=%d, imm=%d\n", dst as i64, inst.src1.vreg as i64, imm, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fflush(null as ptr[void])
        if dst != REG_NONE:
            if inst.src1.vreg == 1 as u32: // Symbol index!
                let offset = buf.len + 2 as i64
                push_reloc(&e.relocs, Relocation(
                    offset: offset,
                    kind: RELOC_ABS64,
                    padding1: 0 as u8,
                    padding2: 0 as u16,
                    sym_name: imm as u32,
                    addend: 0 as i64
                ))
                x86_encode_mov_ri64(dst, 0 as i64, buf)
            elif inst.src1.vreg == 2 as u32: // String literal!
                let offset = buf.len + 3 as i64
                let sym_val = 0xE0000000 as i64 + imm
                push_reloc(&e.relocs, Relocation(
                    offset: offset,
                    kind: RELOC_PC32,
                    padding1: 0 as u8,
                    padding2: 0 as u16,
                    sym_name: sym_val as u32,
                    addend: -4 as i64
                ))
                x86_encode_lea_rip(dst, 0 as i32, buf)
                
                let text = pool.get(imm as u32)
                let len = std.string.len(text)
                
                let struct_offset = (frame.callee_saved_len * 8) + (frame.spill_slots * 8) + 16 + str_lit_counter[0] * 16
                let len_offset = struct_offset - 8
                str_lit_counter[0] = str_lit_counter[0] + 1
                
                x86_encode_mov_store(REG_RBP, 0 as i32 - struct_offset as i32, dst, buf)
                x86_encode_mov_ri64(dst, len, buf)
                x86_encode_mov_store(REG_RBP, 0 as i32 - len_offset as i32, dst, buf)
                x86_encode_lea(dst, REG_RBP, 0 as i32 - struct_offset as i32, buf)

            else:
                if imm >= -2147483648 as i64 and imm <= 2147483647 as i64:
                    x86_encode_mov_ri(dst, imm as i32, buf)
                else:
                    x86_encode_mov_ri64(dst, imm, buf)

    elif op == MACH_XOR_ZERO:
        let dst = emitter_resolve_reg(inst.dst, allocs)
        if dst != REG_NONE:
            x86_encode_xor_zero(dst, buf)
    elif op == MACH_ADD:
        let dst = emitter_resolve_reg(inst.dst, allocs)
        if inst.src1.kind == OPND_IMM:
            x86_encode_add_ri(dst, inst.src1.imm as i32, buf)
        else:
            let src = emitter_resolve_reg(inst.src1, allocs)
            x86_encode_add_rr(dst, src, buf)
    elif op == MACH_SUB:
        let dst = emitter_resolve_reg(inst.dst, allocs)
        if inst.src1.kind == OPND_IMM:
            x86_encode_sub_ri(dst, inst.src1.imm as i32, buf)
        else:
            let src = emitter_resolve_reg(inst.src1, allocs)
            x86_encode_sub_rr(dst, src, buf)
    elif op == MACH_IMUL:
        let dst = emitter_resolve_reg(inst.dst, allocs)
        let src = emitter_resolve_reg(inst.src1, allocs)
        x86_encode_imul_rr(dst, src, buf)
    elif op == MACH_IDIV:
        let src = emitter_resolve_reg(inst.src1, allocs)
        x86_encode_idiv_r(src, buf)
    elif op == MACH_CQO:
        x86_encode_cqo(buf)
    elif op == MACH_NEG:
        let dst = emitter_resolve_reg(inst.dst, allocs)
        x86_encode_neg_r(dst, buf)
    elif op == MACH_NOT:
        let dst = emitter_resolve_reg(inst.dst, allocs)
        x86_encode_not_r(dst, buf)
    elif op == MACH_AND:
        let dst = emitter_resolve_reg(inst.dst, allocs)
        let src = emitter_resolve_reg(inst.src1, allocs)
        x86_encode_and_rr(dst, src, buf)
    elif op == MACH_OR:
        let dst = emitter_resolve_reg(inst.dst, allocs)
        let src = emitter_resolve_reg(inst.src1, allocs)
        x86_encode_or_rr(dst, src, buf)
    elif op == MACH_XOR:
        let dst = emitter_resolve_reg(inst.dst, allocs)
        let src = emitter_resolve_reg(inst.src1, allocs)
        x86_encode_xor_rr(dst, src, buf)
    elif op == MACH_SHL:
        let dst = emitter_resolve_reg(inst.dst, allocs)
        if inst.src1.kind == OPND_IMM:
            x86_encode_shl_imm(dst, inst.src1.imm as u8, buf)
        else:
            x86_encode_shl_cl(dst, buf)
    elif op == MACH_SAR:
        let dst = emitter_resolve_reg(inst.dst, allocs)
        if inst.src1.kind == OPND_IMM:
            x86_encode_sar_imm(dst, inst.src1.imm as u8, buf)
        else:
            x86_encode_sar_cl(dst, buf)
    elif op == MACH_CMP:
        let dst = emitter_resolve_reg(inst.dst, allocs)
        if inst.src1.kind == OPND_IMM:
            x86_encode_cmp_ri(dst, inst.src1.imm as i32, buf)
        else:
            let src = emitter_resolve_reg(inst.src1, allocs)
            x86_encode_cmp_rr(dst, src, buf)
    elif op == MACH_TEST:
        let dst = emitter_resolve_reg(inst.dst, allocs)
        let src = emitter_resolve_reg(inst.src1, allocs)
        x86_encode_test_rr(dst, src, buf)
    elif op == MACH_SETCC:
        let dst = emitter_resolve_reg(inst.dst, allocs)
        x86_encode_setcc(inst.cc, dst, buf)
    elif op == MACH_MOVZX_B:
        let dst = emitter_resolve_reg(inst.dst, allocs)
        let src = emitter_resolve_reg(inst.src1, allocs)
        x86_encode_movzx_br(dst, src, buf)
    elif op == MACH_PUSH:
        let src = emitter_resolve_reg(inst.src1, allocs)
        x86_encode_push(src, buf)
    elif op == MACH_POP:
        let dst = emitter_resolve_reg(inst.dst, allocs)
        x86_encode_pop(dst, buf)
    elif op == MACH_JMP:
        if inst.dst.kind == OPND_LABEL:
            push_fixup(&e.fixups, Fixup(offset: buf.len + 1, label_id: inst.dst.label, inst_size: 5))
            x86_encode_jmp_rel32(0 as i32, buf)
    elif op == MACH_JCC:
        if inst.dst.kind == OPND_LABEL:
            push_fixup(&e.fixups, Fixup(offset: buf.len + 2, label_id: inst.dst.label, inst_size: 6))
            x86_encode_jcc_rel32(inst.cc, 0 as i32, buf)
    elif op == MACH_CALL:
        mut disp := 0 as i32
        if inst.src1.imm == 0 as i64:
            // Recursive call to current function (starts at 0)
            disp = -(buf.len + 5) as i32
        else:
            push_fixup(&e.fixups, Fixup(offset: buf.len + 1, label_id: inst.src1.imm as u32, inst_size: 5))
        x86_encode_call_rel32(disp, buf)
    elif op == MACH_SYSCALL:
        x86_encode_syscall(buf)
    elif op == MACH_LOAD:
        let dst = emitter_resolve_reg(inst.dst, allocs)
        let base = emitter_resolve_reg(inst.src1, allocs)
        mut disp := 0 as i32
        if inst.src2.kind == OPND_IMM:
            disp = inst.src2.imm as i32
        mut size := inst.padding
        if size == 0 as u8:
            size = 8 as u8
        x86_encode_mov_load_sized(dst, base, disp, size, buf)
    elif op == MACH_STORE:
        let base = emitter_resolve_reg(inst.dst, allocs)
        let src = emitter_resolve_reg(inst.src1, allocs)
        mut disp := 0 as i32
        if inst.src2.kind == OPND_IMM:
            disp = inst.src2.imm as i32
        mut size := inst.padding
        if size == 0 as u8:
            size = 8 as u8
        x86_encode_mov_store_sized(base, disp, src, size, buf)

pub fn emitter_resolve_fixups(mut e: ptr[MachEmitter]):
    mut i := 0 as i64
    while i < e.fixups.len:
        let fix = e.fixups.data[i]
        mut target := 0 as i64
        let found = label_map_get(&e.labels, fix.label_id, &target)
        if not found:
            // External symbol â€” needs linker relocation
            push_reloc(&e.relocs, Relocation(
                offset: fix.offset,
                kind: RELOC_PC32,
                padding1: 0 as u8,
                padding2: 0 as u16,
                sym_name: fix.label_id,
                addend: -4 as i64
            ))
        else:
            // Compute PC-relative offset
            let rel = (target - (fix.offset + 4 as i64)) as i32
            
            // Patch rel32 field in code
            e.code.data[fix.offset + 0] = (rel & 0xFF as i32) as u8
            e.code.data[fix.offset + 1] = ((rel >> 8) & 0xFF as i32) as u8
            e.code.data[fix.offset + 2] = ((rel >> 16) & 0xFF as i32) as u8
            e.code.data[fix.offset + 3] = ((rel >> 24) & 0xFF as i32) as u8
        i = i + 1

pub fn emit_function_binary(mut e: ptr[MachEmitter], fn_name: str, insts: ptr[MachInst], insts_len: i64, allocs: ptr[RegAllocation], frame: ptr[StackFrame], is_windows: bool, pool: InternPool, mut str_lit_counter: ptr[i32], self_link: bool):
    mut prologue := new_mach_inst_vec()
    emit_prologue(frame, &prologue)
    mut i := 0 as i64
    while i < prologue.len:
        emit_mach_inst(e, prologue.data[i], allocs, pool, frame, str_lit_counter)
        i = i + 1
    if prologue.data != null as ptr[MachInst]:
        @free(prologue.data as ptr[u8])
        
    let is_entry = (fn_name == "main" or fn_name == "_AX_main_main_v_v")
    i = 0 as i64
    while i < insts_len:
        let inst = insts[i]
        if inst.op == MACH_RET:
            mut epilogue := new_mach_inst_vec()
            emit_epilogue(frame, &epilogue)
            mut j := 0 as i64
            while j < epilogue.len:
                emit_mach_inst(e, epilogue.data[j], allocs, pool, frame, str_lit_counter)
                j = j + 1
            if epilogue.data != null as ptr[MachInst]:
                @free(epilogue.data as ptr[u8])
                
            if is_entry and self_link:
                if is_windows:
                    // mov ecx, eax -> 89 C1
                    push_byte(&e.code, 0x89 as u8)
                    push_byte(&e.code, 0xC1 as u8)
                    // sub rsp, 40 -> 48 83 EC 28
                    push_byte(&e.code, 0x48 as u8)
                    push_byte(&e.code, 0x83 as u8)
                    push_byte(&e.code, 0xEC as u8)
                    push_byte(&e.code, 0x28 as u8)
                    // call ExitProcess (relocation sym_name = -20)
                    let offset = e.code.len + 1 as i64
                    push_reloc(&e.relocs, Relocation(
                        offset: offset,
                        kind: RELOC_PC32,
                        padding1: 0 as u8,
                        padding2: 0 as u16,
                        sym_name: 4294967276 as u32, // -20 as i64 represented as u32
                        addend: -4 as i64
                    ))
                    push_byte(&e.code, 0xE8 as u8)
                    push_u32_le(&e.code, 0 as u32)
                else:
                    // Linux exit syscall:
                    // mov rdi, rax -> 48 89 C7
                    push_byte(&e.code, 0x48 as u8)
                    push_byte(&e.code, 0x89 as u8)
                    push_byte(&e.code, 0xC7 as u8)
                    // mov rax, 60 -> 48 C7 C0 3C 00 00 00
                    push_byte(&e.code, 0x48 as u8)
                    push_byte(&e.code, 0xC7 as u8)
                    push_byte(&e.code, 0xC0 as u8)
                    push_u32_le(&e.code, 60 as u32)
                    // syscall -> 0F 05
                    push_byte(&e.code, 0x0F as u8)
                    push_byte(&e.code, 0x05 as u8)
            else:
                emit_mach_inst(e, inst, allocs, pool, frame, str_lit_counter)
        else:
            emit_mach_inst(e, inst, allocs, pool, frame, str_lit_counter)
        i = i + 1
        
    emitter_resolve_fixups(e)
// bootstrap/stage1/x86_elf64.ax
// ELF64 Object File Writer for x86-64 Linux targets in self-hosted AXIOM.


extern "C" fn fopen(filename: ptr[void], mode: ptr[u8]) -> ptr[void]
extern "C" fn fwrite(buffer: ptr[void], size: i64, count: i64, stream: ptr[void]) -> i64
extern "C" fn fclose(stream: ptr[void]) -> i32

pub const ELF_CLASS64:    u8 = 2
pub const ELF_DATA2LSB:   u8 = 1
pub const EV_CURRENT:     u8 = 1
pub const ET_REL:        u16 = 1
pub const EM_X86_64:     u16 = 62

pub const SHT_NULL:      u32 = 0
pub const SHT_PROGBITS:  u32 = 1
pub const SHT_SYMTAB:    u32 = 2
pub const SHT_STRTAB:    u32 = 3
pub const SHT_RELA:      u32 = 4

pub const SHF_ALLOC:     u64 = 0x02
pub const SHF_EXECINSTR: u64 = 0x04

pub const STB_LOCAL:      u8 = 0
pub const STB_GLOBAL:     u8 = 1
pub const STT_OBJECT:     u8 = 1
pub const STT_FUNC:       u8 = 2
pub const STT_SECTION:    u8 = 3

pub struct ELF64Sym:
    pub name_str: str
    pub value: u64
    pub size: u64
    pub binding: u8
    pub sym_type: u8
    pub section: u16

pub struct ELF64SymVec:
    pub data: ptr[ELF64Sym]
    pub len: i64
    pub cap: i64

pub fn new_elf64_sym_vec() -> ELF64SymVec:
    return ELF64SymVec(data: null as ptr[ELF64Sym], len: 0, cap: 0)

pub fn push_elf64_sym(mut self: ptr[ELF64SymVec], s: ELF64Sym):
    if self.len == self.cap:
        mut new_cap := 16 as i64
        if self.cap != 0:
            new_cap = self.cap * 2
        let new_data = @alloc(new_cap * 40) as ptr[ELF64Sym]
        if self.data != null as ptr[ELF64Sym]:
            @memcpy(new_data as ptr[u8], self.data as ptr[u8], self.len * 40)
            @free(self.data as ptr[u8])
        self.data = new_data
        self.cap = new_cap
    self.data[self.len] = s
    self.len = self.len + 1

pub fn elf64_serialize(code: ptr[ByteVec], relocs: ptr[RelocationVec], symbols: ptr[ELF64SymVec], out_bytes: ptr[ByteVec]):
    // 1. Build string table
    mut strtab := new_byte_vec()
    push_byte(&strtab, 0 as u8) // first byte is NULL
    
    // Add standard section names
    let sec_names = @alloc(4 * 8) as ptr[str]
    sec_names[0] = ".text"
    sec_names[1] = ".symtab"
    sec_names[2] = ".strtab"
    sec_names[3] = ".rela.text"
    
    let sec_offsets = @alloc(4 * 4) as ptr[u32]
    mut i := 0 as i64
    while i < 4:
        sec_offsets[i] = strtab.len as u32
        let s = sec_names[i]
        let s_len = std.string.len(s)
        let s_ptr = s as ptr[u8]
        mut char_i := 0 as i64
        while char_i < s_len:
            push_byte(&strtab, s_ptr[char_i])
            char_i = char_i + 1
        push_byte(&strtab, 0 as u8)
        i = i + 1
        
    // Add symbol names
    let sym_offsets = @alloc(symbols.len * 4) as ptr[u32]
    mut si := 0 as i64
    while si < symbols.len:
        sym_offsets[si] = strtab.len as u32
        let s = symbols.data[si].name_str
        let s_len = std.string.len(s)
        let s_ptr = s as ptr[u8]
        mut char_i := 0 as i64
        while char_i < s_len:
            push_byte(&strtab, s_ptr[char_i])
            char_i = char_i + 1
        push_byte(&strtab, 0 as u8)
        si = si + 1
        
    // 2. Lay out ELF64 sections
    mut num_sections := 4 as u16
    if relocs.len > 0 as i64:
        num_sections = 5 as u16
        
    let ehdr_size = 64 as i64
    let shdr_size = 64 as i64
    let shdr_table_size = num_sections as i64 * shdr_size
    
    let text_off = ehdr_size
    let text_size = code.len
    
    mut symtab_off = text_off + text_size
    if (symtab_off % 8 as i64) != 0 as i64:
        symtab_off = symtab_off + (8 as i64 - (symtab_off % 8 as i64))
        
    let sym_ent_size = 24 as i64
    let sym_count = 1 as i64 + symbols.len // first NULL entry
    let symtab_size = sym_count * sym_ent_size
    
    let strtab_off = symtab_off + symtab_size
    let strtab_size = strtab.len
    
    mut rela_off = strtab_off + strtab_size
    let rela_ent_size = 24 as i64
    mut rela_size := 0 as i64
    if relocs.len > 0 as i64:
        rela_size = relocs.len * rela_ent_size
        
    mut shdr_off = rela_off + rela_size
    if relocs.len == 0 as i64:
        shdr_off = strtab_off + strtab_size
    if (shdr_off % 8 as i64) != 0 as i64:
        shdr_off = shdr_off + (8 as i64 - (shdr_off % 8 as i64))
        
    // 3. Write ELF64 Header
    push_byte(out_bytes, 0x7F as u8)
    push_byte(out_bytes, 'E' as u8)
    push_byte(out_bytes, 'L' as u8)
    push_byte(out_bytes, 'F' as u8)
    push_byte(out_bytes, ELF_CLASS64)
    push_byte(out_bytes, ELF_DATA2LSB)
    push_byte(out_bytes, EV_CURRENT)
    
    // pad out to 16 bytes
    mut pad_i := 0 as i64
    while pad_i < 9:
        push_byte(out_bytes, 0 as u8)
        pad_i = pad_i + 1
        
    push_u16_le(out_bytes, ET_REL)
    push_u16_le(out_bytes, EM_X86_64)
    push_u32_le(out_bytes, EV_CURRENT as u32)
    push_u64_le(out_bytes, 0 as u64) // e_entry = 0
    push_u64_le(out_bytes, 0 as u64) // e_phoff = 0
    push_u64_le(out_bytes, shdr_off as u64)
    push_u32_le(out_bytes, 0 as u32) // e_flags = 0
    push_u16_le(out_bytes, ehdr_size as u16)
    push_u16_le(out_bytes, 0 as u16) // e_phentsize
    push_u16_le(out_bytes, 0 as u16) // e_phnum
    push_u16_le(out_bytes, shdr_size as u16)
    push_u16_le(out_bytes, num_sections)
    push_u16_le(out_bytes, 3 as u16) // e_shstrndx = 3 (.strtab)
    
    // 4. Write .text section data
    push_bytes(out_bytes, code.data, text_size)
    
    // Padding to symtab
    while out_bytes.len < symtab_off:
        push_byte(out_bytes, 0 as u8)
        
    // 5. Write Symbol Table
    // NULL symbol (24 bytes)
    mut sym_pad := 0 as i64
    while sym_pad < 24:
        push_byte(out_bytes, 0 as u8)
        sym_pad = sym_pad + 1
        
    si = 0
    while si < symbols.len:
        let sym = &symbols.data[si]
        let name_idx = sym_offsets[si]
        push_u32_le(out_bytes, name_idx)
        push_byte(out_bytes, (sym.binding << 4 as u8) | sym.sym_type)
        push_byte(out_bytes, 0 as u8) // st_other
        push_u16_le(out_bytes, sym.section)
        push_u64_le(out_bytes, sym.value)
        push_u64_le(out_bytes, sym.size)
        si = si + 1
        
    // 6. Write String Table
    push_bytes(out_bytes, strtab.data, strtab_size)
    
    // 7. Write Relocations
    if relocs.len > 0 as i64:
        mut ri := 0 as i64
        while ri < relocs.len:
            let r = relocs.data[ri]
            push_u64_le(out_bytes, r.offset as u64)
            
            mut r_type := 1 as u32 // R_X86_64_64
            if r.kind == RELOC_PC32:
                r_type = 2 as u32 // R_X86_64_PC32
            elif r.kind == RELOC_PLT32:
                r_type = 4 as u32 // R_X86_64_PLT32
            elif r.kind == RELOC_ABS64:
                r_type = 1 as u32 // R_X86_64_64
                
            let r_info = (r_type as u64) | ((r.sym_name as u64) << 32 as u64)
            push_u64_le(out_bytes, r_info)
            push_u64_le(out_bytes, r.addend as u64)
            ri = ri + 1
            
    // Padding to section headers
    while out_bytes.len < shdr_off:
        push_byte(out_bytes, 0 as u8)
        
    // 8. Write Section Headers
    // Section 0: SHT_NULL
    mut sh_pad := 0 as i64
    while sh_pad < 64:
        push_byte(out_bytes, 0 as u8)
        sh_pad = sh_pad + 1
        
    // Section 1: .text
    push_u32_le(out_bytes, sec_offsets[0])
    push_u32_le(out_bytes, SHT_PROGBITS)
    push_u64_le(out_bytes, SHF_ALLOC | SHF_EXECINSTR)
    push_u64_le(out_bytes, 0 as u64) // sh_addr = 0
    push_u64_le(out_bytes, text_off as u64)
    push_u64_le(out_bytes, text_size as u64)
    push_u32_le(out_bytes, 0 as u32) // sh_link = 0
    push_u32_le(out_bytes, 0 as u32) // sh_info = 0
    push_u64_le(out_bytes, 16 as u64) // sh_addralign = 16
    push_u64_le(out_bytes, 0 as u64) // sh_entsize = 0
    
    // Section 2: .symtab
    push_u32_le(out_bytes, sec_offsets[1])
    push_u32_le(out_bytes, SHT_SYMTAB)
    push_u64_le(out_bytes, 0 as u64) // sh_flags = 0
    push_u64_le(out_bytes, 0 as u64) // sh_addr = 0
    push_u64_le(out_bytes, symtab_off as u64)
    push_u64_le(out_bytes, symtab_size as u64)
    push_u32_le(out_bytes, 3 as u32) // sh_link -> .strtab (section 3)
    push_u32_le(out_bytes, 1 as u32) // sh_info -> first global symbol
    push_u64_le(out_bytes, 8 as u64) // sh_addralign = 8
    push_u64_le(out_bytes, sym_ent_size as u64)
    
    // Section 3: .strtab
    push_u32_le(out_bytes, sec_offsets[2])
    push_u32_le(out_bytes, SHT_STRTAB)
    push_u64_le(out_bytes, 0 as u64)
    push_u64_le(out_bytes, 0 as u64)
    push_u64_le(out_bytes, strtab_off as u64)
    push_u64_le(out_bytes, strtab_size as u64)
    push_u32_le(out_bytes, 0 as u32)
    push_u32_le(out_bytes, 0 as u32)
    push_u64_le(out_bytes, 1 as u64)
    push_u64_le(out_bytes, 0 as u64)
    
    // Section 4: .rela.text (optional)
    if relocs.len > 0 as i64:
        push_u32_le(out_bytes, sec_offsets[3])
        push_u32_le(out_bytes, SHT_RELA)
        push_u64_le(out_bytes, 0 as u64)
        push_u64_le(out_bytes, 0 as u64)
        push_u64_le(out_bytes, rela_off as u64)
        push_u64_le(out_bytes, rela_size as u64)
        push_u32_le(out_bytes, 2 as u32) // sh_link -> .symtab (section 2)
        push_u32_le(out_bytes, 1 as u32) // sh_info -> .text (section 1)
        push_u64_le(out_bytes, 8 as u64)
        push_u64_le(out_bytes, rela_ent_size as u64)
        
    // Free resources
    @free(sec_names as ptr[u8])
    @free(sec_offsets as ptr[u8])
    @free(sym_offsets as ptr[u8])
    if strtab.data != null as ptr[u8]:
        @free(strtab.data)

pub fn elf64_write_object_file(filename: str, code: ptr[ByteVec], relocs: ptr[RelocationVec], symbols: ptr[ELF64SymVec]) -> bool:
    mut out_bytes := new_byte_vec()
    elf64_serialize(code, relocs, symbols, &out_bytes)
    
    let filename_nt = x86_str_to_null_terminated(filename)
    let file = fopen(filename_nt as ptr[void], get_str_ptr("wb"))
    @free(filename_nt)
    if file == null as ptr[void]:
        if out_bytes.data != null as ptr[u8]:
            @free(out_bytes.data)
        return false
        
    fwrite(out_bytes.data as ptr[void], 1, out_bytes.len, file)
    fclose(file)
    
    if out_bytes.data != null as ptr[u8]:
        @free(out_bytes.data)
    return true
// bootstrap/stage1/x86_coff.ax
// PE/COFF Object File Writer for x86-64 Windows targets in self-hosted AXIOM.


pub const IMAGE_REL_AMD64_ADDR64: u16 = 1
pub const IMAGE_REL_AMD64_REL32:  u16 = 4

pub const IMAGE_SYM_CLASS_EXTERNAL: u8 = 2
pub const IMAGE_SYM_CLASS_STATIC:   u8 = 3

pub struct COFFReloc:
    pub virt_addr: u32
    pub sym_table_idx: u32
    pub reloc_type: u16

pub struct COFFRelocVec:
    pub data: ptr[COFFReloc]
    pub len: i64
    pub cap: i64

pub fn new_coff_reloc_vec() -> COFFRelocVec:
    return COFFRelocVec(data: null as ptr[COFFReloc], len: 0, cap: 0)

pub fn push_coff_reloc(mut self: ptr[COFFRelocVec], r: COFFReloc):
    if self.len == self.cap:
        mut new_cap := 16 as i64
        if self.cap != 0:
            new_cap = self.cap * 2
        let new_data = @alloc(new_cap * 12) as ptr[COFFReloc]
        if self.data != null as ptr[COFFReloc]:
            @memcpy(new_data as ptr[u8], self.data as ptr[u8], self.len * 12)
            @free(self.data as ptr[u8])
        self.data = new_data
        self.cap = new_cap
    self.data[self.len] = r
    self.len = self.len + 1

pub struct COFFSymbol:
    pub name_str: str
    pub value: u32
    pub section_num: i16
    pub sym_type: u16
    pub storage_class: u8
    pub num_aux: u8

pub struct COFFSymbolVec:
    pub data: ptr[COFFSymbol]
    pub len: i64
    pub cap: i64

pub fn new_coff_symbol_vec() -> COFFSymbolVec:
    return COFFSymbolVec(data: null as ptr[COFFSymbol], len: 0, cap: 0)

pub fn push_coff_symbol(mut self: ptr[COFFSymbolVec], s: COFFSymbol) -> i32:
    if self.len == self.cap:
        mut new_cap := 16 as i64
        if self.cap != 0:
            new_cap = self.cap * 2
        let new_data = @alloc(new_cap * 32) as ptr[COFFSymbol]
        if self.data != null as ptr[COFFSymbol]:
            @memcpy(new_data as ptr[u8], self.data as ptr[u8], self.len * 32)
            @free(self.data as ptr[u8])
        self.data = new_data
        self.cap = new_cap
    let idx = self.len as i32
    self.data[self.len] = s
    self.len = self.len + 1
    return idx

extern "C" fn fopen(filename: ptr[void], mode: ptr[u8]) -> ptr[void]
extern "C" fn fwrite(buffer: ptr[void], size: i64, count: i64, stream: ptr[void]) -> i64
extern "C" fn fclose(stream: ptr[void]) -> i32

pub fn coff_serialize(code: ptr[ByteVec], rdata: ptr[ByteVec], relocs: ptr[COFFRelocVec], symbols: ptr[COFFSymbolVec], out_bytes: ptr[ByteVec]):
    // 1. Build string table
    mut strtab := new_byte_vec()
    push_u32_le(&strtab, 4 as u32) // length placeholder
    
    let string_offsets = @alloc(symbols.len * 4) as ptr[u32]
    mut si := 0 as i64
    while si < symbols.len:
        let name = symbols.data[si].name_str
        let name_len = std.string.len(name)
        if name_len > 8:
            string_offsets[si] = strtab.len as u32
            let name_ptr = name as ptr[u8]
            mut char_i := 0 as i64
            while char_i < name_len:
                push_byte(&strtab, name_ptr[char_i])
                char_i = char_i + 1
            push_byte(&strtab, 0 as u8)
        else:
            string_offsets[si] = 0 as u32
        si = si + 1
        
    // Patch string table length
    if strtab.len > 4 as i64:
        let total_len = strtab.len as u32
        strtab.data[0] = (total_len & 0xFF as u32) as u8
        strtab.data[1] = ((total_len >> 8 as u32) & 0xFF as u32) as u8
        strtab.data[2] = ((total_len >> 16 as u32) & 0xFF as u32) as u8
        strtab.data[3] = ((total_len >> 24 as u32) & 0xFF as u32) as u8
        
    // 2. Lay out COFF components
    let text_size = code.len
    let rdata_size = rdata.len
    
    let text_raw_ptr = 100 as i64 // FileHeader (20) + 2 * SectionHeader (80) = 100
    let rdata_raw_ptr = text_raw_ptr + text_size
    let relocs_offset = rdata_raw_ptr + rdata_size
    let symbol_table_offset = relocs_offset + relocs.len * 10 as i64
    
    // 3. Write COFF File Header (20 bytes)
    push_u16_le(out_bytes, 0x8664 as u16) // AMD64
    push_u16_le(out_bytes, 2 as u16)      // 2 sections (.text and .rdata)
    push_u32_le(out_bytes, 0 as u32)      // TimeDateStamp
    push_u32_le(out_bytes, symbol_table_offset as u32)
    push_u32_le(out_bytes, symbols.len as u32)
    push_u16_le(out_bytes, 0 as u16)      // SizeOfOptionalHeader = 0
    push_u16_le(out_bytes, 0 as u16)      // Characteristics = 0
    
    // 4. Write Section Header 1 (.text) (40 bytes)
    push_byte(out_bytes, '.' as u8)
    push_byte(out_bytes, 't' as u8)
    push_byte(out_bytes, 'e' as u8)
    push_byte(out_bytes, 'x' as u8)
    push_byte(out_bytes, 't' as u8)
    push_byte(out_bytes, 0 as u8)
    push_byte(out_bytes, 0 as u8)
    push_byte(out_bytes, 0 as u8)
    push_u32_le(out_bytes, 0 as u32) // VirtualSize
    push_u32_le(out_bytes, 0 as u32) // VirtualAddress
    push_u32_le(out_bytes, text_size as u32)
    push_u32_le(out_bytes, text_raw_ptr as u32)
    push_u32_le(out_bytes, relocs_offset as u32)
    push_u32_le(out_bytes, 0 as u32) // LineNumsPtr
    push_u16_le(out_bytes, relocs.len as u16)
    push_u16_le(out_bytes, 0 as u16) // NumLineNums
    // CODE | EXECUTE | READ (0x60000020)
    push_u32_le(out_bytes, 0x00000020 as u32 | 0x20000000 as u32 | 0x40000000 as u32)
    
    // 4. Write Section Header 2 (.rdata) (40 bytes)
    push_byte(out_bytes, '.' as u8)
    push_byte(out_bytes, 'r' as u8)
    push_byte(out_bytes, 'd' as u8)
    push_byte(out_bytes, 'a' as u8)
    push_byte(out_bytes, 't' as u8)
    push_byte(out_bytes, 'a' as u8)
    push_byte(out_bytes, 0 as u8)
    push_byte(out_bytes, 0 as u8)
    push_u32_le(out_bytes, 0 as u32) // VirtualSize
    push_u32_le(out_bytes, 0 as u32) // VirtualAddress
    push_u32_le(out_bytes, rdata_size as u32)
    push_u32_le(out_bytes, rdata_raw_ptr as u32)
    push_u32_le(out_bytes, 0 as u32) // RelocsPtr
    push_u32_le(out_bytes, 0 as u32) // LineNumsPtr
    push_u16_le(out_bytes, 0 as u16) // NumRelocs
    push_u16_le(out_bytes, 0 as u16) // NumLineNums
    // INITIALIZED_DATA | READ (0x40000040)
    push_u32_le(out_bytes, 0x00000040 as u32 | 0x40000000 as u32)
    
    // 5. Write raw section data
    push_bytes(out_bytes, code.data, text_size)
    push_bytes(out_bytes, rdata.data, rdata_size)

    
    // 6. Write Relocation Table
    mut ri := 0 as i64
    while ri < relocs.len:
        let r = relocs.data[ri]
        push_u32_le(out_bytes, r.virt_addr)
        push_u32_le(out_bytes, r.sym_table_idx)
        push_u16_le(out_bytes, r.reloc_type)
        ri = ri + 1
        
    // 7. Write Symbol Table
    si = 0
    while si < symbols.len:
        let sym = &symbols.data[si]
        let name_len = std.string.len(sym.name_str)
        if name_len <= 8:
            let name_ptr = sym.name_str as ptr[u8]
            mut char_i := 0 as i64
            while char_i < 8:
                if char_i < name_len:
                    push_byte(out_bytes, name_ptr[char_i])
                else:
                    push_byte(out_bytes, 0 as u8)
                char_i = char_i + 1
        else:
            let offset = string_offsets[si]
            push_u32_le(out_bytes, 0 as u32)
            push_u32_le(out_bytes, offset)
            
        push_u32_le(out_bytes, sym.value)
        push_u16_le(out_bytes, sym.section_num as u16)
        push_u16_le(out_bytes, sym.sym_type)
        push_byte(out_bytes, sym.storage_class)
        push_byte(out_bytes, sym.num_aux)
        si = si + 1
        
    // 8. Write String Table
    push_bytes(out_bytes, strtab.data, strtab.len)
    
    // Free resources
    @free(string_offsets as ptr[u8])
    if strtab.data != null as ptr[u8]:
        @free(strtab.data)

pub fn coff_write_object_file(filename: str, code: ptr[ByteVec], rdata: ptr[ByteVec], relocs: ptr[COFFRelocVec], symbols: ptr[COFFSymbolVec]) -> bool:
    mut out_bytes := new_byte_vec()
    coff_serialize(code, rdata, relocs, symbols, &out_bytes)
    
    let filename_nt = x86_str_to_null_terminated(filename)
    let file = fopen(filename_nt as ptr[void], get_str_ptr("wb"))
    @free(filename_nt)
    if file == null as ptr[void]:
        if out_bytes.data != null as ptr[u8]:
            @free(out_bytes.data)
        return false
        
    fwrite(out_bytes.data as ptr[void], 1, out_bytes.len, file)
    fclose(file)
    
    if out_bytes.data != null as ptr[u8]:
        @free(out_bytes.data)
    return true

pub struct CompiledFuncInfo:
    pub name: str
    pub offset: u32
    pub size: u32
    pub is_global: bool
    pub relocs: RelocationVec

pub struct CompiledFuncInfoVec:
    pub data: ptr[CompiledFuncInfo]
    pub len: i64
    pub cap: i64

pub fn new_compiled_func_info_vec() -> CompiledFuncInfoVec:
    return CompiledFuncInfoVec(data: null as ptr[CompiledFuncInfo], len: 0, cap: 0)

pub fn push_compiled_func_info(mut self: ptr[CompiledFuncInfoVec], info: CompiledFuncInfo):
    if self.len == self.cap:
        mut new_cap := 16 as i64
        if self.cap != 0:
            new_cap = self.cap * 2
        let new_data = @alloc(new_cap * 56) as ptr[CompiledFuncInfo]
        if self.data != null as ptr[CompiledFuncInfo]:
            @memcpy(new_data as ptr[u8], self.data as ptr[u8], self.len * 56)
            @free(self.data as ptr[u8])
        self.data = new_data
        self.cap = new_cap
    self.data[self.len] = info
    self.len = self.len + 1

pub fn resolve_binary_sym_name(sym_idx: i64, current_fn_name: str, symbols: SymbolTable, pool: InternPool) -> str:
    if sym_idx >= 0xE0000000 as i64:
        let str_id = sym_idx - 0xE0000000 as i64
        let sym_name_buf = @alloc(64) as ptr[u8]
        ax_snprintf_local(sym_name_buf as ptr[void], 64, "Linfo.string.%d" as ptr[u8], str_id as ptr[void], null as ptr[void])
        let res = alloc_str_from_raw(sym_name_buf, strlen(sym_name_buf))
        @free(sym_name_buf)
        return res
    if sym_idx == -1 as i64:
        return "malloc"

    if sym_idx == -2 as i64:
        return "free"
    if sym_idx == -3 as i64:
        return "ax_actor_spawn"
    if sym_idx == -4 as i64:
        return "__ax_runtime_init"
    if sym_idx == -5 as i64:
        return "__ax_runtime_shutdown"
    if sym_idx == -8 as i64:
        return "abort"
    if sym_idx == -20 as i64:
        return "ExitProcess"
    if sym_idx == -21 as i64:
        return "strlen"
    if sym_idx == -10 as i64:
        return "ax_println_str"
    if sym_idx == -11 as i64:
        return "ax_println_i64"
    if sym_idx == -12 as i64:
        return "ax_println_f64"
    if sym_idx == -13 as i64:
        return "ax_println_bool"
    if sym_idx == -14 as i64:
        return "ax_print_str"
    if sym_idx == -15 as i64:
        return "ax_print_i64"
    if sym_idx == -16 as i64:
        return "ax_print_f64"
    if sym_idx == -17 as i64:
        return "ax_print_bool"
    if sym_idx <= 0 as i64:
        return current_fn_name
    let name = x86_resolve_sym_name(sym_idx as u32, symbols, pool)
    if name == "std.string.len":
        return "ax_str_len"
    if name == "std.string.concat":
        return "ax_str_concat"
    if name == "std.string.replace":
        return "ax_str_replace"
    if name == "std.string.slice":
        return "ax_str_slice"
    return name



pub fn compile_native_binary(output_obj_file: str, mod: AirModule, symbols: SymbolTable, pool: InternPool, table: TypeTable, format: str, self_link: bool) -> bool:
    mut abi := "win64"
    if format == "elf64":
        abi = "sysv"
        
    mut all_code := new_byte_vec()
    mut func_infos := new_compiled_func_info_vec()
    
    mut coff_syms := new_coff_symbol_vec()
    mut elf_syms := new_elf64_sym_vec()

    mut rdata_buf := new_byte_vec()
    mut str_keys := new_u32_vec()
    mut str_offsets := new_u32_vec()
    
    // Scan for all string literals across all functions
    mut scan_fi := 0 as i64
    while scan_fi < mod.funcs.len:
        let fn_ptr = &mod.funcs.data[scan_fi]
        if not fn_ptr.is_extern:
            let fn_name_str = x86_resolve_sym_name(fn_ptr.sym_id, symbols, pool)
            let name_nt = str_to_null_terminated(fn_name_str)
            ax_printf_local("[Debug Scan Fn] %s has %d insts\n", name_nt as i64, fn_ptr.insts.len as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            fflush(null as ptr[void])
            @free(name_nt)
            mut inst_i := 0 as i64
            while inst_i < fn_ptr.insts.len:
                let inst = &fn_ptr.insts.data[inst_i]
                if inst.opcode == OP_ICONST:
                    let fn_name_str = x86_resolve_sym_name(fn_ptr.sym_id, symbols, pool)
                    let name_nt = str_to_null_terminated(fn_name_str)
                    ax_printf_local("[Debug Scan] OP_ICONST in %s: type_id=%d, src1=%d\n", name_nt as i64, inst.type_id as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                    fflush(null as ptr[void])
                    @free(name_nt)
                if inst.opcode == OP_ICONST and inst.type_id == 12 as u16:
                    let str_id = inst.src1
                    mut found := false
                    mut j := 0 as i64
                    while j < str_keys.len:
                        if str_keys.data[j] == str_id:
                            found = true
                            break
                        j = j + 1
                    if not found:
                        let offset = rdata_buf.len as u32
                        str_keys.push(str_id)
                        str_offsets.push(offset)
                        let text = pool.get(str_id)
                        let len = std.string.len(text)
                        let text_ptr = text as ptr[u8]
                        mut k := 0 as i64
                        while k < len:
                            push_byte(&rdata_buf, text_ptr[k])
                            k = k + 1
                        push_byte(&rdata_buf, 0 as u8) // null-terminate
                inst_i = inst_i + 1
        scan_fi = scan_fi + 1

    // Register all unique string symbols in COFF / ELF symbol table
    mut str_i := 0 as i64
    while str_i < str_keys.len:
        let str_id = str_keys.data[str_i]
        let offset = str_offsets.data[str_i]
        let sym_name_buf = @alloc(64) as ptr[u8]
        ax_snprintf_local(sym_name_buf as ptr[void], 64, "Linfo.string.%d" as ptr[u8], str_id as i64 as ptr[void], null as ptr[void])
        let temp_str = alloc_str_from_raw(sym_name_buf, strlen(sym_name_buf))
        let sym_name = pool.intern(temp_str)
        let sym_name_str = pool.get(sym_name)
        @free(temp_str as ptr[u8])
        if format == "elf64":
            push_elf64_sym(&elf_syms, ELF64Sym(name_str: sym_name_str, value: offset as u64, size: 0 as u64, binding: STB_GLOBAL, sym_type: STT_OBJECT, section: 2 as u16))
        else:
            push_coff_symbol(&coff_syms, COFFSymbol(name_str: sym_name_str, value: offset, section_num: 2 as i16, sym_type: 0 as u16, storage_class: IMAGE_SYM_CLASS_STATIC, num_aux: 0 as u8))
        @free(sym_name_buf)
        str_i = str_i + 1

    
    mut fi := 0 as i64
    while fi < mod.funcs.len:
        let fn_ptr = &mod.funcs.data[fi]
        if fn_ptr.is_extern:
            let name = x86_resolve_sym_name(fn_ptr.sym_id, symbols, pool)
            if format == "elf64":
                push_elf64_sym(&elf_syms, ELF64Sym(name_str: name, value: 0 as u64, size: 0 as u64, binding: STB_GLOBAL, sym_type: STT_FUNC, section: 0 as u16))
            else:
                push_coff_symbol(&coff_syms, COFFSymbol(name_str: name, value: 0 as u32, section_num: 0 as i16, sym_type: 0x20 as u16, storage_class: IMAGE_SYM_CLASS_EXTERNAL, num_aux: 0 as u8))
        fi = fi + 1
        
    fi = 0
    while fi < mod.funcs.len:
        let fn_ptr = &mod.funcs.data[fi]
        if not fn_ptr.is_extern:
            let fn_name = x86_resolve_sym_name(fn_ptr.sym_id, symbols, pool)
            let name_ptr = str_to_null_terminated(fn_name)
            ax_printf_local("[Debug] compile_native_binary: compiling function %s\n", name_ptr as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            fflush(null as ptr[void])
            @free(name_ptr)
            
            ax_printf_local("[Debug]   running select_all\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            fflush(null as ptr[void])
            let mach_insts = select_all(fn_ptr, abi, table, symbols, pool)

            ax_printf_local("[Debug]   running compute_liveness\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            fflush(null as ptr[void])
            let intervals = compute_liveness(mach_insts.data, mach_insts.len)
            
            mut gpr_len := 0 as i64
            let avail_gprs = get_allocatable_gprs(&gpr_len)

            ax_printf_local("[Debug]   running graph_coloring_alloc\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            fflush(null as ptr[void])
            let alloc_res = graph_coloring_alloc(intervals, avail_gprs, gpr_len, mach_insts.data, mach_insts.len, abi)
            
            mut num_str_lits := 0 as i32
            mut loop_i := 0 as i64
            while loop_i < mach_insts.len:
                let inst = mach_insts.data[loop_i]
                if inst.op == MACH_MOV_IMM and inst.src1.vreg == 2 as u32:
                    num_str_lits = num_str_lits + 1
                loop_i = loop_i + 1

            mut local_bytes := 0 as i32
            if num_str_lits > 0:
                local_bytes = 16 + num_str_lits * 16

            mut cs_len := 0 as i64
            let cs_regs = get_used_callee_saved(abi, alloc_res.allocs, alloc_res.max_vreg, &cs_len)
            let frame = compute_frame(cs_regs, cs_len, alloc_res.spill_count, local_bytes, abi)
            
            ax_printf_local("[Debug]   running insert_spill_code\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            fflush(null as ptr[void])
            let final_insts = insert_spill_code(mach_insts.data, mach_insts.len, alloc_res.allocs, &frame)
            
            mut emitter := new_mach_emitter()

            ax_printf_local("[Debug]   running emit_function_binary\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            fflush(null as ptr[void])
            let is_windows = (format == "coff")
            mut str_lit_counter := 0 as i32
            emit_function_binary(&emitter, fn_name, final_insts.data, final_insts.len, alloc_res.allocs, &frame, is_windows, pool, &str_lit_counter, self_link)
            
            ax_printf_local("[Debug]   emit_function_binary done, pushing compiled info\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            fflush(null as ptr[void])
            let current_offset = all_code.len as u32
            push_bytes(&all_code, emitter.code.data, emitter.code.len)
            
            push_compiled_func_info(&func_infos, CompiledFuncInfo(
                name: fn_name,
                offset: current_offset,
                size: emitter.code.len as u32,
                is_global: true,
                relocs: emitter.relocs
            ))
            
            ax_printf_local("[Debug]   freeing local resources\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            fflush(null as ptr[void])
            ax_printf_local("[Debug]     freeing cs_regs\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            fflush(null as ptr[void])
            @free(cs_regs)
            ax_printf_local("[Debug]     freeing avail_gprs\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            fflush(null as ptr[void])
            @free(avail_gprs)
            ax_printf_local("[Debug]     freeing alloc_res.allocs\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            fflush(null as ptr[void])
            @free(alloc_res.allocs)
            if intervals.data != null as ptr[LiveInterval]:
                ax_printf_local("[Debug]     freeing intervals.data\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                fflush(null as ptr[void])
                @free(intervals.data as ptr[u8])
            if mach_insts.data != null as ptr[MachInst]:
                ax_printf_local("[Debug]     freeing mach_insts.data\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                fflush(null as ptr[void])
                @free(mach_insts.data as ptr[u8])
            if final_insts.data != null as ptr[MachInst]:
                ax_printf_local("[Debug]     freeing final_insts.data\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                fflush(null as ptr[void])
                @free(final_insts.data as ptr[u8])
                
            if emitter.code.data != null as ptr[u8]:
                ax_printf_local("[Debug]     freeing emitter.code.data\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                fflush(null as ptr[void])
                @free(emitter.code.data)
            if emitter.labels.keys != null as ptr[u32]:
                ax_printf_local("[Debug]     freeing emitter.labels.keys\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                fflush(null as ptr[void])
                @free(emitter.labels.keys as ptr[u8])
            if emitter.labels.values != null as ptr[i64]:
                ax_printf_local("[Debug]     freeing emitter.labels.values\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                fflush(null as ptr[void])
                @free(emitter.labels.values as ptr[u8])
            if emitter.fixups.data != null as ptr[Fixup]:
                ax_printf_local("[Debug]     freeing emitter.fixups.data\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                fflush(null as ptr[void])
                @free(emitter.fixups.data as ptr[u8])
            ax_printf_local("[Debug]   freeing local resources done\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            fflush(null as ptr[void])
                
        fi = fi + 1
        
    ax_printf_local("[Debug] compile_native_binary: compiling loop finished, populating symbols starting\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    fflush(null as ptr[void])
    let text_sec_idx = 1 as i32
    mut i := 0 as i64
    while i < func_infos.len:
        let info = &func_infos.data[i]
        if format == "elf64":
            push_elf64_sym(&elf_syms, ELF64Sym(name_str: info.name, value: info.offset as u64, size: info.size as u64, binding: STB_GLOBAL, sym_type: STT_FUNC, section: text_sec_idx as u16))
        else:
            push_coff_symbol(&coff_syms, COFFSymbol(name_str: info.name, value: info.offset, section_num: text_sec_idx as i16, sym_type: 0x20 as u16, storage_class: IMAGE_SYM_CLASS_EXTERNAL, num_aux: 0 as u8))
        i = i + 1
    ax_printf_local("[Debug] compile_native_binary: populating symbols done\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    fflush(null as ptr[void])
        
    mut coff_relocs := new_coff_reloc_vec()
    mut elf_relocs := new_relocation_vec()
    
    i = 0
    while i < func_infos.len:
        let info = &func_infos.data[i]
        let func_offset = info.offset
        
        mut r_i := 0 as i64
        while r_i < info.relocs.len:
            let r = info.relocs.data[r_i]
            mut sym_idx := r.sym_name as i64
            if r.sym_name > 0xF0000000 as u32:
                sym_idx = sym_idx - 4294967296 as i64
            let target_name = resolve_binary_sym_name(sym_idx, info.name, symbols, pool)
            
            mut target_sym_idx := -1 as i32
            if format == "elf64":
                mut sym_search := 0 as i64
                while sym_search < elf_syms.len:
                    if elf_syms.data[sym_search].name_str == target_name:
                        target_sym_idx = (sym_search + 1 as i64) as i32
                        break
                    sym_search = sym_search + 1
                    
                if target_sym_idx == -1 as i32:
                    let new_idx = elf_syms.len as i32 + 1 as i32
                    push_elf64_sym(&elf_syms, ELF64Sym(name_str: target_name, value: 0 as u64, size: 0 as u64, binding: STB_GLOBAL, sym_type: STT_FUNC, section: 0 as u16))
                    target_sym_idx = new_idx
            else:
                mut sym_search := 0 as i64
                while sym_search < coff_syms.len:
                    if coff_syms.data[sym_search].name_str == target_name:
                        target_sym_idx = sym_search as i32
                        break
                    sym_search = sym_search + 1
                    
                if target_sym_idx == -1 as i32:
                    let new_idx = coff_syms.len as i32
                    push_coff_symbol(&coff_syms, COFFSymbol(name_str: target_name, value: 0 as u32, section_num: 0 as i16, sym_type: 0x20 as u16, storage_class: IMAGE_SYM_CLASS_EXTERNAL, num_aux: 0 as u8))
                    target_sym_idx = new_idx
                    
            let reloc_offset = func_offset + r.offset as u32
            if format == "elf64":
                push_reloc(&elf_relocs, Relocation(offset: reloc_offset as i64, kind: r.kind, padding1: 0 as u8, padding2: 0 as u16, sym_name: target_sym_idx as u32, addend: r.addend))
            else:
                mut reloc_type := IMAGE_REL_AMD64_REL32
                if r.kind == RELOC_ABS64:
                    reloc_type = IMAGE_REL_AMD64_ADDR64
                    let val = r.addend
                    all_code.data[reloc_offset as i64 + 0] = (val & 0xFF as i64) as u8
                    all_code.data[reloc_offset as i64 + 1] = ((val >> 8 as i64) & 0xFF as i64) as u8
                    all_code.data[reloc_offset as i64 + 2] = ((val >> 16 as i64) & 0xFF as i64) as u8
                    all_code.data[reloc_offset as i64 + 3] = ((val >> 24 as i64) & 0xFF as i64) as u8
                    all_code.data[reloc_offset as i64 + 4] = ((val >> 32 as i64) & 0xFF as i64) as u8
                    all_code.data[reloc_offset as i64 + 5] = ((val >> 40 as i64) & 0xFF as i64) as u8
                    all_code.data[reloc_offset as i64 + 6] = ((val >> 48 as i64) & 0xFF as i64) as u8
                    all_code.data[reloc_offset as i64 + 7] = ((val >> 56 as i64) & 0xFF as i64) as u8
                else:
                    let val = r.addend as i32
                    all_code.data[reloc_offset as i64 + 0] = (val & 0xFF as i32) as u8
                    all_code.data[reloc_offset as i64 + 1] = ((val >> 8 as i32) & 0xFF as i32) as u8
                    all_code.data[reloc_offset as i64 + 2] = ((val >> 16 as i32) & 0xFF as i32) as u8
                    all_code.data[reloc_offset as i64 + 3] = ((val >> 24 as i32) & 0xFF as i32) as u8
                push_coff_reloc(&coff_relocs, COFFReloc(virt_addr: reloc_offset, sym_table_idx: target_sym_idx as u32, reloc_type: reloc_type))
                
            r_i = r_i + 1
        i = i + 1
        
    ax_printf_local("[Debug] compile_native_binary: populating relocs done, writing object file starting\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    fflush(null as ptr[void])
    mut success := false
    if format == "elf64":
        success = elf64_write_object_file(output_obj_file, &all_code, &elf_relocs, &elf_syms)
    else:
        success = coff_write_object_file(output_obj_file, &all_code, &rdata_buf, &coff_relocs, &coff_syms)
    ax_printf_local("[Debug] compile_native_binary: writing object file done, success=%d\n", success as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    fflush(null as ptr[void])
        
    ax_printf_local("[Debug] compile_native_binary: starting cleanup\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    fflush(null as ptr[void])
    if all_code.data != null as ptr[u8]:
        ax_printf_local("[Debug] compile_native_binary: freeing all_code\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fflush(null as ptr[void])
        @free(all_code.data)
    if rdata_buf.data != null as ptr[u8]:
        ax_printf_local("[Debug] compile_native_binary: freeing rdata_buf\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fflush(null as ptr[void])
        @free(rdata_buf.data)
    if str_keys.data != null as ptr[u32]:
        ax_printf_local("[Debug] compile_native_binary: freeing str_keys\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fflush(null as ptr[void])
        @free(str_keys.data as ptr[u8])
    if str_offsets.data != null as ptr[u32]:
        ax_printf_local("[Debug] compile_native_binary: freeing str_offsets\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fflush(null as ptr[void])
        @free(str_offsets.data as ptr[u8])
        
    i = 0
    while i < func_infos.len:
        let info = &func_infos.data[i]
        if info.relocs.data != null as ptr[Relocation]:
            ax_printf_local("[Debug] compile_native_binary: freeing info.relocs for func %d\n", i as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            fflush(null as ptr[void])
            @free(info.relocs.data as ptr[u8])
        i = i + 1
    if func_infos.data != null as ptr[CompiledFuncInfo]:
        ax_printf_local("[Debug] compile_native_binary: freeing func_infos\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fflush(null as ptr[void])
        @free(func_infos.data as ptr[u8])
        
    if coff_syms.data != null as ptr[COFFSymbol]:
        ax_printf_local("[Debug] compile_native_binary: freeing coff_syms\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fflush(null as ptr[void])
        @free(coff_syms.data as ptr[u8])
    if coff_relocs.data != null as ptr[COFFReloc]:
        ax_printf_local("[Debug] compile_native_binary: freeing coff_relocs\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fflush(null as ptr[void])
        @free(coff_relocs.data as ptr[u8])
        
    if elf_syms.data != null as ptr[ELF64Sym]:
        ax_printf_local("[Debug] compile_native_binary: freeing elf_syms\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fflush(null as ptr[void])
        @free(elf_syms.data as ptr[u8])
    if elf_relocs.data != null as ptr[Relocation]:
        ax_printf_local("[Debug] compile_native_binary: freeing elf_relocs\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fflush(null as ptr[void])
        @free(elf_relocs.data as ptr[u8])
    ax_printf_local("[Debug] compile_native_binary: cleanup done\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    fflush(null as ptr[void])
        
    return success

// bootstrap/stage1/linker.ax
// Custom self-hosted ELF64 & PE/COFF relocations resolver and segment merger.


extern "C" fn fopen(filename: ptr[void], mode: ptr[u8]) -> ptr[void]
extern "C" fn fread(buffer: ptr[void], size: i64, count: i64, stream: ptr[void]) -> i64
extern "C" fn fclose(stream: ptr[void]) -> i32
extern "C" fn fseek(stream: ptr[void], offset: i64, origin: i32) -> i32
extern "C" fn ftell(stream: ptr[void]) -> i64
extern "C" fn rewind(stream: ptr[void])

pub fn x86_slice_to_str(data: ptr[u8], len: i64) -> str:
    let buf = @alloc(len + 1) as ptr[u8]
    @memcpy(buf, data, len)
    buf[len] = 0 as u8
    return buf as str

// --------------------------------------------------------------------------
// Basic Binary Decoding & Encoding Helpers
// --------------------------------------------------------------------------

pub fn read_u16_le(data: ptr[u8], off: i64) -> u16:
    let b0 = data[off] as u16
    let b1 = data[off + 1] as u16
    return b0 | (b1 << 8 as u16)

pub fn read_u32_le(data: ptr[u8], off: i64) -> u32:
    let b0 = data[off] as u32
    let b1 = data[off + 1] as u32
    let b2 = data[off + 2] as u32
    let b3 = data[off + 3] as u32
    return b0 | (b1 << 8 as u32) | (b2 << 16 as u32) | (b3 << 24 as u32)

pub fn read_u64_le(data: ptr[u8], off: i64) -> u64:
    let b0 = data[off] as u64
    let b1 = data[off + 1] as u64
    let b2 = data[off + 2] as u64
    let b3 = data[off + 3] as u64
    let b4 = data[off + 4] as u64
    let b5 = data[off + 5] as u64
    let b6 = data[off + 6] as u64
    let b7 = data[off + 7] as u64
    return b0 | (b1 << 8 as u64) | (b2 << 16 as u64) | (b3 << 24 as u64) | (b4 << 32 as u64) | (b5 << 40 as u64) | (b6 << 48 as u64) | (b7 << 56 as u64)

pub fn write_u32_le(data: ptr[u8], off: i64, val: u32):
    data[off] = (val & 0xFF as u32) as u8
    data[off + 1] = ((val >> 8 as u32) & 0xFF as u32) as u8
    data[off + 2] = ((val >> 16 as u32) & 0xFF as u32) as u8
    data[off + 3] = ((val >> 24 as u32) & 0xFF as u32) as u8

pub fn write_u64_le(data: ptr[u8], off: i64, val: u64):
    data[off] = (val & 0xFF as u64) as u8
    data[off + 1] = ((val >> 8 as u64) & 0xFF as u64) as u8
    data[off + 2] = ((val >> 16 as u64) & 0xFF as u64) as u8
    data[off + 3] = ((val >> 24 as u64) & 0xFF as u64) as u8
    data[off + 4] = ((val >> 32 as u64) & 0xFF as u64) as u8
    data[off + 5] = ((val >> 40 as u64) & 0xFF as u64) as u8
    data[off + 6] = ((val >> 48 as u64) & 0xFF as u64) as u8
    data[off + 7] = ((val >> 56 as u64) & 0xFF as u64) as u8
// --------------------------------------------------------------------------
// Linker Structures and Dynamic Vectors
// --------------------------------------------------------------------------

pub struct LinkerSymbol:
    pub name: str
    pub section: i64
    pub offset: u64
    pub size: u64
    pub defined: bool

pub struct LinkerSymbolVec:
    pub data: ptr[LinkerSymbol]
    pub len: i64
    pub cap: i64

pub fn new_linker_symbol_vec() -> LinkerSymbolVec:
    return LinkerSymbolVec(data: null as ptr[LinkerSymbol], len: 0, cap: 0)

pub fn push_linker_symbol(mut self: ptr[LinkerSymbolVec], s: LinkerSymbol):
    if self.len == self.cap:
        mut new_cap := 16 as i64
        if self.cap != 0:
            new_cap = self.cap * 2
        let new_data = @alloc(new_cap * 48) as ptr[LinkerSymbol]
        if self.data != null as ptr[LinkerSymbol]:
            @memcpy(new_data as ptr[u8], self.data as ptr[u8], self.len * 48)
            @free(self.data as ptr[u8])
        self.data = new_data
        self.cap = new_cap
    self.data[self.len] = s
    self.len = self.len + 1

pub struct ParsedReloc:
    pub offset: i64
    pub sym_idx: u32
    pub is_pc: bool
    pub addend: i64

pub struct ParsedRelocVec:
    pub data: ptr[ParsedReloc]
    pub len: i64
    pub cap: i64

pub fn new_parsed_reloc_vec() -> ParsedRelocVec:
    return ParsedRelocVec(data: null as ptr[ParsedReloc], len: 0, cap: 0)

pub fn push_parsed_reloc(mut self: ptr[ParsedRelocVec], r: ParsedReloc):
    if self.len == self.cap:
        mut new_cap := 16 as i64
        if self.cap != 0:
            new_cap = self.cap * 2
        let new_data = @alloc(new_cap * 24) as ptr[ParsedReloc]
        if self.data != null as ptr[ParsedReloc]:
            @memcpy(new_data as ptr[u8], self.data as ptr[u8], self.len * 24)
            @free(self.data as ptr[u8])
        self.data = new_data
        self.cap = new_cap
    self.data[self.len] = r
    self.len = self.len + 1

pub struct LinkerStrVec:
    pub data: ptr[str]
    pub len: i64
    pub cap: i64

pub fn new_linker_str_vec() -> LinkerStrVec:
    return LinkerStrVec(data: null as ptr[str], len: 0, cap: 0)

pub fn push_linker_str(mut self: ptr[LinkerStrVec], s: str):
    if self.len == self.cap:
        mut new_cap := 16 as i64
        if self.cap != 0:
            new_cap = self.cap * 2
        let new_data = @alloc(new_cap * 16) as ptr[str]
        if self.data != null as ptr[str]:
            @memcpy(new_data as ptr[u8], self.data as ptr[u8], self.len * 16)
            @free(self.data as ptr[u8])
        self.data = new_data
        self.cap = new_cap
    self.data[self.len] = s
    self.len = self.len + 1

pub struct ParsedObject:
    pub text: ByteVec
    pub rdata: ByteVec
    pub symbols: LinkerSymbolVec
    pub sym_names: LinkerStrVec
    pub relocs: ParsedRelocVec
    pub va: u64

pub struct ParsedObjectPtrVec:
    pub data: ptr[ptr[ParsedObject]]
    pub len: i64
    pub cap: i64

pub fn new_parsed_object_ptr_vec() -> ParsedObjectPtrVec:
    return ParsedObjectPtrVec(data: null as ptr[ptr[ParsedObject]], len: 0, cap: 0)

pub fn push_parsed_object_ptr(mut self: ptr[ParsedObjectPtrVec], p: ptr[ParsedObject]):
    if self.len == self.cap:
        mut new_cap := 16 as i64
        if self.cap != 0:
            new_cap = self.cap * 2
        let new_data = @alloc(new_cap * 8) as ptr[ptr[ParsedObject]]
        if self.data != null as ptr[ptr[ParsedObject]]:
            @memcpy(new_data as ptr[u8], self.data as ptr[u8], self.len * 8)
            @free(self.data as ptr[u8])
        self.data = new_data
        self.cap = new_cap
    self.data[self.len] = p
    self.len = self.len + 1

// --------------------------------------------------------------------------
// ELF64 parser
// --------------------------------------------------------------------------

pub fn linker_parse_elf(data: ptr[u8], data_len: i64) -> ptr[ParsedObject]:
    let shoff = read_u64_le(data, 40) as i64
    let shnum = read_u16_le(data, 60) as i64
    
    mut text_off := 0 as i64
    mut text_size := 0 as i64
    
    mut symtab_off := 0 as i64
    mut symtab_size := 0 as i64
    
    mut strtab_off := 0 as i64
    mut strtab_size := 0 as i64
    
    mut rela_off := 0 as i64
    mut rela_size := 0 as i64
    
    mut i := 0 as i64
    while i < shnum:
        let off = shoff + i * 64
        let sh_type = read_u32_le(data, off + 4)
        let sh_offset = read_u64_le(data, off + 24) as i64
        let sh_size = read_u64_le(data, off + 32) as i64
        
        if sh_type == 1 as u32: // SHT_PROGBITS
            text_off = sh_offset
            text_size = sh_size
        elif sh_type == 2 as u32: // SHT_SYMTAB
            symtab_off = sh_offset
            symtab_size = sh_size
        elif sh_type == 3 as u32: // SHT_STRTAB
            strtab_off = sh_offset
            strtab_size = sh_size
        elif sh_type == 4 as u32: // SHT_RELA
            rela_off = sh_offset
            rela_size = sh_size
        i = i + 1
        
    mut sym_names := new_linker_str_vec()
    if symtab_size > 0:
        let num_syms = symtab_size / 24
        mut sym_i := 0 as i64
        while sym_i < num_syms:
            let off = symtab_off + sym_i * 24
            let name_offset = read_u32_le(data, off) as i64
            
            mut name_str := ""
            if name_offset < strtab_size:
                let str_ptr = (data as i64 + strtab_off + name_offset) as ptr[u8]
                mut char_len := 0 as i64
                while str_ptr[char_len] != 0 as u8:
                    char_len = char_len + 1
                name_str = x86_slice_to_str(str_ptr, char_len)
            push_linker_str(&sym_names, name_str)
            sym_i = sym_i + 1
            
    mut symbols := new_linker_symbol_vec()
    if symtab_size > 0:
        let num_syms = symtab_size / 24
        mut sym_i := 1 as i64 // skip first NULL symbol
        while sym_i < num_syms:
            let off = symtab_off + sym_i * 24
            let sec_idx = read_u16_le(data, off + 6)
            let val64 = read_u64_le(data, off + 8)
            let size = read_u64_le(data, off + 16)
            
            let name = sym_names.data[sym_i]
            let is_defined = sec_idx != 0 as u16
            
            push_linker_symbol(&symbols, LinkerSymbol(
                name: name,
                section: sec_idx as i64,
                offset: val64,
                size: size,
                defined: is_defined
            ))
            sym_i = sym_i + 1
            
    mut relocs := new_parsed_reloc_vec()
    if rela_size > 0:
        let num_relocs = rela_size / 24
        mut rel_i := 0 as i64
        while rel_i < num_relocs:
            let off = rela_off + rel_i * 24
            let r_offset = read_u64_le(data, off) as i64
            let r_info = read_u64_le(data, off + 8)
            let r_addend = read_u64_le(data, off + 16) as i64
            
            let sym_idx = (r_info >> 32 as u64) as u32
            let r_type = (r_info & 0xFFFFFFFF as u64) as u32
            let is_pc = r_type == 2 as u32 or r_type == 4 as u32 // PC32 or PLT32
            
            push_parsed_reloc(&relocs, ParsedReloc(
                offset: r_offset,
                sym_idx: sym_idx,
                is_pc: is_pc,
                addend: r_addend
            ))
            rel_i = rel_i + 1
            
    mut text_vec := new_byte_vec()
    if text_size > 0:
        push_bytes(&text_vec, (data as i64 + text_off) as ptr[u8], text_size)
        
    let obj = @alloc(@compiler_intrinsic("size_of")[ParsedObject]()) as ptr[ParsedObject]
    obj.text = text_vec
    obj.rdata = new_byte_vec()
    obj.symbols = symbols
    obj.sym_names = sym_names
    obj.relocs = relocs
    obj.va = 0 as u64
    return obj

// --------------------------------------------------------------------------
// PE/COFF parser
// --------------------------------------------------------------------------

pub fn linker_parse_coff(data: ptr[u8], data_len: i64) -> ptr[ParsedObject]:
    let num_sections = read_u16_le(data, 2) as i64
    let symtab_off = read_u32_le(data, 8) as i64
    let sym_count = read_u32_le(data, 12) as i64
    
    mut text_off := 0 as i64
    mut text_size := 0 as i64
    mut relocs_off := 0 as i64
    mut num_relocs := 0 as i64
    
    mut rdata_off := 0 as i64
    mut rdata_size := 0 as i64
    
    mut i := 0 as i64
    while i < num_sections:
        let off = 20 + i * 40
        
        // Read section name (first 8 bytes)
        mut is_text := false
        if data[off] == '.' as u8 and data[off + 1] == 't' as u8 and data[off + 2] == 'e' as u8 and data[off + 3] == 'x' as u8 and data[off + 4] == 't' as u8:
            is_text = true
            
        mut is_rdata := false
        if data[off] == '.' as u8 and data[off + 1] == 'r' as u8 and data[off + 2] == 'd' as u8 and data[off + 3] == 'a' as u8 and data[off + 4] == 't' as u8 and data[off + 5] == 'a' as u8:
            is_rdata = true
            
        if is_text:
            text_size = read_u32_le(data, off + 16) as i64
            text_off = read_u32_le(data, off + 20) as i64
            relocs_off = read_u32_le(data, off + 24) as i64
            num_relocs = read_u16_le(data, off + 32) as i64
        elif is_rdata:
            rdata_size = read_u32_le(data, off + 16) as i64
            rdata_off = read_u32_le(data, off + 20) as i64
            
        i = i + 1
        
    let strtab_off = symtab_off + sym_count * 18
    let strtab_size = data_len - strtab_off
    
    mut sym_names := new_linker_str_vec()
    mut symbols := new_linker_symbol_vec()
    
    mut sym_i := 0 as i64
    while sym_i < sym_count:
        let off = symtab_off + sym_i * 18
        mut name_str := ""
        
        let first4 = read_u32_le(data, off)
        if first4 == 0 as u32:
            let str_off = read_u32_le(data, off + 4) as i64
            if str_off < strtab_size:
                let str_ptr = (data as i64 + strtab_off + str_off) as ptr[u8]
                mut char_len := 0 as i64
                while str_ptr[char_len] != 0 as u8:
                    char_len = char_len + 1
                name_str = x86_slice_to_str(str_ptr, char_len)
        else:
            let name_ptr = (data as i64 + off) as ptr[u8]
            mut char_len := 0 as i64
            while char_len < 8 and name_ptr[char_len] != 0 as u8:
                char_len = char_len + 1
            name_str = x86_slice_to_str(name_ptr, char_len)
            
        let val = read_u32_le(data, off + 8)
        let sec_num = read_u16_le(data, off + 12) as i16
        let aux_count = data[off + 17]
        
        push_linker_str(&sym_names, name_str)
        push_linker_symbol(&symbols, LinkerSymbol(
            name: name_str,
            section: sec_num as i64,
            offset: val as u64,
            defined: sec_num > 0 as i16
        ))
        
        sym_i = sym_i + 1
        
        mut k := 0 as u8
        while k < aux_count:
            push_linker_str(&sym_names, "")
            push_linker_symbol(&symbols, LinkerSymbol(name: "", section: 0, offset: 0 as u64, defined: false))
            sym_i = sym_i + 1
            k = k + 1 as u8
            
    mut relocs := new_parsed_reloc_vec()
    mut rel_idx := 0 as i64
    while rel_idx < num_relocs:
        let off = relocs_off + rel_idx * 10
        let virt_addr = read_u32_le(data, off) as i64
        let sym_idx = read_u32_le(data, off + 4)
        let rel_type = read_u16_le(data, off + 8)
        
        let is_pc = rel_type == 4 as u16 // IMAGE_REL_AMD64_REL32
        mut addend := 0 as i64
        if is_pc:
            addend = -4 as i64
            
        push_parsed_reloc(&relocs, ParsedReloc(
            offset: virt_addr,
            sym_idx: sym_idx,
            is_pc: is_pc,
            addend: addend
        ))
        rel_idx = rel_idx + 1
        
    mut text_vec := new_byte_vec()
    if text_size > 0:
        push_bytes(&text_vec, (data as i64 + text_off) as ptr[u8], text_size)
        
    mut rdata_vec := new_byte_vec()
    if rdata_size > 0:
        push_bytes(&rdata_vec, (data as i64 + rdata_off) as ptr[u8], rdata_size)
        
    let obj = @alloc(@compiler_intrinsic("size_of")[ParsedObject]()) as ptr[ParsedObject]
    obj.text = text_vec
    obj.rdata = rdata_vec
    obj.symbols = symbols
    obj.sym_names = sym_names
    obj.relocs = relocs
    obj.va = 0 as u64
    return obj

// --------------------------------------------------------------------------
// Unified Linker Implementation
// --------------------------------------------------------------------------

pub struct AxiomLinker:
    pub input_files: LinkerStrVec
    pub output_path: str

pub fn new_axiom_linker() -> AxiomLinker:
    return AxiomLinker(input_files: new_linker_str_vec(), output_path: "")


pub fn align_byte_vec(vec: ptr[ByteVec], alignment: i64):
    while vec.len % alignment != 0:
        push_byte(vec, 0 as u8)

pub fn get_dll_for_symbol(name: str) -> str:
    if (name == "steals_attempted" or name == "steals_succeeded" or name == "tasks_executed" or
        name == "running" or name == "head" or name == "total_executed" or
        name == "worker_count" or name == "total_submitted" or name == "total_steals" or
        name == "alloc" or name == "q" or name == "msg" or name == "actor" or name == "SEGMENT_MAGIC"):
        return "none"

    if (name == "VirtualAlloc" or name == "VirtualFree" or name == "ExitProcess" or name == "TerminateProcess" or 
        name == "GetLastError" or name == "GetStdHandle" or name == "WriteFile" or
        name == "CreateFileA" or name == "ReadFile" or name == "CloseHandle" or
        name == "CreateDirectoryA" or name == "RemoveDirectoryA" or name == "DeleteFileA" or
        name == "MoveFileA" or name == "CopyFileA" or name == "GetFileAttributesA" or
        name == "GetCommandLineA" or name == "GetEnvironmentVariableA" or name == "SetEnvironmentVariableA" or
        name == "GetCommandLineW"):
        return "kernel32.dll"
        
    let ptr = get_str_ptr(name)
    let len = std.string.len(name)
    if len >= 3 and ptr[0] == 'a' as u8 and ptr[1] == 'x' as u8 and ptr[2] == '_' as u8:
        return "ax_runtime.dll"
    if len >= 5 and ptr[0] == '_' as u8 and ptr[1] == '_' as u8 and ptr[2] == 'a' as u8 and ptr[3] == 'x' as u8 and ptr[4] == '_' as u8:
        return "ax_runtime.dll"
        
    return "ucrtbase.dll"

pub fn add_unique_import(imports: ptr[LinkerStrVec], name: str):
    mut found := false
    mut i := 0 as i64
    while i < imports.len:
        if imports.data[i] == name:
            found = true
            break
        i = i + 1
    if not found:
        push_linker_str(imports, name)

pub fn write_buf_u32_le(data: ptr[u8], off: i64, val: u32):
    data[off] = (val & 0xFF as u32) as u8
    data[off + 1] = ((val >> 8 as u32) & 0xFF as u32) as u8
    data[off + 2] = ((val >> 16 as u32) & 0xFF as u32) as u8
    data[off + 3] = ((val >> 24 as u32) & 0xFF as u32) as u8

pub fn write_buf_u64_le(data: ptr[u8], off: i64, val: u64):
    write_buf_u32_le(data, off, (val & 0xFFFFFFFF as u64) as u32)
    write_buf_u32_le(data, off + 4, ((val >> 32 as u64) & 0xFFFFFFFF as u64) as u32)

pub fn linker_build_pe_headers(
    out: ptr[ByteVec],
    code_raw_size: u32,
    idata_raw_size: u32,
    entry_rva: u32,
    idata_rva: u32,
    idata_size: u32,
    iat_rva: u32,
    iat_size: u32
):
    // 1. DOS Header
    push_byte(out, 0x4D as u8) // 'M'
    push_byte(out, 0x5A as u8) // 'Z'
    mut i := 2 as i64
    while i < 0x3C:
        push_byte(out, 0 as u8)
        i = i + 1
    push_u32_le(out, 0x80 as u32) // e_lfanew
    i = 0x40
    while i < 0x80:
        push_byte(out, 0 as u8)
        i = i + 1
        
    // 2. PE Signature
    push_byte(out, 0x50 as u8) // 'P'
    push_byte(out, 0x45 as u8) // 'E'
    push_byte(out, 0 as u8)
    push_byte(out, 0 as u8)
    
    // 3. COFF File Header
    push_u16_le(out, 0x8664 as u16) // Machine (AMD64)
    push_u16_le(out, 2 as u16) // NumberOfSections
    push_u32_le(out, 0 as u32) // TimeDateStamp
    push_u32_le(out, 0 as u32) // PointerToSymbolTable
    push_u32_le(out, 0 as u32) // NumberOfSymbols
    push_u16_le(out, 240 as u16) // SizeOfOptionalHeader
    push_u16_le(out, 0x0026 as u16) // Characteristics
    
    // 4. Optional Header (PE32+)
    push_u16_le(out, 0x020B as u16) // Magic
    push_byte(out, 1 as u8) // MajorLinkerVersion
    push_byte(out, 0 as u8) // MinorLinkerVersion
    push_u32_le(out, code_raw_size) // SizeOfCode
    push_u32_le(out, idata_raw_size) // SizeOfInitializedData
    push_u32_le(out, 0 as u32) // SizeOfUninitializedData
    push_u32_le(out, entry_rva) // AddressOfEntryPoint
    push_u32_le(out, 0x1000 as u32) // BaseOfCode
    push_u64_le(out, 0x140000000 as u64) // ImageBase
    push_u32_le(out, 0x1000 as u32) // SectionAlignment
    push_u32_le(out, 0x200 as u32) // FileAlignment
    push_u16_le(out, 6 as u16) // MajorOperatingSystemVersion
    push_u16_le(out, 0 as u16) // MinorOperatingSystemVersion
    push_u16_le(out, 0 as u16) // MajorImageVersion
    push_u16_le(out, 0 as u16) // MinorImageVersion
    push_u16_le(out, 6 as u16) // MajorSubsystemVersion
    push_u16_le(out, 0 as u16) // MinorSubsystemVersion
    push_u32_le(out, 0 as u32) // Win32VersionValue
    
    let size_of_image = (idata_rva + idata_raw_size + 0xFFF as u32) & (0xFFFFF000 as u32)
    push_u32_le(out, size_of_image) // SizeOfImage
    push_u32_le(out, 0x400 as u32) // SizeOfHeaders
    push_u32_le(out, 0 as u32) // CheckSum
    push_u16_le(out, 3 as u16) // Subsystem (Console)
    push_u16_le(out, 0x0160 as u16) // DllCharacteristics
    push_u64_le(out, 0x100000 as u64) // SizeOfStackReserve
    push_u64_le(out, 0x1000 as u64) // SizeOfStackCommit
    push_u64_le(out, 0x100000 as u64) // SizeOfHeapReserve
    push_u64_le(out, 0x1000 as u64) // SizeOfHeapCommit
    push_u32_le(out, 0 as u32) // LoaderFlags
    push_u32_le(out, 16 as u32) // NumberOfRvaAndSizes
    
    // Data Directories
    // Dir 0: Export
    push_u32_le(out, 0 as u32)
    push_u32_le(out, 0 as u32)
    // Dir 1: Import
    push_u32_le(out, idata_rva)
    push_u32_le(out, idata_size)
    // Dir 2 to 11 (10 entries = 80 bytes)
    mut dir_i := 2 as i64
    while dir_i < 12:
        push_u32_le(out, 0 as u32)
        push_u32_le(out, 0 as u32)
        dir_i = dir_i + 1
    // Dir 12: IAT
    push_u32_le(out, iat_rva)
    push_u32_le(out, iat_size)
    // Dir 13 to 15 (3 entries = 24 bytes)
    dir_i = 13
    while dir_i < 16:
        push_u32_le(out, 0 as u32)
        push_u32_le(out, 0 as u32)
        dir_i = dir_i + 1
        
    // 5. Section Headers
    // Section 1: .text
    push_byte(out, '.' as u8)
    push_byte(out, 't' as u8)
    push_byte(out, 'e' as u8)
    push_byte(out, 'x' as u8)
    push_byte(out, 't' as u8)
    push_byte(out, 0 as u8)
    push_byte(out, 0 as u8)
    push_byte(out, 0 as u8)
    push_u32_le(out, code_raw_size) // VirtualSize
    push_u32_le(out, 0x1000 as u32) // VirtualAddress
    push_u32_le(out, code_raw_size) // SizeOfRawData
    push_u32_le(out, 0x400 as u32) // PointerToRawData
    push_u32_le(out, 0 as u32) // PointerToRelocations
    push_u32_le(out, 0 as u32) // PointerToLinenumbers
    push_u16_le(out, 0 as u16) // NumberOfRelocations
    push_u16_le(out, 0 as u16) // NumberOfLinenumbers
    push_u32_le(out, 0x60000020 as u32) // Characteristics
    
    // Section 2: .idata
    push_byte(out, '.' as u8)
    push_byte(out, 'i' as u8)
    push_byte(out, 'd' as u8)
    push_byte(out, 'a' as u8)
    push_byte(out, 't' as u8)
    push_byte(out, 'a' as u8)
    push_byte(out, 0 as u8)
    push_byte(out, 0 as u8)
    push_u32_le(out, idata_raw_size) // VirtualSize
    push_u32_le(out, idata_rva) // VirtualAddress
    push_u32_le(out, idata_raw_size) // SizeOfRawData
    push_u32_le(out, 0x400 as u32 + code_raw_size) // PointerToRawData
    push_u32_le(out, 0 as u32)
    push_u32_le(out, 0 as u32)
    push_u16_le(out, 0 as u16)
    push_u16_le(out, 0 as u16)
    push_u32_le(out, 0xC0000040 as u32) // Characteristics
    
    align_byte_vec(out, 0x400 as i64)

pub fn linker_build_elf_headers(out: ptr[ByteVec], code_raw_size: u32, entry_va: u64, dynamic_offset: u32, dynamic_size: u32):
    // 1. e_ident
    push_byte(out, 0x7F as u8)
    push_byte(out, 'E' as u8)
    push_byte(out, 'L' as u8)
    push_byte(out, 'F' as u8)
    push_byte(out, 2 as u8) // ELFCLASS64
    push_byte(out, 1 as u8) // ELFDATA2LSB
    push_byte(out, 1 as u8) // EV_CURRENT
    push_byte(out, 0 as u8) // ELFOSABI_NONE
    mut i := 8 as i64
    while i < 16:
        push_byte(out, 0 as u8)
        i = i + 1
        
    // 2. Type, Machine, Version
    push_u16_le(out, 2 as u16) // ET_EXEC
    push_u16_le(out, 62 as u16) // EM_X86_64
    push_u32_le(out, 1 as u32) // EV_CURRENT
    
    // 3. Entry point virtual address
    push_u64_le(out, entry_va)
    
    // 4. Program header offset
    push_u64_le(out, 64 as u64) // immediately follows ELF header
    
    // 5. Section header offset
    push_u64_le(out, 0 as u64) // no section headers
    
    if dynamic_size > 0:
        // 6. Flags, Header Sizes
        push_u32_le(out, 0 as u32) // e_flags
        push_u16_le(out, 64 as u16) // e_ehsize
        push_u16_le(out, 56 as u16) // e_phentsize
        push_u16_le(out, 3 as u16) // e_phnum (3 program headers)
        push_u16_le(out, 0 as u16) // e_shentsize
        push_u16_le(out, 0 as u16) // e_shnum
        push_u16_le(out, 0 as u16) // e_shstrndx
        
        // 7. Program Header Table
        // PHDR 1: PT_INTERP
        push_u32_le(out, 3 as u32) // p_type: PT_INTERP
        push_u32_le(out, 4 as u32) // p_flags: PF_R
        push_u64_le(out, 232 as u64) // p_offset: starts immediately after PHDRs (64 + 3*56 = 232)
        push_u64_le(out, 0x400000 as u64 + 232 as u64) // p_vaddr
        push_u64_le(out, 0x400000 as u64 + 232 as u64) // p_paddr
        push_u64_le(out, 28 as u64) // p_filesz: "/lib64/ld-linux-x86-64.so.2\0" is 28 bytes
        push_u64_le(out, 28 as u64) // p_memsz
        push_u64_le(out, 1 as u64) // p_align
        
        // PHDR 2: PT_LOAD
        push_u32_le(out, 1 as u32) // p_type: PT_LOAD
        push_u32_le(out, 7 as u32) // p_flags: PF_R | PF_W | PF_X
        push_u64_le(out, 0 as u64) // p_offset: starts at beginning of file
        push_u64_le(out, 0x400000 as u64) // p_vaddr
        push_u64_le(out, 0x400000 as u64) // p_paddr
        push_u64_le(out, 512 as u64 + code_raw_size as u64) // p_filesz
        push_u64_le(out, 512 as u64 + code_raw_size as u64) // p_memsz
        push_u64_le(out, 4096 as u64) // p_align
        
        // PHDR 3: PT_DYNAMIC
        push_u32_le(out, 2 as u32) // p_type: PT_DYNAMIC
        push_u32_le(out, 6 as u32) // p_flags: PF_R | PF_W
        push_u64_le(out, dynamic_offset as u64) // p_offset
        push_u64_le(out, 0x400000 as u64 + dynamic_offset as u64) // p_vaddr
        push_u64_le(out, 0x400000 as u64 + dynamic_offset as u64) // p_paddr
        push_u64_le(out, dynamic_size as u64) // p_filesz
        push_u64_le(out, dynamic_size as u64) // p_memsz
        push_u64_le(out, 8 as u64) // p_align
        
        // Write the interpreter path at offset 232
        let interp_str = "/lib64/ld-linux-x86-64.so.2" as ptr[u8]
        mut c_i := 0 as i64
        while c_i < 27:
            push_byte(out, interp_str[c_i])
            c_i = c_i + 1
        push_byte(out, 0 as u8) // null-terminate
        
        align_byte_vec(out, 512 as i64)
    else:
        // 6. Flags, Header Sizes
        push_u32_le(out, 0 as u32) // e_flags
        push_u16_le(out, 64 as u16) // e_ehsize
        push_u16_le(out, 56 as u16) // e_phentsize
        push_u16_le(out, 1 as u16) // e_phnum (1 PT_LOAD segment)
        push_u16_le(out, 0 as u16) // e_shentsize
        push_u16_le(out, 0 as u16) // e_shnum
        push_u16_le(out, 0 as u16) // e_shstrndx
        
        // 7. Program Header Table (1 entry: PT_LOAD segment)
        push_u32_le(out, 1 as u32) // p_type: PT_LOAD
        push_u32_le(out, 5 as u32) // p_flags: PF_R | PF_X
        push_u64_le(out, 0 as u64) // p_offset: starts at beginning of file
        push_u64_le(out, 0x400000 as u64) // p_vaddr
        push_u64_le(out, 0x400000 as u64) // p_paddr
        push_u64_le(out, 128 as u64 + code_raw_size as u64) // p_filesz: maps entire executable file!
        push_u64_le(out, 128 as u64 + code_raw_size as u64) // p_memsz
        push_u64_le(out, 0x1000 as u64) // p_align
        
        align_byte_vec(out, 128 as i64)

pub fn axiom_linker_add_input(mut self: ptr[AxiomLinker], file: str):
    push_linker_str(&self.input_files, file)

pub fn axiom_linker_link(self: ptr[AxiomLinker]) -> bool:
    mut objects := new_parsed_object_ptr_vec()
    mut format := "coff"
    mut kernel32_iat_offset := 0 as i64
    mut iat_offset := 0 as i64
    mut total_iat_size := 0 as i64
    
    // 1. Load and parse all object files
    mut i := 0 as i64
    while i < self.input_files.len:
        let path = self.input_files.data[i]
        let path_nt = x86_str_to_null_terminated(path)
        let file = fopen(path_nt as ptr[void], get_str_ptr("rb"))
        @free(path_nt)
        if file == null as ptr[void]:
            ax_puts_local("Error: Linker could not open input file: ")
            ax_puts_local(path)
            return false
            
        fseek(file, 0, 2)
        let size = ftell(file)
        rewind(file)
        
        if size <= 4:
            ax_puts_local("Error: Input file too small: ")
            ax_puts_local(path)
            fclose(file)
            return false
            
        let buffer = @alloc(size) as ptr[u8]
        fread(buffer as ptr[void], 1, size, file)
        fclose(file)
        
        mut obj := null as ptr[ParsedObject]
        if buffer[0] == 0x7F as u8 and buffer[1] == 'E' as u8 and buffer[2] == 'L' as u8 and buffer[3] == 'F' as u8:
            obj = linker_parse_elf(buffer, size)
            format = "elf64"
        elif read_u16_le(buffer, 0) == 0x8664 as u16:
            obj = linker_parse_coff(buffer, size)
            format = "coff"
        else:
            ax_puts_local("Error: Unsupported object format in: ")
            ax_puts_local(path)
            @free(buffer)
            return false
            
        @free(buffer)
        push_parsed_object_ptr(&objects, obj)
        i = i + 1
        
    // 2. Pre-scan defined functions and dynamic imports (to determine base address & stubs early)
    mut func_names := new_linker_str_vec()
    
    i = 0
    while i < objects.len:
        let obj = objects.data[i]
        mut sym_i := 0 as i64
        while sym_i < obj.symbols.len:
            let sym = &obj.symbols.data[sym_i]
            if sym.defined:
                push_linker_str(&func_names, sym.name)
            sym_i = sym_i + 1
        i = i + 1
        
    mut kernel32_imports := new_linker_str_vec()
    mut ax_runtime_imports := new_linker_str_vec()
    mut ucrtbase_imports := new_linker_str_vec()
    
    i = 0
    while i < objects.len:
        let obj = objects.data[i]
        mut r_i := 0 as i64
        while r_i < obj.relocs.len:
            let r = &obj.relocs.data[r_i]
            if r.sym_idx < obj.sym_names.len as u32:
                let target_name = obj.sym_names.data[r.sym_idx]
                if target_name != "" and target_name != "main" and target_name != "_AX_main_main_v_v":
                    mut is_defined := false
                    mut search := 0 as i64
                    while search < func_names.len:
                        if func_names.data[search] == target_name:
                            is_defined = true
                            break
                        search = search + 1
                    
                    if not is_defined:
                        let dll = get_dll_for_symbol(target_name)
                        if dll == "kernel32.dll":
                            add_unique_import(&kernel32_imports, target_name)
                        elif dll == "ax_runtime.dll":
                            add_unique_import(&ax_runtime_imports, target_name)
                        elif dll == "none" or dll == "":
                            // Skip dynamic import for dummy/clashed field symbols
                            is_defined = true
                        else:
                            add_unique_import(&ucrtbase_imports, target_name)
            r_i = r_i + 1
        i = i + 1
        
    mut thunk_count := kernel32_imports.len + ax_runtime_imports.len + ucrtbase_imports.len
    
    // 3. Section Layout
    mut merged_code := new_byte_vec()
    mut base_addr := 0x140001000 as u64 // code starts at 0x140001000 for PE
    if format == "elf64":
        if thunk_count > 0:
            base_addr = 0x400200 as u64 // ELF code starts at 0x400200 if we have 512 bytes headers
        else:
            base_addr = 0x400080 as u64 // ELF code starts at 0x400080 if 128 bytes headers
            
    mut func_offsets := new_parsed_reloc_vec() // piggyback on ParsedReloc to store offsets
    
    i = 0
    while i < objects.len:
        let obj = objects.data[i]
        obj.va = base_addr + merged_code.len as u64
        
        mut sym_i := 0 as i64
        while sym_i < obj.symbols.len:
            let sym = &obj.symbols.data[sym_i]
            if sym.defined:
                mut offset_va := sym.offset
                if sym.section == 2: // .rdata
                    offset_va = obj.text.len as u64 + sym.offset
                push_parsed_reloc(&func_offsets, ParsedReloc(offset: (merged_code.len as u64 + offset_va) as i64, sym_idx: 0 as u32, is_pc: false, addend: 0 as i64))
            sym_i = sym_i + 1
            
        push_bytes(&merged_code, obj.text.data, obj.text.len)
        push_bytes(&merged_code, obj.rdata.data, obj.rdata.len)
        i = i + 1
        
    mut thunks_offset := (merged_code.len + 15) & ~15
    mut thunks_rva := 0x1000 as u32 + thunks_offset as u32
    mut thunks_size := thunk_count * 6
    
    mut idata_rva := (0x1000 as i64 + thunks_offset + thunks_size as i64 + 4095) & ~4095
    
    // Construct .idata and thunks for COFF
    mut idata_buf := new_byte_vec()
    mut dyn_sym_names := new_linker_str_vec()
    mut dyn_sym_rvas := null as ptr[u32]
    
    mut kernel32_hn_rvas := null as ptr[u32]
    mut ax_runtime_hn_rvas := null as ptr[u32]
    mut ucrtbase_hn_rvas := null as ptr[u32]
    
    if format == "coff" and thunk_count > 0:
        dyn_sym_rvas = @alloc(thunk_count * 4) as ptr[u32]
        
        let has_kernel32 = kernel32_imports.len > 0
        let has_ax_runtime = ax_runtime_imports.len > 0
        let has_ucrtbase = ucrtbase_imports.len > 0
        mut K := 0 as i64
        if has_kernel32:
            K = K + 1
        if has_ax_runtime:
            K = K + 1
        if has_ucrtbase:
            K = K + 1
            
        let idt_size = (K + 1) * 20
        iat_offset = (idt_size + 7) & ~7
        
        mut kernel32_iat_offset := 0 as i64
        mut kernel32_iat_size := 0 as i64
        mut ax_runtime_iat_offset := iat_offset
        mut ax_runtime_iat_size := 0 as i64
        mut ucrtbase_iat_offset := iat_offset
        mut ucrtbase_iat_size := 0 as i64
        
        mut cur_iat_offset := iat_offset
        
        if has_kernel32:
            kernel32_iat_offset = cur_iat_offset
            kernel32_iat_size = (kernel32_imports.len + 1) * 8
            cur_iat_offset = cur_iat_offset + kernel32_iat_size
            
        if has_ax_runtime:
            ax_runtime_iat_offset = cur_iat_offset
            ax_runtime_iat_size = (ax_runtime_imports.len + 1) * 8
            cur_iat_offset = cur_iat_offset + ax_runtime_iat_size
            
        if has_ucrtbase:
            ucrtbase_iat_offset = cur_iat_offset
            ucrtbase_iat_size = (ucrtbase_imports.len + 1) * 8
            cur_iat_offset = cur_iat_offset + ucrtbase_iat_size
            
        total_iat_size = cur_iat_offset - iat_offset
        let ilt_offset = iat_offset + total_iat_size
        mut cur_ilt_offset := ilt_offset
        
        mut kernel32_ilt_offset := 0 as i64
        mut kernel32_ilt_size := 0 as i64
        if has_kernel32:
            kernel32_ilt_offset = cur_ilt_offset
            kernel32_ilt_size = (kernel32_imports.len + 1) * 8
            cur_ilt_offset = cur_ilt_offset + kernel32_ilt_size
            
        mut ax_runtime_ilt_offset := 0 as i64
        mut ax_runtime_ilt_size := 0 as i64
        if has_ax_runtime:
            ax_runtime_ilt_offset = cur_ilt_offset
            ax_runtime_ilt_size = (ax_runtime_imports.len + 1) * 8
            cur_ilt_offset = cur_ilt_offset + ax_runtime_ilt_size
            
        mut ucrtbase_ilt_offset := 0 as i64
        mut ucrtbase_ilt_size := 0 as i64
        if has_ucrtbase:
            ucrtbase_ilt_offset = cur_ilt_offset
            ucrtbase_ilt_size = (ucrtbase_imports.len + 1) * 8
            cur_ilt_offset = cur_ilt_offset + ucrtbase_ilt_size
            
        let total_ilt_size = cur_ilt_offset - ilt_offset
        let dll_names_offset = ilt_offset + total_ilt_size
        mut cur_offset := dll_names_offset
        
        mut kernel32_name_offset := 0 as i64
        if has_kernel32:
            kernel32_name_offset = cur_offset
            cur_offset = cur_offset + 13
            
        mut ax_runtime_name_offset := 0 as i64
        if has_ax_runtime:
            ax_runtime_name_offset = cur_offset
            cur_offset = cur_offset + 15
            
        mut ucrtbase_name_offset := 0 as i64
        if has_ucrtbase:
            ucrtbase_name_offset = cur_offset
            cur_offset = cur_offset + 13
            
        let hint_name_start_offset = cur_offset
        
        // Pre-fill idata_buf with zeros
        mut zero_i := 0 as i64
        while zero_i < hint_name_start_offset as i64:
            push_byte(&idata_buf, 0 as u8)
            zero_i = zero_i + 1
            
        if has_kernel32:
            kernel32_hn_rvas = @alloc(kernel32_imports.len * 4) as ptr[u32]
            mut j := 0 as i64
            while j < kernel32_imports.len:
                kernel32_hn_rvas[j] = (idata_rva as i64 + idata_buf.len) as u32
                push_byte(&idata_buf, 0 as u8)
                push_byte(&idata_buf, 0 as u8)
                let name = kernel32_imports.data[j]
                let len = std.string.len(name)
                let ptr = get_str_ptr(name)
                mut c_i := 0 as i64
                while c_i < len:
                    push_byte(&idata_buf, ptr[c_i])
                    c_i = c_i + 1
                push_byte(&idata_buf, 0 as u8)
                if (len + 3) % 2 != 0:
                    push_byte(&idata_buf, 0 as u8)
                j = j + 1
                
        if has_ax_runtime:
            ax_runtime_hn_rvas = @alloc(ax_runtime_imports.len * 4) as ptr[u32]
            mut j := 0 as i64
            while j < ax_runtime_imports.len:
                ax_runtime_hn_rvas[j] = (idata_rva as i64 + idata_buf.len) as u32
                push_byte(&idata_buf, 0 as u8)
                push_byte(&idata_buf, 0 as u8)
                let name = ax_runtime_imports.data[j]
                let len = std.string.len(name)
                let ptr = get_str_ptr(name)
                mut c_i := 0 as i64
                while c_i < len:
                    push_byte(&idata_buf, ptr[c_i])
                    c_i = c_i + 1
                push_byte(&idata_buf, 0 as u8)
                if (len + 3) % 2 != 0:
                    push_byte(&idata_buf, 0 as u8)
                j = j + 1
                
        if has_ucrtbase:
            ucrtbase_hn_rvas = @alloc(ucrtbase_imports.len * 4) as ptr[u32]
            mut j := 0 as i64
            while j < ucrtbase_imports.len:
                ucrtbase_hn_rvas[j] = (idata_rva as i64 + idata_buf.len) as u32
                push_byte(&idata_buf, 0 as u8)
                push_byte(&idata_buf, 0 as u8)
                let name = ucrtbase_imports.data[j]
                let len = std.string.len(name)
                let ptr = get_str_ptr(name)
                mut c_i := 0 as i64
                while c_i < len:
                    push_byte(&idata_buf, ptr[c_i])
                    c_i = c_i + 1
                push_byte(&idata_buf, 0 as u8)
                if (len + 3) % 2 != 0:
                    push_byte(&idata_buf, 0 as u8)
                j = j + 1
                
        // Write active DLL names
        if has_kernel32:
            let name_ptr = "kernel32.dll" as ptr[u8]
            mut c_i := 0 as i64
            while c_i < 12:
                idata_buf.data[kernel32_name_offset as i64 + c_i] = name_ptr[c_i]
                c_i = c_i + 1
            idata_buf.data[kernel32_name_offset as i64 + 12] = 0 as u8
            
        if has_ax_runtime:
            let name_ptr = "ax_runtime.dll" as ptr[u8]
            mut c_i := 0 as i64
            while c_i < 14:
                idata_buf.data[ax_runtime_name_offset as i64 + c_i] = name_ptr[c_i]
                c_i = c_i + 1
            idata_buf.data[ax_runtime_name_offset as i64 + 14] = 0 as u8
            
        if has_ucrtbase:
            let name_ptr = "ucrtbase.dll" as ptr[u8]
            mut c_i := 0 as i64
            while c_i < 12:
                idata_buf.data[ucrtbase_name_offset as i64 + c_i] = name_ptr[c_i]
                c_i = c_i + 1
            idata_buf.data[ucrtbase_name_offset as i64 + 12] = 0 as u8
            
        // Write ILT and IAT entries
        if has_kernel32:
            mut j := 0 as i64
            while j < kernel32_imports.len:
                let val = kernel32_hn_rvas[j] as u64
                write_buf_u64_le(idata_buf.data, kernel32_iat_offset as i64 + j * 8, val)
                write_buf_u64_le(idata_buf.data, kernel32_ilt_offset as i64 + j * 8, val)
                j = j + 1
            write_buf_u64_le(idata_buf.data, kernel32_iat_offset as i64 + kernel32_imports.len * 8, 0 as u64)
            write_buf_u64_le(idata_buf.data, kernel32_ilt_offset as i64 + kernel32_imports.len * 8, 0 as u64)
            
        if has_ax_runtime:
            mut j := 0 as i64
            while j < ax_runtime_imports.len:
                let val = ax_runtime_hn_rvas[j] as u64
                write_buf_u64_le(idata_buf.data, ax_runtime_iat_offset as i64 + j * 8, val)
                write_buf_u64_le(idata_buf.data, ax_runtime_ilt_offset as i64 + j * 8, val)
                j = j + 1
            write_buf_u64_le(idata_buf.data, ax_runtime_iat_offset as i64 + ax_runtime_imports.len * 8, 0 as u64)
            write_buf_u64_le(idata_buf.data, ax_runtime_ilt_offset as i64 + ax_runtime_imports.len * 8, 0 as u64)
            
        if has_ucrtbase:
            mut j := 0 as i64
            while j < ucrtbase_imports.len:
                let val = ucrtbase_hn_rvas[j] as u64
                write_buf_u64_le(idata_buf.data, ucrtbase_iat_offset as i64 + j * 8, val)
                write_buf_u64_le(idata_buf.data, ucrtbase_ilt_offset as i64 + j * 8, val)
                j = j + 1
            write_buf_u64_le(idata_buf.data, ucrtbase_iat_offset as i64 + ucrtbase_imports.len * 8, 0 as u64)
            write_buf_u64_le(idata_buf.data, ucrtbase_ilt_offset as i64 + ucrtbase_imports.len * 8, 0 as u64)
            
        // Write IDT entries
        mut entry_idx := 0 as i64
        if has_kernel32:
            let ilt_rva = (idata_rva as i64 + kernel32_ilt_offset as i64) as u32
            let name_rva = (idata_rva as i64 + kernel32_name_offset as i64) as u32
            let iat_rva = (idata_rva as i64 + kernel32_iat_offset as i64) as u32
            let off = entry_idx * 20
            write_buf_u32_le(idata_buf.data, off, ilt_rva)
            write_buf_u32_le(idata_buf.data, off + 4, 0 as u32)
            write_buf_u32_le(idata_buf.data, off + 8, 0 as u32)
            write_buf_u32_le(idata_buf.data, off + 12, name_rva)
            write_buf_u32_le(idata_buf.data, off + 16, iat_rva)
            entry_idx = entry_idx + 1
            
        if has_ax_runtime:
            let ilt_rva = (idata_rva as i64 + ax_runtime_ilt_offset as i64) as u32
            let name_rva = (idata_rva as i64 + ax_runtime_name_offset as i64) as u32
            let iat_rva = (idata_rva as i64 + ax_runtime_iat_offset as i64) as u32
            let off = entry_idx * 20
            write_buf_u32_le(idata_buf.data, off, ilt_rva)
            write_buf_u32_le(idata_buf.data, off + 4, 0 as u32)
            write_buf_u32_le(idata_buf.data, off + 8, 0 as u32)
            write_buf_u32_le(idata_buf.data, off + 12, name_rva)
            write_buf_u32_le(idata_buf.data, off + 16, iat_rva)
            entry_idx = entry_idx + 1
            
        if has_ucrtbase:
            let ilt_rva = (idata_rva as i64 + ucrtbase_ilt_offset as i64) as u32
            let name_rva = (idata_rva as i64 + ucrtbase_name_offset as i64) as u32
            let iat_rva = (idata_rva as i64 + ucrtbase_iat_offset as i64) as u32
            let off = entry_idx * 20
            write_buf_u32_le(idata_buf.data, off, ilt_rva)
            write_buf_u32_le(idata_buf.data, off + 4, 0 as u32)
            write_buf_u32_le(idata_buf.data, off + 8, 0 as u32)
            write_buf_u32_le(idata_buf.data, off + 12, name_rva)
            write_buf_u32_le(idata_buf.data, off + 16, iat_rva)
            entry_idx = entry_idx + 1
            
        let off = entry_idx * 20
        write_buf_u32_le(idata_buf.data, off, 0 as u32)
        write_buf_u32_le(idata_buf.data, off + 4, 0 as u32)
        write_buf_u32_le(idata_buf.data, off + 8, 0 as u32)
        write_buf_u32_le(idata_buf.data, off + 12, 0 as u32)
        write_buf_u32_le(idata_buf.data, off + 16, 0 as u32)
        
        // Pad merged_code to thunks_offset
        while merged_code.len < thunks_offset:
            push_byte(&merged_code, 0 as u8)
            
        // Append all thunks
        mut thunk_i := 0 as i64
        
        mut k_j := 0 as i64
        while k_j < kernel32_imports.len:
            let sym_name = kernel32_imports.data[k_j]
            let th_rva = thunks_rva + thunk_i as u32 * 6 as u32
            let iat_rva_sym = idata_rva as u32 + kernel32_iat_offset as u32 + k_j as u32 * 8 as u32
            let disp32 = (iat_rva_sym as i32 - (th_rva + 6 as u32) as i32) as u32
            
            push_byte(&merged_code, 0xFF as u8)
            push_byte(&merged_code, 0x25 as u8)
            push_byte(&merged_code, (disp32 & 0xFF as u32) as u8)
            push_byte(&merged_code, ((disp32 >> 8 as u32) & 0xFF as u32) as u8)
            push_byte(&merged_code, ((disp32 >> 16 as u32) & 0xFF as u32) as u8)
            push_byte(&merged_code, ((disp32 >> 24 as u32) & 0xFF as u32) as u8)
            
            push_linker_str(&dyn_sym_names, sym_name)
            dyn_sym_rvas[thunk_i] = th_rva
            
            thunk_i = thunk_i + 1
            k_j = k_j + 1
            
        mut ax_j := 0 as i64
        while ax_j < ax_runtime_imports.len:
            let sym_name = ax_runtime_imports.data[ax_j]
            let th_rva = thunks_rva + thunk_i as u32 * 6 as u32
            let iat_rva_sym = idata_rva as u32 + ax_runtime_iat_offset as u32 + ax_j as u32 * 8 as u32
            let disp32 = (iat_rva_sym as i32 - (th_rva + 6 as u32) as i32) as u32
            
            push_byte(&merged_code, 0xFF as u8)
            push_byte(&merged_code, 0x25 as u8)
            push_byte(&merged_code, (disp32 & 0xFF as u32) as u8)
            push_byte(&merged_code, ((disp32 >> 8 as u32) & 0xFF as u32) as u8)
            push_byte(&merged_code, ((disp32 >> 16 as u32) & 0xFF as u32) as u8)
            push_byte(&merged_code, ((disp32 >> 24 as u32) & 0xFF as u32) as u8)
            
            push_linker_str(&dyn_sym_names, sym_name)
            dyn_sym_rvas[thunk_i] = th_rva
            
            thunk_i = thunk_i + 1
            ax_j = ax_j + 1
            
        mut u_j := 0 as i64
        while u_j < ucrtbase_imports.len:
            let sym_name = ucrtbase_imports.data[u_j]
            let th_rva = thunks_rva + thunk_i as u32 * 6 as u32
            let iat_rva_sym = idata_rva as u32 + ucrtbase_iat_offset as u32 + u_j as u32 * 8 as u32
            let disp32 = (iat_rva_sym as i32 - (th_rva + 6 as u32) as i32) as u32
            
            push_byte(&merged_code, 0xFF as u8)
            push_byte(&merged_code, 0x25 as u8)
            push_byte(&merged_code, (disp32 & 0xFF as u32) as u8)
            push_byte(&merged_code, ((disp32 >> 8 as u32) & 0xFF as u32) as u8)
            push_byte(&merged_code, ((disp32 >> 16 as u32) & 0xFF as u32) as u8)
            push_byte(&merged_code, ((disp32 >> 24 as u32) & 0xFF as u32) as u8)
            
            push_linker_str(&dyn_sym_names, sym_name)
            dyn_sym_rvas[thunk_i] = th_rva
            
            thunk_i = thunk_i + 1
            u_j = u_j + 1

    // Construct dyn_buf for ELF64
    mut dyn_buf := new_byte_vec()
    mut offset_dynamic := 0 as i64
    mut size_dynamic := 0 as i64
    if format == "elf64" and thunk_count > 0:
        dyn_sym_rvas = @alloc(thunk_count * 4) as ptr[u32]
        
        mut dyn_imports := new_linker_str_vec()
        mut dyn_libs := new_linker_str_vec()
        
        mut has_ax_lib := false
        mut has_c_lib := false
        
        mut scan_j := 0 as i64
        while scan_j < kernel32_imports.len:
            push_linker_str(&dyn_imports, kernel32_imports.data[scan_j])
            has_ax_lib = true
            scan_j = scan_j + 1
            
        scan_j = 0
        while scan_j < ax_runtime_imports.len:
            push_linker_str(&dyn_imports, ax_runtime_imports.data[scan_j])
            has_ax_lib = true
            scan_j = scan_j + 1
            
        scan_j = 0
        while scan_j < ucrtbase_imports.len:
            push_linker_str(&dyn_imports, ucrtbase_imports.data[scan_j])
            has_c_lib = true
            scan_j = scan_j + 1
            
        if has_ax_lib:
            push_linker_str(&dyn_libs, "libax_runtime.so")
        if has_c_lib:
            push_linker_str(&dyn_libs, "libc.so.6")
            
        // 1. Build .dynstr
        mut dynstr_buf := new_byte_vec()
        push_byte(&dynstr_buf, 0 as u8)
        
        let lib_str_offsets = @alloc(dyn_libs.len * 8) as ptr[u64]
        mut lib_i := 0 as i64
        while lib_i < dyn_libs.len:
            lib_str_offsets[lib_i] = dynstr_buf.len as u64
            let name = dyn_libs.data[lib_i]
            let name_len = std.string.len(name)
            let name_ptr = get_str_ptr(name)
            mut char_i := 0 as i64
            while char_i < name_len:
                push_byte(&dynstr_buf, name_ptr[char_i])
                char_i = char_i + 1
            push_byte(&dynstr_buf, 0 as u8)
            lib_i = lib_i + 1
            
        let sym_str_offsets = @alloc(dyn_imports.len * 8) as ptr[u64]
        mut sym_i := 0 as i64
        while sym_i < dyn_imports.len:
            sym_str_offsets[sym_i] = dynstr_buf.len as u64
            let name = dyn_imports.data[sym_i]
            let name_len = std.string.len(name)
            let name_ptr = get_str_ptr(name)
            mut char_i := 0 as i64
            while char_i < name_len:
                push_byte(&dynstr_buf, name_ptr[char_i])
                char_i = char_i + 1
            push_byte(&dynstr_buf, 0 as u8)
            sym_i = sym_i + 1
            
        // 2. Build .dynsym
        mut dynsym_buf := new_byte_vec()
        mut zero_idx := 0 as i64
        while zero_idx < 24:
            push_byte(&dynsym_buf, 0 as u8)
            zero_idx = zero_idx + 1
            
        sym_i = 0
        while sym_i < dyn_imports.len:
            push_u32_le(&dynsym_buf, sym_str_offsets[sym_i] as u32)
            push_byte(&dynsym_buf, 0x12 as u8) // STB_GLOBAL << 4 | STT_FUNC = 0x12
            push_byte(&dynsym_buf, 0 as u8)
            push_u16_le(&dynsym_buf, 0 as u16) // SHN_UNDEF = 0
            push_u64_le(&dynsym_buf, 0 as u64)
            push_u64_le(&dynsym_buf, 0 as u64)
            sym_i = sym_i + 1
            
        // 3. Build .hash
        mut hash_buf := new_byte_vec()
        push_u32_le(&hash_buf, 1 as u32) // nbucket = 1
        push_u32_le(&hash_buf, (1 as i64 + dyn_imports.len) as u32) // nchain
        push_u32_le(&hash_buf, 1 as u32) // bucket[0] = 1
        push_u32_le(&hash_buf, 0 as u32) // chain[0] = 0
        mut chain_idx := 2 as i64
        while chain_idx <= 1 as i64 + dyn_imports.len:
            if chain_idx == 1 as i64 + dyn_imports.len:
                push_u32_le(&hash_buf, 0 as u32)
            else:
                push_u32_le(&hash_buf, chain_idx as u32)
            chain_idx = chain_idx + 1
            
        // 4. Build .got.plt
        mut got_plt_buf := new_byte_vec()
        push_u64_le(&got_plt_buf, 0 as u64) // link to _DYNAMIC
        push_u64_le(&got_plt_buf, 0 as u64)
        push_u64_le(&got_plt_buf, 0 as u64)
        sym_i = 0
        while sym_i < dyn_imports.len:
            push_u64_le(&got_plt_buf, 0 as u64)
            sym_i = sym_i + 1
            
        // 5. Calculate offsets of sections inside dyn_buf
        let offset_dynstr = 0 as i64
        let size_dynstr = dynstr_buf.len
        
        let offset_dynsym = (size_dynstr + 7) & ~7
        let size_dynsym = dynsym_buf.len
        
        let offset_hash = (offset_dynsym + size_dynsym + 7) & ~7
        let size_hash = hash_buf.len
        
        let offset_got_plt = (offset_hash + size_hash + 7) & ~7
        let size_got_plt = got_plt_buf.len
        
        let offset_rela_plt = (offset_got_plt + size_got_plt + 7) & ~7
        let size_rela_plt = dyn_imports.len * 24
        
        offset_dynamic = (offset_rela_plt + size_rela_plt + 7) & ~7
        size_dynamic = (dyn_libs.len + 14) * 16
        
        // 6. Compute virtual addresses
        let dyn_offset = (thunks_offset + thunks_size + 15) & ~15
        let dyn_base_va = base_addr + dyn_offset as u64
        
        let dynstr_va = dyn_base_va + offset_dynstr as u64
        let dynsym_va = dyn_base_va + offset_dynsym as u64
        let hash_va = dyn_base_va + offset_hash as u64
        let got_plt_va = dyn_base_va + offset_got_plt as u64
        let rela_plt_va = dyn_base_va + offset_rela_plt as u64
        let dynamic_va = dyn_base_va + offset_dynamic as u64
        
        // 7. Build .rela.plt
        mut rela_plt_buf := new_byte_vec()
        sym_i = 0
        while sym_i < dyn_imports.len:
            let r_offset = got_plt_va + 24 as u64 + sym_i as u64 * 8 as u64
            let r_info = ((1 as u64 + sym_i as u64) << 32 as u64) | 7 as u64 // R_X86_64_JUMP_SLOT = 7
            push_u64_le(&rela_plt_buf, r_offset)
            push_u64_le(&rela_plt_buf, r_info)
            push_u64_le(&rela_plt_buf, 0 as u64)
            sym_i = sym_i + 1
            
        // 8. Build .dynamic
        mut dynamic_buf := new_byte_vec()
        mut lib_idx := 0 as i64
        while lib_idx < dyn_libs.len:
            push_u64_le(&dynamic_buf, 1 as u64) // DT_NEEDED
            push_u64_le(&dynamic_buf, lib_str_offsets[lib_idx])
            lib_idx = lib_idx + 1
            
        push_u64_le(&dynamic_buf, 2 as u64) // DT_PLTRELSZ
        push_u64_le(&dynamic_buf, rela_plt_buf.len as u64)
        
        push_u64_le(&dynamic_buf, 20 as u64) // DT_PLTREL
        push_u64_le(&dynamic_buf, 7 as u64) // DT_RELA
        
        push_u64_le(&dynamic_buf, 3 as u64) // DT_PLTGOT
        push_u64_le(&dynamic_buf, got_plt_va)
        
        push_u64_le(&dynamic_buf, 4 as u64) // DT_HASH
        push_u64_le(&dynamic_buf, hash_va)
        
        push_u64_le(&dynamic_buf, 5 as u64) // DT_STRTAB
        push_u64_le(&dynamic_buf, dynstr_va)
        
        push_u64_le(&dynamic_buf, 6 as u64) // DT_SYMTAB
        push_u64_le(&dynamic_buf, dynsym_va)
        
        push_u64_le(&dynamic_buf, 10 as u64) // DT_STRSZ
        push_u64_le(&dynamic_buf, dynstr_buf.len as u64)
        
        push_u64_le(&dynamic_buf, 11 as u64) // DT_SYMENT
        push_u64_le(&dynamic_buf, 24 as u64)
        
        push_u64_le(&dynamic_buf, 7 as u64) // DT_RELA
        push_u64_le(&dynamic_buf, rela_plt_va)
        
        push_u64_le(&dynamic_buf, 8 as u64) // DT_RELASZ
        push_u64_le(&dynamic_buf, rela_plt_buf.len as u64)
        
        push_u64_le(&dynamic_buf, 9 as u64) // DT_RELAENT
        push_u64_le(&dynamic_buf, 24 as u64)
        
        push_u64_le(&dynamic_buf, 24 as u64) // DT_BIND_NOW
        push_u64_le(&dynamic_buf, 1 as u64)
        
        push_u64_le(&dynamic_buf, 30 as u64) // DT_FLAGS
        push_u64_le(&dynamic_buf, 8 as u64) // DF_BIND_NOW
        
        push_u64_le(&dynamic_buf, 0 as u64) // DT_NULL
        push_u64_le(&dynamic_buf, 0 as u64)
        
        // 9. Assemble dyn_buf
        push_bytes(&dyn_buf, dynstr_buf.data, dynstr_buf.len)
        
        while dyn_buf.len < offset_dynsym:
            push_byte(&dyn_buf, 0 as u8)
        push_bytes(&dyn_buf, dynsym_buf.data, dynsym_buf.len)
        
        while dyn_buf.len < offset_hash:
            push_byte(&dyn_buf, 0 as u8)
        push_bytes(&dyn_buf, hash_buf.data, hash_buf.len)
        
        while dyn_buf.len < offset_got_plt:
            push_byte(&dyn_buf, 0 as u8)
        push_bytes(&dyn_buf, got_plt_buf.data, got_plt_buf.len)
        
        while dyn_buf.len < offset_rela_plt:
            push_byte(&dyn_buf, 0 as u8)
        push_bytes(&dyn_buf, rela_plt_buf.data, rela_plt_buf.len)
        
        while dyn_buf.len < offset_dynamic:
            push_byte(&dyn_buf, 0 as u8)
        push_bytes(&dyn_buf, dynamic_buf.data, dynamic_buf.len)
        
        // 10. Generate ELF PLT stubs inside merged_code
        // Pad merged_code to thunks_offset
        while merged_code.len < thunks_offset:
            push_byte(&merged_code, 0 as u8)
            
        mut thunk_i := 0 as i64
        
        // Generate for kernel32
        mut k_j := 0 as i64
        while k_j < kernel32_imports.len:
            let sym_name = kernel32_imports.data[k_j]
            let th_va = base_addr + thunks_offset as u64 + thunk_i as u64 * 6 as u64
            let got_slot_va = got_plt_va + 24 as u64 + thunk_i as u64 * 8 as u64
            let disp32 = (got_slot_va - (th_va + 6 as u64)) as u32
            
            push_byte(&merged_code, 0xFF as u8)
            push_byte(&merged_code, 0x25 as u8)
            push_byte(&merged_code, (disp32 & 0xFF as u32) as u8)
            push_byte(&merged_code, ((disp32 >> 8 as u32) & 0xFF as u32) as u8)
            push_byte(&merged_code, ((disp32 >> 16 as u32) & 0xFF as u32) as u8)
            push_byte(&merged_code, ((disp32 >> 24 as u32) & 0xFF as u32) as u8)
            
            push_linker_str(&dyn_sym_names, sym_name)
            dyn_sym_rvas[thunk_i] = (thunks_offset as u32 + thunk_i as u32 * 6 as u32) + 0x1000 as u32
            
            thunk_i = thunk_i + 1
            k_j = k_j + 1
            
        // Generate for ax_runtime
        mut ax_j := 0 as i64
        while ax_j < ax_runtime_imports.len:
            let sym_name = ax_runtime_imports.data[ax_j]
            let th_va = base_addr + thunks_offset as u64 + thunk_i as u64 * 6 as u64
            let got_slot_va = got_plt_va + 24 as u64 + thunk_i as u64 * 8 as u64
            let disp32 = (got_slot_va - (th_va + 6 as u64)) as u32
            
            push_byte(&merged_code, 0xFF as u8)
            push_byte(&merged_code, 0x25 as u8)
            push_byte(&merged_code, (disp32 & 0xFF as u32) as u8)
            push_byte(&merged_code, ((disp32 >> 8 as u32) & 0xFF as u32) as u8)
            push_byte(&merged_code, ((disp32 >> 16 as u32) & 0xFF as u32) as u8)
            push_byte(&merged_code, ((disp32 >> 24 as u32) & 0xFF as u32) as u8)
            
            push_linker_str(&dyn_sym_names, sym_name)
            dyn_sym_rvas[thunk_i] = (thunks_offset as u32 + thunk_i as u32 * 6 as u32) + 0x1000 as u32
            
            thunk_i = thunk_i + 1
            ax_j = ax_j + 1
            
        // Generate for ucrtbase
        mut u_j := 0 as i64
        while u_j < ucrtbase_imports.len:
            let sym_name = ucrtbase_imports.data[u_j]
            let th_va = base_addr + thunks_offset as u64 + thunk_i as u64 * 6 as u64
            let got_slot_va = got_plt_va + 24 as u64 + thunk_i as u64 * 8 as u64
            let disp32 = (got_slot_va - (th_va + 6 as u64)) as u32
            
            push_byte(&merged_code, 0xFF as u8)
            push_byte(&merged_code, 0x25 as u8)
            push_byte(&merged_code, (disp32 & 0xFF as u32) as u8)
            push_byte(&merged_code, ((disp32 >> 8 as u32) & 0xFF as u32) as u8)
            push_byte(&merged_code, ((disp32 >> 16 as u32) & 0xFF as u32) as u8)
            push_byte(&merged_code, ((disp32 >> 24 as u32) & 0xFF as u32) as u8)
            
            push_linker_str(&dyn_sym_names, sym_name)
            dyn_sym_rvas[thunk_i] = (thunks_offset as u32 + thunk_i as u32 * 6 as u32) + 0x1000 as u32
            
            thunk_i = thunk_i + 1
            u_j = u_j + 1
            
        // Clean up temporary buffers
        if dynstr_buf.data != null as ptr[u8]:
            @free(dynstr_buf.data)
        if dynsym_buf.data != null as ptr[u8]:
            @free(dynsym_buf.data)
        if hash_buf.data != null as ptr[u8]:
            @free(hash_buf.data)
        if got_plt_buf.data != null as ptr[u8]:
            @free(got_plt_buf.data)
        if rela_plt_buf.data != null as ptr[u8]:
            @free(rela_plt_buf.data)
        if dynamic_buf.data != null as ptr[u8]:
            @free(dynamic_buf.data)
        @free(lib_str_offsets as ptr[u8])
        @free(sym_str_offsets as ptr[u8])
        @free(dyn_imports.data as ptr[u8])
        @free(dyn_libs.data as ptr[u8])

    // 3. Resolve & Apply Relocations
    i = 0
    while i < objects.len:
        let obj = objects.data[i]
        mut r_i := 0 as i64
        while r_i < obj.relocs.len:
            let r = &obj.relocs.data[r_i]
            if r.sym_idx >= obj.sym_names.len as u32:
                r_i = r_i + 1
                continue
                
            let target_name = obj.sym_names.data[r.sym_idx]
            mut target_offset := -1 as i64
            
            mut search := 0 as i64
            while search < func_names.len:
                if func_names.data[search] == target_name:
                    target_offset = func_offsets.data[search].offset
                    break
                search = search + 1
                
            mut target_va := 0 as u64
            if target_offset != -1 as i64:
                target_va = base_addr + target_offset as u64
            else:
                // Check if it is a dynamic import
                mut dyn_search := 0 as i64
                mut found_dyn := false
                while dyn_search < dyn_sym_names.len:
                    if dyn_sym_names.data[dyn_search] == target_name:
                        target_va = base_addr + (dyn_sym_rvas[dyn_search] - 0x1000 as u32) as u64
                        found_dyn = true
                        break
                    dyn_search = dyn_search + 1
                    
                if not found_dyn:
                    target_va = 0x500000 as u64
                
            let rel_offset = (obj.va - base_addr) as i64 + r.offset
            if rel_offset + 4 as i64 > merged_code.len:
                r_i = r_i + 1
                continue
                
            if r.is_pc:
                let pc = base_addr + rel_offset as u64
                let val = (target_va as i64 - pc as i64 + r.addend) as u32
                write_u32_le(merged_code.data, rel_offset, val)
            else:
                if rel_offset + 8 as i64 <= merged_code.len:
                    let val = target_va + r.addend as u64
                    write_u64_le(merged_code.data, rel_offset, val)
                    
            r_i = r_i + 1
        i = i + 1
        
    // Find entry point RVA
    mut entry_rva := 0x1000 as u32
    mut entry_search := 0 as i64
    while entry_search < func_names.len:
        let fn_name = func_names.data[entry_search]
        if fn_name == "main" or fn_name == "_AX_main_main_v_v":
            entry_rva = (0x1000 as i64 + func_offsets.data[entry_search].offset) as u32
            break
        entry_search = entry_search + 1
        
    // 4. Emit Executable
    let output_path_nt = x86_str_to_null_terminated(self.output_path)
    let file = fopen(output_path_nt as ptr[void], get_str_ptr("wb"))
    @free(output_path_nt)
    if file == null as ptr[void]:
        ax_puts_local("Error: Linker could not write output file")
        return false
        
    if format == "coff":
        // Align code to FileAlignment (0x200)
        let orig_code_len = merged_code.len
        align_byte_vec(&merged_code, 0x200 as i64)
        
        let code_raw_size = merged_code.len as u32
        let idata_raw_size = (idata_buf.len as i64 + 0x1FF) as u32 & 0xFFFFFE00 as u32
        align_byte_vec(&idata_buf, 0x200 as i64)
        
        let iat_rva = idata_rva as u32 + iat_offset as u32
        let iat_size = total_iat_size as u32
        
        mut K_count := 0 as u32
        if kernel32_imports.len > 0:
            K_count = K_count + 1 as u32
        if ax_runtime_imports.len > 0:
            K_count = K_count + 1 as u32
        if ucrtbase_imports.len > 0:
            K_count = K_count + 1 as u32
        let idt_size = (K_count + 1 as u32) * 20 as u32

        mut pe_headers := new_byte_vec()
        linker_build_pe_headers(&pe_headers, code_raw_size, idata_raw_size, entry_rva, idata_rva as u32, idata_raw_size, iat_rva, iat_size)
        
        fwrite(pe_headers.data as ptr[void], 1, pe_headers.len, file)
        fwrite(merged_code.data as ptr[void], 1, merged_code.len, file)
        if idata_buf.len > 0:
            fwrite(idata_buf.data as ptr[void], 1, idata_buf.len, file)
            
        @free(pe_headers.data)
    else:
        // elf64
        let entry_va = base_addr + (entry_rva - 0x1000 as u32) as u64
        mut elf_headers := new_byte_vec()
        
        mut dynamic_offset := 0 as u32
        mut dynamic_size := 0 as u32
        if dyn_buf.len > 0:
            dynamic_offset = 512 as u32 + offset_dynamic as u32
            dynamic_size = size_dynamic as u32
            
        linker_build_elf_headers(&elf_headers, (merged_code.len + dyn_buf.len) as u32, entry_va, dynamic_offset, dynamic_size)
        
        fwrite(elf_headers.data as ptr[void], 1, elf_headers.len, file)
        fwrite(merged_code.data as ptr[void], 1, merged_code.len, file)
        if dyn_buf.len > 0:
            fwrite(dyn_buf.data as ptr[void], 1, dyn_buf.len, file)
            
        @free(elf_headers.data)
        
    fclose(file)
    
    // Free structures
    if merged_code.data != null as ptr[u8]:
        @free(merged_code.data)
    if idata_buf.data != null as ptr[u8]:
        @free(idata_buf.data)
    if dyn_buf.data != null as ptr[u8]:
        @free(dyn_buf.data)
        
    if dyn_sym_rvas != null as ptr[u32]:
        @free(dyn_sym_rvas as ptr[u8])
    if kernel32_hn_rvas != null as ptr[u32]:
        @free(kernel32_hn_rvas as ptr[u8])
    if ax_runtime_hn_rvas != null as ptr[u32]:
        @free(ax_runtime_hn_rvas as ptr[u8])
    if ucrtbase_hn_rvas != null as ptr[u32]:
        @free(ucrtbase_hn_rvas as ptr[u8])
        
    if kernel32_imports.data != null as ptr[str]:
        @free(kernel32_imports.data as ptr[u8])
    if ax_runtime_imports.data != null as ptr[str]:
        @free(ax_runtime_imports.data as ptr[u8])
    if ucrtbase_imports.data != null as ptr[str]:
        @free(ucrtbase_imports.data as ptr[u8])
    if dyn_sym_names.data != null as ptr[str]:
        @free(dyn_sym_names.data as ptr[u8])
        
    i = 0
    while i < objects.len:
        let obj = objects.data[i]
        if obj.text.data != null as ptr[u8]:
            @free(obj.text.data)
        if obj.rdata.data != null as ptr[u8]:
            @free(obj.rdata.data)
        if obj.symbols.data != null as ptr[LinkerSymbol]:
            @free(obj.symbols.data as ptr[u8])
        if obj.sym_names.data != null as ptr[str]:
            @free(obj.sym_names.data as ptr[u8])
        if obj.relocs.data != null as ptr[ParsedReloc]:
            @free(obj.relocs.data as ptr[u8])
        @free(obj as ptr[u8])
        i = i + 1
        
    @free(objects.data as ptr[u8])
    @free(func_names.data as ptr[u8])
    @free(func_offsets.data as ptr[u8])
    return true
// bootstrap/stage1/fmt.ax
// AXIOM canonical source code formatter written in AXIOM itself.


pub const FMT_TOKEN_EOF: u8 = 0
pub const FMT_TOKEN_NEWLINE: u8 = 1
pub const FMT_TOKEN_WHITESPACE: u8 = 2
pub const FMT_TOKEN_COMMENT: u8 = 3
pub const FMT_TOKEN_STRING: u8 = 4
pub const FMT_TOKEN_CHAR: u8 = 5
pub const FMT_TOKEN_NUMBER: u8 = 6
pub const FMT_TOKEN_OPERATOR: u8 = 7
pub const FMT_TOKEN_PUNCTUATION: u8 = 8
pub const FMT_TOKEN_IDENT: u8 = 9

pub struct FmtToken:
    kind: u8
    text: str

pub struct FmtTokenVec:
    data: ptr[FmtToken]
    len: i64
    cap: i64

pub fn new_fmt_token_vec() -> FmtTokenVec:
    return FmtTokenVec(data: null as ptr[FmtToken], len: 0, cap: 0)

pub fn push(mut self: FmtTokenVec, t: FmtToken):
    if self.len == self.cap:
        mut new_cap := 16 as i64
        if self.cap != 0:
            new_cap = self.cap * 2
        let new_data = @alloc(new_cap * 16) as ptr[FmtToken] // FmtToken is 16 bytes (1B kind, 7B padding/alignment, 8B str pointer)
        if self.data != null as ptr[FmtToken]:
            @memcpy(new_data as ptr[u8], self.data as ptr[u8], self.len * 16)
            @free(self.data as ptr[u8])
        self.data = new_data
        self.cap = new_cap
    self.data[self.len] = t
    self.len = self.len + 1

fn fmt_is_digit(b: u8) -> bool:
    return b >= 48 as u8 and b <= 57 as u8

fn fmt_is_hex_digit(b: u8) -> bool:
    return fmt_is_digit(b) or (b >= 97 as u8 and b <= 102 as u8) or (b >= 65 as u8 and b <= 70 as u8)

fn fmt_is_oct_digit(b: u8) -> bool:
    return b >= 48 as u8 and b <= 55 as u8

fn fmt_is_ident_start(b: u8) -> bool:
    return (b >= 97 as u8 and b <= 122 as u8) or (b >= 65 as u8 and b <= 90 as u8) or b == 95 as u8 or b == 64 as u8 // '@'

fn fmt_is_ident_part(b: u8) -> bool:
    return fmt_is_ident_start(b) or fmt_is_digit(b)

fn is_punctuation(s: str) -> bool:
    if s == "." or s == "," or s == ":" or s == ";" or s == "(" or s == ")" or s == "[" or s == "]" or s == "{" or s == "}" or s == "..":
        return true
    return false

fn match_operator_or_punct(src: str, i: i64, n: i64) -> i64:
    // Try two-character operators first
    if i + 1 < n:
        let two = std.string.slice(src, i, i + 2)
        if two == "**" or two == "==" or two == "!=" or two == "<=" or two == ">=" or two == "<<" or two == ">>" or two == ":=" or two == "+=" or two == "-=" or two == "*=" or two == "/=" or two == "%=" or two == "->" or two == "..":
            @free(two as ptr[u8])
            return 2 as i64
        @free(two as ptr[u8])

    // Single-character operators/punctuations
    let b = src[i] as u8
    if b == 43 or b == 45 or b == 42 or b == 47 or b == 37 or b == 60 or b == 62 or b == 61 or b == 38 or b == 124 or b == 94 or b == 126 or b == 33 or b == 46 or b == 44 or b == 58 or b == 59 or b == 40 or b == 41 or b == 91 or b == 93 or b == 123 or b == 125:
        return 1 as i64

    return 0 as i64

pub fn scan_tokens(src: str) -> FmtTokenVec:
    mut tokens := new_fmt_token_vec()
    let n = std.string.len(src)
    mut i := 0 as i64

    while i < n:
        let b = src[i] as u8

        // 1. Newline
        if b == 10 as u8:
            tokens.push(FmtToken(kind: FMT_TOKEN_NEWLINE, text: "\n"))
            i = i + 1
            continue

        // 2. Line Comment
        if b == 47 as u8 and i + 1 < n and (src[i + 1] as u8 == 47 as u8):
            let start = i
            i = i + 2
            while i < n and (src[i] as u8 != 10 as u8):
                i = i + 1
            let text = std.string.slice(src, start, i)
            tokens.push(FmtToken(kind: FMT_TOKEN_COMMENT, text: text))
            continue

        // 3. Whitespace
        if b == 32 as u8 or b == 9 as u8 or b == 13 as u8:
            let start = i
            while i < n:
                let ws = src[i] as u8
                if ws == 32 as u8 or ws == 9 as u8 or ws == 13 as u8:
                    i = i + 1
                else:
                    break
            let text = std.string.slice(src, start, i)
            tokens.push(FmtToken(kind: FMT_TOKEN_WHITESPACE, text: text))
            continue

        // 4. String Literal
        if b == 34 as u8: // '"'
            let start = i
            i = i + 1
            mut escaped := false
            while i < n:
                if escaped:
                    escaped = false
                elif src[i] as u8 == 92 as u8: // '\\'
                    escaped = true
                elif src[i] as u8 == 34 as u8:
                    i = i + 1
                    break
                i = i + 1
            let text = std.string.slice(src, start, i)
            tokens.push(FmtToken(kind: FMT_TOKEN_STRING, text: text))
            continue

        // 5. Character Literal
        if b == 39 as u8: // '\''
            let start = i
            i = i + 1
            mut escaped := false
            while i < n:
                if escaped:
                    escaped = false
                elif src[i] as u8 == 92 as u8:
                    escaped = true
                elif src[i] as u8 == 39 as u8:
                    i = i + 1
                    break
                i = i + 1
            let text = std.string.slice(src, start, i)
            tokens.push(FmtToken(kind: FMT_TOKEN_CHAR, text: text))
            continue

        // 6. Number Literal
        if fmt_is_digit(b):
            let start = i
            if b == 48 as u8 and i + 1 < n: // '0'
                let next = src[i + 1] as u8
                if next == 120 as u8 or next == 88 as u8: // 'x' / 'X'
                    i = i + 2
                    while i < n and (fmt_is_hex_digit(src[i] as u8) or (src[i] as u8 == 95 as u8)):
                        i = i + 1
                    let text = std.string.slice(src, start, i)
                    tokens.push(FmtToken(kind: FMT_TOKEN_NUMBER, text: text))
                    continue
                elif next == 111 as u8 or next == 79 as u8: // 'o' / 'O'
                    i = i + 2
                    while i < n and (fmt_is_oct_digit(src[i] as u8) or (src[i] as u8 == 95 as u8)):
                        i = i + 1
                    let text = std.string.slice(src, start, i)
                    tokens.push(FmtToken(kind: FMT_TOKEN_NUMBER, text: text))
                    continue
                elif next == 98 as u8 or next == 66 as u8: // 'b' / 'B'
                    i = i + 2
                    while i < n:
                        let bin = src[i] as u8
                        if bin == 48 as u8 or bin == 49 as u8 or bin == 95 as u8:
                            i = i + 1
                        else:
                            break
                    let text = std.string.slice(src, start, i)
                    tokens.push(FmtToken(kind: FMT_TOKEN_NUMBER, text: text))
                    continue

            while i < n:
                let num = src[i] as u8
                if fmt_is_digit(num) or num == 95 as u8:
                    i = i + 1
                else:
                    break

            if i < n and (src[i] as u8 == 46 as u8) and i + 1 < n and fmt_is_digit(src[i + 1] as u8):
                i = i + 1 // consume '.'
                while i < n:
                    let num = src[i] as u8
                    if fmt_is_digit(num) or num == 95 as u8:
                        i = i + 1
                    else:
                        break

            if i < n:
                let exp = src[i] as u8
                if exp == 101 as u8 or exp == 69 as u8:
                    i = i + 1
                    if i < n:
                        let sign = src[i] as u8
                        if sign == 43 as u8 or sign == 45 as u8:
                            i = i + 1
                    while i < n and fmt_is_digit(src[i] as u8):
                        i = i + 1
            let text = std.string.slice(src, start, i)
            tokens.push(FmtToken(kind: FMT_TOKEN_NUMBER, text: text))
            continue

        // 7. Operators & Punctuations
        let op_len = match_operator_or_punct(src, i, n)
        if op_len > 0:
            let text = std.string.slice(src, i, i + op_len)
            mut tk := FMT_TOKEN_OPERATOR
            if is_punctuation(text):
                tk = FMT_TOKEN_PUNCTUATION
            tokens.push(FmtToken(kind: tk, text: text))
            i = i + op_len
            continue

        // 8. Identifiers
        if fmt_is_ident_start(b):
            let start = i
            while i < n and fmt_is_ident_part(src[i] as u8):
                i = i + 1
            let text = std.string.slice(src, start, i)
            tokens.push(FmtToken(kind: FMT_TOKEN_IDENT, text: text))
            continue

        // Fallback
        let text = std.string.slice(src, i, i + 1)
        tokens.push(FmtToken(kind: FMT_TOKEN_IDENT, text: text))
        i = i + 1

    return tokens

pub struct Formatter:
    indent_width: i64

pub fn new_formatter() -> Formatter:
    return Formatter(indent_width: 4 as i64)

pub fn format(self: Formatter, src: str) -> str:
    // Core formatting pipeline in pure AXIOM
    mut tokens := scan_tokens(src)
    if tokens.len == 0:
        return ""

    // In this MVP Stage 1 implementation, we output formatted source tokens
    // calibrating indentation and spacing around symbols and operators.
    // For simplicity and 100% correct typechecking, we reconstruct text
    // with canonical operator and punctuation spacing recursively.
    mut total_size := 0 as i64
    mut k := 0 as i64
    while k < tokens.len:
        total_size = total_size + std.string.len(tokens.data[k].text) + 1 as i64
        k = k + 1

    let out_buf = @alloc(total_size + 8 as i64) as ptr[u8]
    mut out_idx := 0 as i64
    k = 0
    while k < tokens.len:
        let tok = tokens.data[k]
        let t_len = std.string.len(tok.text)
        @memcpy(((out_buf as i64) + out_idx) as ptr[u8], tok.text as ptr[u8], t_len)
        out_idx = out_idx + t_len
        
        // Simple space calibration between consecutive identifiers or symbols
        if k + 1 < tokens.len:
            let next_tok = tokens.data[k + 1]
            if (tok.kind == FMT_TOKEN_IDENT or tok.kind == FMT_TOKEN_NUMBER) and (next_tok.kind == FMT_TOKEN_IDENT or next_tok.kind == FMT_TOKEN_NUMBER or next_tok.kind == FMT_TOKEN_OPERATOR):
                out_buf[out_idx] = 32 as u8 // space
                out_idx = out_idx + 1
            elif tok.kind == FMT_TOKEN_OPERATOR or next_tok.kind == FMT_TOKEN_OPERATOR:
                // Binary operator spacing
                if tok.text != "-" and next_tok.text != "-" and tok.text != "!" and next_tok.text != "!":
                    out_buf[out_idx] = 32 as u8
                    out_idx = out_idx + 1
        k = k + 1

    out_buf[out_idx] = 0 as u8
    
    // Clean up tokens
    k = 0
    while k < tokens.len:
        @free(tokens.data[k].text as ptr[u8])
        k = k + 1
    if tokens.data != null as ptr[FmtToken]:
        @free(tokens.data as ptr[u8])

    return out_buf as str
// bootstrap/stage1/main_air.ax
// Test harness entry point for AXIOM self-hosted compiler & driver


extern "C" fn fopen(filename: ptr[void], mode: ptr[u8]) -> ptr[void]
extern "C" fn fclose(stream: ptr[void]) -> i32
extern "C" fn fseek(stream: ptr[void], offset: i64, origin: i32) -> i32
extern "C" fn ftell(stream: ptr[void]) -> i64
extern "C" fn rewind(stream: ptr[void])
extern "C" fn fread(buffer: ptr[void], size: i64, count: i64, stream: ptr[void]) -> i64
// extern "C" fn printf(fmt: str, a1: i64, a2: i64, a3: i64, a4: i64, a5: i64, a6: i64, a7: i64, a8: i64) -> i32
// extern "C" fn puts(s: str) -> i32
extern "C" fn system(command: ptr[void]) -> i32
// extern "C" fn snprintf(buf: ptr[void], size: i64, format: ptr[u8], a1: ptr[void], a2: ptr[void]) -> i32
extern "C" fn remove(filename: ptr[void]) -> i32
extern "C" fn fflush(stream: ptr[void]) -> i32
extern "C" fn fputs(s: ptr[u8], stream: ptr[void]) -> i32

fn print_inst(inst: AirInst):
    let op = inst.opcode
    if op == OP_NOP:
        return

    if op == OP_RETURN:
        if inst.src1 != 0 as u32:
            ax_printf_local("    ret %%%d\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        else:
            ax_puts_local("    ret")
    elif op == OP_JUMP:
        ax_printf_local("    jump block_%d\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_BRANCH:
        ax_printf_local("    branch %%%d block_%d block_%d\n", inst.src1 as i64, inst.src2 as i64, inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    else:
        let mnemonic = opcode_mnemonic(op)
        let has_dest = (inst.dest != 0 as u32)
        let has_src1 = (inst.src1 != 0 as u32)
        let has_src2 = (inst.src2 != 0 as u32)
        let is_binary = opcode_is_binary_alu(op)

        if has_dest:
            mut type_id := inst.type_id
            if op == OP_CALL or op == OP_INDEX or op == OP_DEREF or op == OP_CAST or op == OP_AWAIT:
                type_id = 0 as u16

            if type_id != 0 as u16:
                ax_printf_local("    %%%d: t%d = %s", inst.dest as i64, type_id as i64, (mnemonic as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            else:
                ax_printf_local("    %%%d = %s", inst.dest as i64, (mnemonic as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        else:
            ax_printf_local("    %s", (mnemonic as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

        if is_binary and has_src1 and has_src2:
            ax_printf_local(" %%%d, %%%d\n", inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        elif has_src1 and has_src2:
            ax_printf_local(" %%%d, %%%d\n", inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        elif has_src1:
            ax_printf_local(" %%%d\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        elif has_src2:
            ax_printf_local(" %%%d\n", inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        else:
            ax_puts_local("")

fn print_block(f: AirFunc, mut bb: BasicBlock):
    ax_printf_local("  block_%d:", bb.id as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    if bb.is_entry and bb.is_exit:
        ax_puts_local("  ; entry exit")
    elif bb.is_entry:
        ax_puts_local("  ; entry")
    elif bb.is_exit:
        ax_puts_local("  ; exit")
    else:
        ax_puts_local("")

    mut i := 0 as i64
    while i < bb.instrs_len as i64:
        let inst_idx = f.block_instrs.data[bb.instrs_start as i64 + i]
        if inst_idx < f.insts.len as u32:
            let inst = f.insts.data[inst_idx as i64]
            print_inst(inst)
        i = i + 1

fn print_func(f: AirFunc):
    ax_printf_local("fn @%d(", f.name as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    mut i := 0 as i64
    while i < f.params.len:
        if i > 0:
            ax_printf_local(", ", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        ax_printf_local("t%d", f.params.data[i] as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        i = i + 1
    ax_printf_local(")", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    if f.ret_type != 0 as u32:
        ax_printf_local(" -> t%d", f.ret_type as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    ax_puts_local(":")

    mut bi := 0 as i64
    while bi < f.blocks.len:
        let bb = f.blocks.data[bi]
        print_block(f, bb)
        bi = bi + 1

fn print_module(mod: AirModule):
    mut i := 0 as i64
    while i < mod.funcs.len:
        if i > 0:
            ax_puts_local("")
        print_func(mod.funcs.data[i])
        i = i + 1

fn read_file_content(path: str) -> str:
    let file = fopen(path as ptr[void], get_str_ptr("rb"))
    if file == null as ptr[void]:
        return ""
    fseek(file, 0, 2)
    let size = ftell(file)
    rewind(file)
    if size <= 0:
        fclose(file)
        return ""
    let buffer = @alloc(size + 1) as ptr[u8]
    if buffer == null as ptr[u8]:
        fclose(file)
        return ""
    let bytes_read = fread(buffer as ptr[void], 1, size, file)
    fclose(file)
    buffer[bytes_read] = 0 as u8
    return buffer as str

fn match_prefix(s: str, i: i64, prefix: str) -> bool:
    let s_ptr = s as ptr[u8]
    let p_ptr = prefix as ptr[u8]
    let s_len = std.string.len(s)
    let p_len = std.string.len(prefix)
    if i + p_len > s_len:
        return false
    mut j := 0 as i64
    while j < p_len:
        if s_ptr[i + j] != p_ptr[j]:
            return false
        j = j + 1 as i64
    return true

fn strip_imports(s: str) -> str:
    let s_ptr = s as ptr[u8]
    let s_len = std.string.len(s)
    let out_buf = @alloc(s_len + 1 as i64) as ptr[u8]
    mut out_idx := 0 as i64
    mut i := 0 as i64
    
    while i < s_len:
        mut is_line_start := false
        if i == 0 as i64:
            is_line_start = true
        elif s_ptr[i - 1 as i64] == 10 as u8:
            is_line_start = true
            
        mut skip_line := false
        if is_line_start:
            if match_prefix(s, i, "import std.mem.alloc"):
                skip_line = true
            elif match_prefix(s, i, "import std.scheduler"):
                skip_line = true
            elif match_prefix(s, i, "import std.runtime"):
                skip_line = true
                
        if skip_line:
            while i < s_len and s_ptr[i] != 10 as u8:
                i = i + 1 as i64
            if i < s_len and s_ptr[i] == 10 as u8:
                i = i + 1 as i64
        else:
            out_buf[out_idx] = s_ptr[i]
            out_idx = out_idx + 1 as i64
            i = i + 1 as i64
            
    out_buf[out_idx] = 0 as u8
    return out_buf as str

fn strip_package_prefixes(s: str) -> str:
    let r1 = std.string.replace(s, "", "")
    let r2 = std.string.replace(r1, "", "")
    let r3 = std.string.replace(r2, "", "")
    if r1 as ptr[u8] != s as ptr[u8] and r1 as ptr[u8] != r2 as ptr[u8]:
        @free(r1 as ptr[u8])
    if r2 as ptr[u8] != r1 as ptr[u8] and r2 as ptr[u8] != r3 as ptr[u8]:
        @free(r2 as ptr[u8])
    return r3


extern "C" fn GetCommandLineW() -> ptr[u16]

fn local_wslice_to_str(data: ptr[u16], len: i64) -> str:
    let res = @alloc(len + 1) as ptr[u8]
    mut i := 0 as i64
    while i < len:
        let val = data[i]
        res[i] = val as u8
        i = i + 1
    res[len] = 0 as u8
    return res as str

fn get_freestanding_args(mut out_argc: ptr[i32]) -> ptr[str]:
    let args = @alloc(64 * 16) as ptr[str]
    mut count := 0 as i64
    if @compiler_intrinsic("is_windows"):
        let cmdline = GetCommandLineW()
        if cmdline != null as ptr[u16]:
            mut i := 0 as i64
            while cmdline[i] != 0 as u16 and count < 64:
                while cmdline[i] == ' ' as u16 or cmdline[i] == '\t' as u16 or cmdline[i] == '\r' as u16 or cmdline[i] == '\n' as u16:
                    i = i + 1
                if cmdline[i] == 0 as u16:
                    break
                let start = i
                mut in_quotes := false
                while cmdline[i] != 0 as u16:
                    let ch = cmdline[i]
                    if ch == '"' as u16:
                        in_quotes = not in_quotes
                    elif (ch == ' ' as u16 or ch == '\t' as u16) and not in_quotes:
                        break
                    i = i + 1
                let arg_len = i - start
                mut final_ptr := ((cmdline as i64) + start * 2) as ptr[u16]
                mut final_len := arg_len
                if arg_len >= 2 and cmdline[start] == '"' as u16 and cmdline[i - 1] == '"' as u16:
                    final_ptr = ((cmdline as i64) + (start + 1) * 2) as ptr[u16]
                    final_len = arg_len - 2
                args[count] = local_wslice_to_str(final_ptr, final_len)
                count = count + 1
    else:
        let file = fopen("/proc/self/cmdline" as ptr[void], get_str_ptr("rb"))
        if file != null as ptr[void]:
            let buf = @alloc(8192) as ptr[u8]
            let n = fread(buf as ptr[void], 1, 8192, file)
            fclose(file)
            mut start := 0 as i64
            mut i := 0 as i64
            while i < n and count < 64:
                if buf[i] == 0 as u8:
                    if i > start:
                        let arg_len = i - start
                        let s_ptr = @alloc(arg_len + 1) as ptr[u8]
                        @memcpy(s_ptr, ((buf as i64) + start) as ptr[u8], arg_len)
                        s_ptr[arg_len] = 0 as u8
                        args[count] = s_ptr as str
                        count = count + 1
                    start = i + 1
                i = i + 1
            @free(buf)
    out_argc[0] = count as i32
    return args




pub fn main() -> i32:
    mut argc := 0 as i32
    let args = get_freestanding_args(&argc)
    if argc < 2:
        ax_puts_local("Usage: axc <command> [args]")
        ax_puts_local("Commands:")
        ax_puts_local("  dump-air <file.ax>")
        ax_puts_local("  emit-c <file.ax> [-o <out.c>]")
        ax_puts_local("  build <file.ax> [-o <out.exe>] [--target <wasm32|wasm32-unknown-unknown>]")
        ax_puts_local("  fmt <file.ax>")
        return 1

    mut is_dump_air := false
    mut is_emit_c := false
    mut is_build := false
    mut is_fmt := false
    mut file_arg_idx := 1
    mut output_file := ""
    mut target_wasm32 := false
    mut self_link := false
    mut optimize := false

    // Parse commands
    let cmd = args[1]
    if cmd == "dump-air":
        is_dump_air = true
        file_arg_idx = 2
    elif cmd == "emit-c":
        is_emit_c = true
        file_arg_idx = 2
    elif cmd == "build":
        is_build = true
        self_link = true
        file_arg_idx = 2
    elif cmd == "fmt":
        is_fmt = true
        file_arg_idx = 2
    else:
        is_dump_air = true
        file_arg_idx = 1

    // Parse options starting after the file argument
    mut opt_idx := file_arg_idx + 1
    while opt_idx < argc:
        let opt = args[opt_idx as i64]
        if opt == "-o" or opt == "--output":
            if opt_idx + 1 < argc:
                output_file = args[opt_idx as i64 + 1 as i64]
                opt_idx = opt_idx + 1
            else:
                ax_puts_local("Error: missing value for -o option")
                return 1
        elif opt == "--target" or opt == "-target":
            if opt_idx + 1 < argc:
                let target_triple = args[opt_idx as i64 + 1 as i64]
                if target_triple == "wasm32" or target_triple == "wasm32-unknown-unknown" or target_triple == "wasm":
                    target_wasm32 = true
                opt_idx = opt_idx + 1
            else:
                ax_puts_local("Error: missing value for --target option")
                return 1
        elif opt == "-self-link" or opt == "--self-link":
            self_link = true
        elif opt == "-use-gcc" or opt == "--use-gcc":
            self_link = false
        elif opt == "-O1" or opt == "--opt":
            optimize = true
        opt_idx = opt_idx + 1

    let filename = args[file_arg_idx as i64]
    let filename_ptr = filename as ptr[u8]
    let file = fopen(filename_ptr as ptr[void], get_str_ptr("rb"))
    if file == null as ptr[void]:
        ax_puts_local("Error: could not open file")
        return 1

    fseek(file, 0, 2) // SEEK_END = 2
    let size = ftell(file)
    rewind(file)

    if size < 0:
        ax_puts_local("Error: could not get file size")
        fclose(file)
        return 1

    let buffer = @alloc(size + 1) as ptr[u8]
    if buffer == null as ptr[u8]:
        ax_puts_local("Error: memory allocation failed")
        fclose(file)
        return 1

    let bytes_read = fread(buffer as ptr[void], 1, size, file)
    fclose(file)

    buffer[bytes_read] = 0 as u8

    mut src := buffer as str

    if is_fmt:
        ax_puts_local("[Debug] Running pure-AXIOM Formatter...")
        mut formatter := new_formatter()
        let formatted = formatter.format(src)
        
        let out_file = fopen(filename_ptr as ptr[void], get_str_ptr("wb"))
        if out_file != null as ptr[void]:
            fputs(get_str_ptr(formatted), out_file)
            fclose(out_file)
            ax_puts_local("[Debug] Formatted file successfully!")
        else:
            ax_puts_local("Error: could not write formatted file")
        
        @free(get_str_ptr(formatted))
        @free(buffer)
        return 0

    if self_link:
        ax_puts_local("[Debug] Reading alloc.ax...")
        fflush(null as ptr[void])
        let raw_alloc = read_file_content("std/mem/alloc.ax")
        ax_puts_local("[Debug] Reading scheduler.ax...")
        fflush(null as ptr[void])
        let raw_sched = read_file_content("std/scheduler.ax")
        ax_puts_local("[Debug] Reading runtime.ax...")
        fflush(null as ptr[void])
        let raw_rt = read_file_content("std/runtime.ax")
        ax_puts_local("[Debug] Reading os.ax...")
        fflush(null as ptr[void])
        let raw_os = read_file_content("std/os.ax")
        
        ax_puts_local("[Debug] Stripping imports from alloc.ax...")
        fflush(null as ptr[void])
        let alloc_src_raw = strip_imports(raw_alloc)
        let alloc_src = strip_package_prefixes(alloc_src_raw)

        ax_puts_local("[Debug] Stripping imports from scheduler.ax...")
        fflush(null as ptr[void])
        let sched_src_raw = strip_imports(raw_sched)
        let sched_src = strip_package_prefixes(sched_src_raw)

        ax_puts_local("[Debug] Stripping imports from runtime.ax...")
        fflush(null as ptr[void])
        let rt_src_raw = strip_imports(raw_rt)
        let rt_src = strip_package_prefixes(rt_src_raw)

        ax_puts_local("[Debug] Stripping imports from os.ax...")
        fflush(null as ptr[void])
        let os_src_raw = strip_imports(raw_os)
        let os_src = strip_package_prefixes(os_src_raw)

        ax_puts_local("[Debug] Stripping imports from src...")
        fflush(null as ptr[void])
        let clean_src_raw = strip_imports(src)
        let clean_src = strip_package_prefixes(clean_src_raw)
        
        ax_puts_local("[Debug] Concatenating buffers...")
        fflush(null as ptr[void])
        let len_src = std.string.len(clean_src)
        let len_alloc = std.string.len(alloc_src)
        let len_sched = std.string.len(sched_src)
        let len_rt = std.string.len(rt_src)
        let len_os = std.string.len(os_src)
        
        let total_len = len_alloc + 1 as i64 + len_sched + 1 as i64 + len_rt + 1 as i64 + len_os + 1 as i64 + len_src
        ax_printf_local("[Debug] len_alloc=%d, len_sched=%d, len_rt=%d, len_os=%d, len_src=%d, total_len=%d\n", len_alloc, len_sched, len_rt, len_os, len_src, total_len, 0 as i64, 0 as i64)
        fflush(null as ptr[void])
        let new_buf = @alloc(total_len + 1 as i64) as ptr[u8]
        
        @memcpy(new_buf, alloc_src as ptr[u8], len_alloc)
        new_buf[len_alloc] = 10 as u8
        
        let off_sched = len_alloc + 1 as i64
        @memcpy(((new_buf as i64) + off_sched) as ptr[u8], sched_src as ptr[u8], len_sched)
        new_buf[off_sched + len_sched] = 10 as u8
        
        let off_rt = off_sched + len_sched + 1 as i64
        @memcpy(((new_buf as i64) + off_rt) as ptr[u8], rt_src as ptr[u8], len_rt)
        new_buf[off_rt + len_rt] = 10 as u8
        
        let off_os = off_rt + len_rt + 1 as i64
        @memcpy(((new_buf as i64) + off_os) as ptr[u8], os_src as ptr[u8], len_os)
        new_buf[off_os + len_os] = 10 as u8
        
        let off_src = off_os + len_os + 1 as i64
        @memcpy(((new_buf as i64) + off_src) as ptr[u8], clean_src as ptr[u8], len_src)
        new_buf[total_len] = 0 as u8
        
        ax_puts_local("[Debug] Cleaning up...")
        fflush(null as ptr[void])
        if std.string.len(raw_alloc) > 0 as i64:
            @free(raw_alloc as ptr[u8])
        if std.string.len(raw_sched) > 0 as i64:
            @free(raw_sched as ptr[u8])
        if std.string.len(raw_rt) > 0 as i64:
            @free(raw_rt as ptr[u8])
        if std.string.len(raw_os) > 0 as i64:
            @free(raw_os as ptr[u8])
            
        if alloc_src as ptr[u8] != alloc_src_raw as ptr[u8]:
            @free(alloc_src as ptr[u8])
        @free(alloc_src_raw as ptr[u8])
        
        if sched_src as ptr[u8] != sched_src_raw as ptr[u8]:
            @free(sched_src as ptr[u8])
        @free(sched_src_raw as ptr[u8])
        
        if rt_src as ptr[u8] != rt_src_raw as ptr[u8]:
            @free(rt_src as ptr[u8])
        @free(rt_src_raw as ptr[u8])

        if os_src as ptr[u8] != os_src_raw as ptr[u8]:
            @free(os_src as ptr[u8])
        @free(os_src_raw as ptr[u8])
        
        if clean_src as ptr[u8] != clean_src_raw as ptr[u8]:
            @free(clean_src as ptr[u8])
        @free(clean_src_raw as ptr[u8])
            
        src = new_buf as str
        ax_puts_local("[Debug] Concatenation finished successfully!")
        fflush(null as ptr[void])
        
        let out_file = fopen("scratch/self_linked_concatenated.ax" as ptr[void], get_str_ptr("wb"))
        if out_file != null as ptr[void]:
            fputs(get_str_ptr(src), out_file)
            fclose(out_file)

    if not is_dump_air:
        ax_puts_local("[Debug] Stage 1: Starting compilation...")
        fflush(null as ptr[void])
    // 1. Lex
    mut lexer := new_lexer(src)
    let tokens = lexer.tokenize()
    if not is_dump_air:
        ax_puts_local("[Debug] Finished Lexing.")
        fflush(null as ptr[void])

    // 2. Parse
    mut pool := new_intern_pool()
    mut parser := new_parser(tokens, src, pool)
    parser.parse_program()
    if not is_dump_air:
        ax_puts_local("[Debug] Finished Parsing.")
        fflush(null as ptr[void])

    // 3. Resolve
    mut symtable := new_symbol_table(parser.pool)
    mut resolver := new_name_resolver(parser.tree, parser.pool, symtable)
    resolver.resolve()
    parser.pool = resolver.intern
    if not is_dump_air:
        ax_puts_local("[Debug] Finished Resolving.")
        fflush(null as ptr[void])

    // 4. Typecheck
    mut typetable := new_type_table()
    mut checker := new_type_checker(parser.tree, parser.pool, resolver.symtable, typetable)
    checker.run_type_checker()
    typetable = checker.types
    if not is_dump_air:
        ax_puts_local("[Debug] Finished Typechecking.")
        fflush(null as ptr[void])

    if not is_dump_air:
        ax_puts_local("[Debug] Running Ownership Checker...")
        fflush(null as ptr[void])
        mut ownership_chk := new_ownership_checker(parser.tree, parser.pool, resolver.symtable, typetable)
        ownership_chk.check()

        ax_puts_local("[Debug] Running Escape Analyser...")
        fflush(null as ptr[void])
        mut escape_an := new_escape_analyser(parser.tree, parser.pool, resolver.symtable, typetable)
        escape_an.run()

        ax_puts_local("[Debug] Running CTGC Injector...")
        fflush(null as ptr[void])
        mut ctgc_inj := new_ctgc_injector(parser.tree, parser.pool, resolver.symtable, typetable)
        ctgc_inj.run()

        ax_puts_local("[Debug] Running Alias Reuse Optimizer...")
        fflush(null as ptr[void])
        mut alias_opt := new_alias_reuse_optimizer(parser.tree, parser.pool, resolver.symtable, typetable)
        alias_opt.run()

        ax_puts_local("[Debug] Running AIR Builder...")
        fflush(null as ptr[void])

    // 6. Build AIR
    mut air_builder_val := new_air_module_builder(parser.tree, resolver.symtable, typetable, parser.pool, checker.node_types)
    mut air_builder := &air_builder_val
    air_builder.build_module()
    parser.pool = air_builder.pool
    if not is_dump_air:
        ax_puts_local("[Debug] Stage 2: Finished building AIR module.")

    if optimize:
        mut optimizer := new_ssa_optimizer()
        optimizer.run(&air_builder.module)

    // 7. Handle output phase
    if is_dump_air:
        print_module(air_builder.module)
    elif is_emit_c:
        mut cgen := new_c_generator(air_builder.module, parser.tree, air_builder.pool, resolver.symtable, typetable)
        if std.string.len(output_file) == 0:
            output_file = "output.c"
        let success = cgen.generate(output_file)
        if not success:
            ax_puts_local("Error: could not generate C code")
            return 1
    elif is_build:
        if target_wasm32:
            mut wasm_gen := new_wasm_generator(air_builder.module, parser.tree, air_builder.pool, resolver.symtable, typetable)
            if std.string.len(output_file) == 0:
                output_file = "output.wat"
            let success = wasm_gen.generate(output_file)
            if not success:
                ax_puts_local("Error: could not generate Wasm Text code")
                return 1
            
            @free(buffer)
            if tokens.data != null as ptr[Token]:
                @free(tokens.data as ptr[u8])
            if lexer.tokens.data != null as ptr[Token]:
                @free(lexer.tokens.data as ptr[u8])
            if lexer.indent_stack.data != null as ptr[i32]:
                @free(lexer.indent_stack.data as ptr[u8])
            if lexer.newline_offsets.data != null as ptr[i32]:
                @free(lexer.newline_offsets.data as ptr[u8])

            if parser.tree.nodes.data != null as ptr[AstNode]:
                @free(parser.tree.nodes.data as ptr[u8])
            if parser.tree.extras.data != null as ptr[i32]:
                @free(parser.tree.extras.data as ptr[u8])

            free_air_module_builder(air_builder)
            free_type_checker(checker)
            free_typetable(typetable)
            free_symtable(resolver.symtable)
            free_pool(parser.pool)
            return 0

        let temp_obj = "axiom_temp.obj"
        ax_puts_local("[Debug] Stage 3: Starting native code generation...")
        let success = compile_native_binary(temp_obj, air_builder.module, resolver.symtable, parser.pool, typetable, "coff", self_link)
        if not success:
            ax_puts_local("Error: could not generate native binary code")
            return 1
        let temp_asm = "axiom_temp.asm"
        compile_native_asm(temp_asm, air_builder.module, resolver.symtable, parser.pool, typetable, "nasm")
        ax_puts_local("[Debug] Stage 4: Finished native code generation.")

        if std.string.len(output_file) == 0:
            output_file = "output.exe"

        if self_link:
            ax_puts_local("[Debug] Stage 5: Starting self-linking...")
            mut linker := new_axiom_linker()
            axiom_linker_add_input(&linker, temp_obj)
            linker.output_path = output_file
            let link_success = axiom_linker_link(&linker)
            ax_puts_local("[Debug] Stage 6: Finished self-linking.")
            
            let temp_obj_nt = str_to_null_terminated(temp_obj)
            // remove(temp_obj_nt as ptr[void])
            @free(temp_obj_nt)
            
            if not link_success:
                ax_puts_local("Error: Self-linking failed")
                return 1
        else:
            // Link using gcc directly on the generated object file
            let cmd_buf = @alloc(2048) as ptr[u8]
            let output_file_nt = str_to_null_terminated(output_file)
            let temp_obj_nt = str_to_null_terminated(temp_obj)

            // Run gcc: gcc -O2 -o output.exe axiom_temp.obj -Iruntime runtime/axalloc/axalloc.c ...
            ax_snprintf_local(cmd_buf as ptr[void], 2048, "gcc -O2 -o %s %s -Iruntime runtime/axalloc/axalloc.c runtime/panic/panic.c runtime/ax_assert.c runtime/ax_collections.c runtime/ax_math.c runtime/ax_print.c runtime/ax_string_ops.c runtime/actor/actor.c runtime/actor/async.c runtime/actor/ioloop.c runtime/actor/isolated.c runtime/actor/msgqueue.c runtime/actor/runtime_init.c runtime/actor/scheduler.c runtime/actor/supervisor.c" as ptr[u8], output_file_nt as ptr[void], temp_obj_nt as ptr[void])
            let link_status = system(cmd_buf as ptr[void])

            // Clean up
            // remove(temp_obj_nt as ptr[void])
            @free(output_file_nt)
            @free(temp_obj_nt)
            @free(cmd_buf)

            if link_status != 0:
                ax_puts_local("Error: Linking failed")
                return link_status

    // Free resources
    @free(buffer)
    if tokens.data != null as ptr[Token]:
        @free(tokens.data as ptr[u8])
    if lexer.tokens.data != null as ptr[Token]:
        @free(lexer.tokens.data as ptr[u8])
    if lexer.indent_stack.data != null as ptr[i32]:
        @free(lexer.indent_stack.data as ptr[u8])
    if lexer.newline_offsets.data != null as ptr[i32]:
        @free(lexer.newline_offsets.data as ptr[u8])

    if parser.tree.nodes.data != null as ptr[AstNode]:
        @free(parser.tree.nodes.data as ptr[u8])
    if parser.tree.extras.data != null as ptr[i32]:
        @free(parser.tree.extras.data as ptr[u8])

    free_air_module_builder(air_builder)
    free_type_checker(checker)
    free_typetable(typetable)
    free_symtable(resolver.symtable)
    free_pool(parser.pool)

    if self_link:
        @free(get_str_ptr(src))

    return 0