        out_insts.push(MachInst(op: MACH_JCC, cc: 0x04 as u8, padding: 0 as u8, 
            dst: MachOperand(kind: OPND_LABEL, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: lbl_ok_uaf, imm: 0 as i64), 
            src1: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), 
