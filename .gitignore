# bin/
*.exe
*.exe~
*.dll
*.so
*.dylib

# ----------------------------------------------------------
# Build Artifacts (object files, assembly, def files)
# ----------------------------------------------------------
*.obj
*.o
*.asm
*.def

# ----------------------------------------------------------
# Test Binaries
# ----------------------------------------------------------
*.test

# ----------------------------------------------------------
# Go Coverage
# ----------------------------------------------------------
*.out
coverage.html

# ----------------------------------------------------------
# Log Files
# ----------------------------------------------------------
*.log

# ----------------------------------------------------------
# Build Output Text Files
# ----------------------------------------------------------
stdout.txt
stderr.txt
stdout_stage2.txt
stderr_stage2.txt
out.txt
out.log
err.txt
compile_out.txt
compile_stage2.log

# ----------------------------------------------------------
# Dump / Trace Files
# ----------------------------------------------------------
*_dump.txt
trace*.txt
*_debug_dump.txt

# ----------------------------------------------------------
# AIR Output Files
# ----------------------------------------------------------
air.txt
air_stage0.txt
air_stage1.txt
test_malloc_air*.txt

# ----------------------------------------------------------
# Test Output Files
# ----------------------------------------------------------
test_out*.txt
test_run*.log
test_dump*.log
test_stage*.log
sema_test*.log
test_output.log
out_test.txt

