        mut fi_params_len := 0 as i64
        mut fi_params_data := null as ptr[u32]
        
        mut builtin_params := null as ptr[u32]

        if op == OP_CALL:
            if inst.src1 == 0 as u32:
                // Direct call
                let sym_idx = inst.type_id as u32
                if sym_idx != 0 as u32 and (sym_idx as i64) < self.symtable.symbols.len:
                    let sym = self.symtable.symbols.data[sym_idx as i64]
                    let fn_name = self.pool.get(sym.name_id)
                    if fn_name == "memcpy" or fn_name == "memmove":
                        let builtin_len = 3 as i64
                        builtin_params = @alloc(3 * 4) as ptr[u32]
                        builtin_params[0] = 0x1f as u32 // void*
                        builtin_params[1] = 0x1f as u32 // void*
                        builtin_params[2] = 8 as u32    // u64/usize
                        has_fi = true
                        fi_params_len = builtin_len
                        fi_params_data = builtin_params
                    elif fn_name == "fwrite" or fn_name == "fread":
                        let builtin_len = 4 as i64
                        builtin_params = @alloc(4 * 4) as ptr[u32]
                        builtin_params[0] = 0x1f as u32 // void*
                        builtin_params[1] = 8 as u32    // size_t
                        builtin_params[2] = 8 as u32    // size_t
                        builtin_params[3] = 0x1f as u32 // FILE*
                        has_fi = true
                        fi_params_len = builtin_len
                        fi_params_data = builtin_params
                    elif fn_name == "ax_alloc" or fn_name == "alloc":
                        let builtin_len = 1 as i64
                        builtin_params = @alloc(1 * 4) as ptr[u32]
                        builtin_params[0] = 4 as u32 // i64
                        has_fi = true
                        fi_params_len = builtin_len
                        fi_params_data = builtin_params
                    else:
                        let fn_type_id = sym.type_id
                        if fn_type_id != 0 as u32 and (fn_type_id as i64) < self.typetable.entries.len:
                            let entry = self.typetable.entries.data[fn_type_id]
                            if entry.kind == TYPE_KIND_FUNC:
                                let fi = self.typetable.funcs.data[entry.extra as i64]
                                has_fi = true
                                fi_params_len = fi.params.len
                                fi_params_data = fi.params.data
            else:
                // Indirect call
                if self.reg_types != null as ptr[u32] and inst.src1 > 0 as u32:
                    let r_type = self.reg_types[inst.src1]
                    if r_type != 0 as u32 and (r_type as i64) < self.typetable.entries.len:
                        mut entry = self.typetable.entries.data[r_type]
                        if entry.kind == TYPE_KIND_POINTER:
                            let pointee_id = entry.extra
                            if pointee_id != 0 as u32 and (pointee_id as i64) < self.typetable.entries.len:
                                entry = self.typetable.entries.data[pointee_id]
                        if entry.kind == TYPE_KIND_FUNC:
                            let fi = self.typetable.funcs.data[entry.extra as i64]
                            has_fi = true
                            fi_params_len = fi.params.len
                            fi_params_data = fi.params.data
        
        // Print callee
        mut fn_name := "func"
        mut is_allocated := false
        if op == OP_SYSCALL:
            fn_name = "ax_syscall"
        elif inst.src1 == 0 as u32:
            // Direct function call
            // We find the function name from type_id (which is symbol idx in this case or typetable extra)
            let sym_idx = inst.type_id as u32
            if sym_idx != 0 as u32 and (sym_idx as i64) < self.symtable.symbols.len:
                fn_name = self.get_mangled_name_by_sym(sym_idx)
                is_allocated = true
                let s_flags = self.symtable.symbols.data[sym_idx as i64].flags
                if (s_flags & 4 as u16) != 0 as u16:
                    is_extern = true
                
                if fn_name == "ax_compiler_intrinsic":
                    let arg_reg = f.extras.data[arg_start as i64 + 1]
                    mut str_val := ""
                    mut found_sconst := false
                    mut search_idx := 0 as i64
                    while search_idx < f.insts.len:
                        let prev_inst = f.insts.data[search_idx]
                        if prev_inst.dest == arg_reg and prev_inst.opcode == 0x0201 as u32 and prev_inst.type_id == 12 as u32:
                            str_val = self.pool.get(prev_inst.src1)
                            found_sconst = true
                        search_idx = search_idx + 1
                    
                    if found_sconst:
                        mut mapped_name := ""
                        mut param_count := 0 as i64
                        if str_val == "\"str_char_count\"" or str_val == "'str_char_count'" or str_val == "str_char_count":
                            mapped_name = "ax_str_char_count"
                            param_count = 1
                        elif str_val == "\"str_concat\"" or str_val == "'str_concat'" or str_val == "str_concat":
                            mapped_name = "ax_str_concat"
                            param_count = 2
                        elif str_val == "\"str_slice\"" or str_val == "'str_slice'" or str_val == "str_slice":
                            mapped_name = "ax_str_slice"
                            param_count = 3
                        elif str_val == "\"str_contains\"" or str_val == "'str_contains'" or str_val == "str_contains":
                            mapped_name = "ax_str_contains"
                            param_count = 2
                        elif str_val == "\"str_starts_with\"" or str_val == "'str_starts_with'" or str_val == "str_starts_with":
                            mapped_name = "ax_str_starts_with"
                            param_count = 2
                        elif str_val == "\"str_ends_with\"" or str_val == "'str_ends_with'" or str_val == "str_ends_with":
                            mapped_name = "ax_str_ends_with"
                            param_count = 2
                        elif str_val == "\"str_index_of\"" or str_val == "'str_index_of'" or str_val == "str_index_of":
                            mapped_name = "ax_str_index_of"
                            param_count = 2
                        elif str_val == "\"str_split\"" or str_val == "'str_split'" or str_val == "str_split":
                            mapped_name = "ax_str_split"
                            param_count = 2
                        elif str_val == "\"str_trim\"" or str_val == "'str_trim'" or str_val == "str_trim":
                            mapped_name = "ax_str_trim"
                            param_count = 1
                        elif str_val == "\"str_to_upper\"" or str_val == "'str_to_upper'" or str_val == "str_to_upper":
                            mapped_name = "ax_str_to_upper"
                            param_count = 1
                        elif str_val == "\"str_to_lower\"" or str_val == "'str_to_lower'" or str_val == "str_to_lower":
                            mapped_name = "ax_str_to_lower"
                            param_count = 1
                        elif str_val == "\"str_repeat\"" or str_val == "'str_repeat'" or str_val == "str_repeat":
                            mapped_name = "ax_str_repeat"
                            param_count = 2
                        elif str_val == "\"str_replace\"" or str_val == "'str_replace'" or str_val == "str_replace":
                            mapped_name = "ax_str_replace"
                            param_count = 3
                        elif str_val == "\"str_to_i64\"" or str_val == "'str_to_i64'" or str_val == "str_to_i64":
                            mapped_name = "ax_str_to_i64"
                            param_count = 1
                        elif str_val == "\"str_to_f64\"" or str_val == "'str_to_f64'" or str_val == "str_to_f64":
                            mapped_name = "ax_str_to_f64"
                            param_count = 1
                        elif str_val == "\"str_is_valid_utf8\"" or str_val == "'str_is_valid_utf8'" or str_val == "str_is_valid_utf8":
                            mapped_name = "ax_str_is_valid_utf8"
                            param_count = 1
                        
                        if param_count > 0:
                            if is_allocated:
                                @free(get_str_ptr(fn_name))
                            fn_name = alloc_str(mapped_name)
                            is_allocated = true
                            is_intrinsic_mapped = true
                            mapped_param_count = param_count
            if fn_name == "assert":
                if is_allocated:
                    @free(get_str_ptr(fn_name))
                fn_name = "ax_assert_axiom"
                is_allocated = false
                is_assert = true
            elif fn_name == "println" or fn_name == "print" or fn_name == "eprint" or fn_name == "eprintln":
                // Map to typed builtin
                mut suffix := "_str"
                if arg_count > 0 as u32:
                    let first_arg_reg = f.extras.data[arg_start as i64 + 1]
                    if self.reg_types != null as ptr[u32] and first_arg_reg > 0 as u32:
                        let t_id = self.reg_types[first_arg_reg]
                        if t_id == 3 as u32 or t_id == 4 as u32 or t_id == 7 as u32 or t_id == 8 as u32:
                            suffix = "_i64"
                        elif t_id == 9 as u32 or t_id == 10 as u32:
                            suffix = "_f64"
                        elif t_id == 11 as u32:
                            suffix = "_bool"
                
                // Mangle to ax_<func_name><suffix>
                let fn_len = std.string.len(fn_name)
                let suffix_len = std.string.len(suffix)
                mut mapped_name := @alloc(fn_len + suffix_len + 4) as ptr[u8]
                @memcpy(mapped_name, "ax_" as ptr[u8], 3)
                
                let dest1 = ((mapped_name as u64) + 3 as u64) as ptr[u8]
                @memcpy(dest1, get_str_ptr(fn_name), fn_len)
                
                let dest2 = ((mapped_name as u64) + 3 as u64 + fn_len as u64) as ptr[u8]
                @memcpy(dest2, suffix as ptr[u8], suffix_len)
                
                let term_idx = 3 + fn_len + suffix_len
                mapped_name[term_idx] = 0 as u8
                
                let old_fn_name = fn_name
                fn_name = mapped_name as str
                if is_allocated:
                    @free(get_str_ptr(old_fn_name))
                is_allocated = true
 
            if inst.dest != 0 as u32 and (self.reg_types == null as ptr[u32] or self.reg_types[inst.dest] != 14 as u32):
                if self.reg_types[inst.dest] == 0 as u32:
                    ax_fprintf_local(self.file, "    r_%d = (void*)%s(", inst.dest as i64, (get_str_ptr(fn_name)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                else:
                    ax_fprintf_local(self.file, "    r_%d = %s(", inst.dest as i64, (get_str_ptr(fn_name)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            else:
                ax_fprintf_local(self.file, "    %s(", (get_str_ptr(fn_name)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            
            if is_allocated:
                @free(get_str_ptr(fn_name))
        else:
            // Indirect function call
            if inst.dest != 0 as u32 and (self.reg_types == null as ptr[u32] or self.reg_types[inst.dest] != 14 as u32):
                if self.reg_types[inst.dest] == 0 as u32:
                    ax_fprintf_local(self.file, "    r_%d = (void*)((void*(*)(", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                else:
                    ax_fprintf_local(self.file, "    r_%d = ((void*(*)(", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            else:
                fputs(get_str_ptr("    ((void(*)("), self.file)

            mut p_i := 0 as u32
            while p_i < arg_count:
                if p_i > 0 as u32:
                    fputs(get_str_ptr(", "), self.file)
                
                mut p_type_name := "void*"
                if has_fi and p_i < fi_params_len as u32:
                    let p_t = fi_params_data[p_i]
                    if p_t != 0 as u32:
                        p_type_name = self.get_c_type(p_t)
                        if p_type_name == "void":
                            p_type_name = "void*"
                else:
                    let arg_reg = f.extras.data[arg_start as i64 + 1 + p_i as i64]
                    if self.reg_types != null as ptr[u32] and arg_reg > 0 as u32:
                        let arg_t = self.reg_types[arg_reg]
                        if arg_t != 0 as u32:
                            p_type_name = self.get_c_type(arg_t)
                            if p_type_name == "void":
                                p_type_name = "void*"
                
                fputs(get_str_ptr(p_type_name), self.file)
                if p_type_name != "void*" and p_type_name != "void" and p_type_name != "ax_string" and not std.string.ends_with(p_type_name, "*"):
                    @free(get_str_ptr(p_type_name))
                p_i = p_i + 1 as u32

            ax_fprintf_local(self.file, "))r_%d)(", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

        if is_intrinsic_mapped:
            mut p_i := 0 as i64
            while p_i < mapped_param_count:
                if p_i > 0:
                    fputs(get_str_ptr(", "), self.file)
                ax_fprintf_local(self.file, "p_%d", p_i, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                p_i = p_i + 1
        else:
            mut i := 0 as i64
            while i < arg_count as i64:
                if i > 0:
                    fputs(get_str_ptr(", "), self.file)
                let arg_reg = f.extras.data[arg_start as i64 + 1 + i]
                mut is_str := false
                mut actual_t := 0 as u32
                if self.reg_types != null as ptr[u32] and arg_reg > 0 as u32:
                    actual_t = self.reg_types[arg_reg]
                    if actual_t == 12 as u32:
                        is_str = true
                
                mut needs_cast := false
                mut cast_type := "void*"
                if has_fi and i < fi_params_len:
                    let expected_t = fi_params_data[i]
                    if expected_t != 0 as u32 and expected_t != actual_t:
                        needs_cast = true
                        cast_type = self.get_c_type(expected_t)
                        if cast_type == "void":
                            cast_type = "void*"

                if (is_extern or fn_name == "ax_panic") and is_str:
                    ax_fprintf_local(self.file, "(const char*)(r_%d).ptr", arg_reg as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                else:
                    if needs_cast:
                        mut is_struct_val := false
                        if actual_t != 0 as u32 and (actual_t as i64) < self.typetable.entries.len:
                            let a_entry = self.typetable.entries.data[actual_t]
                            if a_entry.kind == TYPE_KIND_SUM or actual_t == 12 as u32:
                                is_struct_val = true
                        if is_struct_val:
                            ax_fprintf_local(self.file, "(%s)&r_%d", (get_str_ptr(cast_type)) as i64, arg_reg as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                        else:
                            ax_fprintf_local(self.file, "(%s)r_%d", (get_str_ptr(cast_type)) as i64, arg_reg as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                    else:
                        ax_fprintf_local(self.file, "r_%d", arg_reg as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                i = i + 1
        if is_assert:
            fputs(get_str_ptr(", AX_STR(\"assertion failed\")"), self.file)
        fputs(get_str_ptr(");\n"), self.file)

        if builtin_params != null as ptr[u32]:
            @free(builtin_params as ptr[u8])
