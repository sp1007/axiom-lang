// bootstrap/stage1/x86_selector.ax
// Instruction selector for x86-64 in self-hosted AXIOM.
// Translates flat/block AIR instructions into virtual-register machine instructions (MachInst).

import std.string

pub const MACH_NOP: u16 = 0
pub const MACH_MOV: u16 = 1
pub const MACH_MOV_IMM: u16 = 2
pub const MACH_ADD: u16 = 3
pub const MACH_SUB: u16 = 4
pub const MACH_IMUL: u16 = 5
pub const MACH_IDIV: u16 = 6
pub const MACH_CQO: u16 = 7
pub const MACH_NEG: u16 = 8
pub const MACH_NOT: u16 = 9
pub const MACH_AND: u16 = 10
pub const MACH_OR: u16 = 11
pub const MACH_XOR: u16 = 12
pub const MACH_SHL: u16 = 13
pub const MACH_SAR: u16 = 14
pub const MACH_CMP: u16 = 15
pub const MACH_TEST: u16 = 16
pub const MACH_SETCC: u16 = 17
pub const MACH_MOVZX_B: u16 = 18
pub const MACH_JMP: u16 = 19
pub const MACH_JCC: u16 = 20
pub const MACH_CALL: u16 = 21
pub const MACH_CALL_INDIRECT: u16 = 22
pub const MACH_RET: u16 = 23
pub const MACH_PUSH: u16 = 24
pub const MACH_POP: u16 = 25
pub const MACH_LEA: u16 = 26
pub const MACH_LOAD: u16 = 27
pub const MACH_STORE: u16 = 28
pub const MACH_XOR_ZERO: u16 = 29
pub const MACH_LABEL: u16 = 30
pub const MACH_SYSCALL: u16 = 31
pub const MACH_SHR: u16 = 32
pub const MACH_FADD: u16 = 33
pub const MACH_FSUB: u16 = 34
pub const MACH_FMUL: u16 = 35
pub const MACH_FDIV: u16 = 36
pub const MACH_FCMP: u16 = 37
pub const MACH_ITOF: u16 = 38
pub const MACH_FTOI: u16 = 39
pub const MACH_MOVDQ: u16 = 40
pub const MACH_MOVQD: u16 = 41

pub const OPND_NONE: u8 = 0
pub const OPND_VREG: u8 = 1
pub const OPND_PHYS: u8 = 2
pub const OPND_IMM: u8 = 3
pub const OPND_LABEL: u8 = 4
pub const OPND_MEM: u8 = 5

pub const CC_O: u8 = 0x00
pub const CC_NO: u8 = 0x01
pub const CC_B: u8 = 0x02
pub const CC_AE: u8 = 0x03
pub const CC_E: u8 = 0x04
pub const CC_NE: u8 = 0x05
pub const CC_BE: u8 = 0x06
pub const CC_A: u8 = 0x07
pub const CC_S: u8 = 0x08
pub const CC_NS: u8 = 0x09
pub const CC_PE: u8 = 0x0A
pub const CC_PO: u8 = 0x0B
pub const CC_L: u8 = 0x0C
pub const CC_GE: u8 = 0x0D
pub const CC_LE: u8 = 0x0E
pub const CC_G: u8 = 0x0F

pub fn cond_code_to_str(cc: u8) -> str:
    if cc == CC_O:
        return "o"
    if cc == CC_NO:
        return "no"
    if cc == CC_B:
        return "b"
    if cc == CC_AE:
        return "ae"
    if cc == CC_E:
        return "e"
    if cc == CC_NE:
        return "ne"
    if cc == CC_BE:
        return "be"
    if cc == CC_A:
        return "a"
    if cc == CC_S:
        return "s"
    if cc == CC_NS:
        return "ns"
    if cc == CC_PE:
        return "pe"
    if cc == CC_PO:
        return "po"
    if cc == CC_L:
        return "l"
    if cc == CC_GE:
        return "ge"
    if cc == CC_LE:
        return "le"
    if cc == CC_G:
        return "g"
    return "??"

pub struct MachOperand:
    pub kind: u8
    pub phys: u8
    pub padding: u16
    pub vreg: u32
    pub label: u32
    pub imm: i64

pub struct MachInst:
    pub op: u16
    pub cc: u8
    pub padding: u8
    pub dst: MachOperand
    pub src1: MachOperand
    pub src2: MachOperand

pub struct MachInstVec:
    pub data: ptr[MachInst]
    pub len: i64
    pub cap: i64

pub fn new_mach_inst_vec() -> MachInstVec:
    return MachInstVec(data: null as ptr[MachInst], len: 0, cap: 0)

pub fn push(mut self: MachInstVec, inst: MachInst) -> u32:
    if self.len == self.cap:
        mut new_cap := 16 as i64
        if self.cap != 0:
            new_cap = self.cap * 2
        let new_data = @alloc(new_cap * 80) as ptr[MachInst]
        if self.data != null as ptr[MachInst]:
            @memcpy(new_data as ptr[u8], self.data as ptr[u8], self.len * 80)
            @free(self.data as ptr[u8])
        self.data = new_data
        self.cap = new_cap
    let idx = self.len as u32
    self.data[self.len] = inst
    self.len = self.len + 1
    return idx

pub fn type_size_and_align(table: ptr[TypeTable], type_id: u32, out_size: ptr[u32], out_align: ptr[u32]):
    if type_id == 0 as u32:
        out_size[0] = 8 as u32
        out_align[0] = 8 as u32
        return

    mut entry := &table.entries.data[type_id]
    if entry.size != 0 as u32:
        out_size[0] = entry.size
        out_align[0] = entry.align
        return

    if entry.kind == TYPE_KIND_PRIMITIVE:
        out_size[0] = entry.size
        out_align[0] = entry.align
        return
    elif entry.kind == TYPE_KIND_STRUCT:
        let struct_idx = entry.extra
        let info = table.structs.data[struct_idx]
        mut offset := 0 as u32
        mut max_align := 1 as u32
        mut i := 0 as i64
        while i < info.fields.len:
            let f = info.fields.data[i]
            mut f_size := 0 as u32
            mut f_align := 0 as u32
            type_size_and_align(table, f.type_id, &f_size, &f_align)
            if f_align == 0 as u32:
                f_align = 8 as u32
            // Align offset
            offset = (offset + f_align - 1 as u32) & ~(f_align - 1 as u32)
            offset = offset + f_size
            if f_align > max_align:
                max_align = f_align
            i = i + 1
        
        mut size := (offset + max_align - 1 as u32) & ~(max_align - 1 as u32)
        if size == 0 as u32:
            size = 8 as u32
        entry.size = size
        entry.align = max_align
        out_size[0] = size
        out_align[0] = max_align
    elif entry.kind == TYPE_KIND_ARRAY:
        let elem_id = entry.extra
        let length = entry.name_id
        mut elem_size := 0 as u32
        mut elem_align := 0 as u32
        type_size_and_align(table, elem_id, &elem_size, &elem_align)
        if elem_align == 0 as u32:
            elem_align = 8 as u32
        let size = length * elem_size
        entry.size = size
        entry.align = elem_align
        out_size[0] = size
        out_align[0] = elem_align
    else:
        out_size[0] = 8 as u32
        out_align[0] = 8 as u32

pub fn field_offset(table: ptr[TypeTable], struct_type_id: u32, field_idx: u32) -> u32:
    if struct_type_id == 0 as u32:
        return field_idx * 8 as u32
    ax_printf_local("[Debug field_offset] struct_type_id=%d, table.entries.len=%d\n", struct_type_id as i64, table.entries.len as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    fflush(null as ptr[void])
    mut real_type_id := struct_type_id
    mut entry = table.entries.data[real_type_id]
    if entry.kind == 9 as u8: // TYPE_KIND_POINTER = 9
        real_type_id = entry.extra
        entry = table.entries.data[real_type_id]
    ax_printf_local("[field_offset] struct_type_id=%d, entry.kind=%d, entry.extra=%d, entry.size=%d\n", real_type_id as i64, entry.kind as i64, entry.extra as i64, entry.size as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    fflush(null as ptr[void])
    if entry.kind != 1 as u8: // TYPE_KIND_STRUCT = 1
        return field_idx * 8 as u32
    
    let struct_idx = entry.extra
    let info = table.structs.data[struct_idx]
    ax_printf_local("[field_offset] info.fields.len=%d, info.fields.data=%x\n", info.fields.len as i64, (info.fields.data as i64) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    fflush(null as ptr[void])
    mut offset := 0 as u32
    mut i := 0 as i64
    while i < info.fields.len:
        let f = info.fields.data[i]
        mut f_size := 0 as u32
        mut f_align := 0 as u32
        type_size_and_align(table, f.type_id, &f_size, &f_align)
        if f_align == 0 as u32:
            f_align = 8 as u32
        // Align offset
        offset = (offset + f_align - 1 as u32) & ~(f_align - 1 as u32)
        ax_printf_local("[field_offset]   field %d: name_id=%d, type_id=%d, f_size=%d, f_align=%d, aligned_offset=%d\n", i as i64, f.name_id as i64, f.type_id as i64, f_size as i64, f_align as i64, offset as i64, 0 as i64, 0 as i64)
        fflush(null as ptr[void])
        if i as u32 == field_idx:
            return offset
        offset = offset + f_size
        i = i + 1
    return field_idx * 8 as u32

pub fn field_size(table: ptr[TypeTable], struct_type_id: u32, field_idx: u32) -> u32:
    if struct_type_id == 0 as u32:
        return 8 as u32
    ax_printf_local("[Debug field_size] struct_type_id=%d, table.entries.len=%d\n", struct_type_id as i64, table.entries.len as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    fflush(null as ptr[void])
    mut real_type_id := struct_type_id
    mut entry = table.entries.data[real_type_id]
    if entry.kind == 9 as u8: // TYPE_KIND_POINTER = 9
        real_type_id = entry.extra
        entry = table.entries.data[real_type_id]
    if entry.kind != 1 as u8: // TYPE_KIND_STRUCT = 1
        return 8 as u32
    
    let struct_idx = entry.extra
    let info = table.structs.data[struct_idx]
    if field_idx as i64 >= info.fields.len:
        return 8 as u32
    let f = info.fields.data[field_idx]
    mut f_size := 0 as u32
    mut f_align := 0 as u32
    type_size_and_align(table, f.type_id, &f_size, &f_align)
    if f_size == 0 as u32:
        return 8 as u32
    return f_size

pub fn abi_int_arg_reg(abi: str, idx: i64) -> u8:
    if abi == "win64":
        return get_win64_arg_reg(idx)
    return get_sysv_arg_reg(idx)

pub fn abi_float_arg_reg(abi: str, idx: i64) -> u8:
    if abi == "win64":
        return get_win64_float_arg_reg(idx)
    return get_sysv_float_arg_reg(idx)

pub fn abi_return_reg(abi: str) -> u8:
    return REG_RAX

pub struct InstructionSelector:
    pub fn_ptr: ptr[AirFunc]
    pub abi_name: str
    pub table: ptr[TypeTable]
    pub param_idx_processed: i32
    pub symbols: ptr[SymbolTable]
    pub pool: ptr[InternPool]
    pub max_vreg: u32
    pub max_label: u32

pub fn next_vreg(sel: ptr[InstructionSelector]) -> u32:
    sel.max_vreg = sel.max_vreg + 1 as u32
    return sel.max_vreg

pub fn next_label(sel: ptr[InstructionSelector]) -> u32:
    sel.max_label = sel.max_label + 1 as u32
    return sel.max_label

pub fn get_register_type(sel: ptr[InstructionSelector], reg: u32) -> u32:
    if reg == 0:
        return 0 as u32
    if reg >= 1 as u32 and reg <= sel.fn_ptr.params.len as u32:
        return sel.fn_ptr.params.data[reg as i64 - 1 as i64] as u32
    mut i := 0 as i64
    while i < sel.fn_ptr.insts.len:
        let inst = &sel.fn_ptr.insts.data[i]
        if inst.dest == reg:
            if inst.opcode == OP_CALL and inst.src1 == 0 as u32:
                let sym_idx = inst.type_id as u32
                if sym_idx != 0 as u32 and (sym_idx as i64) < sel.symbols.symbols.len:
                    let sym = sel.symbols.symbols.data[sym_idx as i64]
                    if sym.kind == SYM_FUNC:
                        let func_type = sym.type_id
                        if func_type != 0 as u32 and (func_type as i64) < sel.table.entries.len:
                            let entry = sel.table.entries.data[func_type as i64]
                            if entry.kind == TYPE_KIND_FUNC:
                                let fi_idx = entry.extra
                                if (fi_idx as i64) < sel.table.funcs.len:
                                    let fi = sel.table.funcs.data[fi_idx as i64]
                                    return fi.ret
                    elif sym.kind == SYM_STRUCT:
                        return sym.type_id
                return 0 as u32
            return inst.type_id as u32
        i = i + 1
    return 0 as u32

pub fn regalloc_is_16byte(vreg: u32, fn_ptr: ptr[AirFunc], table: ptr[TypeTable], symbols: ptr[SymbolTable]) -> bool:
    if vreg == 0:
        return false
    if vreg >= 1 as u32 and vreg <= fn_ptr.params.len as u32:
        let type_id = fn_ptr.params.data[vreg as i64 - 1 as i64] as u32
        if type_id < table.entries.len as u32:
            let size = table.entries.data[type_id].size
            if size == 16 as u32:
                return true
        return false
    mut i := 0 as i64
    while i < fn_ptr.insts.len:
        let inst = &fn_ptr.insts.data[i]
        if inst.dest == vreg:
            let op = inst.opcode
            // Ignore control-flow, store, and other instructions that don't actually define a destination register
            if op != OP_BRANCH and op != OP_JUMP and op != OP_RETURN and op != OP_STORE and op != OP_SET_FIELD and op != OP_FREE and op != OP_DESTROY and op != OP_LOOP_BEGIN and op != OP_LOOP_END and op != OP_SEND:
                if op == OP_CALL:
                    if inst.src1 == 0 as u32: // Direct function call
                        let sym_idx = inst.type_id as u32
                        if symbols != null as ptr[SymbolTable] and sym_idx != 0 as u32 and (sym_idx as i64) < symbols.symbols.len:
                            let sym = &symbols.symbols.data[sym_idx as i64]
                            if sym.kind == 1 as u8 or sym.kind == 10 as u8: // SYM_FUNC or other func symbol kinds
                                let fn_type_id = sym.type_id as u32
                                if fn_type_id < table.entries.len as u32:
                                    let entry = &table.entries.data[fn_type_id]
                                    if entry.kind == 2 as u8: // TYPE_KIND_FUNC = 2
                                        let fi = &table.funcs.data[entry.extra as i64]
                                        let ret_type_id = fi.ret
                                        if ret_type_id < table.entries.len as u32:
                                            let size = table.entries.data[ret_type_id].size
                                            if size == 16 as u32:
                                                return true
                    else: // Dynamic function call
                        let type_id = inst.type_id as u32
                        if type_id < table.entries.len as u32:
                            let size = table.entries.data[type_id].size
                            if size == 16 as u32:
                                return true
                    return false
                elif op == OP_ALLOC or op == OP_ARENA_ALLOC or op == OP_SYSCALL:
                    return false
                elif op == OP_COPY or op == OP_MOVE or op == OP_CAST:
                    let type_id = inst.type_id as u32
                    if type_id < table.entries.len as u32:
                        let size = table.entries.data[type_id].size
                        if size == 16 as u32:
                            return true
                    // Recursively check src1 for type size
                    return regalloc_is_16byte(inst.src1, fn_ptr, table, symbols)
                else:
                    let type_id = inst.type_id as u32
                    if type_id < table.entries.len as u32:
                        let size = table.entries.data[type_id].size
                        if size == 16 as u32:
                            return true
                    return false
        i = i + 1
    return false


pub fn select_comparison(sel: ptr[InstructionSelector], inst: ptr[AirInst], int_cc: u8, float_cc: u8, out_insts: ptr[MachInstVec]):
    let src_type = get_register_type(sel, inst.src1)
    if src_type == 9 as u32 or src_type == 10 as u32:
        out_insts.push(MachInst(op: MACH_FCMP, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.src1, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.src2, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
        out_insts.push(MachInst(op: MACH_SETCC, cc: float_cc, padding: 0 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.dest, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
    else:
        out_insts.push(MachInst(op: MACH_CMP, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.src1, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.src2, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
        out_insts.push(MachInst(op: MACH_SETCC, cc: int_cc, padding: 0 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.dest, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
    out_insts.push(MachInst(op: MACH_MOVZX_B, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.dest, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.dest, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))

pub fn emit_block_copy_ext(sel: ptr[InstructionSelector], dst_reg: u32, dst_disp: u32, src_reg: u32, src_disp: u32, size: u32, out_insts: ptr[MachInstVec]):
    mut offset := 0 as u32
    mut remaining := size
    while remaining >= 8 as u32:
        let tmp_val = next_vreg(sel)
        out_insts.push(MachInst(op: MACH_LOAD, cc: 0 as u8, padding: 8 as u8, 
            dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_val, label: 0 as u32, imm: 0 as i64), 
            src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: src_reg, label: 0 as u32, imm: 0 as i64), 
            src2: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: (src_disp + offset) as i64)))
        out_insts.push(MachInst(op: MACH_STORE, cc: 0 as u8, padding: 8 as u8, 
            dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: dst_reg, label: 0 as u32, imm: 0 as i64), 
            src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_val, label: 0 as u32, imm: 0 as i64), 
            src2: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: (dst_disp + offset) as i64)))
        offset = offset + 8 as u32
        remaining = remaining - 8 as u32
        
    if remaining >= 4 as u32:
        let tmp_val = next_vreg(sel)
        out_insts.push(MachInst(op: MACH_LOAD, cc: 0 as u8, padding: 4 as u8, 
            dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_val, label: 0 as u32, imm: 0 as i64), 
            src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: src_reg, label: 0 as u32, imm: 0 as i64), 
            src2: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: (src_disp + offset) as i64)))
        out_insts.push(MachInst(op: MACH_STORE, cc: 0 as u8, padding: 4 as u8, 
            dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: dst_reg, label: 0 as u32, imm: 0 as i64), 
            src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_val, label: 0 as u32, imm: 0 as i64), 
            src2: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: (dst_disp + offset) as i64)))
        offset = offset + 4 as u32
        remaining = remaining - 4 as u32
        
    if remaining >= 2 as u32:
        let tmp_val = next_vreg(sel)
        out_insts.push(MachInst(op: MACH_LOAD, cc: 0 as u8, padding: 2 as u8, 
            dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_val, label: 0 as u32, imm: 0 as i64), 
            src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: src_reg, label: 0 as u32, imm: 0 as i64), 
            src2: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: (src_disp + offset) as i64)))
        out_insts.push(MachInst(op: MACH_STORE, cc: 0 as u8, padding: 2 as u8, 
            dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: dst_reg, label: 0 as u32, imm: 0 as i64), 
            src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_val, label: 0 as u32, imm: 0 as i64), 
            src2: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: (dst_disp + offset) as i64)))
        offset = offset + 2 as u32
        remaining = remaining - 2 as u32
        
    if remaining >= 1 as u32:
        let tmp_val = next_vreg(sel)
        out_insts.push(MachInst(op: MACH_LOAD, cc: 0 as u8, padding: 1 as u8, 
            dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_val, label: 0 as u32, imm: 0 as i64), 
            src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: src_reg, label: 0 as u32, imm: 0 as i64), 
            src2: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: (src_disp + offset) as i64)))
        out_insts.push(MachInst(op: MACH_STORE, cc: 0 as u8, padding: 1 as u8, 
            dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: dst_reg, label: 0 as u32, imm: 0 as i64), 
            src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_val, label: 0 as u32, imm: 0 as i64), 
            src2: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: (dst_disp + offset) as i64)))

pub fn emit_block_copy(sel: ptr[InstructionSelector], dst_reg: u32, dst_disp: u32, src_reg: u32, size: u32, out_insts: ptr[MachInstVec]):
    mut final_src_reg := src_reg
    if regalloc_is_16byte(src_reg, sel.fn_ptr, sel.table, sel.symbols):
        final_src_reg = next_vreg(sel)
        out_insts.push(MachInst(op: MACH_LEA, cc: 0 as u8, padding: 0 as u8, 
            dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: final_src_reg, label: 0 as u32, imm: 0 as i64), 
            src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: src_reg, label: 0 as u32, imm: 0 as i64), 
            src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
    emit_block_copy_ext(sel, dst_reg, dst_disp, final_src_reg, 0 as u32, size, out_insts)

pub fn select_inst(mut sel: ptr[InstructionSelector], inst: ptr[AirInst], mut out_insts: ptr[MachInstVec]):
    let op = inst.opcode
    if op == OP_NOP:
        return

    if op == OP_ICONST:
        let t_id = inst.type_id as u32
        mut is_str := (t_id == 12 as u32)
        if t_id < sel.table.entries.len as u32:
            if sel.table.entries.data[t_id].size == 16 as u32:
                is_str = true
        if inst.src1 == 0 as u32 and not is_str:
            out_insts.push(MachInst(op: MACH_XOR_ZERO, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.dest, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
        else:
            let val = inst.src1 as i64
            mut vreg_flag := 0 as u32
            if is_str:
                vreg_flag = 2 as u32
            ax_printf_local("[Debug select_inst] OP_ICONST dest=%d, type_id=%d, src1=%d, is_str=%d, vreg_flag=%d\n", inst.dest as i64, inst.type_id as i64, inst.src1 as i64, is_str as i64, vreg_flag as i64, 0 as i64, 0 as i64, 0 as i64)
            fflush(null as ptr[void])
            if is_str:
                let tmp_struct_addr = next_vreg(sel)
                out_insts.push(MachInst(op: MACH_MOV_IMM, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_struct_addr, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: vreg_flag, label: 0 as u32, imm: val), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
                let tmp_dest_addr = next_vreg(sel)
                out_insts.push(MachInst(op: MACH_LEA, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_dest_addr, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.dest, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
                emit_block_copy(sel, tmp_dest_addr, 0 as u32, tmp_struct_addr, 16 as u32, out_insts)
            else:
                out_insts.push(MachInst(op: MACH_MOV_IMM, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.dest, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: vreg_flag, label: 0 as u32, imm: val), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))



    elif op == OP_FCONST:
        let val = inst.src1 as i64
        out_insts.push(MachInst(op: MACH_MOV_IMM, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.dest, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: val), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))

    elif op == OP_COPY or op == OP_MOVE:
        if sel.param_idx_processed < sel.fn_ptr.params.len as i32 and inst.src1 == (sel.param_idx_processed + 1) as u32:
            let param_idx = sel.param_idx_processed
            sel.param_idx_processed = sel.param_idx_processed + 1
            let phys = abi_int_arg_reg(sel.abi_name, param_idx as i64)
            if phys != REG_NONE:
                let dest_type = get_register_type(sel, inst.dest)
                mut dest_size := 8 as u32
                if dest_type < sel.table.entries.len as u32:
                    dest_size = sel.table.entries.data[dest_type].size
                
                if dest_size == 16 as u32:
                    let tmp_val1 = next_vreg(sel)
                    out_insts.push(MachInst(op: MACH_LOAD, cc: 0 as u8, padding: 8 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_val1, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_PHYS, phys: phys, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
                    
                    let tmp_val2 = next_vreg(sel)
                    out_insts.push(MachInst(op: MACH_LOAD, cc: 0 as u8, padding: 8 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_val2, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_PHYS, phys: phys, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 8 as i64)))

                    let tmp_dest_addr = next_vreg(sel)
                    out_insts.push(MachInst(op: MACH_LEA, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_dest_addr, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.dest, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))

                    out_insts.push(MachInst(op: MACH_STORE, cc: 0 as u8, padding: 8 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_dest_addr, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_val1, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
                    out_insts.push(MachInst(op: MACH_STORE, cc: 0 as u8, padding: 8 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_dest_addr, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_val2, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 8 as i64)))
                else:
                    out_insts.push(MachInst(op: MACH_MOV, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.dest, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_PHYS, phys: phys, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
                return
            else:
                mut offset := 0 as i64
                if sel.abi_name == "win64":
                    offset = 48 as i64 + (param_idx as i64 - 4 as i64) * 8 as i64
                else:
                    offset = 16 as i64 + (param_idx as i64 - 6 as i64) * 8 as i64
                out_insts.push(MachInst(op: MACH_LOAD, cc: 0 as u8, padding: 8 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.dest, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_PHYS, phys: REG_RBP, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: offset)))
                return
        if regalloc_is_16byte(inst.dest, sel.fn_ptr, sel.table, sel.symbols):
            let tmp_dest_addr = next_vreg(sel)
            out_insts.push(MachInst(op: MACH_LEA, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_dest_addr, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.dest, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
            let tmp_src_addr = next_vreg(sel)
            out_insts.push(MachInst(op: MACH_LEA, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_src_addr, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.src1, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
            emit_block_copy(sel, tmp_dest_addr, 0 as u32, tmp_src_addr, 16 as u32, out_insts)
        else:
            out_insts.push(MachInst(op: MACH_MOV, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.dest, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.src1, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))


    elif op == OP_CAST:
        let t_id = inst.type_id as u32
        mut is_str := (t_id == 12 as u32)
        if t_id < sel.table.entries.len as u32:
            if sel.table.entries.data[t_id].size == 16 as u32:
                is_str = true
        if is_str:
            let tmp_len = next_vreg(sel)
            let arg0 = abi_int_arg_reg(sel.abi_name, 0)
            
            if sel.abi_name == "win64":
                out_insts.push(MachInst(op: MACH_SUB, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_PHYS, phys: REG_RSP, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 32 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
            
            out_insts.push(MachInst(op: MACH_MOV, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_PHYS, phys: arg0, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.src1, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
            out_insts.push(MachInst(op: MACH_CALL, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: -21 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
            
            if sel.abi_name == "win64":
                out_insts.push(MachInst(op: MACH_ADD, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_PHYS, phys: REG_RSP, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 32 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
                
            out_insts.push(MachInst(op: MACH_MOV, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_len, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_PHYS, phys: REG_RAX, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))

            let tmp_dest_addr = next_vreg(sel)
            out_insts.push(MachInst(op: MACH_LEA, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_dest_addr, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.dest, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
            out_insts.push(MachInst(op: MACH_STORE, cc: 0 as u8, padding: 8 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_dest_addr, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.src1, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
            out_insts.push(MachInst(op: MACH_STORE, cc: 0 as u8, padding: 8 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_dest_addr, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_len, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 8 as i64)))
        else:
