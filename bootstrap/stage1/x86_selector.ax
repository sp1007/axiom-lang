                    else:
                        mut offset := 0 as i64
                        if sel.abi_name == "win64":
                            offset = 48 as i64 + (param_idx as i64 - 4 as i64) * 8 as i64
                        else:
                            offset = 16 as i64 + (param_idx as i64 - 6 as i64) * 8 as i64
                        let tmp_addr = next_vreg(sel)
                        out_insts.push(MachInst(op: MACH_LOAD, cc: 0 as u8, padding: 8 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_addr, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_PHYS, phys: REG_RBP, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: offset)))
                        if dest_size == 16 as u32:
                            let tmp_val1 = next_vreg(sel)
