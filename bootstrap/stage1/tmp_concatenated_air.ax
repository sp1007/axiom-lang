import std.string

// bootstrap/stage1/token.ax
// Defines the 82 TokenKind constants for AXIOM.

pub const TK_INT_LIT: u8 = 0
pub const TK_FLOAT_LIT: u8 = 1
pub const TK_STRING_LIT: u8 = 2
pub const TK_CHAR_LIT: u8 = 3

pub const TK_IDENT: u8 = 4

// Keywords (alphabetical)
pub const TK_AND: u8 = 5
pub const TK_AS: u8 = 6
pub const TK_ASYNC: u8 = 7
pub const TK_AWAIT: u8 = 8
pub const TK_CONST: u8 = 9
pub const TK_DEFER: u8 = 10
pub const TK_ELIF: u8 = 11
pub const TK_ELSE: u8 = 12
pub const TK_EXTERN: u8 = 13
pub const TK_FALSE: u8 = 14
pub const TK_FN: u8 = 15
pub const TK_FOR: u8 = 16
pub const TK_FUTURE: u8 = 17
pub const TK_IF: u8 = 18
pub const TK_IMPORT: u8 = 19
pub const TK_IN: u8 = 20
pub const TK_INTERFACE: u8 = 21
pub const TK_ISOLATED: u8 = 22
pub const TK_LENT: u8 = 23
pub const TK_LET: u8 = 24
pub const TK_MATCH: u8 = 25
pub const TK_MUT: u8 = 26
pub const TK_NIL: u8 = 27
pub const TK_NOT: u8 = 28
pub const TK_OR: u8 = 29
pub const TK_PACKED: u8 = 30
pub const TK_PUB: u8 = 31
pub const TK_RETURN: u8 = 32
pub const TK_SPAWN: u8 = 33
pub const TK_STRUCT: u8 = 34
pub const TK_TRUE: u8 = 35
pub const TK_TYPE: u8 = 36
pub const TK_UNSAFE: u8 = 37
pub const TK_WHILE: u8 = 38

// Arithmetic operators
pub const TK_PLUS: u8 = 39
pub const TK_MINUS: u8 = 40
pub const TK_STAR: u8 = 41
pub const TK_SLASH: u8 = 42
pub const TK_PERCENT: u8 = 43
pub const TK_STAR_STAR: u8 = 44

// Comparison operators
pub const TK_EQ_EQ: u8 = 45
pub const TK_BANG_EQ: u8 = 46
pub const TK_LT: u8 = 47
pub const TK_GT: u8 = 48
pub const TK_LT_EQ: u8 = 49
pub const TK_GT_EQ: u8 = 50

// Bitwise operators
pub const TK_AMP: u8 = 51
pub const TK_PIPE: u8 = 52
pub const TK_CARET: u8 = 53
pub const TK_TILDE: u8 = 54
pub const TK_LT_LT: u8 = 55
pub const TK_GT_GT: u8 = 56

// Assignment operators
pub const TK_EQ: u8 = 57
pub const TK_COLON_EQ: u8 = 58
pub const TK_PLUS_EQ: u8 = 59
pub const TK_MINUS_EQ: u8 = 60
pub const TK_STAR_EQ: u8 = 61
pub const TK_SLASH_EQ: u8 = 62
pub const TK_PERCENT_EQ: u8 = 63

// Punctuation
pub const TK_DOT: u8 = 64
pub const TK_DOT_STAR: u8 = 65
pub const TK_COMMA: u8 = 66
pub const TK_COLON: u8 = 67
pub const TK_SEMICOLON: u8 = 68
pub const TK_ARROW: u8 = 69
pub const TK_BANG: u8 = 70
pub const TK_L_PAREN: u8 = 71
pub const TK_R_PAREN: u8 = 72
pub const TK_L_BRACKET: u8 = 73
pub const TK_R_BRACKET: u8 = 74
pub const TK_L_BRACE: u8 = 75
pub const TK_R_BRACE: u8 = 76

// Indentation/structure tokens (synthesized by post-processor)
pub const TK_INDENT: u8 = 77
pub const TK_DEDENT: u8 = 78
pub const TK_NEWLINE: u8 = 79

// Control tokens
pub const TK_EOF: u8 = 80
pub const TK_ERROR: u8 = 81
pub const TK_DOT_DOT: u8 = 82
pub const TK_HASH: u8 = 83


pub struct Token:
    kind: u8
    padding: u8
    len: u16
    offset: u32

// bootstrap/stage1/lexer.ax
// AXIOM Lexer written in AXIOM itself.


// Custom monomorphic token vector to avoid generic monomorphization dependency
pub struct TokenVec:
    data: ptr[Token]
    len: i64
    cap: i64

pub fn new_token_vec() -> TokenVec:
    return TokenVec(data: null as ptr[Token], len: 0, cap: 0)

pub fn push(mut self: TokenVec, t: Token):
    if self.len == self.cap:
        mut new_cap := 16 as i64
        if self.cap != 0:
            new_cap = self.cap * 2
        let new_data = @alloc(new_cap * 8) as ptr[Token] // Token size is 8 bytes
        if self.data != null as ptr[Token]:
            @memcpy(new_data as ptr[u8], self.data as ptr[u8], self.len * 8)
            @free(self.data as ptr[u8])
        self.data = new_data
        self.cap = new_cap
    self.data[self.len] = t
    self.len = self.len + 1

// Custom monomorphic integer vector for indent/newline tracking
pub struct IntVec:
    data: ptr[i32]
    len: i64
    cap: i64

pub fn new_int_vec() -> IntVec:
    return IntVec(data: null as ptr[i32], len: 0, cap: 0)

pub fn push(mut self: IntVec, val: i32):
    if self.len == self.cap:
        mut new_cap := 16 as i64
        if self.cap != 0:
            new_cap = self.cap * 2
        let new_data = @alloc(new_cap * 4) as ptr[i32] // i32 size is 4 bytes
        if self.data != null as ptr[i32]:
            @memcpy(new_data as ptr[u8], self.data as ptr[u8], self.len * 4)
            @free(self.data as ptr[u8])
        self.data = new_data
        self.cap = new_cap
    self.data[self.len] = val
    self.len = self.len + 1

pub fn pop(mut self: IntVec) -> i32:
    if self.len == 0:
        return 0
    self.len = self.len - 1
    return self.data[self.len]

pub fn top(self: IntVec) -> i32:
    if self.len == 0:
        return 0
    return self.data[self.len - 1]

// The Lexer struct
pub struct Lexer:
    src: str
    len: i64
    pos: i64
    tokens: TokenVec
    indent_stack: IntVec
    newline_offsets: IntVec

pub fn new_lexer(src: str) -> Lexer:
    mut indent_stack := new_int_vec()
    indent_stack.push(0) // base indentation level is 0
    return Lexer(
        src: src,
        len: std.string.len(src),
        pos: 0,
        tokens: new_token_vec(),
        indent_stack: indent_stack,
        newline_offsets: new_int_vec(),
    )

pub fn peek1(self: Lexer) -> u8:
    if self.pos + 1 < self.len:
        return self.src[self.pos + 1] as u8
    return 0 as u8

pub fn emit(mut self: Lexer, kind: u8, offset: i64, length: i64):
    self.tokens.push(Token(
        kind: kind,
        padding: 0 as u8,
        len: length as u16,
        offset: offset as u32,
    ))

fn lookup_keyword(s: str) -> u8:
    if s == "and":
        return TK_AND
    if s == "as":
        return TK_AS
    if s == "async":
        return TK_ASYNC
    if s == "await":
        return TK_AWAIT
    if s == "const":
        return TK_CONST
    if s == "defer":
        return TK_DEFER
    if s == "elif":
        return TK_ELIF
    if s == "else":
        return TK_ELSE
    if s == "extern":
        return TK_EXTERN
    if s == "false":
        return TK_FALSE
    if s == "fn":
        return TK_FN
    if s == "for":
        return TK_FOR
    if s == "Future":
        return TK_FUTURE
    if s == "if":
        return TK_IF
    if s == "import":
        return TK_IMPORT
    if s == "in":
        return TK_IN
    if s == "interface":
        return TK_INTERFACE
    if s == "Isolated":
        return TK_ISOLATED
    if s == "lent":
        return TK_LENT
    if s == "let":
        return TK_LET
    if s == "match":
        return TK_MATCH
    if s == "mut":
        return TK_MUT
    if s == "nil":
        return TK_NIL
    if s == "not":
        return TK_NOT
    if s == "or":
        return TK_OR
    if s == "packed":
        return TK_PACKED
    if s == "pub":
        return TK_PUB
    if s == "return":
        return TK_RETURN
    if s == "spawn":
        return TK_SPAWN
    if s == "struct":
        return TK_STRUCT
    if s == "true":
        return TK_TRUE
    if s == "type":
        return TK_TYPE
    if s == "unsafe":
        return TK_UNSAFE
    if s == "while":
        return TK_WHILE
    return TK_IDENT

fn is_ident_start(b: u8) -> bool:
    return (b >= 97 and b <= 122) or (b >= 65 and b <= 90) or b == 95

fn is_ident_continue(b: u8) -> bool:
    return is_ident_start(b) or (b >= 48 and b <= 57)

pub fn scan_ident(mut self: Lexer):
    let start = self.pos
    self.pos = self.pos + 1
    while self.pos < self.len:
        let b = self.src[self.pos] as u8
        if is_ident_continue(b):
            self.pos = self.pos + 1
        else:
            break
    let text = std.string.slice(self.src, start, self.pos)
    let kind = lookup_keyword(text)
    self.emit(kind, start, self.pos - start)

fn is_dec_digit(b: u8) -> bool:
    return b >= 48 and b <= 57

fn is_hex_digit(b: u8) -> bool:
    return is_dec_digit(b) or (b >= 97 and b <= 102) or (b >= 65 and b <= 70)

fn is_oct_digit(b: u8) -> bool:
    return b >= 48 and b <= 55

fn is_bin_digit(b: u8) -> bool:
    return b == 48 or b == 49

pub fn scan_dec_digits(mut self: Lexer):
    while self.pos < self.len:
        let b = self.src[self.pos] as u8
        if is_dec_digit(b) or b == 95:
            self.pos = self.pos + 1
        else:
            break

pub fn scan_hex_digits(mut self: Lexer):
    while self.pos < self.len:
        let b = self.src[self.pos] as u8
        if is_hex_digit(b) or b == 95:
            self.pos = self.pos + 1
        else:
            break

pub fn scan_oct_digits(mut self: Lexer):
    while self.pos < self.len:
        let b = self.src[self.pos] as u8
        if is_oct_digit(b) or b == 95:
            self.pos = self.pos + 1
        else:
            break

pub fn scan_bin_digits(mut self: Lexer):
    while self.pos < self.len:
        let b = self.src[self.pos] as u8
        if is_bin_digit(b) or b == 95:
            self.pos = self.pos + 1
        else:
            break

pub fn scan_number(mut self: Lexer):
    let start = self.pos
    let b = self.src[self.pos] as u8

    if b == 48 and self.pos + 1 < self.len: // '0'
        let next = self.src[self.pos + 1] as u8
        if next == 120 or next == 88: // 'x', 'X'
            self.pos = self.pos + 2
            self.scan_hex_digits()
            self.emit(TK_INT_LIT, start, self.pos - start)
            return
        elif next == 111 or next == 79: // 'o', 'O'
            self.pos = self.pos + 2
            self.scan_oct_digits()
            self.emit(TK_INT_LIT, start, self.pos - start)
            return
        elif next == 98 or next == 66: // 'b', 'B'
            self.pos = self.pos + 2
            self.scan_bin_digits()
            self.emit(TK_INT_LIT, start, self.pos - start)
            return

    self.scan_dec_digits()

    // Check for float: decimal point followed by digit
    if self.pos < self.len and self.src[self.pos] as u8 == 46: // '.'
        if self.pos + 1 < self.len:
            let next = self.src[self.pos + 1] as u8
            if is_dec_digit(next):
                self.pos = self.pos + 1 // consume '.'
                self.scan_dec_digits()
                // Optional exponent
                if self.pos < self.len:
                    let exp = self.src[self.pos] as u8
                    if exp == 101 or exp == 69: // 'e', 'E'
                        self.pos = self.pos + 1
                        if self.pos < self.len:
                            let sign = self.src[self.pos] as u8
                            if sign == 43 or sign == 45: // '+', '-'
                                self.pos = self.pos + 1
                        self.scan_dec_digits()
                self.emit(TK_FLOAT_LIT, start, self.pos - start)
                return

    self.emit(TK_INT_LIT, start, self.pos - start)

pub fn scan_string(mut self: Lexer):
    let start = self.pos
    self.pos = self.pos + 1 // skip opening '"'
    while self.pos < self.len:
        let b = self.src[self.pos] as u8
        if b == 34: // '"'
            self.pos = self.pos + 1 // skip closing '"'
            self.emit(TK_STRING_LIT, start, self.pos - start)
            return
        if b == 92: // '\'
            self.pos = self.pos + 1 // skip backslash
            if self.pos < self.len:
                self.pos = self.pos + 1 // skip escaped char
            continue
        if b == 10: // '\n'
            // Unterminated string
            self.emit(TK_STRING_LIT, start, self.pos - start)
            return
        self.pos = self.pos + 1

    self.emit(TK_STRING_LIT, start, self.pos - start)

pub fn scan_char(mut self: Lexer):
    let start = self.pos
    self.pos = self.pos + 1 // skip opening '\''
    if self.pos < self.len:
        let b = self.src[self.pos] as u8
        if b == 92: // '\'
            self.pos = self.pos + 1 // skip backslash
            if self.pos < self.len:
                self.pos = self.pos + 1 // skip escaped char
        elif b != 39: // '\''
            self.pos = self.pos + 1

    if self.pos < self.len and self.src[self.pos] as u8 == 39:
        self.pos = self.pos + 1
    self.emit(TK_CHAR_LIT, start, self.pos - start)

pub fn scan_line_comment(mut self: Lexer):
    self.pos = self.pos + 2 // skip //
    while self.pos < self.len and self.src[self.pos] as u8 != 10: // '\n'
        self.pos = self.pos + 1

pub fn scan_operator_or_punct(mut self: Lexer):
    let start = self.pos
    let b = self.src[self.pos] as u8

    if self.pos + 1 < self.len:
        let next = self.src[self.pos + 1] as u8
        if b == 61 and next == 61:
            self.pos = self.pos + 2
            self.emit(TK_EQ_EQ, start, 2)
            return
        if b == 33 and next == 61:
            self.pos = self.pos + 2
            self.emit(TK_BANG_EQ, start, 2)
            return
        if b == 60 and next == 61:
            self.pos = self.pos + 2
            self.emit(TK_LT_EQ, start, 2)
            return
        if b == 62 and next == 61:
            self.pos = self.pos + 2
            self.emit(TK_GT_EQ, start, 2)
            return
        if b == 42 and next == 42:
            self.pos = self.pos + 2
            self.emit(TK_STAR_STAR, start, 2)
            return
        if b == 60 and next == 60:
            self.pos = self.pos + 2
            self.emit(TK_LT_LT, start, 2)
            return
        if b == 62 and next == 62:
            self.pos = self.pos + 2
            self.emit(TK_GT_GT, start, 2)
            return
        if b == 45 and next == 62:
            self.pos = self.pos + 2
            self.emit(TK_ARROW, start, 2)
            return
        if b == 58 and next == 61:
            self.pos = self.pos + 2
            self.emit(TK_COLON_EQ, start, 2)
            return
        if b == 43 and next == 61:
            self.pos = self.pos + 2
            self.emit(TK_PLUS_EQ, start, 2)
            return
        if b == 45 and next == 61:
            self.pos = self.pos + 2
            self.emit(TK_MINUS_EQ, start, 2)
            return
        if b == 42 and next == 61:
            self.pos = self.pos + 2
            self.emit(TK_STAR_EQ, start, 2)
            return
        if b == 47 and next == 61:
            self.pos = self.pos + 2
            self.emit(TK_SLASH_EQ, start, 2)
            return
        if b == 37 and next == 61:
            self.pos = self.pos + 2
            self.emit(TK_PERCENT_EQ, start, 2)
            return
        if b == 46 and next == 42:
            self.pos = self.pos + 2
            self.emit(TK_DOT_STAR, start, 2)
            return
        if b == 46 and next == 46:
            self.pos = self.pos + 2
            self.emit(TK_DOT_DOT, start, 2)
            return

    if b == 43: // '+'
        self.pos = self.pos + 1
        self.emit(TK_PLUS, start, 1)
        return
    if b == 45: // '-'
        self.pos = self.pos + 1
        self.emit(TK_MINUS, start, 1)
        return
    if b == 42: // '*'
        self.pos = self.pos + 1
        self.emit(TK_STAR, start, 1)
        return
    if b == 47: // '/'
        self.pos = self.pos + 1
        self.emit(TK_SLASH, start, 1)
        return
    if b == 37: // '%'
        self.pos = self.pos + 1
        self.emit(TK_PERCENT, start, 1)
        return
    if b == 61: // '='
        self.pos = self.pos + 1
        self.emit(TK_EQ, start, 1)
        return
    if b == 60: // '<'
        self.pos = self.pos + 1
        self.emit(TK_LT, start, 1)
        return
    if b == 62: // '>'
        self.pos = self.pos + 1
        self.emit(TK_GT, start, 1)
        return
    if b == 38: // '&'
        self.pos = self.pos + 1
        self.emit(TK_AMP, start, 1)
        return
    if b == 124: // '|'
        self.pos = self.pos + 1
        self.emit(TK_PIPE, start, 1)
        return
    if b == 94: // '^'
        self.pos = self.pos + 1
        self.emit(TK_CARET, start, 1)
        return
    if b == 126: // '~'
        self.pos = self.pos + 1
        self.emit(TK_TILDE, start, 1)
        return
    if b == 46: // '.'
        self.pos = self.pos + 1
        self.emit(TK_DOT, start, 1)
        return
    if b == 44: // ','
        self.pos = self.pos + 1
        self.emit(TK_COMMA, start, 1)
        return
    if b == 58: // ':'
        self.pos = self.pos + 1
        self.emit(TK_COLON, start, 1)
        return
    if b == 59: // ';'
        self.pos = self.pos + 1
        self.emit(TK_SEMICOLON, start, 1)
        return
    if b == 33: // '!'
        self.pos = self.pos + 1
        self.emit(TK_BANG, start, 1)
        return
    if b == 40: // '('
        self.pos = self.pos + 1
        self.emit(TK_L_PAREN, start, 1)
        return
    if b == 41: // ')'
        self.pos = self.pos + 1
        self.emit(TK_R_PAREN, start, 1)
        return
    if b == 91: // '['
        self.pos = self.pos + 1
        self.emit(TK_L_BRACKET, start, 1)
        return
    if b == 93: // ']'
        self.pos = self.pos + 1
        self.emit(TK_R_BRACKET, start, 1)
        return
    if b == 123: // '{'
        self.pos = self.pos + 1
        self.emit(TK_L_BRACE, start, 1)
        return
    if b == 125: // '}'
        self.pos = self.pos + 1
        self.emit(TK_R_BRACE, start, 1)
        return
    if b == 35: // '#'
        self.pos = self.pos + 1
        self.emit(TK_HASH, start, 1)
        return


    self.pos = self.pos + 1
    self.emit(TK_ERROR, start, 1)

pub fn run(mut self: Lexer):
    while self.pos < self.len:
        let b = self.src[self.pos] as u8
        if b == 32 or b == 13: // ' ' or '\r'
            self.pos = self.pos + 1
        elif b == 64: // '@'
            if self.pos + 1 < self.len and is_ident_start(self.src[self.pos+1] as u8):
                self.pos = self.pos + 1
            else:
                self.scan_operator_or_punct()
        elif b == 9: // '\t'
            self.pos = self.pos + 1
        elif b == 10: // '\n'
            let offset = self.pos
            self.newline_offsets.push(offset as i32)
            self.emit(TK_NEWLINE, offset, 1)
            self.pos = self.pos + 1
        elif b == 47 and self.peek1() == 47: // '//'
            self.scan_line_comment()
        elif b >= 48 and b <= 57: // '0'..'9'
            self.scan_number()
        elif b == 34: // '"'
            self.scan_string()
        elif b == 39: // '\''
            self.scan_char()
        elif is_ident_start(b):
            self.scan_ident()
        else:
            self.scan_operator_or_punct()

    self.emit(TK_EOF, self.pos, 0)

fn find_line_start(src: str, pos: i64) -> i64:
    mut i := pos - 1
    while i >= 0:
        if src[i] as u8 == 10: // '\n'
            return i + 1
        i = i - 1
    return 0

pub fn find_next_content_offset(self: Lexer, start_idx: i64) -> i64:
    mut j := start_idx
    while j < self.tokens.len:
        let tok = self.tokens.data[j]
        if tok.kind == TK_NEWLINE:
            j = j + 1
            continue
        if tok.kind == TK_EOF:
            return -1
        let line_start = find_line_start(self.src, tok.offset as i64)
        return line_start
    return -1

fn count_leading_spaces(src: str, offset: i64, len: i64) -> i64:
    mut count := 0
    mut i := offset
    while i < len:
        if src[i] as u8 == 32: // ' '
            count = count + 1
        else:
            break
        i = i + 1
    return count

pub fn process_indentation(mut self: Lexer) -> TokenVec:
    mut out := new_token_vec()
    mut stack := new_int_vec()
    stack.push(0)

    mut nesting_depth := 0
    mut i := 0
    while i < self.tokens.len:
        let tok = self.tokens.data[i]

        if tok.kind == TK_L_PAREN or tok.kind == TK_L_BRACKET or tok.kind == TK_L_BRACE:
            nesting_depth = nesting_depth + 1
        elif tok.kind == TK_R_PAREN or tok.kind == TK_R_BRACKET or tok.kind == TK_R_BRACE:
            nesting_depth = nesting_depth - 1
            if nesting_depth < 0:
                nesting_depth = 0

        if tok.kind != TK_NEWLINE:
            if tok.kind == TK_EOF:
                while stack.top() > 0:
                    out.push(Token(kind: TK_DEDENT, padding: 0 as u8, len: 0 as u16, offset: tok.offset))
                    stack.pop()
                out.push(tok)
                i = i + 1
                continue
            out.push(tok)
            i = i + 1
            continue

        if nesting_depth > 0:
            i = i + 1
            continue

        let next_start = self.find_next_content_offset(i + 1)
        if next_start < 0:
            out.push(tok)
            i = i + 1
            continue

        let next_indent = count_leading_spaces(self.src, next_start, self.len)
        let current_indent = stack.top()

        if next_indent > current_indent:
            stack.push(next_indent as i32)
            out.push(tok) // keep NEWLINE
            out.push(Token(kind: TK_INDENT, padding: 0 as u8, len: 0 as u16, offset: tok.offset))
        elif next_indent < current_indent:
            out.push(tok) // keep NEWLINE
            while stack.top() > next_indent as i32:
                out.push(Token(kind: TK_DEDENT, padding: 0 as u8, len: 0 as u16, offset: tok.offset))
                stack.pop()
        else:
            out.push(tok)

        i = i + 1

    if stack.data != null as ptr[i32]:
        @free(stack.data as ptr[u8])

    return out

pub fn tokenize(mut self: Lexer) -> TokenVec:
    self.run()
    let processed = self.process_indentation()
    return processed
// bootstrap/stage1/ast.ax
// AST structure definitions for the self-hosted AXIOM compiler frontend.

// NodeKind enum constants (matching compiler/ast/node.go exactly)
pub const NODE_INVALID: u8 = 0
pub const NODE_PROGRAM: u8 = 1
pub const NODE_FUNC_DECL: u8 = 2
pub const NODE_STRUCT_DECL: u8 = 3
pub const NODE_INTERFACE_DECL: u8 = 4
pub const NODE_IMPORT_DECL: u8 = 5
pub const NODE_CONST_DECL: u8 = 6
pub const NODE_TYPE_ALIAS_DECL: u8 = 7

pub const NODE_PARAM_DECL: u8 = 8
pub const NODE_FIELD_DECL: u8 = 9
pub const NODE_METHOD_SIG: u8 = 10
pub const NODE_VARIANT_DECL: u8 = 11

pub const NODE_BLOCK: u8 = 12
pub const NODE_VAR_DECL: u8 = 13
pub const NODE_ASSIGN_STMT: u8 = 14
pub const NODE_RETURN_STMT: u8 = 15
pub const NODE_IF_STMT: u8 = 16
pub const NODE_ELIF_CLAUSE: u8 = 17
pub const NODE_ELSE_CLAUSE: u8 = 18
pub const NODE_FOR_STMT: u8 = 19
pub const NODE_WHILE_STMT: u8 = 20
pub const NODE_MATCH_STMT: u8 = 21
pub const NODE_MATCH_ARM: u8 = 22
pub const NODE_DEFER_STMT: u8 = 23
pub const NODE_UNSAFE_BLOCK: u8 = 24
pub const NODE_ARENA_BLOCK: u8 = 25

pub const NODE_BINARY_EXPR: u8 = 26
pub const NODE_UNARY_EXPR: u8 = 27
pub const NODE_CALL_EXPR: u8 = 28
pub const NODE_INDEX_EXPR: u8 = 29
pub const NODE_FIELD_EXPR: u8 = 30
pub const NODE_CAST_EXPR: u8 = 31
pub const NODE_DEREF_EXPR: u8 = 32
pub const NODE_SPAWN_EXPR: u8 = 33
pub const NODE_AWAIT_EXPR: u8 = 34
pub const NODE_CLOSURE_EXPR: u8 = 35

pub const NODE_INT_LIT: u8 = 36
pub const NODE_FLOAT_LIT: u8 = 37
pub const NODE_STRING_LIT: u8 = 38
pub const NODE_CHAR_LIT: u8 = 39
pub const NODE_BOOL_LIT: u8 = 40
pub const NODE_NIL_LIT: u8 = 41
pub const NODE_IDENT: u8 = 42
pub const NODE_ARRAY_LIT: u8 = 43
pub const NODE_STRUCT_LIT: u8 = 44
pub const NODE_NAMED_ARG: u8 = 45

pub const NODE_TYPE_EXPR: u8 = 46
pub const NODE_PTR_TYPE: u8 = 47
pub const NODE_SLICE_TYPE: u8 = 48
pub const NODE_ARRAY_TYPE: u8 = 49
pub const NODE_FUNC_TYPE: u8 = 50
pub const NODE_GENERIC_TYPE: u8 = 51
pub const NODE_ISOLATED_TYPE: u8 = 52
pub const NODE_FUTURE_TYPE: u8 = 53
pub const NODE_SUM_TYPE: u8 = 54

pub const NODE_WILDCARD_PAT: u8 = 55
pub const NODE_LITERAL_PAT: u8 = 56
pub const NODE_BINDING_PAT: u8 = 57
pub const NODE_VARIANT_PAT: u8 = 58
pub const NODE_TUPLE_PAT: u8 = 59

pub const NODE_GENERIC_PARAMS: u8 = 60
pub const NODE_GENERIC_PARAM: u8 = 61

pub const NODE_EFFECT_ANNOTATION: u8 = 62
pub const NODE_ERROR: u8 = 63

pub const NODE_DESTROY_STMT: u8 = 64
pub const NODE_ALIAS_STMT: u8 = 65
pub const NODE_COMPTIME: u8 = 66


// Flags constants (matching compiler/ast/node.go exactly)
pub const FLAG_IS_PUB: u16 = 1
pub const FLAG_IS_MUT: u16 = 2
pub const FLAG_IS_ASYNC: u16 = 4
pub const FLAG_IS_EXTERN: u16 = 8
pub const FLAG_IS_SINK: u16 = 16
pub const FLAG_IS_LENT: u16 = 32
pub const FLAG_IS_PACKED: u64 = 64
pub const FLAG_ESCAPES_TO_HEAP: u16 = 128
pub const FLAG_USES_ARENA: u16 = 256
pub const FLAG_IS_GENERIC: u16 = 512
pub const FLAG_IS_MOVED: u16 = 1024

pub const NULL_IDX: u32 = 0

// Flat AST node. Exactly 24 bytes.
pub struct AstNode:
    kind: u8
    padding: u8
    flags: u16
    token_idx: u32
    first_child: u32
    next_sibling: u32
    payload: u32
    extra_idx: u32

// Custom monomorphic node vector to avoid generic monomorphization dependency
pub struct NodeVec:
    data: ptr[AstNode]
    len: i64
    cap: i64

pub fn new_node_vec() -> NodeVec:
    return NodeVec(data: null as ptr[AstNode], len: 0, cap: 0)

pub fn push(mut self: NodeVec, node: AstNode) -> u32:
    if self.len == self.cap:
        mut new_cap := 16 as i64
        if self.cap != 0:
            new_cap = self.cap * 2
        let new_data = @alloc(new_cap * 24) as ptr[AstNode] // Node size is 24 bytes
        if self.data != null as ptr[AstNode]:
            @memcpy(new_data as ptr[u8], self.data as ptr[u8], self.len * 24)
            @free(self.data as ptr[u8])
        self.data = new_data
        self.cap = new_cap
    let idx = self.len as u32
    self.data[self.len] = node
    self.len = self.len + 1
    return idx

// AstTree holds the parsed compilation unit.
pub struct AstTree:
    nodes: NodeVec
    extras: IntVec // Custom monomorphic IntVec used from lexer.ax
    src: str
    tokens: TokenVec

pub fn new_ast_tree(src: str, tokens: TokenVec) -> AstTree:
    mut nodes := new_node_vec()
    // Append root program node at index 0
    nodes.push(AstNode(
        kind: NODE_PROGRAM,
        padding: 0 as u8,
        flags: 0 as u16,
        token_idx: 0 as u32,
        first_child: NULL_IDX,
        next_sibling: NULL_IDX,
        payload: 0 as u32,
        extra_idx: 0 as u32,
    ))
    return AstTree(
        nodes: nodes,
        extras: new_int_vec(),
        src: src,
        tokens: tokens,
    )

pub fn add_node(mut self: AstTree, kind: u8, token_idx: u32) -> u32:
    return self.nodes.push(AstNode(
        kind: kind,
        padding: 0 as u8,
        flags: 0 as u16,
        token_idx: token_idx,
        first_child: NULL_IDX,
        next_sibling: NULL_IDX,
        payload: 0 as u32,
        extra_idx: 0 as u32,
    ))

pub fn add_extra(mut self: AstTree, val: i32) -> u32:
    let idx = self.extras.len as u32
    self.extras.push(val)
    return idx
// bootstrap/stage1/intern.ax
// Open-addressing string interning pool for AXIOM compiler frontend.

pub struct InternEntry:
    hash: u32
    padding: u32
    start: u32
    len: u32
    id: u32
    dummy: u32

pub fn fnv1a(s: str) -> u32:
    mut h := 2166136261 as u32
    let length = std.string.len(s)
    mut i := 0
    while i < length:
        h = h ^ (s[i] as u32)
        h = h * 16777619 as u32
        i = i + 1
    return h

pub struct InternPool:
    arena: ptr[u8]
    arena_len: i64
    arena_cap: i64
    table: ptr[InternEntry]
    table_size: i64 // power of 2
    ids: ptr[InternEntry]
    count: i64

pub fn new_intern_pool() -> InternPool:
    let table_size = 512 as i64
    let table = @alloc(table_size * 24) as ptr[InternEntry] // InternEntry size is 24 bytes
    mut i := 0
    while i < table_size:
        table[i] = InternEntry(hash: 0 as u32, padding: 0 as u32, start: 0 as u32, len: 0 as u32, id: 0 as u32, dummy: 0 as u32)
        i = i + 1
    let ids = @alloc(256 * 24) as ptr[InternEntry]
    return InternPool(
        arena: null as ptr[u8],
        arena_len: 0,
        arena_cap: 0,
        table: table,
        table_size: table_size,
        ids: ids,
        count: 0,
    )

fn alloc_str_from_raw(data: ptr[u8], len: i64) -> str:
    // Raw copy to string representation
    let buf = @alloc(len + 1) as ptr[u8]
    @memcpy(buf, data, len)
    buf[len] = 0 as u8
    return buf as str

pub fn get_str(self: InternPool, id: u32) -> str:
    if id == 0 as u32 or id > self.count as u32:
        return ""
    let entry = self.ids[id as i64 - 1]
    let start_ptr = (self.arena as i64 + entry.start as i64) as ptr[u8]
    return alloc_str_from_raw(start_ptr, entry.len as i64)

pub fn get(self: InternPool, id: u32) -> str:
    return self.get_str(id)

pub fn intern(mut self: InternPool, s: str) -> u32:
    let length = std.string.len(s)
    if length == 0:
        return 0 as u32

    let h = fnv1a(s)
    let mask = self.table_size - 1
    mut idx = (h as i64) & mask

    while true:
        let entry = self.table[idx]
        if entry.id == 0 as u32:
            // Insert slot
            return self.insert_at(idx, s, h)
        if entry.hash == h and entry.len as i64 == length:
            // Check if string matches exactly
            mut is_match := true
            mut i := 0
            while i < length:
                if self.arena[entry.start as i64 + i] != s[i] as u8:
                    is_match = false
                    break
                i = i + 1
            if is_match:
                return entry.id
        idx = (idx + 1) & mask

    return 0 as u32

pub fn intern_string(mut self: InternPool, s: str) -> u32:
    return self.intern(s)

fn insert_at(mut self: InternPool, slot: i64, s: str, h: u32) -> u32:
    let length = std.string.len(s)
    
    // Check if we need to resize ids table
    // For simplicity, just grow by doubling if it exceeds current limit
    // We assume max count starts at 256. Let's make it robust:
    if self.count > 0 and self.count % 256 == 0:
        let new_ids = @alloc((self.count + 256) * 24) as ptr[InternEntry]
        @memcpy(new_ids as ptr[u8], self.ids as ptr[u8], self.count * 24)
        @free(self.ids as ptr[u8])
        self.ids = new_ids

    // Resize arena if needed
    if self.arena_len + length >= self.arena_cap:
        mut new_cap := 1024 as i64
        if self.arena_cap != 0:
            new_cap = self.arena_cap * 2
        if new_cap < self.arena_len + length:
            new_cap = self.arena_len + length + 1024
        let new_arena = @alloc(new_cap) as ptr[u8]
        if self.arena != null as ptr[u8]:
            @memcpy(new_arena, self.arena, self.arena_len)
            @free(self.arena)
        self.arena = new_arena
        self.arena_cap = new_cap

    let start = self.arena_len
    mut i := 0
    while i < length:
        self.arena[start + i] = s[i] as u8
        i = i + 1
    self.arena_len = self.arena_len + length

    let new_id = (self.count + 1) as u32
    let entry = InternEntry(
        hash: h,
        padding: 0 as u32,
        start: start as u32,
        len: length as u32,
        id: new_id,
        dummy: 0 as u32,
    )

    self.table[slot] = entry
    self.ids[self.count] = entry
    self.count = self.count + 1

    // If load factor exceeds 70%, we grow the hash table
    if (self.count * 100) / self.table_size > 70:
        self.grow_table()

    return new_id

fn grow_table(mut self: InternPool):
    let old_size = self.table_size
    let new_size = old_size * 2
    let new_table = @alloc(new_size * 24) as ptr[InternEntry]
    mut i := 0
    while i < new_size:
        new_table[i] = InternEntry(hash: 0 as u32, padding: 0 as u32, start: 0 as u32, len: 0 as u32, id: 0 as u32, dummy: 0 as u32)
        i = i + 1

    let mask = new_size - 1
    i = 0
    while i < old_size:
        let entry = self.table[i]
        if entry.id != 0 as u32:
            mut idx = (entry.hash as i64) & mask
            while new_table[idx].id != 0 as u32:
                idx = (idx + 1) & mask
            new_table[idx] = entry
        i = i + 1

    @free(self.table as ptr[u8])
    self.table = new_table
    self.table_size = new_size

pub fn free_pool(mut self: InternPool):
    if self.arena != null as ptr[u8]:
        @free(self.arena)
    if self.table != null as ptr[InternEntry]:
        @free(self.table as ptr[u8])
    if self.ids != null as ptr[InternEntry]:
        @free(self.ids as ptr[u8])
// bootstrap/stage1/parser.ax
// AXIOM Recursive Descent + Pratt parser written in AXIOM itself.


extern "C" fn printf(fmt: str, a1: i64, a2: i64, a3: i64, a4: i64, a5: i64, a6: i64, a7: i64, a8: i64) -> i32
extern "C" fn puts(s: str) -> i32

// Pratt binding power constants
pub const BP_NONE: i32 = 0
pub const BP_OR: i32 = 10
pub const BP_AND: i32 = 20
pub const BP_NOT: i32 = 30
pub const BP_CMP: i32 = 40
pub const BP_BIT_OR: i32 = 50
pub const BP_BIT_XOR: i32 = 60
pub const BP_BIT_AND: i32 = 70
pub const BP_SHIFT: i32 = 80
pub const BP_ADD: i32 = 90
pub const BP_MUL: i32 = 100
pub const BP_POWER: i32 = 110
pub const BP_UNARY: i32 = 120
pub const BP_POSTFIX: i32 = 130

pub struct Parser:
    tokens: TokenVec
    pos: i64
    tree: AstTree
    pool: InternPool
    src: str
    diags_count: i64

pub fn new_parser(tokens: TokenVec, src: str, pool: InternPool) -> Parser:
    return Parser(
        tokens: tokens,
        pos: 0,
        tree: new_ast_tree(src, tokens),
        pool: pool,
        src: src,
        diags_count: 0,
    )

pub fn peek(mut self: Parser) -> Token:
    // Skip bare NEWLINEs
    while self.pos < self.tokens.len and self.tokens.data[self.pos].kind == TK_NEWLINE:
        self.pos = self.pos + 1
    if self.pos >= self.tokens.len:
        return Token(kind: TK_EOF, padding: 0 as u8, len: 0 as u16, offset: 0 as u32)
    return self.tokens.data[self.pos]

pub fn peek_raw(self: Parser) -> Token:
    if self.pos >= self.tokens.len:
        return Token(kind: TK_EOF, padding: 0 as u8, len: 0 as u16, offset: 0 as u32)
    return self.tokens.data[self.pos]

pub fn peek_at(self: Parser, offset: i64) -> Token:
    mut pos := self.pos + offset
    while pos < self.tokens.len and self.tokens.data[pos].kind == TK_NEWLINE:
        pos = pos + 1
    if pos >= self.tokens.len:
        return Token(kind: TK_EOF, padding: 0 as u8, len: 0 as u16, offset: 0 as u32)
    return self.tokens.data[pos]

pub fn consume(mut self: Parser) -> Token:
    let tok = self.peek()
    if self.pos < self.tokens.len:
        self.pos = self.pos + 1
    return tok

pub fn check(mut self: Parser, kind: u8) -> bool:
    return self.peek().kind == kind

pub fn check_raw(self: Parser, kind: u8) -> bool:
    return self.peek_raw().kind == kind

pub fn errorf(mut self: Parser, tok: Token, msg: str):
    self.diags_count = self.diags_count + 1
    // Simple diagnostic printing
    printf("error: %s at offset %d\n", (msg as ptr[u8]) as i64, tok.offset as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

pub fn expect(mut self: Parser, kind: u8) -> Token:
    let tok = self.peek()
    if tok.kind != kind:
        self.errorf(tok, "unexpected token")
        return tok
    return self.consume()

pub fn expect_newline(mut self: Parser):
    if self.pos < self.tokens.len and self.tokens.data[self.pos].kind == TK_NEWLINE:
        self.pos = self.pos + 1
        return
    let raw = self.peek_raw()
    if raw.kind != TK_EOF and raw.kind != TK_DEDENT:
        self.errorf(raw, "expected newline")

pub fn token_idx(self: Parser, tok: Token) -> u32:
    mut lo := 0 as i64
    mut hi := self.tokens.len
    while lo < hi:
        let mid = (lo + hi) / 2
        if self.tokens.data[mid].offset < tok.offset:
            lo = mid + 1
        else:
            hi = mid
    if lo < self.tokens.len:
        return lo as u32
    return 0 as u32

pub fn token_text(self: Parser, tok: Token) -> str:
    if tok.len == 0 as u16:
        return ""
    let start_ptr = ((self.src as ptr[u8]) as i64 + tok.offset as i64) as ptr[u8]
    return alloc_str_from_raw(start_ptr, tok.len as i64)

pub fn append_child(mut self: Parser, parent: u32, child: u32):
    if self.tree.nodes.data[parent].first_child == NULL_IDX:
        self.tree.nodes.data[parent].first_child = child
        return
    mut cur := self.tree.nodes.data[parent].first_child
    while self.tree.nodes.data[cur].next_sibling != NULL_IDX:
        cur = self.tree.nodes.data[cur].next_sibling
    self.tree.nodes.data[cur].next_sibling = child

pub fn set_payload(mut self: Parser, node: u32, payload: u32):
    self.tree.nodes.data[node].payload = payload

pub fn set_flags(mut self: Parser, node: u32, flags: u16):
    self.tree.nodes.data[node].flags = self.tree.nodes.data[node].flags | flags

fn left_binding_power(kind: u8) -> i32:
    if kind == TK_OR:
        return BP_OR
    if kind == TK_AND:
        return BP_AND
    if kind == TK_EQ_EQ or kind == TK_BANG_EQ or kind == TK_LT or kind == TK_GT or kind == TK_LT_EQ or kind == TK_GT_EQ:
        return BP_CMP
    if kind == TK_PIPE:
        return BP_BIT_OR
    if kind == TK_CARET:
        return BP_BIT_XOR
    if kind == TK_AMP:
        return BP_BIT_AND
    if kind == TK_LT_LT or kind == TK_GT_GT:
        return BP_SHIFT
    if kind == TK_PLUS or kind == TK_MINUS:
        return BP_ADD
    if kind == TK_STAR or kind == TK_SLASH or kind == TK_PERCENT:
        return BP_MUL
    if kind == TK_STAR_STAR:
        return BP_POWER
    if kind == TK_DOT_DOT:
        return 35 // range
    if kind == TK_DOT or kind == TK_DOT_STAR or kind == TK_L_BRACKET or kind == TK_L_PAREN or kind == TK_AS:
        return BP_POSTFIX
    return BP_NONE

pub fn parse_expr_with_prec(mut self: Parser, min_bp: i32) -> u32:
    mut left := self.parse_nud()
    if left == 0 as u32:
        return 0 as u32
    while true:
        let tok = self.peek_raw()
        let bp = left_binding_power(tok.kind)
        if bp <= min_bp:
            break
        left = self.parse_led(left, tok, bp)
        if left == 0 as u32:
            break
    return left

pub fn parse_nud(mut self: Parser) -> u32:
    let tok = self.peek()
    if tok.kind == TK_IDENT:
        self.consume()
        let node = self.tree.add_node(NODE_IDENT, self.token_idx(tok))
        let text = self.token_text(tok)
        let name_id = self.pool.intern(text)
        @free(text as ptr[u8])
        self.set_payload(node, name_id)
        return node
    if tok.kind == TK_INT_LIT:
        self.consume()
        return self.tree.add_node(NODE_INT_LIT, self.token_idx(tok))
    if tok.kind == TK_FLOAT_LIT:
        self.consume()
        return self.tree.add_node(NODE_FLOAT_LIT, self.token_idx(tok))
    if tok.kind == TK_STRING_LIT:
        self.consume()
        return self.tree.add_node(NODE_STRING_LIT, self.token_idx(tok))
    if tok.kind == TK_CHAR_LIT:
        self.consume()
        return self.tree.add_node(NODE_CHAR_LIT, self.token_idx(tok))
    if tok.kind == TK_TRUE or tok.kind == TK_FALSE:
        self.consume()
        return self.tree.add_node(NODE_BOOL_LIT, self.token_idx(tok))
    if tok.kind == TK_NIL:
        self.consume()
        return self.tree.add_node(NODE_NIL_LIT, self.token_idx(tok))
    if tok.kind == TK_MINUS or tok.kind == TK_TILDE or tok.kind == TK_AMP:
        self.consume()
        let node = self.tree.add_node(NODE_UNARY_EXPR, self.token_idx(tok))
        let operand = self.parse_expr_with_prec(BP_UNARY)
        if operand != 0 as u32:
            self.append_child(node, operand)
        return node
    if tok.kind == TK_NOT:
        self.consume()
        let node = self.tree.add_node(NODE_UNARY_EXPR, self.token_idx(tok))
        let operand = self.parse_expr_with_prec(BP_NOT)
        if operand != 0 as u32:
            self.append_child(node, operand)
        return node
    if tok.kind == TK_L_PAREN:
        self.consume() // '('
        let inner = self.parse_expr_with_prec(BP_NONE)
        self.expect(TK_R_PAREN)
        return inner
    if tok.kind == TK_HASH:
        let hash_tok = self.consume()
        let run_tok = self.expect(TK_IDENT)
        let run_text = self.token_text(run_tok)
        mut is_run := false
        if std.string.len(run_text) > 0:
            if run_text == "run":
                is_run = true
            @free(run_text as ptr[u8])

        if is_run:
            let comptime_node = self.tree.add_node(NODE_COMPTIME, self.token_idx(hash_tok))
            if self.check(TK_L_BRACE):
                self.consume() // '{'
                let block_node = self.tree.add_node(NODE_BLOCK, self.token_idx(run_tok))
                while not self.check(TK_R_BRACE) and not self.check(TK_EOF):
                    let prev_pos = self.pos
                    let stmt = self.parse_stmt()
                    if stmt != 0 as u32:
                        self.append_child(block_node, stmt)
                    if self.pos == prev_pos:
                        self.consume()
                self.expect(TK_R_BRACE)
                self.append_child(comptime_node, block_node)
            elif self.check(TK_COLON):
                self.consume() // ':'
                let block_node = self.parse_block()
                if block_node != 0 as u32:
                    self.append_child(comptime_node, block_node)
            else:
                let expr_node = self.parse_expr_with_prec(BP_NONE)
                if expr_node != 0 as u32:
                    self.append_child(comptime_node, expr_node)
            return comptime_node
        else:
            return self.tree.add_node(NODE_ERROR, self.token_idx(hash_tok))

    self.errorf(tok, "expected expression nud")
    self.consume()
    return 0 as u32

pub fn parse_led(mut self: Parser, left: u32, op_tok: Token, bp: i32) -> u32:
    self.consume() // consume operator
    if (op_tok.kind == TK_OR or op_tok.kind == TK_AND or
        op_tok.kind == TK_EQ_EQ or op_tok.kind == TK_BANG_EQ or
        op_tok.kind == TK_LT or op_tok.kind == TK_GT or op_tok.kind == TK_LT_EQ or op_tok.kind == TK_GT_EQ or
        op_tok.kind == TK_PIPE or op_tok.kind == TK_CARET or op_tok.kind == TK_AMP or
        op_tok.kind == TK_LT_LT or op_tok.kind == TK_GT_GT or
        op_tok.kind == TK_PLUS or op_tok.kind == TK_MINUS or
        op_tok.kind == TK_STAR or op_tok.kind == TK_SLASH or op_tok.kind == TK_PERCENT or
        op_tok.kind == TK_DOT_DOT):
        let node = self.tree.add_node(NODE_BINARY_EXPR, self.token_idx(op_tok))
        mut flags := 0 as u16
        if (op_tok.kind == TK_EQ_EQ or op_tok.kind == TK_BANG_EQ or
            op_tok.kind == TK_LT or op_tok.kind == TK_GT or
            op_tok.kind == TK_LT_EQ or op_tok.kind == TK_GT_EQ):
            flags = 1 as u16
        elif op_tok.kind == TK_AND or op_tok.kind == TK_OR:
            flags = 2 as u16
        if flags != 0 as u16:
            self.set_flags(node, flags)
        self.append_child(node, left)
        let right = self.parse_expr_with_prec(bp)
        if right != 0 as u32:
            self.append_child(node, right)
        return node
    if op_tok.kind == TK_STAR_STAR:
        let node = self.tree.add_node(NODE_BINARY_EXPR, self.token_idx(op_tok))
        self.append_child(node, left)
        let right = self.parse_expr_with_prec(bp - 1)
        if right != 0 as u32:
            self.append_child(node, right)
        return node
    if op_tok.kind == TK_DOT:
        let tok = self.peek()
        let field_tok = self.expect(TK_IDENT)
        let node = self.tree.add_node(NODE_FIELD_EXPR, self.token_idx(tok))
        self.append_child(node, left)
        let text = self.token_text(field_tok)
        self.set_payload(node, self.pool.intern(text))
        @free(text as ptr[u8])
        let field_name = self.tree.add_node(NODE_IDENT, self.token_idx(field_tok))
        self.append_child(node, field_name)
        return node
    if op_tok.kind == TK_DOT_STAR:
        let node = self.tree.add_node(NODE_DEREF_EXPR, self.token_idx(op_tok))
        self.append_child(node, left)
        return node
    if op_tok.kind == TK_L_BRACKET:
        let node = self.tree.add_node(NODE_INDEX_EXPR, self.token_idx(op_tok))
        self.append_child(node, left)
        let idx = self.parse_expr_with_prec(BP_NONE)
        if idx != 0 as u32:
            self.append_child(node, idx)
        self.expect(TK_R_BRACKET)
        return node
    if op_tok.kind == TK_L_PAREN:
        return self.parse_call_args(left, op_tok)
    if op_tok.kind == TK_AS:
        let node = self.tree.add_node(NODE_CAST_EXPR, self.token_idx(op_tok))
        self.append_child(node, left)
        let type_node = self.parse_type_expr()
        if type_node != 0 as u32:
            self.append_child(node, type_node)
        return node

    return left

pub fn parse_call_args(mut self: Parser, callee: u32, lparen: Token) -> u32:
    let node = self.tree.add_node(NODE_CALL_EXPR, self.token_idx(lparen))
    self.append_child(node, callee)
    while not self.check(TK_R_PAREN) and not self.check(TK_EOF):
        let prev_pos = self.pos
        if self.check(TK_IDENT) and self.peek_at(1 as i64).kind == TK_COLON:
            let arg_node = self.tree.add_node(NODE_NAMED_ARG, self.token_idx(self.peek()))
            let name_tok = self.consume()
            self.consume() // :
            let text = self.token_text(name_tok)
            let name_id = self.pool.intern(text)
            @free(text as ptr[u8])
            self.set_payload(arg_node, name_id)
            let expr = self.parse_expr_with_prec(BP_NONE)
            if expr != 0 as u32:
                self.append_child(arg_node, expr)
            self.append_child(node, arg_node)
        else:
            let expr = self.parse_expr_with_prec(BP_NONE)
            if expr != 0 as u32:
                self.append_child(node, expr)
        if not self.check(TK_R_PAREN):
            self.expect(TK_COMMA)
        if self.pos == prev_pos:
            self.consume()
    self.expect(TK_R_PAREN)
    return node

pub fn parse_stmt(mut self: Parser) -> u32:
    let tok = self.peek()
    if tok.kind == TK_LET or tok.kind == TK_MUT:
        return self.parse_var_decl()
    if tok.kind == TK_RETURN:
        return self.parse_return_stmt()
    if tok.kind == TK_IF:
        return self.parse_if_stmt()
    if tok.kind == TK_WHILE:
        return self.parse_while_loop()
    if tok.kind == TK_FOR:
        return self.parse_for_loop()
    if tok.kind == TK_MATCH:
        return self.parse_match_stmt()

    return self.parse_expr_stmt()

pub fn parse_var_decl(mut self: Parser) -> u32:
    let tok = self.consume() // let/mut
    let node = self.tree.add_node(NODE_VAR_DECL, self.token_idx(tok))
    if tok.kind == TK_MUT:
        self.set_flags(node, FLAG_IS_MUT as u16)
    let name_tok = self.expect(TK_IDENT)
    let text = self.token_text(name_tok)
    self.set_payload(node, self.pool.intern(text))
    @free(text as ptr[u8])
    if self.check(TK_COLON):
        self.consume() // ':'
        let t = self.parse_type_expr()
        if t != 0 as u32:
            self.append_child(node, t)
    if self.check(TK_EQ) or self.check(TK_COLON_EQ):
        self.consume()
        let val = self.parse_expr_with_prec(BP_NONE)
        if val != 0 as u32:
            self.append_child(node, val)
    self.expect_newline()
    return node

pub fn parse_return_stmt(mut self: Parser) -> u32:
    let tok = self.expect(TK_RETURN)
    let node = self.tree.add_node(NODE_RETURN_STMT, self.token_idx(tok))
    let raw = self.peek_raw()
    if raw.kind != TK_NEWLINE and raw.kind != TK_DEDENT and raw.kind != TK_EOF:
        let val = self.parse_expr_with_prec(BP_NONE)
        if val != 0 as u32:
            self.append_child(node, val)
    self.expect_newline()
    return node

pub fn parse_if_stmt(mut self: Parser) -> u32:
    let tok = self.expect(TK_IF)
    let node = self.tree.add_node(NODE_IF_STMT, self.token_idx(tok))
    let cond = self.parse_expr_with_prec(BP_NONE)
    if cond != 0 as u32:
        self.append_child(node, cond)
    self.expect(TK_COLON)
    let body = self.parse_block()
    if body != 0 as u32:
        self.append_child(node, body)

    while self.check(TK_ELIF):
        let elif_tok = self.consume()
        let elif_node = self.tree.add_node(NODE_ELIF_CLAUSE, self.token_idx(elif_tok))
        let elif_cond = self.parse_expr_with_prec(BP_NONE)
        if elif_cond != 0 as u32:
            self.append_child(elif_node, elif_cond)
        self.expect(TK_COLON)
        let elif_body = self.parse_block()
        if elif_body != 0 as u32:
            self.append_child(elif_node, elif_body)
        self.append_child(node, elif_node)

    if self.check(TK_ELSE):
        let else_tok = self.consume()
        let else_node = self.tree.add_node(NODE_ELSE_CLAUSE, self.token_idx(else_tok))
        self.expect(TK_COLON)
        let else_body = self.parse_block()
        if else_body != 0 as u32:
            self.append_child(else_node, else_body)
        self.append_child(node, else_node)

    return node

pub fn parse_while_loop(mut self: Parser) -> u32:
    let tok = self.expect(TK_WHILE)
    let node = self.tree.add_node(NODE_WHILE_STMT, self.token_idx(tok))
    let cond = self.parse_expr_with_prec(BP_NONE)
    if cond != 0 as u32:
        self.append_child(node, cond)
    self.expect(TK_COLON)
    let body = self.parse_block()
    if body != 0 as u32:
        self.append_child(node, body)
    return node

pub fn parse_for_loop(mut self: Parser) -> u32:
    let tok = self.expect(TK_FOR)
    let node = self.tree.add_node(NODE_FOR_STMT, self.token_idx(tok))
    let var_tok = self.expect(TK_IDENT)
    let text = self.token_text(var_tok)
    self.set_payload(node, self.pool.intern(text))
    @free(text as ptr[u8])
    self.expect(TK_IN)
    let iter = self.parse_expr_with_prec(BP_NONE)
    if iter != 0 as u32:
        self.append_child(node, iter)
    self.expect(TK_COLON)
    let body = self.parse_block()
    if body != 0 as u32:
        self.append_child(node, body)
    return node

pub fn parse_match_stmt(mut self: Parser) -> u32:
    let tok = self.expect(TK_MATCH)
    let node = self.tree.add_node(NODE_MATCH_STMT, self.token_idx(tok))
    let expr = self.parse_expr_with_prec(BP_NONE)
    if expr != 0 as u32:
        self.append_child(node, expr)
    self.expect(TK_COLON)
    if not self.check(TK_INDENT):
        let p = self.peek()
        self.errorf(p, "expected INDENT after match")
        return node
    self.consume() // consume INDENT
    while not self.check(TK_DEDENT) and not self.check(TK_EOF):
        let prev_pos = self.pos
        let arm = self.parse_match_arm()
        if arm != 0 as u32:
            self.append_child(node, arm)
        if self.pos == prev_pos:
            self.pos = self.pos + 1
    if self.check(TK_DEDENT):
        self.consume()
    return node

pub fn parse_match_arm(mut self: Parser) -> u32:
    let tok = self.peek()
    let node = self.tree.add_node(NODE_MATCH_ARM, self.token_idx(tok))
    let pat = self.parse_pattern()
    if pat != 0 as u32:
        self.append_child(node, pat)
    self.expect(TK_COLON)
    if self.check(TK_INDENT):
        let body = self.parse_block()
        if body != 0 as u32:
            self.append_child(node, body)
    else:
        let expr = self.parse_expr_with_prec(BP_NONE)
        if expr != 0 as u32:
            self.append_child(node, expr)
        self.expect_newline()
    return node

pub fn parse_pattern(mut self: Parser) -> u32:
    let tok = self.peek()
    if tok.kind == TK_IDENT:
        self.consume()
        let text = self.token_text(tok)
        let len = std.string.len(text)
        if len == 1 and text[0] as u8 == 95 as u8: // '_' ASCII is 95
            @free(text as ptr[u8])
            return self.tree.add_node(NODE_WILDCARD_PAT, self.token_idx(tok))
        if self.check(TK_L_PAREN):
            let node = self.tree.add_node(NODE_VARIANT_PAT, self.token_idx(tok))
            self.set_payload(node, self.pool.intern(text))
            @free(text as ptr[u8])
            self.consume() // '('
            while not self.check(TK_R_PAREN) and not self.check(TK_EOF):
                let prev_pos = self.pos
                let inner = self.parse_pattern()
                if inner != 0 as u32:
                    self.append_child(node, inner)
                if not self.check(TK_R_PAREN):
                    self.expect(TK_COMMA)
                if self.pos == prev_pos:
                    self.consume()
            self.expect(TK_R_PAREN)
            return node
        let node = self.tree.add_node(NODE_BINDING_PAT, self.token_idx(tok))
        self.set_payload(node, self.pool.intern(text))
        @free(text as ptr[u8])
        return node
    elif (tok.kind == TK_INT_LIT or tok.kind == TK_FLOAT_LIT or tok.kind == TK_STRING_LIT or
          tok.kind == TK_CHAR_LIT or tok.kind == TK_TRUE or tok.kind == TK_FALSE or tok.kind == TK_NIL):
        self.consume()
        return self.tree.add_node(NODE_LITERAL_PAT, self.token_idx(tok))
    elif tok.kind == TK_L_PAREN:
        self.consume()
        let node = self.tree.add_node(NODE_TUPLE_PAT, self.token_idx(tok))
        while not self.check(TK_R_PAREN) and not self.check(TK_EOF):
            let prev_pos = self.pos
            let inner = self.parse_pattern()
            if inner != 0 as u32:
                self.append_child(node, inner)
            if not self.check(TK_R_PAREN):
                self.expect(TK_COMMA)
            if self.pos == prev_pos:
                self.consume()
        self.expect(TK_R_PAREN)
        return node
    else:
        self.errorf(tok, "expected pattern")
        self.consume()
        return 0 as u32

pub fn parse_expr_stmt(mut self: Parser) -> u32:
    let expr = self.parse_expr_with_prec(BP_NONE)
    if expr == 0 as u32:
        return 0 as u32
    let tok = self.peek_raw()
    if (tok.kind == TK_EQ or tok.kind == TK_PLUS_EQ or tok.kind == TK_MINUS_EQ or
        tok.kind == TK_STAR_EQ or tok.kind == TK_SLASH_EQ or tok.kind == TK_PERCENT_EQ):
        self.consume()
        let node = self.tree.add_node(NODE_ASSIGN_STMT, self.token_idx(tok))
        self.append_child(node, expr)
        let rhs = self.parse_expr_with_prec(BP_NONE)
        if rhs != 0 as u32:
            self.append_child(node, rhs)
        self.expect_newline()
        return node
    self.expect_newline()
    return expr

pub fn parse_block(mut self: Parser) -> u32:
    let tok = self.expect(TK_INDENT)
    let node = self.tree.add_node(NODE_BLOCK, self.token_idx(tok))
    while not self.check(TK_DEDENT) and not self.check(TK_EOF):
        let prev_pos = self.pos
        let stmt = self.parse_stmt()
        if stmt != 0 as u32:
            self.append_child(node, stmt)
        if self.pos == prev_pos:
            self.pos = self.pos + 1
    self.expect(TK_DEDENT)
    return node

pub fn parse_type_expr(mut self: Parser) -> u32:
    let tok = self.peek()
    if tok.kind == TK_IDENT or tok.kind == TK_FUTURE or tok.kind == TK_ISOLATED:
        self.consume()
        let node = self.tree.add_node(NODE_TYPE_EXPR, self.token_idx(tok))
        let text = self.token_text(tok)
        self.set_payload(node, self.pool.intern(text))
        @free(text as ptr[u8])
        if self.check_raw(TK_L_BRACKET):
            let gen_node = self.tree.add_node(NODE_GENERIC_TYPE, self.token_idx(tok))
            self.append_child(gen_node, node)
            self.consume() // [
            while not self.check(TK_R_BRACKET) and not self.check(TK_EOF):
                let prev_pos = self.pos
                let t = self.parse_type_expr()
                if t != 0 as u32:
                    self.append_child(gen_node, t)
                if not self.check(TK_R_BRACKET):
                    self.expect(TK_COMMA)
                if self.pos == prev_pos:
                    self.consume()
            self.expect(TK_R_BRACKET)
            return gen_node
        return node
    if tok.kind == TK_STAR:
        self.consume()
        let node = self.tree.add_node(NODE_PTR_TYPE, self.token_idx(tok))
        if self.check(TK_MUT):
            self.consume()
            self.set_flags(node, FLAG_IS_MUT as u16)
        let inner = self.parse_type_expr()
        if inner != 0 as u32:
            self.append_child(node, inner)
        return node
    if tok.kind == TK_L_BRACKET:
        self.consume()
        let node = self.tree.add_node(NODE_SLICE_TYPE, self.token_idx(tok))
        let inner = self.parse_type_expr()
        if inner != 0 as u32:
            self.append_child(node, inner)
        self.expect(TK_R_BRACKET)
        return node

    self.errorf(tok, "expected type expression")
    return 0 as u32

pub fn parse_generic_params(mut self: Parser) -> u32:
    let tok = self.peek()
    let node = self.tree.add_node(NODE_GENERIC_PARAMS, self.token_idx(tok))
    self.expect(TK_L_BRACKET)
    while not self.check(TK_R_BRACKET) and not self.check(TK_EOF):
        let prev_pos = self.pos
        let gp = self.parse_generic_param()
        if gp != 0 as u32:
            self.append_child(node, gp)
        if not self.check(TK_R_BRACKET):
            self.expect(TK_COMMA)
        if self.pos == prev_pos:
            self.consume()
    self.expect(TK_R_BRACKET)
    return node

pub fn parse_generic_param(mut self: Parser) -> u32:
    let tok = self.peek()
    let node = self.tree.add_node(NODE_GENERIC_PARAM, self.token_idx(tok))
    let name_tok = self.expect(TK_IDENT)
    let text = self.token_text(name_tok)
    self.set_payload(node, self.pool.intern(text))
    @free(text as ptr[u8])
    if self.check(TK_COLON):
        self.consume()
        let constraint = self.parse_type_expr()
        if constraint != 0 as u32:
            self.append_child(node, constraint)
    return node

pub fn parse_func_decl(mut self: Parser, is_pub: bool) -> u32:
    let fn_tok = self.expect(TK_FN)
    let node = self.tree.add_node(NODE_FUNC_DECL, self.token_idx(fn_tok))
    if is_pub:
        self.set_flags(node, FLAG_IS_PUB as u16)

    let name_tok = self.expect(TK_IDENT)
    let text = self.token_text(name_tok)
    self.set_payload(node, self.pool.intern(text))
    @free(text as ptr[u8])

    self.expect(TK_L_PAREN)
    while not self.check(TK_R_PAREN) and not self.check(TK_EOF):
        let prev_pos = self.pos
        let param_tok = self.peek()
        let param = self.tree.add_node(NODE_PARAM_DECL, self.token_idx(param_tok))
        if self.check(TK_MUT):
            self.consume()
            self.set_flags(param, FLAG_IS_MUT as u16)
        let param_name = self.expect(TK_IDENT)
        let param_text = self.token_text(param_name)
        self.set_payload(param, self.pool.intern(param_text))
        @free(param_text as ptr[u8])
        self.expect(TK_COLON)
        let t = self.parse_type_expr()
        if t != 0 as u32:
            self.append_child(param, t)
        self.append_child(node, param)

        if not self.check(TK_R_PAREN):
            self.expect(TK_COMMA)
        if self.pos == prev_pos:
            self.consume()

    self.expect(TK_R_PAREN)

    if self.check(TK_ARROW):
        self.consume()
        let ret = self.parse_type_expr()
        if ret != 0 as u32:
            self.append_child(node, ret)

    self.expect(TK_COLON)
    let body = self.parse_block()
    if body != 0 as u32:
        self.append_child(node, body)

    return node

pub fn parse_struct_decl(mut self: Parser, is_pub: bool) -> u32:
    mut is_packed := false
    if self.check(TK_PACKED):
        self.consume()
        is_packed = true
    let tok = self.expect(TK_STRUCT)
    let node = self.tree.add_node(NODE_STRUCT_DECL, self.token_idx(tok))
    if is_pub:
        self.set_flags(node, FLAG_IS_PUB as u16)
    if is_packed:
        self.set_flags(node, 64 as u16) // FLAG_IS_PACKED is 64

    let name_tok = self.expect(TK_IDENT)
    let name_text = self.token_text(name_tok)
    self.set_payload(node, self.pool.intern(name_text))
    @free(name_text as ptr[u8])

    if self.check(TK_L_BRACKET):
        self.set_flags(node, FLAG_IS_GENERIC as u16)
        let gp = self.parse_generic_params()
        if gp != 0 as u32:
            self.append_child(node, gp)

    self.expect(TK_COLON)

    if not self.check(TK_INDENT):
        let p = self.peek()
        self.errorf(p, "expected INDENT after struct declaration")
        return node
    self.consume() // consume INDENT

    while not self.check(TK_DEDENT) and not self.check(TK_EOF):
        let prev_pos = self.pos
        let inner = self.peek()
        if inner.kind == TK_FN:
            let m = self.parse_func_decl(false)
            if m != 0 as u32:
                self.append_child(node, m)
        elif inner.kind == TK_PUB:
            self.consume()
            let next = self.peek()
            if next.kind == TK_FN:
                let m = self.parse_func_decl(true)
                if m != 0 as u32:
                    self.append_child(node, m)
            else:
                let f = self.parse_field_decl(true)
                if f != 0 as u32:
                    self.append_child(node, f)
        else:
            let f = self.parse_field_decl(false)
            if f != 0 as u32:
                self.append_child(node, f)
        if self.pos == prev_pos:
            self.consume()

    if self.check(TK_DEDENT):
        self.consume()
    return node

pub fn parse_field_decl(mut self: Parser, is_pub: bool) -> u32:
    mut is_mut := false
    if self.check(TK_MUT):
        self.consume()
        is_mut = true
    let tok = self.peek()
    if tok.kind != TK_IDENT:
        self.errorf(tok, "expected field name")
        self.consume()
        return 0 as u32
    self.consume()
    let node = self.tree.add_node(NODE_FIELD_DECL, self.token_idx(tok))
    if is_pub:
        self.set_flags(node, FLAG_IS_PUB as u16)
    if is_mut:
        self.set_flags(node, FLAG_IS_MUT as u16)
    let text = self.token_text(tok)
    self.set_payload(node, self.pool.intern(text))
    @free(text as ptr[u8])
    self.expect(TK_COLON)
    let type_node = self.parse_type_expr()
    if type_node != 0 as u32:
        self.append_child(node, type_node)
    self.expect_newline()
    return node

pub fn parse_type_alias_decl(mut self: Parser, is_pub: bool) -> u32:
    let tok = self.expect(TK_TYPE)
    let node = self.tree.add_node(NODE_TYPE_ALIAS_DECL, self.token_idx(tok))
    if is_pub:
        self.set_flags(node, FLAG_IS_PUB as u16)

    let name_tok = self.expect(TK_IDENT)
    let name_text = self.token_text(name_tok)
    self.set_payload(node, self.pool.intern(name_text))
    @free(name_text as ptr[u8])

    if self.check(TK_L_BRACKET):
        self.set_flags(node, FLAG_IS_GENERIC as u16)
        let gp = self.parse_generic_params()
        if gp != 0 as u32:
            self.append_child(node, gp)

    self.expect(TK_EQ)

    let sum_tok = self.peek()
    let sum_node = self.tree.add_node(NODE_SUM_TYPE, self.token_idx(sum_tok))
    let v = self.parse_type_variant()
    if v != 0 as u32:
        self.append_child(sum_node, v)

    while self.check_raw(TK_PIPE):
        self.consume()
        let next_v = self.parse_type_variant()
        if next_v != 0 as u32:
            self.append_child(sum_node, next_v)

    self.append_child(node, sum_node)
    self.expect_newline()
    return node

pub fn parse_type_variant(mut self: Parser) -> u32:
    let tok = self.peek()
    if tok.kind != TK_IDENT:
        return 0 as u32
    self.consume()
    let node = self.tree.add_node(NODE_VARIANT_DECL, self.token_idx(tok))
    let text = self.token_text(tok)
    self.set_payload(node, self.pool.intern(text))
    @free(text as ptr[u8])

    if self.check_raw(TK_L_PAREN):
        self.consume() // '('
        while not self.check(TK_R_PAREN) and not self.check(TK_EOF):
            let prev_pos = self.pos
            let t = self.parse_type_expr()
            if t != 0 as u32:
                self.append_child(node, t)
            if not self.check(TK_R_PAREN):
                self.expect(TK_COMMA)
            if self.pos == prev_pos:
                self.consume()
        self.expect(TK_R_PAREN)
    return node

pub fn parse_program(mut self: Parser):
    while not self.check(TK_EOF):
        let prev_pos = self.pos
        let tok = self.peek()
        mut decl := 0 as u32
        if tok.kind == TK_IMPORT:
            decl = self.parse_import_decl()
        elif tok.kind == TK_PUB:
            self.consume()
            let next = self.peek()
            if next.kind == TK_FN:
                decl = self.parse_func_decl(true)
            elif next.kind == TK_STRUCT or next.kind == TK_PACKED:
                decl = self.parse_struct_decl(true)
            elif next.kind == TK_TYPE:
                decl = self.parse_type_alias_decl(true)
            elif next.kind == TK_CONST:
                decl = self.parse_const_decl(true)
            elif next.kind == TK_EXTERN:
                decl = self.parse_extern_decl(true)
        elif tok.kind == TK_FN:
            decl = self.parse_func_decl(false)
        elif tok.kind == TK_STRUCT or tok.kind == TK_PACKED:
            decl = self.parse_struct_decl(false)
        elif tok.kind == TK_TYPE:
            decl = self.parse_type_alias_decl(false)
        elif tok.kind == TK_CONST:
            decl = self.parse_const_decl(false)
        elif tok.kind == TK_EXTERN:
            decl = self.parse_extern_decl(false)
        else:
            self.errorf(tok, "expected top level declaration")
            self.consume()

        if decl != 0 as u32:
            self.append_child(0 as u32, decl)

        if self.pos == prev_pos:
            self.consume()

pub fn parse_param(mut self: Parser) -> u32:
    let param_tok = self.peek()
    let param = self.tree.add_node(NODE_PARAM_DECL, self.token_idx(param_tok))
    if self.check(TK_MUT):
        self.consume()
        self.set_flags(param, FLAG_IS_MUT as u16)
    let param_name = self.expect(TK_IDENT)
    let param_text = self.token_text(param_name)
    self.set_payload(param, self.pool.intern(param_text))
    @free(param_text as ptr[u8])
    self.expect(TK_COLON)
    let t = self.parse_type_expr()
    if t != 0 as u32:
        self.append_child(param, t)
    return param

pub fn parse_const_decl(mut self: Parser, is_pub: bool) -> u32:
    let tok = self.expect(TK_CONST)
    let node = self.tree.add_node(NODE_CONST_DECL, self.token_idx(tok))
    if is_pub:
        self.set_flags(node, FLAG_IS_PUB as u16)

    let name_tok = self.expect(TK_IDENT)
    let name_text = self.token_text(name_tok)
    self.set_payload(node, self.pool.intern(name_text))
    @free(name_text as ptr[u8])

    self.expect(TK_COLON)
    let type_node = self.parse_type_expr()
    if type_node != 0 as u32:
        self.append_child(node, type_node)

    self.expect(TK_EQ)
    let expr = self.parse_expr_with_prec(BP_NONE)
    if expr != 0 as u32:
        self.append_child(node, expr)
    self.expect_newline()
    return node

pub fn parse_extern_decl(mut self: Parser, is_pub: bool) -> u32:
    self.expect(TK_EXTERN)
    
    // Expect ABI string literal, e.g. "C"
    self.expect(TK_STRING_LIT)

    let fn_tok = self.expect(TK_FN)
    let node = self.tree.add_node(NODE_FUNC_DECL, self.token_idx(fn_tok))
    self.set_flags(node, FLAG_IS_EXTERN as u16)
    if is_pub:
        self.set_flags(node, FLAG_IS_PUB as u16)

    let name_tok = self.expect(TK_IDENT)
    let name_text = self.token_text(name_tok)
    self.set_payload(node, self.pool.intern(name_text))
    @free(name_text as ptr[u8])

    if self.check(TK_L_BRACKET):
        self.set_flags(node, FLAG_IS_GENERIC as u16)
        let gp = self.parse_generic_params()
        if gp != 0 as u32:
            self.append_child(node, gp)

    self.expect(TK_L_PAREN)
    while not self.check(TK_R_PAREN) and not self.check(TK_EOF):
        let prev_pos = self.pos
        let param = self.parse_param()
        if param != 0 as u32:
            self.append_child(node, param)
        if not self.check(TK_R_PAREN):
            self.expect(TK_COMMA)
        if self.pos == prev_pos:
            self.consume()
    self.expect(TK_R_PAREN)

    if self.check_raw(TK_ARROW):
        self.consume()
        let ret_type = self.parse_type_expr()
        if ret_type != 0 as u32:
            self.append_child(node, ret_type)
    
    self.expect_newline()
    return node

pub fn parse_import_decl(mut self: Parser) -> u32:
    let tok = self.expect(TK_IMPORT)
    let node = self.tree.add_node(NODE_IMPORT_DECL, self.token_idx(tok))

    let path_tok = self.expect(TK_IDENT)
    let path_text = self.token_text(path_tok)
    mut path_id := self.pool.intern(path_text)
    @free(path_text as ptr[u8])

    while self.check_raw(TK_DOT):
        self.consume()
        let seg_tok = self.expect(TK_IDENT)
        let seg_text = self.token_text(seg_tok)
        let base_str = self.pool.get(path_id)
        
        // Concatenate path segments with '.'
        let len_base = std.string.len(base_str)
        let len_seg = std.string.len(seg_text)
        let total_len = len_base + 1 + len_seg
        mut new_buf := @alloc(total_len + 1) as ptr[u8]
        @memcpy(new_buf, base_str as ptr[u8], len_base)
        new_buf[len_base] = '.' as u8
        @memcpy(((new_buf as i64) + len_base + 1 as i64) as ptr[u8], seg_text as ptr[u8], len_seg)
        new_buf[total_len] = 0 as u8
        
        path_id = self.pool.intern(new_buf as str)
        @free(new_buf)
        @free(seg_text as ptr[u8])

    self.set_payload(node, path_id)

    if self.check_raw(TK_L_BRACE):
        self.consume()
        while not self.check(TK_R_BRACE) and not self.check(TK_EOF):
            let prev_pos = self.pos
            let name_tok = self.expect(TK_IDENT)
            let name_text = self.token_text(name_tok)
            let name_node = self.tree.add_node(NODE_IDENT, self.token_idx(name_tok))
            self.set_payload(name_node, self.pool.intern(name_text))
            @free(name_text as ptr[u8])
            self.append_child(node, name_node)

            if not self.check(TK_R_BRACE):
                self.expect(TK_COMMA)
            if self.pos == prev_pos:
                self.consume()
        self.expect(TK_R_BRACE)

    self.expect_newline()
    return node

// bootstrap/stage1/resolver.ax
// Name resolution pass and Symbol Table implementation for self-hosted compiler.


extern "C" fn printf(fmt: str, a1: i64, a2: i64, a3: i64, a4: i64, a5: i64, a6: i64, a7: i64, a8: i64) -> i32

// SymKind constants
pub const SYM_VAR: u8 = 0
pub const SYM_FUNC: u8 = 1
pub const SYM_STRUCT: u8 = 2
pub const SYM_INTERFACE: u8 = 3
pub const SYM_TYPE_ALIAS: u8 = 4
pub const SYM_VARIANT: u8 = 5
pub const SYM_PARAM: u8 = 6
pub const SYM_FIELD: u8 = 7
pub const SYM_GENERIC_PARAM: u8 = 8
pub const SYM_MODULE: u8 = 9
pub const SYM_BUILTIN_TYPE: u8 = 10
pub const SYM_ENUM_VARIANT: u8 = 11
pub const SYM_CONST: u8 = 12

// SymFlags constants
pub const SYM_FLAG_PUB: u16 = 1
pub const SYM_FLAG_MUT: u16 = 2
pub const SYM_FLAG_EXTERN: u16 = 4
pub const SYM_FLAG_SINK: u16 = 8
pub const SYM_FLAG_LENT: u16 = 16
pub const SYM_FLAG_ASYNC: u16 = 32
pub const SYM_FLAG_PURE: u16 = 64
pub const SYM_FLAG_MOVED: u16 = 128
pub const SYM_FLAG_USED: u16 = 256
pub const SYM_FLAG_COMPTIME: u16 = 512
pub const SYM_FLAG_GENERIC: u16 = 1024

// ScopeKind constants
pub const SCOPE_GLOBAL: u8 = 0
pub const SCOPE_FUNCTION: u8 = 1
pub const SCOPE_BLOCK: u8 = 2
pub const SCOPE_CLOSURE: u8 = 3
pub const SCOPE_LOOP: u8 = 4

// Flat Symbol Representation
pub struct Symbol:
    name_id: u32
    kind: u8
    padding: u8
    flags: u16
    type_id: u32
    decl_node: u32
    scope_id: u32
    next_overload: u32

// Scope Entry for hash table
pub struct ScopeEntry:
    name_id: u32
    symbol_idx: u32

// Scope representation using open addressing hash map
pub struct Scope:
    kind: u8
    padding1: u8
    padding2: u16
    parent_id: u32
    depth: u32
    entries: ptr[ScopeEntry]
    count: u32
    capacity: u32

pub fn init_scope(mut self: Scope, kind: u8, parent_id: u32, depth: u32, capacity: u32):
    self.kind = kind
    self.parent_id = parent_id
    self.depth = depth
    self.capacity = capacity
    self.count = 0 as u32
    self.entries = @alloc(capacity as i64 * 8) as ptr[ScopeEntry] // ScopeEntry is 8 bytes
    // Zero initialize
    mut i := 0 as i64
    while i < capacity as i64:
        self.entries[i] = ScopeEntry(name_id: 0 as u32, symbol_idx: 0 as u32)
        i = i + 1

fn hash_fnv1a(v: u32) -> u32:
    mut hash := 2166136261 as u32
    hash = hash ^ (v & 255 as u32)
    hash = hash * 16777619 as u32
    hash = hash ^ ((v >> 8 as u32) & 255 as u32)
    hash = hash * 16777619 as u32
    hash = hash ^ ((v >> 16 as u32) & 255 as u32)
    hash = hash * 16777619 as u32
    hash = hash ^ ((v >> 24 as u32) & 255 as u32)
    hash = hash * 16777619 as u32
    return hash

pub fn scope_put(mut self: Scope, name_id: u32, symbol_idx: u32):
    if self.count * 4 as u32 > self.capacity * 3 as u32:
        self.scope_grow()
    self.scope_insert(name_id, symbol_idx)
    self.count = self.count + 1 as u32

fn scope_insert(self: Scope, name_id: u32, symbol_idx: u32):
    let mask = self.capacity - 1 as u32
    mut idx = hash_fnv1a(name_id) & mask
    while true:
        if self.entries[idx].name_id == 0 as u32:
            self.entries[idx].name_id = name_id
            self.entries[idx].symbol_idx = symbol_idx
            return
        idx = (idx + 1 as u32) & mask

pub fn scope_get(self: Scope, name_id: u32) -> ScopeEntry:
    if self.capacity == 0 as u32:
        return ScopeEntry(name_id: 0 as u32, symbol_idx: 0 as u32)
    let mask = self.capacity - 1 as u32
    mut idx = hash_fnv1a(name_id) & mask
    let start_idx = idx
    while true:
        let entry = self.entries[idx]
        if entry.name_id == 0 as u32:
            return ScopeEntry(name_id: 0 as u32, symbol_idx: 0 as u32)
        if entry.name_id == name_id:
            return entry
        idx = (idx + 1 as u32) & mask
        if idx == start_idx:
            break
    return ScopeEntry(name_id: 0 as u32, symbol_idx: 0 as u32)

fn scope_grow(mut self: Scope):
    let old_entries = self.entries
    let old_capacity = self.capacity
    let new_cap = old_capacity * 2 as u32
    self.capacity = new_cap
    self.entries = @alloc(new_cap as i64 * 8) as ptr[ScopeEntry]
    mut i := 0 as i64
    while i < new_cap as i64:
        self.entries[i] = ScopeEntry(name_id: 0 as u32, symbol_idx: 0 as u32)
        i = i + 1

    i = 0 as i64
    while i < old_capacity as i64:
        let entry = old_entries[i]
        if entry.name_id != 0 as u32:
            self.scope_insert(entry.name_id, entry.symbol_idx)
        i = i + 1
    @free(old_entries as ptr[u8])

// Monomorphic vectors for symbol table
pub struct SymbolVec:
    data: ptr[Symbol]
    len: i64
    cap: i64

pub fn new_symbol_vec() -> SymbolVec:
    return SymbolVec(data: null as ptr[Symbol], len: 0, cap: 0)

pub fn push(mut self: SymbolVec, sym: Symbol) -> u32:
    if self.len == self.cap:
        mut new_cap := 16 as i64
        if self.cap != 0:
            new_cap = self.cap * 2
        let new_data = @alloc(new_cap * 24) as ptr[Symbol] // Symbol is 24 bytes
        if self.data != null as ptr[Symbol]:
            @memcpy(new_data as ptr[u8], self.data as ptr[u8], self.len * 24)
            @free(self.data as ptr[u8])
        self.data = new_data
        self.cap = new_cap
    let idx = self.len as u32
    self.data[self.len] = sym
    self.len = self.len + 1
    return idx

pub struct ScopeVec:
    data: ptr[Scope]
    len: i64
    cap: i64

pub fn new_scope_vec() -> ScopeVec:
    return ScopeVec(data: null as ptr[Scope], len: 0, cap: 0)

pub fn push(mut self: ScopeVec, scope: Scope) -> u32:
    if self.len == self.cap:
        mut new_cap := 16 as i64
        if self.cap != 0:
            new_cap = self.cap * 2
        let new_data = @alloc(new_cap * 32) as ptr[Scope] // Scope is 32 bytes
        if self.data != null as ptr[Scope]:
            @memcpy(new_data as ptr[u8], self.data as ptr[u8], self.len * 32)
            @free(self.data as ptr[u8])
        self.data = new_data
        self.cap = new_cap
    let idx = self.len as u32
    self.data[self.len] = scope
    self.len = self.len + 1
    return idx

pub struct U32Vec:
    pub data: ptr[u32]
    pub len: i64
    pub cap: i64

pub fn new_u32_vec() -> U32Vec:
    return U32Vec(data: null as ptr[u32], len: 0, cap: 0)

pub fn push(mut self: U32Vec, val: u32) -> u32:
    if self.len == self.cap:
        mut new_cap := 16 as i64
        if self.cap != 0:
            new_cap = self.cap * 2
        let new_data = @alloc(new_cap * 4) as ptr[u32] // u32 is 4 bytes
        if self.data != null as ptr[u32]:
            @memcpy(new_data as ptr[u8], self.data as ptr[u8], self.len * 4)
            @free(self.data as ptr[u8])
        self.data = new_data
        self.cap = new_cap
    let idx = self.len as u32
    self.data[self.len] = val
    self.len = self.len + 1
    return idx

pub fn pop(mut self: U32Vec) -> u32:
    if self.len == 0:
        return 0 as u32
    self.len = self.len - 1
    return self.data[self.len]

pub fn append_unique(mut self: U32Vec, val: u32) -> u32:
    mut i := 0 as i64
    while i < self.len:
        if self.data[i] == val:
            return i as u32
        i = i + 1
    return self.push(val)

pub struct SymbolTable:
    symbols: SymbolVec
    scopes: ScopeVec
    stack: U32Vec

pub fn new_symbol_table(mut intern: InternPool) -> SymbolTable:
    mut st := SymbolTable(
        symbols: new_symbol_vec(),
        scopes: new_scope_vec(),
        stack: new_u32_vec(),
    )

    // Prepopulate global scope
    mut global_scope := Scope(kind: SCOPE_GLOBAL, padding1: 0 as u8, padding2: 0 as u16, parent_id: 0 as u32, depth: 0 as u32, entries: null as ptr[ScopeEntry], count: 0, capacity: 0)
    global_scope.init_scope(SCOPE_GLOBAL, 0 as u32, 0 as u32, 64 as u32)
    st.scopes.push(global_scope)
    st.stack.push(0 as u32)

    // Define builtins
    st.define_builtin("i8", 1, intern)
    st.define_builtin("i16", 2, intern)
    st.define_builtin("i32", 3, intern)
    st.define_builtin("i64", 4, intern)
    st.define_builtin("u8", 5, intern)
    st.define_builtin("u16", 6, intern)
    st.define_builtin("u32", 7, intern)
    st.define_builtin("u64", 8, intern)
    st.define_builtin("f32", 9, intern)
    st.define_builtin("f64", 10, intern)
    st.define_builtin("bool", 11, intern)
    st.define_builtin("string", 12, intern)
    st.define_builtin("char8", 13, intern)
    st.define_builtin("void", 14, intern)
    st.define_builtin("isize", 15, intern)
    st.define_builtin("usize", 16, intern)
    st.define_builtin("ActorRef", 21, intern)
    st.define_builtin("str", 12, intern)
    st.define_builtin("ptr", 0, intern)
    st.define_builtin("null", 0, intern)
    st.define_builtin("alloc", 0, intern)
    st.define_builtin("free", 0, intern)
    st.define_builtin("memcpy", 0, intern)
    st.define_builtin("memset", 0, intern)
    st.define_builtin("print", 0, intern)
    st.define_builtin("println", 0, intern)
    st.define_builtin("compiler_intrinsic", 0, intern)
    st.define_builtin("assert", 0, intern)
    st.define_builtin("panic", 0, intern)

    return st

pub fn define_builtin(mut self: SymbolTable, name: str, type_id: u32, mut intern: InternPool):
    let name_id = intern.intern_string(name)
    let sym_idx = self.symbols.len as u32
    self.symbols.push(Symbol(
        name_id: name_id,
        kind: SYM_BUILTIN_TYPE,
        flags: SYM_FLAG_PUB,
        type_id: type_id,
        decl_node: 0 as u32,
        scope_id: 0 as u32,
        next_overload: 0 as u32,
    ))
    self.scopes.data[0].scope_put(name_id, sym_idx)

pub fn push_scope(mut self: SymbolTable, kind: u8) -> u32:
    let parent_id = self.current_scope()
    let depth = self.current_depth() + 1 as u32
    mut new_scope := Scope(kind: kind, padding1: 0 as u8, padding2: 0 as u16, parent_id: parent_id, depth: depth, entries: null as ptr[ScopeEntry], count: 0, capacity: 0)
    new_scope.init_scope(kind, parent_id, depth, 16 as u32)
    let idx = self.scopes.push(new_scope)
    self.stack.push(idx)
    return idx

pub fn pop_scope(mut self: SymbolTable):
    self.stack.pop()

pub fn current_scope(self: SymbolTable) -> u32:
    return self.stack.data[self.stack.len - 1]

pub fn current_depth(self: SymbolTable) -> u32:
    return (self.stack.len - 1) as u32

pub fn define(mut self: SymbolTable, name_id: u32, kind: u8, flags: u16, decl_node: u32) -> u32:
    let scope_idx = self.current_scope()
    // printf("[DEBUG-RESOLVER-DEFINE] name_id=%d, kind=%d, scope_idx=%d, len=%d\n", name_id as i64, kind as i64, scope_idx as i64, self.symbols.len as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    // Check duplicate in current scope
    let prev = self.scopes.data[scope_idx].scope_get(name_id)
    if prev.name_id != 0 as u32:
        // printf("  [COLLISION] prev.name_id=%d, prev.symbol_idx=%d\n", prev.name_id as i64, prev.symbol_idx as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        // Support function overloading
        if self.symbols.data[prev.symbol_idx].kind == SYM_FUNC and kind == SYM_FUNC:
            mut curr_idx := prev.symbol_idx
            while true:
                if self.symbols.data[curr_idx].next_overload == 0 as u32:
                    break
                curr_idx = self.symbols.data[curr_idx].next_overload
            let sym_idx = self.symbols.len as u32
            self.symbols.push(Symbol(
                name_id: name_id,
                kind: kind,
                flags: flags,
                type_id: 0 as u32,
                decl_node: decl_node,
                scope_id: scope_idx,
                next_overload: 0 as u32,
            ))
            self.symbols.data[curr_idx].next_overload = sym_idx
            return sym_idx
        return prev.symbol_idx // Already defined, return previous
    let sym_idx = self.symbols.len as u32
    self.symbols.push(Symbol(
        name_id: name_id,
        kind: kind,
        flags: flags,
        type_id: 0 as u32,
        decl_node: decl_node,
        scope_id: scope_idx,
        next_overload: 0 as u32,
    ))
    self.scopes.data[scope_idx].scope_put(name_id, sym_idx)
    return sym_idx

pub fn resolve(self: SymbolTable, name_id: u32) -> u32:
    mut i := self.stack.len - 1
    while i >= 0:
        let scope_idx = self.stack.data[i]
        let entry = self.scopes.data[scope_idx].scope_get(name_id)
        if entry.name_id != 0 as u32:
            return entry.symbol_idx
        i = i - 1
    return 0 as u32

pub struct NameResolver:
    tree: AstTree
    intern: InternPool
    symtable: SymbolTable

pub fn new_name_resolver(tree: AstTree, intern: InternPool, symtable: SymbolTable) -> NameResolver:
    return NameResolver(tree: tree, intern: intern, symtable: symtable)

pub fn resolve(mut self: NameResolver):
    if self.tree.nodes.len == 0:
        return
    self.resolve_node(0 as u32)

pub fn resolve_children(mut self: NameResolver, node_idx: u32):
    let node = self.tree.nodes.data[node_idx]
    mut child := node.first_child
    while child != 0 as u32:
        self.resolve_node(child)
        child = self.tree.nodes.data[child].next_sibling

pub fn resolve_node(mut self: NameResolver, node_idx: u32):
    let kind = self.tree.nodes.data[node_idx].kind
    let flags = self.tree.nodes.data[node_idx].flags

    if kind == NODE_PROGRAM:
        self.resolve_children(node_idx)

    elif kind == NODE_IMPORT_DECL:
        let name_id = self.tree.nodes.data[node_idx].payload
        let sym_idx = self.symtable.define(name_id, SYM_MODULE, 0 as u16, node_idx)
        self.tree.nodes.data[node_idx].payload = sym_idx
        
        let name = self.intern.get(name_id)
        if name == "std.string":
            let len_name = self.intern.intern_string("std.string.len")
            self.symtable.define(len_name, SYM_FUNC, 0 as u16, node_idx)
            let slice_name = self.intern.intern_string("std.string.slice")
            self.symtable.define(slice_name, SYM_FUNC, 0 as u16, node_idx)
            let concat_name = self.intern.intern_string("std.string.concat")
            self.symtable.define(concat_name, SYM_FUNC, 0 as u16, node_idx)

    elif kind == NODE_FIELD_EXPR:
        let lhs_idx = self.tree.nodes.data[node_idx].first_child
        if lhs_idx != 0 as u32:
            let lhs_node = self.tree.nodes.data[lhs_idx]
            mut is_module_import := false
            
            if lhs_node.kind == NODE_IDENT:
                let lhs_name = self.intern.get(lhs_node.payload)
                let rhs_name = self.intern.get(self.tree.nodes.data[node_idx].payload)
                let full_name = std.string.concat(lhs_name, std.string.concat(".", rhs_name))
                let full_name_id = self.intern.intern_string(full_name)
                let sym_idx = self.symtable.resolve(full_name_id)
                if sym_idx != 0 as u32:
                    let sym = self.symtable.symbols.data[sym_idx]
                    if sym.kind == SYM_MODULE:
                        self.tree.nodes.data[node_idx].payload = sym_idx
                        is_module_import = true
                        
            if not is_module_import:
                self.resolve_node(lhs_idx)
                let updated_lhs_node = self.tree.nodes.data[lhs_idx]
                if updated_lhs_node.kind == NODE_IDENT or updated_lhs_node.kind == NODE_FIELD_EXPR:
                    let sym_idx = updated_lhs_node.payload
                    if sym_idx != 0 as u32:
                        let sym = self.symtable.symbols.data[sym_idx]
                        if sym.kind == SYM_MODULE:
                            let field_name = self.intern.get(self.tree.nodes.data[node_idx].payload)
                            let module_name = self.intern.get(sym.name_id)
                            let full_name = std.string.concat(module_name, std.string.concat(".", field_name))
                            let full_name_id = self.intern.intern_string(full_name)
                            let resolved_idx = self.symtable.resolve(full_name_id)
                            if resolved_idx != 0 as u32:
                                self.tree.nodes.data[node_idx].payload = resolved_idx
                                self.symtable.symbols.data[resolved_idx].flags = self.symtable.symbols.data[resolved_idx].flags | SYM_FLAG_USED

    elif kind == NODE_FUNC_DECL:
        let name_id = self.tree.nodes.data[node_idx].payload
        mut sym_flags := 0 as u16
        if (flags & FLAG_IS_PUB) != 0 as u16:
            sym_flags = sym_flags | SYM_FLAG_PUB
        if (flags & FLAG_IS_EXTERN) != 0 as u16:
            sym_flags = sym_flags | SYM_FLAG_EXTERN
        if (flags & FLAG_IS_ASYNC) != 0 as u16:
            sym_flags = sym_flags | SYM_FLAG_ASYNC

        let sym_idx = self.symtable.define(name_id, SYM_FUNC, sym_flags, node_idx)
        self.tree.nodes.data[node_idx].payload = sym_idx

        self.symtable.push_scope(SCOPE_FUNCTION)
        self.resolve_children(node_idx)
        self.symtable.pop_scope()

    elif kind == NODE_PARAM_DECL:
        let name_id = self.tree.nodes.data[node_idx].payload
        let sym_idx = self.symtable.define(name_id, SYM_PARAM, 0 as u16, node_idx)
        self.tree.nodes.data[node_idx].payload = sym_idx
        self.resolve_children(node_idx)

    elif kind == NODE_STRUCT_DECL:
        let name_id = self.tree.nodes.data[node_idx].payload
        let sym_idx = self.symtable.define(name_id, SYM_STRUCT, 0 as u16, node_idx)
        self.tree.nodes.data[node_idx].payload = sym_idx
        self.symtable.push_scope(SCOPE_BLOCK)
        self.resolve_children(node_idx)
        self.symtable.pop_scope()

    elif kind == NODE_FIELD_DECL:
        let name_id = self.tree.nodes.data[node_idx].payload
        let sym_idx = self.symtable.define(name_id, SYM_FIELD, 0 as u16, node_idx)
        self.tree.nodes.data[node_idx].payload = sym_idx
        self.resolve_children(node_idx)

    elif kind == NODE_INTERFACE_DECL:
        let name_id = self.tree.nodes.data[node_idx].payload
        let sym_idx = self.symtable.define(name_id, SYM_INTERFACE, 0 as u16, node_idx)
        self.tree.nodes.data[node_idx].payload = sym_idx
        self.symtable.push_scope(SCOPE_BLOCK)
        let self_name_id = self.intern.intern_string("Self")
        self.symtable.define(self_name_id, SYM_TYPE_ALIAS, 0 as u16, node_idx)
        self.resolve_children(node_idx)
        self.symtable.pop_scope()

    elif kind == NODE_VAR_DECL:
        self.resolve_children(node_idx)
        let name_id = self.tree.nodes.data[node_idx].payload
        mut sym_flags := 0 as u16
        if (flags & FLAG_IS_MUT) != 0 as u16:
            sym_flags = sym_flags | SYM_FLAG_MUT
        let sym_idx = self.symtable.define(name_id, SYM_VAR, sym_flags, node_idx)
        self.tree.nodes.data[node_idx].payload = sym_idx

    elif kind == NODE_CONST_DECL:
        self.resolve_children(node_idx)
        let name_id = self.tree.nodes.data[node_idx].payload
        let sym_idx = self.symtable.define(name_id, SYM_CONST, 0 as u16, node_idx)
        self.tree.nodes.data[node_idx].payload = sym_idx

    elif kind == NODE_TYPE_ALIAS_DECL:
        let name_id = self.tree.nodes.data[node_idx].payload
        let sym_idx = self.symtable.define(name_id, SYM_TYPE_ALIAS, 0 as u16, node_idx)
        self.tree.nodes.data[node_idx].payload = sym_idx
        self.symtable.push_scope(SCOPE_BLOCK)
        self.resolve_children(node_idx)
        
        let curr_scope_idx = self.symtable.current_scope()
        self.symtable.pop_scope()
        let parent_scope_idx = self.symtable.current_scope()
        
        // Elevate variant symbols to parent scope
        let curr_scope = self.symtable.scopes.data[curr_scope_idx]
        mut i := 0 as i64
        while i < curr_scope.capacity as i64:
            let entry = curr_scope.entries[i]
            if entry.name_id != 0 as u32:
                let sym = self.symtable.symbols.data[entry.symbol_idx]
                if sym.kind == SYM_VARIANT:
                    self.symtable.scopes.data[parent_scope_idx].scope_put(entry.name_id, entry.symbol_idx)
            i = i + 1

    elif kind == NODE_VARIANT_DECL:
        let name_id = self.tree.nodes.data[node_idx].payload
        let sym_idx = self.symtable.define(name_id, SYM_VARIANT, 0 as u16, node_idx)
        self.tree.nodes.data[node_idx].payload = sym_idx
        self.resolve_children(node_idx)

    elif kind == NODE_IF_STMT or kind == NODE_ELIF_CLAUSE or kind == NODE_ELSE_CLAUSE or kind == NODE_MATCH_ARM or kind == NODE_ARENA_BLOCK or kind == NODE_UNSAFE_BLOCK or kind == NODE_WHILE_STMT:
        self.symtable.push_scope(SCOPE_BLOCK)
        self.resolve_children(node_idx)
        self.symtable.pop_scope()

    elif kind == NODE_FOR_STMT:
        self.symtable.push_scope(SCOPE_LOOP)
        let name_id = self.tree.nodes.data[node_idx].payload
        let sym_idx = self.symtable.define(name_id, SYM_VAR, 0 as u16, node_idx)
        self.tree.nodes.data[node_idx].payload = sym_idx
        self.resolve_children(node_idx)
        self.symtable.pop_scope()

    elif kind == NODE_CLOSURE_EXPR:
        self.symtable.push_scope(SCOPE_CLOSURE)
        self.resolve_children(node_idx)
        self.symtable.pop_scope()

    elif kind == NODE_IDENT:
        let name_id = self.tree.nodes.data[node_idx].payload
        let name = self.intern.get(name_id)
        if name != "break" and name != "continue":
            let sym_idx = self.symtable.resolve(name_id)
            if sym_idx != 0 as u32:
                self.tree.nodes.data[node_idx].payload = sym_idx
                self.symtable.symbols.data[sym_idx].flags = self.symtable.symbols.data[sym_idx].flags | SYM_FLAG_USED
        self.resolve_children(node_idx)

    elif kind == NODE_TYPE_EXPR:
        if self.tree.nodes.data[node_idx].payload != 0 as u32:
            let name_id = self.tree.nodes.data[node_idx].payload
            let sym_idx = self.symtable.resolve(name_id)
            if sym_idx != 0 as u32:
                self.tree.nodes.data[node_idx].payload = sym_idx
                self.symtable.symbols.data[sym_idx].flags = self.symtable.symbols.data[sym_idx].flags | SYM_FLAG_USED
        self.resolve_children(node_idx)

    elif kind == NODE_BINDING_PAT:
        let name_id = self.tree.nodes.data[node_idx].payload
        let sym_idx = self.symtable.define(name_id, SYM_VAR, 0 as u16, node_idx)
        self.tree.nodes.data[node_idx].payload = sym_idx

    elif kind == NODE_VARIANT_PAT:
        let name_id = self.tree.nodes.data[node_idx].payload
        let sym_idx = self.symtable.resolve(name_id)
        if sym_idx != 0 as u32:
            self.tree.nodes.data[node_idx].payload = sym_idx
            self.symtable.symbols.data[sym_idx].flags = self.symtable.symbols.data[sym_idx].flags | SYM_FLAG_USED
        self.resolve_children(node_idx)

    else:
        self.resolve_children(node_idx)

pub fn free_symtable(mut self: SymbolTable):
    mut i := 0 as i64
    while i < self.scopes.len:
        let scope = self.scopes.data[i]
        if scope.entries != null as ptr[ScopeEntry]:
            @free(scope.entries as ptr[u8])
        i = i + 1
    if self.symbols.data != null as ptr[Symbol]:
        @free(self.symbols.data as ptr[u8])
    if self.scopes.data != null as ptr[Scope]:
        @free(self.scopes.data as ptr[u8])
    if self.stack.data != null as ptr[u32]:
        @free(self.stack.data as ptr[u8])
// bootstrap/stage1/typecheck.ax
// AXIOM self-hosted Type Table and Type Checker implementation.


extern "C" fn printf(fmt: str, a1: i64, a2: i64, a3: i64, a4: i64, a5: i64, a6: i64, a7: i64, a8: i64) -> i32
extern "C" fn strlen(s: ptr[u8]) -> i64
extern "C" fn sprintf(buf: ptr[u8], format: ptr[u8], val: f64) -> i32
extern "C" fn atof(s: str) -> f64

// Predefined TypeID constants matching types/typeid.go exactly
pub const TYPE_UNKNOWN: u32 = 0
pub const TYPE_I8: u32 = 1
pub const TYPE_I16: u32 = 2
pub const TYPE_I32: u32 = 3
pub const TYPE_I64: u32 = 4
pub const TYPE_U8: u32 = 5
pub const TYPE_U16: u32 = 6
pub const TYPE_U32: u32 = 7
pub const TYPE_U64: u32 = 8
pub const TYPE_F32: u32 = 9
pub const TYPE_F64: u32 = 10
pub const TYPE_BOOL: u32 = 11
pub const TYPE_STRING: u32 = 12
pub const TYPE_CHAR8: u32 = 13
pub const TYPE_VOID: u32 = 14
pub const TYPE_ISIZE: u32 = 15
pub const TYPE_USIZE: u32 = 16

pub const TYPE_ORD: u32 = 17
pub const TYPE_EQ: u32 = 18
pub const TYPE_HASH: u32 = 19
pub const TYPE_DISPLAY: u32 = 20
pub const TYPE_ACTOR_REF: u32 = 21

pub struct ComptimeValue:
    kind: u32
    int_val: i64
    float_val: f64
    bool_val: bool
    str_val: str

// TypeKind enum matching compiler/types/types.go Kind constants
pub const TYPE_KIND_PRIMITIVE: u8 = 0
pub const TYPE_KIND_STRUCT: u8 = 1
pub const TYPE_KIND_FUNC: u8 = 2
pub const TYPE_KIND_GENERIC: u8 = 3
pub const TYPE_KIND_INTERFACE: u8 = 4
pub const TYPE_KIND_SUM: u8 = 5
pub const TYPE_KIND_POINTER: u8 = 6
pub const TYPE_KIND_SLICE: u8 = 7
pub const TYPE_KIND_ARRAY: u8 = 8

pub struct TypeEntry:
    kind: u8
    padding: u8
    flags: u16
    name_id: u32
    size: u32
    align: u32
    extra: u32 // Index into structs or funcs lists

pub struct StructField:
    name_id: u32
    type_id: u32

pub struct StructFieldVec:
    data: ptr[StructField]
    len: i64
    cap: i64

pub fn push(mut self: StructFieldVec, sf: StructField):
    if self.len == self.cap:
        mut new_cap := 16 as i64
        if self.cap != 0:
            new_cap = self.cap * 2
        let new_data = @alloc(new_cap * 8) as ptr[StructField]
        if self.data != null as ptr[StructField]:
            @memcpy(new_data as ptr[u8], self.data as ptr[u8], self.len * 8)
            @free(self.data as ptr[u8])
        self.data = new_data
        self.cap = new_cap
    self.data[self.len] = sf
    self.len = self.len + 1

pub struct StructInfo:
    fields: StructFieldVec

pub struct StructInfoVec:
    data: ptr[StructInfo]
    len: i64
    cap: i64

pub fn push(mut self: StructInfoVec, si: StructInfo):
    if self.len == self.cap:
        mut new_cap := 16 as i64
        if self.cap != 0:
            new_cap = self.cap * 2
        let new_data = @alloc(new_cap * 24) as ptr[StructInfo]
        if self.data != null as ptr[StructInfo]:
            @memcpy(new_data as ptr[u8], self.data as ptr[u8], self.len * 24)
            @free(self.data as ptr[u8])
        self.data = new_data
        self.cap = new_cap
    self.data[self.len] = si
    self.len = self.len + 1

pub struct VariantInfo:
    name_id: u32
    payload_type: u32
    tag: u8
    padding1: u8
    padding2: u16

pub struct VariantInfoVec:
    data: ptr[VariantInfo]
    len: i64
    cap: i64

pub fn push(mut self: VariantInfoVec, vi: VariantInfo):
    if self.len == self.cap:
        mut new_cap := 16 as i64
        if self.cap != 0:
            new_cap = self.cap * 2
        let new_data = @alloc(new_cap * 16) as ptr[VariantInfo]
        if self.data != null as ptr[VariantInfo]:
            @memcpy(new_data as ptr[u8], self.data as ptr[u8], self.len * 16)
            @free(self.data as ptr[u8])
        self.data = new_data
        self.cap = new_cap
    self.data[self.len] = vi
    self.len = self.len + 1

pub struct SumInfo:
    variants: VariantInfoVec

pub struct SumInfoVec:
    data: ptr[SumInfo]
    len: i64
    cap: i64

pub fn push(mut self: SumInfoVec, si: SumInfo):
    if self.len == self.cap:
        mut new_cap := 16 as i64
        if self.cap != 0:
            new_cap = self.cap * 2
        let new_data = @alloc(new_cap * 24) as ptr[SumInfo]
        if self.data != null as ptr[SumInfo]:
            @memcpy(new_data as ptr[u8], self.data as ptr[u8], self.len * 24)
            @free(self.data as ptr[u8])
        self.data = new_data
        self.cap = new_cap
    self.data[self.len] = si
    self.len = self.len + 1

pub struct FuncInfo:
    params: U32Vec
    ret: u32
    dummy: u32

pub struct FuncInfoVec:
    data: ptr[FuncInfo]
    len: i64
    cap: i64

pub fn push(mut self: FuncInfoVec, fi: FuncInfo):
    if self.len == self.cap:
        mut new_cap := 16 as i64
        if self.cap != 0:
            new_cap = self.cap * 2
        let new_data = @alloc(new_cap * 32) as ptr[FuncInfo]
        if self.data != null as ptr[FuncInfo]:
            @memcpy(new_data as ptr[u8], self.data as ptr[u8], self.len * 32)
            @free(self.data as ptr[u8])
        self.data = new_data
        self.cap = new_cap
    self.data[self.len] = fi
    self.len = self.len + 1

pub struct TypeEntryVec:
    data: ptr[TypeEntry]
    len: i64
    cap: i64

pub fn push(mut self: TypeEntryVec, te: TypeEntry) -> u32:
    if self.len == self.cap:
        mut new_cap := 16 as i64
        if self.cap != 0:
            new_cap = self.cap * 2
        let new_data = @alloc(new_cap * 20) as ptr[TypeEntry]
        if self.data != null as ptr[TypeEntry]:
            @memcpy(new_data as ptr[u8], self.data as ptr[u8], self.len * 20)
            @free(self.data as ptr[u8])
        self.data = new_data
        self.cap = new_cap
    let idx = self.len as u32
    self.data[self.len] = te
    self.len = self.len + 1
    return idx

pub fn new_sum_info_vec() -> SumInfoVec:
    return SumInfoVec(data: null as ptr[SumInfo], len: 0, cap: 0)

pub fn new_variant_info_vec() -> VariantInfoVec:
    return VariantInfoVec(data: null as ptr[VariantInfo], len: 0, cap: 0)

pub struct TypeTable:
    entries: TypeEntryVec
    structs: StructInfoVec
    funcs: FuncInfoVec
    sumtypes: SumInfoVec

pub fn new_type_table() -> TypeTable:
    mut tt := TypeTable(
        entries: TypeEntryVec(data: null as ptr[TypeEntry], len: 0, cap: 0),
        structs: StructInfoVec(data: null as ptr[StructInfo], len: 0, cap: 0),
        funcs: FuncInfoVec(data: null as ptr[FuncInfo], len: 0, cap: 0),
        sumtypes: SumInfoVec(data: null as ptr[SumInfo], len: 0, cap: 0),
    )
    
    // 0: Unknown sentinel
    tt.entries.push(TypeEntry(kind: TYPE_KIND_PRIMITIVE, padding: 0 as u8, flags: 0 as u16, name_id: 0 as u32, size: 0 as u32, align: 0 as u32, extra: 0 as u32))
    
    // 1-16: Primitives
    tt.entries.push(TypeEntry(kind: TYPE_KIND_PRIMITIVE, padding: 0 as u8, flags: 0 as u16, name_id: 0 as u32, size: 1 as u32, align: 1 as u32, extra: 0 as u32)) // i8
    tt.entries.push(TypeEntry(kind: TYPE_KIND_PRIMITIVE, padding: 0 as u8, flags: 0 as u16, name_id: 0 as u32, size: 2 as u32, align: 2 as u32, extra: 0 as u32)) // i16
    tt.entries.push(TypeEntry(kind: TYPE_KIND_PRIMITIVE, padding: 0 as u8, flags: 0 as u16, name_id: 0 as u32, size: 4 as u32, align: 4 as u32, extra: 0 as u32)) // i32
    tt.entries.push(TypeEntry(kind: TYPE_KIND_PRIMITIVE, padding: 0 as u8, flags: 0 as u16, name_id: 0 as u32, size: 8 as u32, align: 8 as u32, extra: 0 as u32)) // i64
    tt.entries.push(TypeEntry(kind: TYPE_KIND_PRIMITIVE, padding: 0 as u8, flags: 0 as u16, name_id: 0 as u32, size: 1 as u32, align: 1 as u32, extra: 0 as u32)) // u8
    tt.entries.push(TypeEntry(kind: TYPE_KIND_PRIMITIVE, padding: 0 as u8, flags: 0 as u16, name_id: 0 as u32, size: 2 as u32, align: 2 as u32, extra: 0 as u32)) // u16
    tt.entries.push(TypeEntry(kind: TYPE_KIND_PRIMITIVE, padding: 0 as u8, flags: 0 as u16, name_id: 0 as u32, size: 4 as u32, align: 4 as u32, extra: 0 as u32)) // u32
    tt.entries.push(TypeEntry(kind: TYPE_KIND_PRIMITIVE, padding: 0 as u8, flags: 0 as u16, name_id: 0 as u32, size: 8 as u32, align: 8 as u32, extra: 0 as u32)) // u64
    tt.entries.push(TypeEntry(kind: TYPE_KIND_PRIMITIVE, padding: 0 as u8, flags: 0 as u16, name_id: 0 as u32, size: 4 as u32, align: 4 as u32, extra: 0 as u32)) // f32
    tt.entries.push(TypeEntry(kind: TYPE_KIND_PRIMITIVE, padding: 0 as u8, flags: 0 as u16, name_id: 0 as u32, size: 8 as u32, align: 8 as u32, extra: 0 as u32)) // f64
    tt.entries.push(TypeEntry(kind: TYPE_KIND_PRIMITIVE, padding: 0 as u8, flags: 0 as u16, name_id: 0 as u32, size: 1 as u32, align: 1 as u32, extra: 0 as u32)) // bool
    tt.entries.push(TypeEntry(kind: TYPE_KIND_PRIMITIVE, padding: 0 as u8, flags: 0 as u16, name_id: 0 as u32, size: 8 as u32, align: 8 as u32, extra: 0 as u32)) // string
    tt.entries.push(TypeEntry(kind: TYPE_KIND_PRIMITIVE, padding: 0 as u8, flags: 0 as u16, name_id: 0 as u32, size: 1 as u32, align: 1 as u32, extra: 0 as u32)) // char8
    tt.entries.push(TypeEntry(kind: TYPE_KIND_PRIMITIVE, padding: 0 as u8, flags: 0 as u16, name_id: 0 as u32, size: 0 as u32, align: 0 as u32, extra: 0 as u32)) // void
    tt.entries.push(TypeEntry(kind: TYPE_KIND_PRIMITIVE, padding: 0 as u8, flags: 0 as u16, name_id: 0 as u32, size: 8 as u32, align: 8 as u32, extra: 0 as u32)) // isize
    tt.entries.push(TypeEntry(kind: TYPE_KIND_PRIMITIVE, padding: 0 as u8, flags: 0 as u16, name_id: 0 as u32, size: 8 as u32, align: 8 as u32, extra: 0 as u32)) // usize

    // 17-20: Built-in interfaces
    mut i := 0
    while i < 4:
        tt.entries.push(TypeEntry(kind: TYPE_KIND_INTERFACE, padding: 0 as u8, flags: 0 as u16, name_id: 0 as u32, size: 16 as u32, align: 8 as u32, extra: 0 as u32))
        i = i + 1

    // 21: ActorRef
    tt.entries.push(TypeEntry(kind: TYPE_KIND_STRUCT, padding: 0 as u8, flags: 0 as u16, name_id: 0 as u32, size: 8 as u32, align: 8 as u32, extra: 0 as u32))

    return tt

pub fn register_sum_type(mut self: TypeTable, name_id: u32, variants: VariantInfoVec) -> u32:
    let s_idx = self.sumtypes.len as u32
    self.sumtypes.push(SumInfo(variants: variants))
    return self.entries.push(TypeEntry(
        kind: TYPE_KIND_SUM,
        padding: 0 as u8,
        flags: 0 as u16,
        name_id: name_id,
        size: 0 as u32,
        align: 0 as u32,
        extra: s_idx,
    ))

pub fn register_struct(mut self: TypeTable, name_id: u32, fields: StructFieldVec) -> u32:
    let s_idx = self.structs.len as u32
    self.structs.push(StructInfo(fields: fields))
    return self.entries.push(TypeEntry(
        kind: TYPE_KIND_STRUCT,
        padding: 0 as u8,
        flags: 0 as u16,
        name_id: name_id,
        size: 0 as u32,
        align: 0 as u32,
        extra: s_idx,
    ))

pub fn register_function(mut self: TypeTable, params: U32Vec, ret: u32) -> u32:
    let f_idx = self.funcs.len as u32
    self.funcs.push(FuncInfo(params: params, ret: ret, dummy: 0 as u32))
    return self.entries.push(TypeEntry(
        kind: TYPE_KIND_FUNC,
        padding: 0 as u8,
        flags: 0 as u16,
        name_id: 0 as u32,
        size: 8 as u32,
        align: 8 as u32,
        extra: f_idx,
    ))

pub fn register_pointer(mut self: TypeTable, inner_id: u32) -> u32:
    mut i := 0 as i64
    while i < self.entries.len:
        let entry = self.entries.data[i]
        if entry.kind == TYPE_KIND_POINTER and entry.extra == inner_id:
            return i as u32
        i = i + 1
    
    return self.entries.push(TypeEntry(
        kind: TYPE_KIND_POINTER,
        padding: 0 as u8,
        flags: 0 as u16,
        name_id: 0 as u32,
        size: 8 as u32,
        align: 8 as u32,
        extra: inner_id,
    ))

pub fn register_slice(mut self: TypeTable, elem_id: u32) -> u32:
    mut i := 0 as i64
    while i < self.entries.len:
        let entry = self.entries.data[i]
        if entry.kind == TYPE_KIND_SLICE and entry.extra == elem_id:
            return i as u32
        i = i + 1
    
    return self.entries.push(TypeEntry(
        kind: TYPE_KIND_SLICE,
        padding: 0 as u8,
        flags: 0 as u16,
        name_id: 0 as u32,
        size: 24 as u32,
        align: 8 as u32,
        extra: elem_id,
    ))

pub fn free_typetable(mut self: TypeTable):
    mut i := 0 as i64
    while i < self.structs.len:
        let s = self.structs.data[i]
        if s.fields.data != null as ptr[StructField]:
            @free(s.fields.data as ptr[u8])
        i = i + 1
    i = 0 as i64
    while i < self.funcs.len:
        let f = self.funcs.data[i]
        if f.params.data != null as ptr[u32]:
            @free(f.params.data as ptr[u8])
        i = i + 1
    i = 0 as i64
    while i < self.sumtypes.len:
        let s = self.sumtypes.data[i]
        if s.variants.data != null as ptr[VariantInfo]:
            @free(s.variants.data as ptr[u8])
        i = i + 1
    if self.sumtypes.data != null as ptr[SumInfo]:
        @free(self.sumtypes.data as ptr[u8])
    if self.entries.data != null as ptr[TypeEntry]:
        @free(self.entries.data as ptr[u8])
    if self.structs.data != null as ptr[StructInfo]:
        @free(self.structs.data as ptr[u8])
    if self.funcs.data != null as ptr[FuncInfo]:
        @free(self.funcs.data as ptr[u8])

pub fn strip_quotes(s: str) -> str:
    let len = std.string.len(s)
    if len >= 2 and s[0] as u8 == '"' as u8 and s[len - 1] as u8 == '"' as u8:
        let ptr_start = ((s as ptr[u8]) as i64 + 1 as i64) as ptr[u8]
        return alloc_str_from_raw(ptr_start, len - 2)
    return s

pub fn format_int(val: i64) -> str:
    if val == 0 as i64:
        return "0"
    if val == -9223372036854775808 as i64:
        return "-9223372036854775808"
    mut temp := val
    mut is_neg := false
    if val < 0 as i64:
        is_neg = true
        temp = 0 as i64 - val
    let buf = @alloc(24) as ptr[u8]
    mut len := 0
    while temp > 0 as i64:
        let rem = (temp % 10 as i64) as u8
        buf[len] = ('0' as u8 + rem)
        len = len + 1
        temp = temp / 10 as i64
    if is_neg:
        buf[len] = '-' as u8
        len = len + 1
    mut i := 0
    mut j := len - 1
    while i < j:
        let tmp = buf[i]
        buf[i] = buf[j]
        buf[j] = tmp
        i = i + 1
        j = j - 1
    buf[len] = 0 as u8
    let result = alloc_str_from_raw(buf, len as i64)
    @free(buf)
    return result

pub fn format_float(val: f64) -> str:
    let buf = @alloc(64) as ptr[u8]
    sprintf(buf, "%g" as ptr[u8], val)
    let len = strlen(buf)
    let result = alloc_str_from_raw(buf, len)
    @free(buf)
    return result

pub struct TypeChecker:
    tree: AstTree
    intern: InternPool
    symtable: SymbolTable
    types: TypeTable
    node_types: ptr[u32]
    current_return: u32
    current_match_scrutinee: u32

pub fn new_type_checker(tree: AstTree, intern: InternPool, symtable: SymbolTable, types: TypeTable) -> TypeChecker:
    let node_count = tree.nodes.len
    let node_types = @alloc(node_count * 4) as ptr[u32]
    mut i := 0 as i64
    while i < node_count:
        node_types[i] = 0 as u32
        i = i + 1
    return TypeChecker(
        tree: tree,
        intern: intern,
        symtable: symtable,
        types: types,
        node_types: node_types,
        current_return: 0 as u32,
        current_match_scrutinee: 0 as u32,
    )

pub fn free_type_checker(mut self: TypeChecker):
    @free(self.node_types as ptr[u8])

pub fn parse_comptime_int(s: str) -> i64:
    let len = std.string.len(s)
    if len == 0:
        return 0 as i64
    mut i := 0
    mut sign := 1 as i64
    if s[0] as u8 == '-' as u8:
        sign = -1 as i64
        i = 1
    elif s[0] as u8 == '+' as u8:
        i = 1

    mut base := 10 as i64
    if i + 1 < len and s[i] as u8 == '0' as u8:
        let next_char = s[i + 1] as u8
        if next_char == 'x' as u8 or next_char == 'X' as u8:
            base = 16 as i64
            i = i + 2
        elif next_char == 'o' as u8 or next_char == 'O' as u8:
            base = 8 as i64
            i = i + 2
        elif next_char == 'b' as u8 or next_char == 'B' as u8:
            base = 2 as i64
            i = i + 2

    mut val := 0 as i64
    while i < len:
        let c = s[i] as u8
        mut digit := -1 as i64
        if c >= '0' as u8 and c <= '9' as u8:
            digit = (c - '0' as u8) as i64
        elif c >= 'a' as u8 and c <= 'f' as u8:
            digit = (c - 'a' as u8 + 10 as u8) as i64
        elif c >= 'A' as u8 and c <= 'F' as u8:
            digit = (c - 'A' as u8 + 10 as u8) as i64

        if digit < 0 or digit >= base:
            break

        val = val * base + digit
        i = i + 1

    return val * sign

pub fn node_text(self: TypeChecker, node_idx: u32) -> str:
    let node = self.tree.nodes.data[node_idx]
    let tok_idx = node.token_idx
    if tok_idx as i64 >= self.tree.tokens.len:
        return ""
    let tok = self.tree.tokens.data[tok_idx as i64]
    if tok.len == 0 as u16:
        return ""
    let start_ptr = ((self.tree.src as ptr[u8]) as i64 + tok.offset as i64) as ptr[u8]
    return alloc_str_from_raw(start_ptr, tok.len as i64)

pub fn eval_comptime(mut self: TypeChecker, node_idx: u32) -> ComptimeValue:
    let node = self.tree.nodes.data[node_idx]
    let kind = node.kind
    
    if kind == NODE_INT_LIT:
        let text = self.node_text(node_idx)
        let val = parse_comptime_int(text)
        return ComptimeValue(kind: TYPE_I64, int_val: val, float_val: 0.0, bool_val: false, str_val: "")
        
    elif kind == NODE_FLOAT_LIT:
        let text = self.node_text(node_idx)
        let val = atof(text)
        return ComptimeValue(kind: TYPE_F64, int_val: 0 as i64, float_val: val, bool_val: false, str_val: "")
        
    elif kind == NODE_BOOL_LIT:
        let text = self.node_text(node_idx)
        let is_true = (text == "true")
        return ComptimeValue(kind: TYPE_BOOL, int_val: 0 as i64, float_val: 0.0, bool_val: is_true, str_val: "")
        
    elif kind == NODE_STRING_LIT:
        let text = self.node_text(node_idx)
        let stripped = strip_quotes(text)
        return ComptimeValue(kind: TYPE_STRING, int_val: 0 as i64, float_val: 0.0, bool_val: false, str_val: stripped)
        
    elif kind == NODE_COMPTIME:
        let child = node.first_child
        if child != 0 as u32:
            return self.eval_comptime(child)
        return ComptimeValue(kind: TYPE_VOID, int_val: 0 as i64, float_val: 0.0, bool_val: false, str_val: "")
        
    elif kind == NODE_BLOCK:
        mut child := node.first_child
        if child == 0 as u32:
            return ComptimeValue(kind: TYPE_VOID, int_val: 0 as i64, float_val: 0.0, bool_val: false, str_val: "")
        mut last_val = ComptimeValue(kind: TYPE_VOID, int_val: 0 as i64, float_val: 0.0, bool_val: false, str_val: "")
        while child != 0 as u32:
            last_val = self.eval_comptime(child)
            child = self.tree.nodes.data[child].next_sibling
        return last_val
        
    elif kind == NODE_RETURN_STMT:
        let child = node.first_child
        if child != 0 as u32:
            return self.eval_comptime(child)
        return ComptimeValue(kind: TYPE_VOID, int_val: 0 as i64, float_val: 0.0, bool_val: false, str_val: "")
        
    elif kind == NODE_UNARY_EXPR:
        let child = node.first_child
        if child == 0 as u32:
            return ComptimeValue(kind: TYPE_VOID, int_val: 0 as i64, float_val: 0.0, bool_val: false, str_val: "")
        let val = self.eval_comptime(child)
        let op = self.node_text(node_idx)
        if op == "-":
            if val.kind == TYPE_I64:
                return ComptimeValue(kind: TYPE_I64, int_val: 0 as i64 - val.int_val, float_val: 0.0, bool_val: false, str_val: "")
            elif val.kind == TYPE_F64:
                return ComptimeValue(kind: TYPE_F64, int_val: 0 as i64, float_val: 0.0 - val.float_val, bool_val: false, str_val: "")
        elif op == "not" or op == "!":
            if val.kind == TYPE_BOOL:
                return ComptimeValue(kind: TYPE_BOOL, int_val: 0 as i64, float_val: 0.0, bool_val: not val.bool_val, str_val: "")
        elif op == "~":
            if val.kind == TYPE_I64:
                return ComptimeValue(kind: TYPE_I64, int_val: 0 as i64 - val.int_val - 1 as i64, float_val: 0.0, bool_val: false, str_val: "")
        return ComptimeValue(kind: TYPE_VOID, int_val: 0 as i64, float_val: 0.0, bool_val: false, str_val: "")
        
    elif kind == NODE_BINARY_EXPR:
        let lhs_idx = node.first_child
        if lhs_idx == 0 as u32:
            return ComptimeValue(kind: TYPE_VOID, int_val: 0 as i64, float_val: 0.0, bool_val: false, str_val: "")
        let rhs_idx = self.tree.nodes.data[lhs_idx].next_sibling
        if rhs_idx == 0 as u32:
            return ComptimeValue(kind: TYPE_VOID, int_val: 0 as i64, float_val: 0.0, bool_val: false, str_val: "")
        let lhs = self.eval_comptime(lhs_idx)
        let rhs = self.eval_comptime(rhs_idx)
        let op = self.node_text(node_idx)
        
        let is_lhs_num = (lhs.kind == TYPE_I64 or lhs.kind == TYPE_F64)
        let is_rhs_num = (rhs.kind == TYPE_I64 or rhs.kind == TYPE_F64)
        if is_lhs_num and is_rhs_num:
            if lhs.kind == TYPE_F64 or rhs.kind == TYPE_F64:
                mut lf := lhs.float_val
                if lhs.kind == TYPE_I64:
                    lf = lhs.int_val as f64
                mut rf := rhs.float_val
                if rhs.kind == TYPE_I64:
                    rf = rhs.int_val as f64
                if op == "+":
                    return ComptimeValue(kind: TYPE_F64, int_val: 0 as i64, float_val: lf + rf, bool_val: false, str_val: "")
                elif op == "-":
                    return ComptimeValue(kind: TYPE_F64, int_val: 0 as i64, float_val: lf - rf, bool_val: false, str_val: "")
                elif op == "*":
                    return ComptimeValue(kind: TYPE_F64, int_val: 0 as i64, float_val: lf * rf, bool_val: false, str_val: "")
                elif op == "/":
                    if rf == 0.0:
                        return ComptimeValue(kind: TYPE_VOID, int_val: 0 as i64, float_val: 0.0, bool_val: false, str_val: "")
                    return ComptimeValue(kind: TYPE_F64, int_val: 0 as i64, float_val: lf / rf, bool_val: false, str_val: "")
                elif op == "==":
                    return ComptimeValue(kind: TYPE_BOOL, int_val: 0 as i64, float_val: 0.0, bool_val: lf == rf, str_val: "")
                elif op == "!=":
                    return ComptimeValue(kind: TYPE_BOOL, int_val: 0 as i64, float_val: 0.0, bool_val: lf != rf, str_val: "")
                elif op == "<":
                    return ComptimeValue(kind: TYPE_BOOL, int_val: 0 as i64, float_val: 0.0, bool_val: lf < rf, str_val: "")
                elif op == "<=":
                    return ComptimeValue(kind: TYPE_BOOL, int_val: 0 as i64, float_val: 0.0, bool_val: lf <= rf, str_val: "")
                elif op == ">":
                    return ComptimeValue(kind: TYPE_BOOL, int_val: 0 as i64, float_val: 0.0, bool_val: lf > rf, str_val: "")
                elif op == ">=":
                    return ComptimeValue(kind: TYPE_BOOL, int_val: 0 as i64, float_val: 0.0, bool_val: lf >= rf, str_val: "")
            else:
                let lh = lhs.int_val
                let rh = rhs.int_val
                if op == "+":
                    return ComptimeValue(kind: TYPE_I64, int_val: lh + rh, float_val: 0.0, bool_val: false, str_val: "")
                elif op == "-":
                    return ComptimeValue(kind: TYPE_I64, int_val: lh - rh, float_val: 0.0, bool_val: false, str_val: "")
                elif op == "*":
                    return ComptimeValue(kind: TYPE_I64, int_val: lh * rh, float_val: 0.0, bool_val: false, str_val: "")
                elif op == "/":
                    if rh == 0 as i64:
                        return ComptimeValue(kind: TYPE_VOID, int_val: 0 as i64, float_val: 0.0, bool_val: false, str_val: "")
                    return ComptimeValue(kind: TYPE_I64, int_val: lh / rh, float_val: 0.0, bool_val: false, str_val: "")
                elif op == "%":
                    if rh == 0 as i64:
                        return ComptimeValue(kind: TYPE_VOID, int_val: 0 as i64, float_val: 0.0, bool_val: false, str_val: "")
                    return ComptimeValue(kind: TYPE_I64, int_val: lh % rh, float_val: 0.0, bool_val: false, str_val: "")
                elif op == "==":
                    return ComptimeValue(kind: TYPE_BOOL, int_val: 0 as i64, float_val: 0.0, bool_val: lh == rh, str_val: "")
                elif op == "!=":
                    return ComptimeValue(kind: TYPE_BOOL, int_val: 0 as i64, float_val: 0.0, bool_val: lh != rh, str_val: "")
                elif op == "<":
                    return ComptimeValue(kind: TYPE_BOOL, int_val: 0 as i64, float_val: 0.0, bool_val: lh < rh, str_val: "")
                elif op == "<=":
                    return ComptimeValue(kind: TYPE_BOOL, int_val: 0 as i64, float_val: 0.0, bool_val: lh <= rh, str_val: "")
                elif op == ">":
                    return ComptimeValue(kind: TYPE_BOOL, int_val: 0 as i64, float_val: 0.0, bool_val: lh > rh, str_val: "")
                elif op == ">=":
                    return ComptimeValue(kind: TYPE_BOOL, int_val: 0 as i64, float_val: 0.0, bool_val: lh >= rh, str_val: "")
        
        if lhs.kind == TYPE_BOOL and rhs.kind == TYPE_BOOL:
            let lb = lhs.bool_val
            let rb = rhs.bool_val
            if op == "and" or op == "&&":
                return ComptimeValue(kind: TYPE_BOOL, int_val: 0 as i64, float_val: 0.0, bool_val: lb and rb, str_val: "")
            elif op == "or" or op == "||":
                return ComptimeValue(kind: TYPE_BOOL, int_val: 0 as i64, float_val: 0.0, bool_val: lb or rb, str_val: "")
            elif op == "==":
                return ComptimeValue(kind: TYPE_BOOL, int_val: 0 as i64, float_val: 0.0, bool_val: lb == rb, str_val: "")
            elif op == "!=":
                return ComptimeValue(kind: TYPE_BOOL, int_val: 0 as i64, float_val: 0.0, bool_val: lb != rb, str_val: "")
                
        if lhs.kind == TYPE_STRING and rhs.kind == TYPE_STRING:
            let ls = lhs.str_val
            let rs = rhs.str_val
            if op == "+":
                return ComptimeValue(kind: TYPE_STRING, int_val: 0 as i64, float_val: 0.0, bool_val: false, str_val: std.string.concat(ls, rs))
            elif op == "==":
                return ComptimeValue(kind: TYPE_BOOL, int_val: 0 as i64, float_val: 0.0, bool_val: ls == rs, str_val: "")
            elif op == "!=":
                return ComptimeValue(kind: TYPE_BOOL, int_val: 0 as i64, float_val: 0.0, bool_val: ls != rs, str_val: "")
                
    return ComptimeValue(kind: TYPE_VOID, int_val: 0 as i64, float_val: 0.0, bool_val: false, str_val: "")

pub fn run_type_checker(mut self: TypeChecker):
    // Phase 0: Register all Type Aliases / Sum Types
    mut i := 0 as i64
    while i < self.tree.nodes.len:
        let node = self.tree.nodes.data[i]
        if node.kind == NODE_TYPE_ALIAS_DECL:
            self.pre_infer_type_alias(i as u32)
        i = i + 1

    // Phase 1: Register all StructDeclarations
    i = 0 as i64
    while i < self.tree.nodes.len:
        let node = self.tree.nodes.data[i]
        if node.kind == NODE_STRUCT_DECL:
            self.pre_infer_struct(i as u32)
        i = i + 1

    // Phase 2: Register all function signatures
    i = 0 as i64
    while i < self.tree.nodes.len:
        let node2 = self.tree.nodes.data[i]
        if node2.kind == NODE_FUNC_DECL:
            self.pre_infer_func_signature(i as u32)
        i = i + 1

    // Phase 3: Traversal type inference
    self.infer_node(0 as u32, TYPE_UNKNOWN)

pub fn pre_infer_type_alias(mut self: TypeChecker, node_idx: u32):
    let sym_idx = self.tree.nodes.data[node_idx].payload
    if sym_idx != 0 as u32:
        let sym = self.symtable.symbols.data[sym_idx]
        if sym.type_id == 0 as u32:
            mut sum_node := 0 as u32
            mut child := self.tree.nodes.data[node_idx].first_child
            while child != 0 as u32:
                let child_node = self.tree.nodes.data[child]
                if child_node.kind == NODE_SUM_TYPE:
                    sum_node = child
                    break
                child = child_node.next_sibling
            
            if sum_node != 0 as u32:
                mut variants := new_variant_info_vec()
                mut tag := 0 as u8
                
                mut v_node := self.tree.nodes.data[sum_node].first_child
                while v_node != 0 as u32:
                    let v_node_struct = self.tree.nodes.data[v_node]
                    if v_node_struct.kind == NODE_VARIANT_DECL:
                        let v_sym_idx = v_node_struct.payload
                        if v_sym_idx != 0 as u32:
                            let v_sym = self.symtable.symbols.data[v_sym_idx]
                            
                            mut payload_type := TYPE_UNKNOWN
                            let type_expr_node = v_node_struct.first_child
                            if type_expr_node != 0 as u32:
                                payload_type = self.infer_node(type_expr_node, TYPE_UNKNOWN)
                                
                            variants.push(VariantInfo(
                                name_id: v_sym.name_id,
                                payload_type: payload_type,
                                tag: tag,
                                padding1: 0 as u8,
                                padding2: 0 as u16,
                            ))
                            tag = tag + 1 as u8
                    v_node = v_node_struct.next_sibling
                
                let type_id = self.types.register_sum_type(sym.name_id, variants)
                self.symtable.symbols.data[sym_idx].type_id = type_id
                self.node_types[node_idx] = type_id
                
                // Assign sum type TypeID to each variant symbol
                v_node = self.tree.nodes.data[sum_node].first_child
                while v_node != 0 as u32:
                    let v_node_struct = self.tree.nodes.data[v_node]
                    if v_node_struct.kind == NODE_VARIANT_DECL:
                        let v_sym_idx = v_node_struct.payload
                        if v_sym_idx != 0 as u32:
                            self.symtable.symbols.data[v_sym_idx].type_id = type_id
                    v_node = v_node_struct.next_sibling

pub fn pre_infer_struct(mut self: TypeChecker, node_idx: u32):
    let sym_idx = self.tree.nodes.data[node_idx].payload
    if sym_idx != 0 as u32:
        let sym = self.symtable.symbols.data[sym_idx]
        if sym.type_id == 0 as u32:
            mut fields := StructFieldVec(data: null as ptr[StructField], len: 0, cap: 0)
            mut child := self.tree.nodes.data[node_idx].first_child
            while child != 0 as u32:
                let child_node = self.tree.nodes.data[child]
                if child_node.kind == NODE_FIELD_DECL:
                    let f_sym_idx = child_node.payload
                    if f_sym_idx != 0 as u32:
                        let f_sym = self.symtable.symbols.data[f_sym_idx]
                        let f_type_node = child_node.first_child
                        mut f_type_id := TYPE_UNKNOWN
                        if f_type_node != 0 as u32:
                            f_type_id = self.infer_node(f_type_node, TYPE_UNKNOWN)
                        self.symtable.symbols.data[f_sym_idx].type_id = f_type_id
                        fields.push(StructField(name_id: f_sym.name_id, type_id: f_type_id))
                child = child_node.next_sibling
            
            let struct_type_id = self.types.register_struct(sym.name_id, fields)
            self.symtable.symbols.data[sym_idx].type_id = struct_type_id
            self.node_types[node_idx] = struct_type_id

pub fn pre_infer_func_signature(mut self: TypeChecker, node_idx: u32):
    let sym_idx = self.tree.nodes.data[node_idx].payload
    mut has_existing := false
    if sym_idx != 0 as u32:
        let sym = self.symtable.symbols.data[sym_idx]
        if sym.type_id != 0 as u32:
            let entry = self.types.entries.data[sym.type_id]
            if entry.kind == TYPE_KIND_FUNC:
                has_existing = true
    
    if not has_existing:
        mut param_types := new_u32_vec()
        mut ret_type := TYPE_UNKNOWN
        mut has_ret_expr := false
        
        let node = self.tree.nodes.data[node_idx]
        mut child := node.first_child
        while child != 0 as u32:
            let child_node = self.tree.nodes.data[child]
            if child_node.kind == NODE_PARAM_DECL:
                let p_type = self.infer_node(child, TYPE_UNKNOWN)
                param_types.push(p_type)
            elif child_node.kind == NODE_TYPE_EXPR or child_node.kind == NODE_GENERIC_TYPE:
                ret_type = self.infer_node(child, TYPE_UNKNOWN)
                has_ret_expr = true
            child = child_node.next_sibling
            
        if not has_ret_expr:
            mut is_main := false
            if sym_idx != 0 as u32:
                let name_id = self.symtable.symbols.data[sym_idx].name_id
                let text = self.intern.get(name_id)
                if text == "main":
                    is_main = true
            if is_main:
                ret_type = TYPE_I32
            else:
                ret_type = TYPE_VOID
        
        let func_type_id = self.types.register_function(param_types, ret_type)
        if sym_idx != 0 as u32:
            self.symtable.symbols.data[sym_idx].type_id = func_type_id
        self.node_types[node_idx] = func_type_id

pub fn infer_node(mut self: TypeChecker, node_idx: u32, expected: u32) -> u32:
    if node_idx == 0 as u32:
        if self.tree.nodes.len == 0 as i64:
            return TYPE_UNKNOWN
        if self.tree.nodes.data[0].kind == 0 as u8: // NODE_INVALID
            return TYPE_UNKNOWN
    
    let kind = self.tree.nodes.data[node_idx].kind
    let flags = self.tree.nodes.data[node_idx].flags
    mut result_type := TYPE_UNKNOWN
    
    if kind == NODE_PROGRAM or kind == NODE_BLOCK:
        mut child := self.tree.nodes.data[node_idx].first_child
        while child != 0 as u32:
            self.infer_node(child, TYPE_UNKNOWN)
            child = self.tree.nodes.data[child].next_sibling
            
    elif kind == NODE_FUNC_DECL:
        let sym_idx = self.tree.nodes.data[node_idx].payload
        mut ret_type := TYPE_UNKNOWN
        if sym_idx != 0 as u32:
            let sym = self.symtable.symbols.data[sym_idx]
            if sym.type_id != 0 as u32:
                let entry = self.types.entries.data[sym.type_id]
                if entry.kind == TYPE_KIND_FUNC:
                    let fi = self.types.funcs.data[entry.extra]
                    ret_type = fi.ret
                    result_type = sym.type_id
        
        let prev_ret = self.current_return
        self.current_return = ret_type
        
        mut child := self.tree.nodes.data[node_idx].first_child
        while child != 0 as u32:
            let child_node = self.tree.nodes.data[child]
            if child_node.kind != NODE_PARAM_DECL and child_node.kind != NODE_TYPE_EXPR:
                self.infer_node(child, TYPE_UNKNOWN)
            child = child_node.next_sibling
            
        self.current_return = prev_ret
        
    elif kind == NODE_STRUCT_DECL:
        let sym_idx = self.tree.nodes.data[node_idx].payload
        if sym_idx != 0 as u32:
            result_type = self.symtable.symbols.data[sym_idx].type_id
            
        mut child := self.tree.nodes.data[node_idx].first_child
        while child != 0 as u32:
            let child_node = self.tree.nodes.data[child]
            if child_node.kind != NODE_FIELD_DECL:
                self.infer_node(child, TYPE_UNKNOWN)
            child = child_node.next_sibling

    elif kind == NODE_TYPE_ALIAS_DECL:
        let sym_idx = self.tree.nodes.data[node_idx].payload
        if sym_idx != 0 as u32:
            result_type = self.symtable.symbols.data[sym_idx].type_id
        
        mut child := self.tree.nodes.data[node_idx].first_child
        while child != 0 as u32:
            let child_node = self.tree.nodes.data[child]
            if child_node.kind != NODE_SUM_TYPE:
                self.infer_node(child, TYPE_UNKNOWN)
            child = child_node.next_sibling

    elif kind == NODE_PARAM_DECL:
        let sym_idx = self.tree.nodes.data[node_idx].payload
        mut p_type := TYPE_UNKNOWN
        let type_node = self.tree.nodes.data[node_idx].first_child
        if type_node != 0 as u32:
            p_type = self.infer_node(type_node, TYPE_UNKNOWN)
        if sym_idx != 0 as u32:
            self.symtable.symbols.data[sym_idx].type_id = p_type
        result_type = p_type
        
    elif kind == NODE_VAR_DECL or kind == NODE_CONST_DECL:
        let sym_idx = self.tree.nodes.data[node_idx].payload
        mut exp_type := TYPE_UNKNOWN
        if sym_idx != 0 as u32:
            exp_type = self.symtable.symbols.data[sym_idx].type_id
            
        mut type_node := 0 as u32
        mut init_expr := 0 as u32
        mut child := self.tree.nodes.data[node_idx].first_child
        while child != 0 as u32:
            let child_node = self.tree.nodes.data[child]
            if child_node.kind == NODE_TYPE_EXPR or child_node.kind == NODE_GENERIC_TYPE:
                type_node = child
            else:
                init_expr = child
            child = child_node.next_sibling
            
        if type_node != 0 as u32:
            exp_type = self.infer_node(type_node, TYPE_UNKNOWN)
            if sym_idx != 0 as u32:
                self.symtable.symbols.data[sym_idx].type_id = exp_type
                
        if init_expr != 0 as u32:
            let inferred := self.infer_node(init_expr, exp_type)
            if exp_type != TYPE_UNKNOWN:
                result_type = exp_type
            else:
                result_type = inferred
                if sym_idx != 0 as u32:
                    self.symtable.symbols.data[sym_idx].type_id = inferred
        else:
            result_type = exp_type
            
    elif kind == NODE_RETURN_STMT:
        let expr = self.tree.nodes.data[node_idx].first_child
        if expr != 0 as u32:
            self.infer_node(expr, self.current_return)

    elif kind == NODE_MATCH_STMT:
        let scrutinee = self.tree.nodes.data[node_idx].first_child
        if scrutinee != 0 as u32:
            let scrutinee_type = self.infer_node(scrutinee, TYPE_UNKNOWN)
            let prev_scrutinee = self.current_match_scrutinee
            self.current_match_scrutinee = scrutinee_type
            
            mut arm := self.tree.nodes.data[scrutinee].next_sibling
            mut arm_type := TYPE_UNKNOWN
            while arm != 0 as u32:
                let t = self.infer_node(arm, expected)
                if arm_type == TYPE_UNKNOWN:
                    arm_type = t
                arm = self.tree.nodes.data[arm].next_sibling
            
            self.current_match_scrutinee = prev_scrutinee
            result_type = arm_type

    elif kind == NODE_MATCH_ARM:
        let pattern = self.tree.nodes.data[node_idx].first_child
        mut body := 0 as u32
        if pattern != 0 as u32:
            body = self.tree.nodes.data[pattern].next_sibling
            
        let scrutinee_type = self.current_match_scrutinee
        if scrutinee_type != TYPE_UNKNOWN:
            let s_entry = self.types.entries.data[scrutinee_type]
            if s_entry.kind == TYPE_KIND_SUM:
                let sum_info = self.types.sumtypes.data[s_entry.extra]
                
                // Let's typecheck the pattern!
                if pattern != 0 as u32:
                    let pat_node = self.tree.nodes.data[pattern]
                    if pat_node.kind == NODE_VARIANT_PAT:
                        let v_sym_idx = pat_node.payload
                        if v_sym_idx != 0 as u32:
                            let v_sym = self.symtable.symbols.data[v_sym_idx]
                            
                            // Find corresponding variant in sum_info
                            mut payload_type := TYPE_UNKNOWN
                            mut found := false
                            mut j := 0 as i64
                            while j < sum_info.variants.len:
                                let v_info = sum_info.variants.data[j]
                                if v_info.name_id == v_sym.name_id:
                                    payload_type = v_info.payload_type
                                    found = true
                                    break
                                j = j + 1
                            
                            // Now assign payload type to binding patterns (which are children of NODE_VARIANT_PAT)
                            let arg = pat_node.first_child
                            if arg != 0 as u32 and self.tree.nodes.data[arg].kind == NODE_BINDING_PAT:
                                let arg_sym_idx = self.tree.nodes.data[arg].payload
                                if arg_sym_idx != 0 as u32:
                                    self.symtable.symbols.data[arg_sym_idx].type_id = payload_type
                                    self.node_types[arg] = payload_type
                    elif pat_node.kind == NODE_BINDING_PAT:
                        let b_sym_idx = pat_node.payload
                        if b_sym_idx != 0 as u32:
                            self.symtable.symbols.data[b_sym_idx].type_id = scrutinee_type
                            self.node_types[pattern] = scrutinee_type
        
        if body != 0 as u32:
            result_type = self.infer_node(body, expected)
        
    elif kind == NODE_IF_STMT:
        let cond = self.tree.nodes.data[node_idx].first_child
        if cond != 0 as u32:
            self.infer_node(cond, TYPE_BOOL)
            let then_branch = self.tree.nodes.data[cond].next_sibling
            if then_branch != 0 as u32:
                result_type = self.infer_node(then_branch, expected)
                mut sibling := self.tree.nodes.data[then_branch].next_sibling
                while sibling != 0 as u32:
                    self.infer_node(sibling, expected)
                    sibling = self.tree.nodes.data[sibling].next_sibling
                    
    elif kind == NODE_ELIF_CLAUSE:
        let cond = self.tree.nodes.data[node_idx].first_child
        if cond != 0 as u32:
            self.infer_node(cond, TYPE_BOOL)
            let body = self.tree.nodes.data[cond].next_sibling
            if body != 0 as u32:
                result_type = self.infer_node(body, expected)
                
    elif kind == NODE_ELSE_CLAUSE:
        let body = self.tree.nodes.data[node_idx].first_child
        if body != 0 as u32:
            result_type = self.infer_node(body, expected)
            
    elif kind == NODE_WHILE_STMT:
        let cond = self.tree.nodes.data[node_idx].first_child
        if cond != 0 as u32:
            self.infer_node(cond, TYPE_BOOL)
            let body = self.tree.nodes.data[cond].next_sibling
            if body != 0 as u32:
                self.infer_node(body, TYPE_UNKNOWN)

    elif kind == NODE_FOR_STMT:
        let iter_var = self.tree.nodes.data[node_idx].payload
        let range_expr = self.tree.nodes.data[node_idx].first_child
        if range_expr != 0 as u32:
            self.infer_node(range_expr, TYPE_UNKNOWN)
            let body = self.tree.nodes.data[range_expr].next_sibling
            if body != 0 as u32:
                self.infer_node(body, TYPE_UNKNOWN)
        if iter_var != 0 as u32:
            self.symtable.symbols.data[iter_var].type_id = TYPE_I32
        
    elif kind == NODE_BINARY_EXPR:
        let lhs = self.tree.nodes.data[node_idx].first_child
        mut rhs := 0 as u32
        if lhs != 0 as u32:
            rhs = self.tree.nodes.data[lhs].next_sibling
            
        if lhs != 0 as u32 and rhs != 0 as u32:
            let op = flags
            if op == 1 as u16: // ==
                self.infer_node(lhs, TYPE_UNKNOWN)
                self.infer_node(rhs, TYPE_UNKNOWN)
                result_type = TYPE_BOOL
            elif op == 2 as u16: // and / or
                self.infer_node(lhs, TYPE_BOOL)
                self.infer_node(rhs, TYPE_BOOL)
                result_type = TYPE_BOOL
            else:
                let t1 = self.infer_node(lhs, TYPE_UNKNOWN)
                let t2 = self.infer_node(rhs, TYPE_UNKNOWN)
                // numeric promotion simple
                if t1 == TYPE_F64 or t2 == TYPE_F64:
                    result_type = TYPE_F64
                elif t1 == TYPE_F32 or t2 == TYPE_F32:
                    result_type = TYPE_F32
                elif t1 == TYPE_I64 or t2 == TYPE_I64:
                    result_type = TYPE_I64
                else:
                    result_type = t1
                    
    elif kind == NODE_CALL_EXPR:
        let callee = self.tree.nodes.data[node_idx].first_child
        if callee != 0 as u32:
            let callee_type = self.infer_node(callee, TYPE_UNKNOWN)
            if callee_type != TYPE_UNKNOWN:
                let entry = self.types.entries.data[callee_type]
                if entry.kind == TYPE_KIND_FUNC:
                    let fi = self.types.funcs.data[entry.extra]
                    result_type = fi.ret
                elif entry.kind == TYPE_KIND_STRUCT:
                    result_type = callee_type
                elif entry.kind == TYPE_KIND_SUM:
                    result_type = callee_type
            
            // Infer arguments
            mut arg := self.tree.nodes.data[callee].next_sibling
            while arg != 0 as u32:
                self.infer_node(arg, TYPE_UNKNOWN)
                arg = self.tree.nodes.data[arg].next_sibling
                
    elif kind == NODE_IDENT:
        let sym_idx = self.tree.nodes.data[node_idx].payload
        if sym_idx != 0 as u32:
            result_type = self.symtable.symbols.data[sym_idx].type_id
            
    elif kind == NODE_TYPE_EXPR:
        let sym_idx = self.tree.nodes.data[node_idx].payload
        if sym_idx != 0 as u32:
            result_type = self.symtable.symbols.data[sym_idx].type_id
            
        let child = self.tree.nodes.data[node_idx].first_child
        if child != 0 as u32:
            let inner = self.infer_node(child, TYPE_UNKNOWN)
            if result_type == TYPE_UNKNOWN:
                result_type = inner
                
    elif kind == NODE_GENERIC_TYPE:
        let base_idx = self.tree.nodes.data[node_idx].first_child
        if base_idx != 0 as u32:
            let base_node = self.tree.nodes.data[base_idx]
            let name_id = base_node.payload
            // Check if name is ptr
            let text = self.intern.get(name_id)
            if text == "ptr":
                let arg_idx = base_node.next_sibling
                if arg_idx != 0 as u32:
                    let inner = self.infer_node(arg_idx, TYPE_UNKNOWN)
                    result_type = self.types.register_pointer(inner)
            elif text == "slice":
                let arg_idx = base_node.next_sibling
                if arg_idx != 0 as u32:
                    let inner = self.infer_node(arg_idx, TYPE_UNKNOWN)
                    result_type = self.types.register_slice(inner)
    elif kind == NODE_UNARY_EXPR:
        let operand = self.tree.nodes.data[node_idx].first_child
        if operand != 0 as u32:
            let operand_type = self.infer_node(operand, expected)
            let op = self.node_text(node_idx)
            if op == "&":
                result_type = self.types.register_pointer(operand_type)
            elif op == "not" or op == "!":
                result_type = TYPE_BOOL
            else:
                result_type = operand_type

    elif kind == NODE_DEREF_EXPR:
        let child = self.tree.nodes.data[node_idx].first_child
        if child != 0 as u32:
            let child_type = self.infer_node(child, TYPE_UNKNOWN)
            if child_type != TYPE_UNKNOWN:
                let entry = self.types.entries.data[child_type]
                if entry.kind == TYPE_KIND_POINTER:
                    result_type = entry.extra
                else:
                    result_type = child_type

    elif kind == NODE_INT_LIT:
        if expected == TYPE_I8 or expected == TYPE_I16 or expected == TYPE_I32 or expected == TYPE_I64 or expected == TYPE_U8 or expected == TYPE_U16 or expected == TYPE_U32 or expected == TYPE_U64 or expected == TYPE_F32 or expected == TYPE_F64 or expected == TYPE_ISIZE or expected == TYPE_USIZE:
            result_type = expected
        else:
            result_type = TYPE_I32
            
    elif kind == NODE_FLOAT_LIT:
        result_type = TYPE_F64
        
    elif kind == NODE_STRING_LIT:
        result_type = TYPE_STRING
        
    elif kind == NODE_BOOL_LIT:
        result_type = TYPE_BOOL
        
    elif kind == NODE_CAST_EXPR:
        let expr = self.tree.nodes.data[node_idx].first_child
        mut target_type := TYPE_UNKNOWN
        if expr != 0 as u32:
            self.infer_node(expr, TYPE_UNKNOWN)
            let target_node = self.tree.nodes.data[expr].next_sibling
            if target_node != 0 as u32:
                target_type = self.infer_node(target_node, TYPE_UNKNOWN)
        if target_type != TYPE_UNKNOWN:
            self.tree.nodes.data[node_idx].payload = target_type
            result_type = target_type
        else:
            result_type = self.tree.nodes.data[node_idx].payload

    elif kind == NODE_FIELD_EXPR:
        let obj = self.tree.nodes.data[node_idx].first_child
        if obj != 0 as u32:
            mut obj_type := self.infer_node(obj, TYPE_UNKNOWN)
            if obj_type != TYPE_UNKNOWN:
                mut entry = self.types.entries.data[obj_type]
                if entry.kind == TYPE_KIND_POINTER:
                    obj_type = entry.extra
                    entry = self.types.entries.data[obj_type]
                if entry.kind == TYPE_KIND_STRUCT:
                    let struct_info = self.types.structs.data[entry.extra]
                    let field_name_id = self.tree.nodes.data[node_idx].payload
                    mut found := false
                    mut j := 0 as i64
                    while j < struct_info.fields.len:
                        let f = struct_info.fields.data[j]
                        if f.name_id == field_name_id:
                            result_type = f.type_id
                            self.tree.nodes.data[node_idx].extra_idx = j as u32
                            found = true
                            break
                        j = j + 1
                    // If not found, check if NameResolver resolved it to a global/builtin method
                    if not found:
                        let sym_idx = self.tree.nodes.data[node_idx].payload
                        if sym_idx != 0 as u32:
                            let sym = self.symtable.symbols.data[sym_idx]
                            result_type = sym.type_id
            else:
                let sym_idx = self.tree.nodes.data[node_idx].payload
                if sym_idx != 0 as u32:
                    let sym = self.symtable.symbols.data[sym_idx]
                    result_type = sym.type_id
                    
    elif kind == NODE_INDEX_EXPR:
        let collection = self.tree.nodes.data[node_idx].first_child
        if collection != 0 as u32:
            let col_type = self.infer_node(collection, TYPE_UNKNOWN)
            let idx = self.tree.nodes.data[collection].next_sibling
            if idx != 0 as u32:
                self.infer_node(idx, TYPE_UNKNOWN)
            if col_type != TYPE_UNKNOWN:
                let c_entry = self.types.entries.data[col_type]
                if c_entry.kind == TYPE_KIND_POINTER or c_entry.kind == TYPE_KIND_SLICE or c_entry.kind == TYPE_KIND_ARRAY:
                    result_type = c_entry.extra
                    
    elif kind == NODE_COMPTIME:
        let child = self.tree.nodes.data[node_idx].first_child
        if child != 0 as u32:
            let child_type = self.infer_node(child, expected)
            if child_type == TYPE_UNKNOWN:
                result_type = TYPE_UNKNOWN
            else:
                let val = self.eval_comptime(child)
                mut lit_kind := NODE_INT_LIT
                mut val_str := ""
                mut tok_kind := TK_INT_LIT
                
                if val.kind == TYPE_BOOL:
                    lit_kind = NODE_BOOL_LIT
                    if val.bool_val:
                        val_str = "true"
                        tok_kind = TK_TRUE
                    else:
                        val_str = "false"
                        tok_kind = TK_FALSE
                elif val.kind == TYPE_STRING:
                    lit_kind = NODE_STRING_LIT
                    val_str = std.string.concat("\"", std.string.concat(val.str_val, "\""))
                    tok_kind = TK_STRING_LIT
                elif val.kind == TYPE_F64:
                    lit_kind = NODE_FLOAT_LIT
                    val_str = format_float(val.float_val)
                    tok_kind = TK_FLOAT_LIT
                else:
                    lit_kind = NODE_INT_LIT
                    val_str = format_int(val.int_val)
                    tok_kind = TK_INT_LIT
                
                let new_offset = std.string.len(self.tree.src) as u32
                self.tree.src = std.string.concat(self.tree.src, val_str)
                
                let new_tok_idx = self.tree.tokens.len as u32
                self.tree.tokens.push(Token(
                    kind: tok_kind,
                    padding: 0 as u8,
                    len: std.string.len(val_str) as u16,
                    offset: new_offset,
                ))
                
                // Mutate the AST node in-place
                self.tree.nodes.data[node_idx].kind = lit_kind
                self.tree.nodes.data[node_idx].token_idx = new_tok_idx
                self.tree.nodes.data[node_idx].first_child = NULL_IDX
                self.tree.nodes.data[node_idx].payload = val.kind
                
                result_type = val.kind
        else:
            result_type = TYPE_VOID

    else:
        // Default traversal
        mut child := self.tree.nodes.data[node_idx].first_child
        while child != 0 as u32:
            self.infer_node(child, TYPE_UNKNOWN)
            child = self.tree.nodes.data[child].next_sibling
            
    self.node_types[node_idx] = result_type
    return result_type
// bootstrap/stage1/connection_graph.ax
// ConnectionGraph models ownership relationships between values as a directed
// graph with typed edges for static memory safety.

pub const EDGE_OWNS: u32 = 0
pub const EDGE_BORROWS: u32 = 1
pub const EDGE_FLOWS_TO: u32 = 2
pub const EDGE_ESCAPES_TO: u32 = 3
pub const EDGE_REUSED_BY: u32 = 4

pub struct CGNode:
    pub id: u32
    pub sym_id: u32
    pub type_id: u32
    pub is_ref: bool
    pub lifetime: u32

pub struct CGNodeVec:
    pub data: ptr[CGNode]
    pub len: i64
    pub cap: i64

pub fn new_cg_node_vec() -> CGNodeVec:
    return CGNodeVec(data: null as ptr[CGNode], len: 0, cap: 0)

pub fn push(mut self: CGNodeVec, n: CGNode) -> u32:
    if self.len == self.cap:
        mut new_cap := 16 as i64
        if self.cap != 0:
            new_cap = self.cap * 2
        let new_data = @alloc(new_cap * 20) as ptr[CGNode] // CGNode size is 20 bytes
        if self.data != null as ptr[CGNode]:
            @memcpy(new_data as ptr[u8], self.data as ptr[u8], self.len * 20)
            @free(self.data as ptr[u8])
        self.data = new_data
        self.cap = new_cap
    let idx = self.len as u32
    self.data[self.len] = n
    self.len = self.len + 1
    return idx

pub struct CGEdge:
    pub from: u32
    pub to: u32
    pub kind: u32

pub struct CGEdgeVec:
    pub data: ptr[CGEdge]
    pub len: i64
    pub cap: i64

pub fn new_cg_edge_vec() -> CGEdgeVec:
    return CGEdgeVec(data: null as ptr[CGEdge], len: 0, cap: 0)

pub fn push(mut self: CGEdgeVec, e: CGEdge) -> u32:
    if self.len == self.cap:
        mut new_cap := 16 as i64
        if self.cap != 0:
            new_cap = self.cap * 2
        let new_data = @alloc(new_cap * 12) as ptr[CGEdge] // CGEdge size is 12 bytes
        if self.data != null as ptr[CGEdge]:
            @memcpy(new_data as ptr[u8], self.data as ptr[u8], self.len * 12)
            @free(self.data as ptr[u8])
        self.data = new_data
        self.cap = new_cap
    let idx = self.len as u32
    self.data[self.len] = e
    self.len = self.len + 1
    return idx

pub struct U32VecVec:
    pub data: ptr[U32Vec]
    pub len: i64
    pub cap: i64

pub fn new_u32_vec_vec() -> U32VecVec:
    return U32VecVec(data: null as ptr[U32Vec], len: 0, cap: 0)

pub fn push(mut self: U32VecVec, v: U32Vec) -> u32:
    if self.len == self.cap:
        mut new_cap := 16 as i64
        if self.cap != 0:
            new_cap = self.cap * 2
        let new_data = @alloc(new_cap * 24) as ptr[U32Vec] // size of U32Vec is 24 bytes
        if self.data != null as ptr[U32Vec]:
            @memcpy(new_data as ptr[u8], self.data as ptr[u8], self.len * 24)
            @free(self.data as ptr[u8])
        self.data = new_data
        self.cap = new_cap
    let idx = self.len as u32
    self.data[self.len] = v
    self.len = self.len + 1
    return idx

pub struct ConnectionGraph:
    pub nodes: CGNodeVec
    pub edges: CGEdgeVec
    pub adj_out: U32VecVec
    pub adj_in: U32VecVec
    pub sym_to_node: U32Vec

pub fn new_connection_graph() -> ConnectionGraph:
    return ConnectionGraph(
        nodes: new_cg_node_vec(),
        edges: new_cg_edge_vec(),
        adj_out: new_u32_vec_vec(),
        adj_in: new_u32_vec_vec(),
        sym_to_node: new_u32_vec(),
    )

pub fn free_connection_graph(mut self: ConnectionGraph):
    if self.nodes.data != null as ptr[CGNode]:
        @free(self.nodes.data as ptr[u8])
    if self.edges.data != null as ptr[CGEdge]:
        @free(self.edges.data as ptr[u8])
    
    mut i := 0 as i64
    while i < self.adj_out.len:
        let v = self.adj_out.data[i]
        if v.data != null as ptr[u32]:
            @free(v.data as ptr[u8])
        i = i + 1
    if self.adj_out.data != null as ptr[U32Vec]:
        @free(self.adj_out.data as ptr[u8])

    i = 0
    while i < self.adj_in.len:
        let v = self.adj_in.data[i]
        if v.data != null as ptr[u32]:
            @free(v.data as ptr[u8])
        i = i + 1
    if self.adj_in.data != null as ptr[U32Vec]:
        @free(self.adj_in.data as ptr[u8])

    if self.sym_to_node.data != null as ptr[u32]:
        @free(self.sym_to_node.data as ptr[u8])

pub fn ensure_adj_capacity(mut self: ConnectionGraph, node_id: u32):
    while self.adj_out.len <= node_id as i64:
        self.adj_out.push(new_u32_vec())
    while self.adj_in.len <= node_id as i64:
        self.adj_in.push(new_u32_vec())

pub fn add_value_node(mut self: ConnectionGraph, sym_id: u32, type_id: u32, lifetime: u32) -> u32:
    let id = self.nodes.len as u32
    self.nodes.push(CGNode(
        id: id,
        sym_id: sym_id,
        type_id: type_id,
        is_ref: false,
        lifetime: lifetime,
    ))
    self.ensure_adj_capacity(id)
    if sym_id != 0:
        while self.sym_to_node.len <= sym_id as i64:
            self.sym_to_node.push(0xffffffff as u32)
        self.sym_to_node.data[sym_id] = id
    return id

pub fn add_ref_node(mut self: ConnectionGraph, target_node_id: u32) -> u32:
    mut type_id := 0 as u32
    mut lifetime := 0 as u32
    if (target_node_id as i64) < self.nodes.len:
        type_id = self.nodes.data[target_node_id].type_id
        lifetime = self.nodes.data[target_node_id].lifetime
    
    let id = self.nodes.len as u32
    self.nodes.push(CGNode(
        id: id,
        sym_id: 0 as u32,
        type_id: type_id,
        is_ref: true,
        lifetime: lifetime,
    ))
    self.ensure_adj_capacity(id)
    self.add_edge(id, target_node_id, EDGE_BORROWS)
    return id

pub fn add_edge(mut self: ConnectionGraph, from: u32, to: u32, kind: u32):
    let edge_idx = self.edges.push(CGEdge(from: from, to: to, kind: kind))
    self.ensure_adj_capacity(from)
    self.ensure_adj_capacity(to)
    self.adj_out.data[from].push(edge_idx)
    self.adj_in.data[to].push(edge_idx)

pub fn node_of_sym(self: ConnectionGraph, sym_id: u32) -> u32:
    if (sym_id as i64) < self.sym_to_node.len:
        return self.sym_to_node.data[sym_id]
    return 0xffffffff as u32

pub fn escapes(self: ConnectionGraph, node_id: u32) -> bool:
    if self.nodes.len == 0:
        return false
    mut visited = @alloc(self.nodes.len) as ptr[bool]
    mut idx := 0 as i64
    while idx < self.nodes.len:
        visited[idx] = false
        idx = idx + 1
    
    let res = self.escape_dfs(node_id, visited)
    @free(visited as ptr[u8])
    return res

pub fn escape_dfs(self: ConnectionGraph, node_id: u32, visited: ptr[bool]) -> bool:
    if (node_id as i64) >= self.nodes.len:
        return false
    if visited[node_id]:
        return false
    visited[node_id] = true

    if (node_id as i64) >= self.adj_out.len:
        return false

    let out_edges = &self.adj_out.data[node_id]
    mut i := 0 as i64
    while i < out_edges.len:
        let edge_idx = out_edges.data[i]
        let edge = self.edges.data[edge_idx]
        if edge.kind == EDGE_ESCAPES_TO:
            return true
        if edge.kind == EDGE_OWNS or edge.kind == EDGE_FLOWS_TO:
            if self.escape_dfs(edge.to, visited):
                return true
        i = i + 1
    return false
// bootstrap/stage1/ownership.ax
// OwnershipChecker checks single ownership, moves, and mutability.


extern "C" fn printf(fmt: str, a1: i64, a2: i64, a3: i64, a4: i64, a5: i64, a6: i64, a7: i64, a8: i64) -> i32
extern "C" fn puts(s: str) -> i32
extern "C" fn exit(code: i32)

pub struct OwnershipChecker:
    pub tree: AstTree
    pub pool: InternPool
    pub symtable: SymbolTable
    pub typetable: TypeTable
    pub errors: u32

pub fn new_ownership_checker(tree: AstTree, pool: InternPool, symtable: SymbolTable, typetable: TypeTable) -> OwnershipChecker:
    return OwnershipChecker(
        tree: tree,
        pool: pool,
        symtable: symtable,
        typetable: typetable,
        errors: 0 as u32,
    )

pub fn check(mut self: OwnershipChecker):
    self.check_node(0 as u32)
    if self.errors > 0 as u32:
        puts("Ownership check failed.")
        exit(1)

pub fn check_node(mut self: OwnershipChecker, node_idx: u32):
    if node_idx == 0xffffffff as u32 or node_idx == 0 as u32:
        return

    let node = self.tree.nodes.data[node_idx]
    let kind = node.kind

    if kind == NODE_VAR_DECL:
        let init_idx = node.first_child
        if init_idx != 0 as u32:
            self.check_node(init_idx)
            self.check_move(init_idx)
        
    elif kind == NODE_ASSIGN_STMT:
        let lhs_idx = node.first_child
        let rhs_idx = self.tree.nodes.data[lhs_idx].next_sibling
        self.check_node(lhs_idx)
        self.check_node(rhs_idx)

        if lhs_idx != 0 as u32:
            let lhs_kind = self.tree.nodes.data[lhs_idx].kind
            if lhs_kind == NODE_IDENT:
                let sym_idx = self.tree.nodes.data[lhs_idx].payload
                if sym_idx != 0 as u32:
                    let sym = self.symtable.symbols.data[sym_idx]
                    if (sym.flags & SYM_FLAG_MUT) == 0 as u16:
                        let tok = self.tree.tokens.data[node.token_idx]
                        printf("error[E4002]: cannot assign to immutable variable at offset %d\n", tok.offset as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                        self.errors = self.errors + 1 as u32
            
            self.check_move(rhs_idx)

    elif kind == NODE_IDENT:
        let sym_idx = node.payload
        if sym_idx != 0 as u32:
            let sym = self.symtable.symbols.data[sym_idx]
            if (sym.flags & SYM_FLAG_MOVED) != 0 as u16:
                let tok = self.tree.tokens.data[node.token_idx]
                printf("error[E4001]: use of moved value at offset %d\n", tok.offset as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                self.errors = self.errors + 1 as u32

    elif kind == NODE_CALL_EXPR:
        mut arg_idx := node.first_child
        if arg_idx != 0 as u32:
            self.check_node(arg_idx)
            arg_idx = self.tree.nodes.data[arg_idx].next_sibling
            while arg_idx != 0 as u32:
                self.check_node(arg_idx)
                self.check_move(arg_idx)
                arg_idx = self.tree.nodes.data[arg_idx].next_sibling

    else:
        mut child_idx := node.first_child
        while child_idx != 0 as u32:
            self.check_node(child_idx)
            child_idx = self.tree.nodes.data[child_idx].next_sibling

pub fn check_move(mut self: OwnershipChecker, node_idx: u32):
    if node_idx == 0 as u32 or node_idx == 0xffffffff as u32:
        return
    let node = self.tree.nodes.data[node_idx]
    if node.kind == NODE_IDENT:
        let sym_idx = node.payload
        if sym_idx != 0 as u32:
            let sym = self.symtable.symbols.data[sym_idx]
            mut is_copyable := true
            let type_id = sym.type_id
            if type_id != 0 as u32 and (type_id as i64) < self.typetable.entries.len:
                let entry = self.typetable.entries.data[type_id]
                if entry.kind == TYPE_KIND_STRUCT or entry.kind == TYPE_KIND_SUM or entry.kind == TYPE_KIND_POINTER:
                    is_copyable = false
            
            if not is_copyable:
                self.symtable.symbols.data[sym_idx].flags = self.symtable.symbols.data[sym_idx].flags | SYM_FLAG_MOVED
// bootstrap/stage1/escape.ax
// EscapeAnalyser performs escape analysis using ConnectionGraph.


extern "C" fn printf(fmt: str, a1: i64, a2: i64, a3: i64, a4: i64, a5: i64, a6: i64, a7: i64, a8: i64) -> i32
extern "C" fn puts(s: str) -> i32

pub struct EscapeAnalyser:
    pub tree: AstTree
    pub pool: InternPool
    pub symtable: SymbolTable
    pub typetable: TypeTable
    pub curr_cg: ConnectionGraph
    pub escape_node_idx: u32

pub fn new_escape_analyser(tree: AstTree, pool: InternPool, symtable: SymbolTable, typetable: TypeTable) -> EscapeAnalyser:
    return EscapeAnalyser(
        tree: tree,
        pool: pool,
        symtable: symtable,
        typetable: typetable,
        curr_cg: new_connection_graph(),
        escape_node_idx: 0 as u32,
    )

pub fn run(mut self: EscapeAnalyser):
    self.curr_cg = new_connection_graph()
    self.escape_node_idx = 0 as u32
    self.traverse_nodes(0 as u32)
    free_connection_graph(self.curr_cg)

pub fn traverse_nodes(mut self: EscapeAnalyser, node_idx: u32):
    if node_idx == 0xffffffff as u32 or node_idx == 0 as u32:
        return

    let node = self.tree.nodes.data[node_idx]
    let kind = node.kind

    if kind == NODE_FUNC_DECL:
        // Build new connection graph for each function
        let old_cg = self.curr_cg
        self.curr_cg = new_connection_graph()
        self.escape_node_idx = self.curr_cg.add_value_node(0 as u32, 0 as u32, 0 as u32)

        // Register parameters
        mut child_idx := node.first_child
        while child_idx != 0 as u32:
            let child = self.tree.nodes.data[child_idx]
            if child.kind == NODE_PARAM_DECL:
                let sym_idx = child.payload
                if sym_idx != 0 as u32:
                    let sym = self.symtable.symbols.data[sym_idx]
                    self.curr_cg.add_value_node(sym_idx, sym.type_id, 0 as u32)
            child_idx = child.next_sibling

        // Analyze function body
        child_idx = node.first_child
        while child_idx != 0 as u32:
            let child = self.tree.nodes.data[child_idx]
            if child.kind == NODE_BLOCK:
                self.analyze_block(child_idx)
            child_idx = child.next_sibling

        // Tag local variables that escape
        mut idx := 0 as i64
        while idx < self.curr_cg.nodes.len:
            let cg_node = self.curr_cg.nodes.data[idx]
            if cg_node.sym_id != 0 as u32:
                let sym_idx = cg_node.sym_id
                let is_escaping = self.curr_cg.escapes(cg_node.id)
                if is_escaping:
                    // Tag symbol and AST decl node
                    self.symtable.symbols.data[sym_idx].flags = self.symtable.symbols.data[sym_idx].flags | (FLAG_ESCAPES_TO_HEAP as u16)
                    let decl_node = self.symtable.symbols.data[sym_idx].decl_node
                    if decl_node != 0 as u32:
                        self.tree.nodes.data[decl_node].flags = self.tree.nodes.data[decl_node].flags | (FLAG_ESCAPES_TO_HEAP as u16)
            idx = idx + 1

        free_connection_graph(self.curr_cg)
        self.curr_cg = old_cg

    else:
        mut child_idx := node.first_child
        while child_idx != 0 as u32:
            self.traverse_nodes(child_idx)
            child_idx = self.tree.nodes.data[child_idx].next_sibling

pub fn analyze_block(mut self: EscapeAnalyser, block_idx: u32):
    if block_idx == 0 as u32 or block_idx == 0xffffffff as u32:
        return
    let node = self.tree.nodes.data[block_idx]
    mut child_idx := node.first_child
    while child_idx != 0 as u32:
        self.analyze_stmt(child_idx)
        child_idx = self.tree.nodes.data[child_idx].next_sibling

pub fn analyze_stmt(mut self: EscapeAnalyser, stmt_idx: u32):
    if stmt_idx == 0 as u32 or stmt_idx == 0xffffffff as u32:
        return
    let node = self.tree.nodes.data[stmt_idx]
    let kind = node.kind

    if kind == NODE_VAR_DECL:
        let sym_idx = node.payload
        if sym_idx != 0 as u32:
            let sym = self.symtable.symbols.data[sym_idx]
            let cg_idx = self.curr_cg.add_value_node(sym_idx, sym.type_id, 0 as u32)
            let init_idx = node.first_child
            if init_idx != 0 as u32:
                self.analyze_expr(init_idx, cg_idx)

    elif kind == NODE_ASSIGN_STMT:
        let lhs_idx = node.first_child
        let rhs_idx = self.tree.nodes.data[lhs_idx].next_sibling
        if lhs_idx != 0 as u32:
            let lhs_kind = self.tree.nodes.data[lhs_idx].kind
            if lhs_kind == NODE_IDENT:
                let sym_idx = self.tree.nodes.data[lhs_idx].payload
                if sym_idx != 0 as u32:
                    let lhs_cg_idx = self.curr_cg.node_of_sym(sym_idx)
                    if lhs_cg_idx != 0xffffffff as u32:
                        self.analyze_expr(rhs_idx, lhs_cg_idx)
            else:
                // non-ident LHS means struct field or indexing, RHS escapes to heap
                self.analyze_expr(rhs_idx, self.escape_node_idx)

    elif kind == NODE_RETURN_STMT:
        let val_idx = node.first_child
        if val_idx != 0 as u32:
            self.analyze_expr(val_idx, self.escape_node_idx)

    elif kind == NODE_IF_STMT:
        mut child_idx := node.first_child
        while child_idx != 0 as u32:
            let child = self.tree.nodes.data[child_idx]
            if child.kind == NODE_BLOCK:
                self.analyze_block(child_idx)
            else:
                self.analyze_stmt(child_idx)
            child_idx = child.next_sibling

    elif kind == NODE_WHILE_STMT or kind == NODE_FOR_STMT:
        mut child_idx := node.first_child
        while child_idx != 0 as u32:
            let child = self.tree.nodes.data[child_idx]
            if child.kind == NODE_BLOCK:
                self.analyze_block(child_idx)
            child_idx = child.next_sibling

    else:
        mut child_idx := node.first_child
        while child_idx != 0 as u32:
            self.analyze_stmt(child_idx)
            child_idx = self.tree.nodes.data[child_idx].next_sibling

pub fn analyze_expr(mut self: EscapeAnalyser, expr_idx: u32, flow_dest: u32):
    if expr_idx == 0 as u32 or expr_idx == 0xffffffff as u32:
        return
    let node = self.tree.nodes.data[expr_idx]
    let kind = node.kind

    if kind == NODE_IDENT:
        let sym_idx = node.payload
        if sym_idx != 0 as u32:
            let cg_src = self.curr_cg.node_of_sym(sym_idx)
            if cg_src != 0xffffffff as u32 and flow_dest != 0xffffffff as u32:
                self.curr_cg.add_edge(cg_src, flow_dest, EDGE_FLOWS_TO)

    elif kind == NODE_CALL_EXPR:
        // Function call: arguments flow to return/escape
        mut child_idx := node.first_child
        if child_idx != 0 as u32:
            // First is callee
            self.analyze_expr(child_idx, self.escape_node_idx)
            child_idx = self.tree.nodes.data[child_idx].next_sibling
            while child_idx != 0 as u32:
                self.analyze_expr(child_idx, self.escape_node_idx)
                child_idx = self.tree.nodes.data[child_idx].next_sibling

    elif kind == NODE_STRUCT_LIT:
        // Struct literal fields flow to the struct dest
        mut child_idx := node.first_child
        while child_idx != 0 as u32:
            let child = self.tree.nodes.data[child_idx]
            let val_idx = child.first_child
            if val_idx != 0 as u32:
                self.analyze_expr(val_idx, flow_dest)
            child_idx = child.next_sibling

    else:
        mut child_idx := node.first_child
        while child_idx != 0 as u32:
            self.analyze_expr(child_idx, flow_dest)
            child_idx = self.tree.nodes.data[child_idx].next_sibling
// bootstrap/stage1/ctgc.ax
// Compile-Time Garbage Collection (CTGC) injector.


extern "C" fn printf(fmt: str, a1: i64, a2: i64, a3: i64, a4: i64, a5: i64, a6: i64, a7: i64, a8: i64) -> i32
extern "C" fn puts(s: str) -> i32

pub struct CtgcInjector:
    pub tree: AstTree
    pub pool: InternPool
    pub symtable: SymbolTable
    pub typetable: TypeTable
    pub active_vars: U32Vec // Stack of active sym_idx's
    pub active_var_decls: U32Vec // Stack of AST node decl indices

pub fn new_ctgc_injector(tree: AstTree, pool: InternPool, symtable: SymbolTable, typetable: TypeTable) -> CtgcInjector:
    return CtgcInjector(
        tree: tree,
        pool: pool,
        symtable: symtable,
        typetable: typetable,
        active_vars: new_u32_vec(),
        active_var_decls: new_u32_vec(),
    )

pub fn run(mut self: CtgcInjector):
    self.traverse_and_inject(0 as u32, 0 as u32)

pub fn traverse_and_inject(mut self: CtgcInjector, node_idx: u32, parent_idx: u32):
    if node_idx == 0xffffffff as u32 or node_idx == 0 as u32:
        return

    let node = self.tree.nodes.data[node_idx]
    let kind = node.kind

    if kind == NODE_BLOCK:
        let start_len = self.active_vars.len
        
        // 1. Collect all non-escaping heap variables declared at this block level
        mut child_idx := node.first_child
        while child_idx != 0 as u32:
            let child = self.tree.nodes.data[child_idx]
            if child.kind == NODE_VAR_DECL:
                let sym_idx = child.payload
                if sym_idx != 0 as u32:
                    let sym = self.symtable.symbols.data[sym_idx]
                    // If it is non-escaping heap variable
                    if (sym.flags & (FLAG_ESCAPES_TO_HEAP as u16)) == 0 as u16:
                        mut is_heap := false
                        let type_id = sym.type_id
                        if type_id != 0 as u32 and (type_id as i64) < self.typetable.entries.len:
                            let entry = self.typetable.entries.data[type_id]
                            if entry.kind == TYPE_KIND_STRUCT or entry.kind == TYPE_KIND_SUM or entry.kind == TYPE_KIND_POINTER:
                                is_heap = true
                        
                        if is_heap:
                            self.active_vars.push(sym_idx)
                            self.active_var_decls.push(child_idx)
            child_idx = child.next_sibling

        // 2. Recursively process children
        child_idx = node.first_child
        while child_idx != 0 as u32:
            self.traverse_and_inject(child_idx, node_idx)
            child_idx = self.tree.nodes.data[child_idx].next_sibling

        // 3. Inject destroy statements for variables declared in this block at the end of the block
        let num_block_vars = self.active_vars.len - start_len
        if num_block_vars > 0 as i64:
            mut idx := self.active_vars.len - 1 as i64
            while idx >= start_len:
                let sym_idx = self.active_vars.data[idx]
                // Create NODE_DESTROY_STMT node
                let destroy_node = self.tree.add_node(NODE_DESTROY_STMT, node.token_idx)
                self.tree.nodes.data[destroy_node].payload = sym_idx
                self.append_child_node(node_idx, destroy_node)
                idx = idx - 1

            // Pop them from stack
            self.active_vars.len = start_len
            self.active_var_decls.len = start_len

    elif kind == NODE_RETURN_STMT:
        // Inject destroy statements for all active variables before the return statement
        if self.active_vars.len > 0 as i64:
            mut idx := self.active_vars.len - 1 as i64
            while idx >= 0 as i64:
                let sym_idx = self.active_vars.data[idx]
                let destroy_node = self.tree.add_node(NODE_DESTROY_STMT, node.token_idx)
                self.tree.nodes.data[destroy_node].payload = sym_idx
                self.insert_before(parent_idx, node_idx, destroy_node)
                idx = idx - 1

    else:
        mut child_idx := node.first_child
        while child_idx != 0 as u32:
            self.traverse_and_inject(child_idx, node_idx)
            child_idx = self.tree.nodes.data[child_idx].next_sibling

pub fn append_child_node(mut self: CtgcInjector, parent: u32, child: u32):
    if self.tree.nodes.data[parent].first_child == 0 as u32:
        self.tree.nodes.data[parent].first_child = child
        return
    mut cur := self.tree.nodes.data[parent].first_child
    while self.tree.nodes.data[cur].next_sibling != 0 as u32:
        cur = self.tree.nodes.data[cur].next_sibling
    self.tree.nodes.data[cur].next_sibling = child

pub fn insert_before(mut self: CtgcInjector, parent: u32, target: u32, new_node: u32):
    if self.tree.nodes.data[parent].first_child == target:
        self.tree.nodes.data[new_node].next_sibling = target
        self.tree.nodes.data[parent].first_child = new_node
        return
    mut cur := self.tree.nodes.data[parent].first_child
    while cur != 0 as u32:
        if self.tree.nodes.data[cur].next_sibling == target:
            self.tree.nodes.data[new_node].next_sibling = target
            self.tree.nodes.data[cur].next_sibling = new_node
            return
        cur = self.tree.nodes.data[cur].next_sibling
// bootstrap/stage1/alias_reuse.ax
// AliasReuseOptimizer optimizes adjacent destroy and alloc pairs into NODE_ALIAS_STMT.


pub struct AliasReuseOptimizer:
    pub tree: AstTree
    pub pool: InternPool
    pub symtable: SymbolTable
    pub typetable: TypeTable

pub fn new_alias_reuse_optimizer(tree: AstTree, pool: InternPool, symtable: SymbolTable, typetable: TypeTable) -> AliasReuseOptimizer:
    return AliasReuseOptimizer(
        tree: tree,
        pool: pool,
        symtable: symtable,
        typetable: typetable,
    )

pub fn run(mut self: AliasReuseOptimizer):
    self.optimize_node(0 as u32)

pub fn optimize_node(mut self: AliasReuseOptimizer, node_idx: u32):
    if node_idx == 0xffffffff as u32 or node_idx == 0 as u32:
        return

    let node = self.tree.nodes.data[node_idx]
    let kind = node.kind

    if kind == NODE_BLOCK:
        mut child_idx := node.first_child
        while child_idx != 0 as u32:
            let child = self.tree.nodes.data[child_idx]
            if child.kind == NODE_DESTROY_STMT:
                let next_idx = child.next_sibling
                if next_idx != 0 as u32:
                    let next_node = self.tree.nodes.data[next_idx]
                    if next_node.kind == NODE_VAR_DECL:
                        // Found adjacent destroy and allocation!
                        let destroy_sym = child.payload
                        let alloc_sym = next_node.payload
                        if destroy_sym != 0 as u32 and alloc_sym != 0 as u32:
                            let sym_d = self.symtable.symbols.data[destroy_sym]
                            let sym_a = self.symtable.symbols.data[alloc_sym]
                            if sym_d.type_id == sym_a.type_id:
                                // Optimize by converting to NODE_ALIAS_STMT!
                                // For simplicity, we flag FlagUsesArena or custom reuse in the AST.
                                self.tree.nodes.data[next_idx].flags = self.tree.nodes.data[next_idx].flags | (FLAG_IS_MOVED as u16)
            
            self.optimize_node(child_idx)
            child_idx = self.tree.nodes.data[child_idx].next_sibling
    else:
        mut child_idx := node.first_child
        while child_idx != 0 as u32:
            self.optimize_node(child_idx)
            child_idx = self.tree.nodes.data[child_idx].next_sibling
// bootstrap/stage1/air.ax
// SSA-form Intermediate Representation (AIR) structures and builders for the self-hosted AXIOM compiler frontend.

pub const OP_NOP: u16 = 0x0000

// Memory class (0x01xx)
pub const OP_ALLOC: u16 = 0x0101
pub const OP_FREE: u16 = 0x0102
pub const OP_LOAD: u16 = 0x0103
pub const OP_STORE: u16 = 0x0104
pub const OP_GEP: u16 = 0x0105
pub const OP_COPY: u16 = 0x0106
pub const OP_MOVE: u16 = 0x0107
pub const OP_MAKE_REF: u16 = 0x0108
pub const OP_DEREF: u16 = 0x0109
pub const OP_ARENA_ALLOC: u16 = 0x010A
pub const OP_DESTROY: u16 = 0x010B
pub const OP_ALIAS_REUSE: u16 = 0x010C
pub const OP_GET_FIELD: u16 = 0x010D
pub const OP_SET_FIELD: u16 = 0x010E
pub const OP_INDEX: u16 = 0x010F
pub const OP_SLICE: u16 = 0x0110

// ALU class (0x02xx)
pub const OP_ICONST: u16 = 0x0201
pub const OP_FCONST: u16 = 0x0202
pub const OP_IADD: u16 = 0x0203
pub const OP_ISUB: u16 = 0x0204
pub const OP_IMUL: u16 = 0x0205
pub const OP_IDIV: u16 = 0x0206
pub const OP_IMOD: u16 = 0x0207
pub const OP_FADD: u16 = 0x0208
pub const OP_FSUB: u16 = 0x0209
pub const OP_FMUL: u16 = 0x020A
pub const OP_FDIV: u16 = 0x020B
pub const OP_EQ: u16 = 0x020C
pub const OP_NE: u16 = 0x020D
pub const OP_LT: u16 = 0x020E
pub const OP_LE: u16 = 0x020F
pub const OP_GT: u16 = 0x0210
pub const OP_GE: u16 = 0x0211
pub const OP_AND: u16 = 0x0212
pub const OP_OR: u16 = 0x0213
pub const OP_XOR: u16 = 0x0214
pub const OP_SHL: u16 = 0x0215
pub const OP_SHR: u16 = 0x0216
pub const OP_NOT: u16 = 0x0217
pub const OP_NEG: u16 = 0x021D
pub const OP_ITOF: u16 = 0x021E
pub const OP_FTOI: u16 = 0x021F
pub const OP_ZEXT: u16 = 0x0220
pub const OP_SEXT: u16 = 0x0221
pub const OP_TRUNC: u16 = 0x0222
pub const OP_CAST: u16 = 0x0223

// Control class (0x03xx)
pub const OP_JUMP: u16 = 0x0301
pub const OP_BRANCH: u16 = 0x0302
pub const OP_CALL: u16 = 0x0303
pub const OP_RETURN: u16 = 0x0304
pub const OP_PHI: u16 = 0x0305
pub const OP_LOOP_BEGIN: u16 = 0x0306
pub const OP_LOOP_END: u16 = 0x0307
pub const OP_SPAWN: u16 = 0x0308
pub const OP_SEND: u16 = 0x0309
pub const OP_RECV: u16 = 0x030A
pub const OP_AWAIT: u16 = 0x030B

// SIMD class (0x04xx)
pub const OP_SIMD_LOAD: u16 = 0x0401
pub const OP_SIMD_STORE: u16 = 0x0402
pub const OP_SIMD_ADD: u16 = 0x0403
pub const OP_SIMD_MUL: u16 = 0x0404
pub const OP_SIMD_FMA: u16 = 0x0405

// Comptime class (0x05xx)
pub const OP_COMPTIME: u16 = 0x0501

// AirInst struct. Layout is FROZEN at 16 bytes.
pub struct AirInst:
    pub opcode: u16
    pub type_id: u16
    pub dest: u32
    pub src1: u32
    pub src2: u32

// Custom monomorphic vectors for AIR builder
pub struct AirInstVec:
    pub data: ptr[AirInst]
    pub len: i64
    pub cap: i64

pub fn new_air_inst_vec() -> AirInstVec:
    return AirInstVec(data: null as ptr[AirInst], len: 0, cap: 0)

pub fn push(mut self: AirInstVec, inst: AirInst) -> u32:
    if self.len == self.cap:
        mut new_cap := 16 as i64
        if self.cap != 0:
            new_cap = self.cap * 2
        let new_data = @alloc(new_cap * 16) as ptr[AirInst]
        if self.data != null as ptr[AirInst]:
            @memcpy(new_data as ptr[u8], self.data as ptr[u8], self.len * 16)
            @free(self.data as ptr[u8])
        self.data = new_data
        self.cap = new_cap
    let idx = self.len as u32
    self.data[self.len] = inst
    self.len = self.len + 1
    return idx

pub struct BasicBlock:
    pub id: u32
    pub instrs_start: u32
    pub instrs_len: u32
    pub succs_start: u32
    pub succs_len: u32
    pub preds_start: u32
    pub preds_len: u32
    pub loop_depth: u8
    pub is_entry: bool
    pub is_exit: bool

pub struct BasicBlockVec:
    pub data: ptr[BasicBlock]
    pub len: i64
    pub cap: i64

pub fn new_basic_block_vec() -> BasicBlockVec:
    return BasicBlockVec(data: null as ptr[BasicBlock], len: 0, cap: 0)

pub fn push(mut self: BasicBlockVec, bb: BasicBlock) -> u32:
    if self.len == self.cap:
        mut new_cap := 16 as i64
        if self.cap != 0:
            new_cap = self.cap * 2
        let new_data = @alloc(new_cap * 32) as ptr[BasicBlock]
        if self.data != null as ptr[BasicBlock]:
            @memcpy(new_data as ptr[u8], self.data as ptr[u8], self.len * 32)
            @free(self.data as ptr[u8])
        self.data = new_data
        self.cap = new_cap
    let idx = self.len as u32
    self.data[self.len] = bb
    self.len = self.len + 1
    return idx


pub struct AirFunc:
    pub sym_id: u32
    pub name: u32
    pub params: U32Vec
    pub ret_type: u32
    pub blocks: BasicBlockVec
    pub insts: AirInstVec
    pub extras: U32Vec
    pub is_async: bool
    pub is_extern: bool
    // Flat block data storage
    pub block_instrs: U32Vec
    pub block_succs: U32Vec
    pub block_preds: U32Vec

pub fn free_air_func(mut f: AirFunc):
    if f.params.data != null as ptr[u32]:
        @free(f.params.data as ptr[u8])
    if f.blocks.data != null as ptr[BasicBlock]:
        @free(f.blocks.data as ptr[u8])
    if f.insts.data != null as ptr[AirInst]:
        @free(f.insts.data as ptr[u8])
    if f.extras.data != null as ptr[u32]:
        @free(f.extras.data as ptr[u8])
    if f.block_instrs.data != null as ptr[u32]:
        @free(f.block_instrs.data as ptr[u8])
    if f.block_succs.data != null as ptr[u32]:
        @free(f.block_succs.data as ptr[u8])
    if f.block_preds.data != null as ptr[u32]:
        @free(f.block_preds.data as ptr[u8])

pub struct AirFuncVec:
    pub data: ptr[AirFunc]
    pub len: i64
    pub cap: i64

pub fn new_air_func_vec() -> AirFuncVec:
    return AirFuncVec(data: null as ptr[AirFunc], len: 0, cap: 0)

pub fn push(mut self: AirFuncVec, f: AirFunc) -> u32:
    if self.len == self.cap:
        mut new_cap := 16 as i64
        if self.cap != 0:
            new_cap = self.cap * 2
        let new_data = @alloc(new_cap * 192) as ptr[AirFunc]
        if self.data != null as ptr[AirFunc]:
            @memcpy(new_data as ptr[u8], self.data as ptr[u8], self.len * 192)
            @free(self.data as ptr[u8])
        self.data = new_data
        self.cap = new_cap
    let idx = self.len as u32
    self.data[self.len] = f
    self.len = self.len + 1
    return idx

pub struct AirModule:
    pub funcs: AirFuncVec

pub fn free_air_module(mut m: AirModule):
    mut i := 0 as i64
    while i < m.funcs.len:
        free_air_func(m.funcs.data[i])
        i = i + 1
    if m.funcs.data != null as ptr[AirFunc]:
        @free(m.funcs.data as ptr[u8])

pub struct AirFuncBuilder:
    pub name: u32
    pub ret_type: u32
    pub blocks: BasicBlockVec
    pub insts: AirInstVec
    pub extras: U32Vec
    pub cur_block: i32
    pub next_reg: u32
    // Flat block data builders
    pub block_instrs: U32Vec
    pub block_succs: U32Vec
    pub block_preds: U32Vec

pub fn new_air_func_builder(name: u32, ret_type: u32) -> AirFuncBuilder:
    mut builder := AirFuncBuilder(
        name: name,
        ret_type: ret_type,
        blocks: new_basic_block_vec(),
        insts: new_air_inst_vec(),
        extras: new_u32_vec(),
        cur_block: -1 as i32,
        next_reg: 1 as u32, // register 0 is NoValue
        block_instrs: new_u32_vec(),
        block_succs: new_u32_vec(),
        block_preds: new_u32_vec(),
    )
    let entry_id = builder.new_block()
    builder.blocks.data[entry_id].is_entry = true
    builder.switch_to(entry_id)
    return builder

pub fn new_block(mut self: AirFuncBuilder) -> u32:
    let id = self.blocks.len as u32
    self.blocks.push(BasicBlock(
        id: id,
        instrs_start: 0 as u32,
        instrs_len: 0 as u32,
        succs_start: 0 as u32,
        succs_len: 0 as u32,
        preds_start: 0 as u32,
        preds_len: 0 as u32,
        loop_depth: 0 as u8,
        is_entry: false,
        is_exit: false,
    ))
    return id

pub fn switch_to(mut self: AirFuncBuilder, block_id: u32):
    self.cur_block = block_id as i32

pub fn current_block(self: AirFuncBuilder) -> u32:
    if self.cur_block < 0:
        return 0xffffffff as u32
    return self.cur_block as u32

pub fn emit(mut self: AirFuncBuilder, inst: AirInst) -> u32:
    let idx = self.insts.push(inst)
    if self.cur_block >= 0 and (self.cur_block as i64) < self.blocks.len:
        mut bb := &self.blocks.data[self.cur_block]
        if bb.instrs_len == 0:
            bb.instrs_start = self.block_instrs.len as u32
        self.block_instrs.push(idx)
        bb.instrs_len = bb.instrs_len + 1 as u32
    return idx

pub fn emit_extra(mut self: AirFuncBuilder, val: u32) -> u32:
    return self.extras.push(val)

pub fn set_extra(mut self: AirFuncBuilder, idx: u32, val: u32):
    if (idx as i64) < self.extras.len:
        self.extras.data[idx] = val

pub fn fresh_reg(mut self: AirFuncBuilder) -> u32:
    let r = self.next_reg
    self.next_reg = self.next_reg + 1 as u32
    return r

pub fn add_edge(mut self: AirFuncBuilder, src: u32, dst: u32):
    if (src as i64) < self.blocks.len and (dst as i64) < self.blocks.len:
        mut src_bb := &self.blocks.data[src]
        if src_bb.succs_len == 0:
            src_bb.succs_start = self.block_succs.len as u32
        // Append unique to flat list
        mut exists := false
        mut i := 0 as i64
        while i < src_bb.succs_len as i64:
            let idx = src_bb.succs_start as i64 + i
            if self.block_succs.data[idx] == dst:
                exists = true
            i = i + 1
        if not exists:
            self.block_succs.push(dst)
            src_bb.succs_len = src_bb.succs_len + 1 as u32

        mut dst_bb := &self.blocks.data[dst]
        if dst_bb.preds_len == 0:
            dst_bb.preds_start = self.block_preds.len as u32
        // Append unique to flat list
        exists = false
        i = 0
        while i < dst_bb.preds_len as i64:
            let idx = dst_bb.preds_start as i64 + i
            if self.block_preds.data[idx] == src:
                exists = true
            i = i + 1
        if not exists:
            self.block_preds.push(src)
            dst_bb.preds_len = dst_bb.preds_len + 1 as u32

pub fn build_func(mut self: AirFuncBuilder) -> AirFunc:
    // Mark exit blocks
    mut i := 0 as i64
    while i < self.blocks.len:
        mut blk := &self.blocks.data[i]
        if blk.instrs_len > 0:
            let last_idx_idx = blk.instrs_start as i64 + (blk.instrs_len as i64) - 1
            let last_idx = self.block_instrs.data[last_idx_idx] as i64
            if last_idx < self.insts.len and self.insts.data[last_idx].opcode == OP_RETURN:
                blk.is_exit = true
        i = i + 1

    return AirFunc(
        sym_id: 0 as u32,
        name: self.name,
        params: new_u32_vec(),
        ret_type: self.ret_type,
        blocks: self.blocks,
        insts: self.insts,
        extras: self.extras,
        is_async: false,
        is_extern: false,
        block_instrs: self.block_instrs,
        block_succs: self.block_succs,
        block_preds: self.block_preds,
    )

