    if op == OP_SLICE:
        return "slice"

    if op == OP_ICONST:
        return "iconst"
    if op == OP_FCONST:
        return "fconst"
    if op == OP_IADD:
        return "iadd"
    if op == OP_ISUB:
        return "isub"
    if op == OP_IMUL:
        return "imul"
    if op == OP_IDIV:
        return "idiv"
    if op == OP_IMOD:
        return "imod"
    if op == OP_FADD:
        return "fadd"
    if op == OP_FSUB:
        return "fsub"
    if op == OP_FMUL:
        return "fmul"
    if op == OP_FDIV:
        return "fdiv"
    if op == OP_EQ:
        return "eq"
    if op == OP_NE:
        return "ne"
    if op == OP_LT:
        return "lt"
    if op == OP_LE:
        return "le"
    if op == OP_GT:
        return "gt"
    if op == OP_GE:
        return "ge"
    if op == OP_AND:
        return "and"
    if op == OP_OR:
        return "or"
    if op == OP_XOR:
        return "xor"
    if op == OP_SHL:
        return "shl"
    if op == OP_SHR:
        return "shr"
    if op == OP_NOT:
        return "not"
    if op == OP_NEG:
        return "neg"
    if op == OP_ITOF:
        return "itof"
    if op == OP_FTOI:
        return "ftoi"
    if op == OP_ZEXT:
        return "zext"
    if op == OP_SEXT:
        return "sext"
    if op == OP_TRUNC:
        return "trunc"
    if op == OP_CAST:
        return "cast"

    if op == OP_JUMP:
        return "jump"
    if op == OP_BRANCH:
        return "branch"
    if op == OP_CALL:
        return "call"
    if op == OP_RETURN:
        return "ret"
    if op == OP_PHI:
        return "phi"
    if op == OP_LOOP_BEGIN:
        return "loopbeg"
    if op == OP_LOOP_END:
        return "loopend"
    if op == OP_SPAWN:
        return "spawn"
    if op == OP_SEND:
        return "send"
    if op == OP_RECV:
        return "recv"
    if op == OP_AWAIT:
        return "await"
    if op == OP_SYSCALL:
        return "syscall"

    if op == OP_SIMD_LOAD:
        return "vload"
    if op == OP_SIMD_STORE:
        return "vstore"
    if op == OP_SIMD_ADD:
        return "vadd"
    if op == OP_SIMD_MUL:
        return "vmul"
    if op == OP_SIMD_FMA:
        return "vfma"

    if op == OP_COMPTIME:
        return "comptime"
    return "???"

pub fn opcode_class(op: u16) -> u16:
    return op >> 8 as u16

pub fn opcode_is_binary_alu(op: u16) -> bool:
    if op == OP_IADD:
        return true
    if op == OP_ISUB:
        return true
    if op == OP_IMUL:
        return true
    if op == OP_IDIV:
        return true
    if op == OP_IMOD:
        return true
    if op == OP_FADD:
        return true
    if op == OP_FSUB:
        return true
    if op == OP_FMUL:
        return true
    if op == OP_FDIV:
        return true
    if op == OP_EQ:
        return true
    if op == OP_NE:
        return true
    if op == OP_LT:
        return true
    if op == OP_LE:
        return true
    if op == OP_GT:
        return true
    if op == OP_GE:
        return true
    if op == OP_AND:
        return true
    if op == OP_OR:
        return true
    if op == OP_XOR:
        return true
    if op == OP_SHL:
        return true
    if op == OP_SHR:
        return true
    return false
// bootstrap/stage1/air_builder.ax
// SSA-form Intermediate Representation (AIR) builder for self-hosted AXIOM frontend.


// extern "C" fn printf(fmt: str, a1: i64, a2: i64, a3: i64, a4: i64, a5: i64, a6: i64, a7: i64, a8: i64) -> i32
extern "C" fn atof(s: ptr[u8]) -> f64

pub struct LocalMapEntry:
    pub name_id: u32
    pub reg: u32

pub struct LocalMap:
    pub entries: ptr[LocalMapEntry]
    pub count: u32
    pub capacity: u32

pub fn new_local_map() -> ptr[LocalMap]:
    let capacity = 16 as u32
    let entries = @alloc(capacity as i64 * 8) as ptr[LocalMapEntry]
    mut i := 0 as i64
    while i < capacity as i64:
        entries[i] = LocalMapEntry(name_id: 0 as u32, reg: 0 as u32)
        i = i + 1
    let lm = @alloc(@compiler_intrinsic("size_of")[LocalMap]()) as ptr[LocalMap]
    lm.entries = entries
    lm.count = 0 as u32
    lm.capacity = capacity
    return lm

pub fn free_local_map(mut self: ptr[LocalMap]):
    if self.entries != null as ptr[LocalMapEntry]:
        @free(self.entries as ptr[u8])

fn local_map_hash(v: u32) -> u32:
    mut hash := 2166136261 as u32
    hash = hash ^ (v & 255 as u32)
    hash = hash * 16777619 as u32
    hash = hash ^ ((v >> 8 as u32) & 255 as u32)
    hash = hash * 16777619 as u32
    hash = hash ^ ((v >> 16 as u32) & 255 as u32)
    hash = hash * 16777619 as u32
    hash = hash ^ ((v >> 24 as u32) & 255 as u32)
    hash = hash * 16777619 as u32
    return hash

pub fn local_map_put(mut self: ptr[LocalMap], name_id: u32, reg: u32):
    if self.count * 4 as u32 > self.capacity * 3 as u32:
        self.local_map_grow()
    self.local_map_insert(name_id, reg)
    self.count = self.count + 1 as u32

fn local_map_insert(self: ptr[LocalMap], name_id: u32, reg: u32):
    let mask = self.capacity - 1 as u32
    mut idx = local_map_hash(name_id) & mask
    while true:
        if self.entries[idx].name_id == 0 as u32 or self.entries[idx].name_id == name_id:
            self.entries[idx].name_id = name_id
            self.entries[idx].reg = reg
            return
        idx = (idx + 1 as u32) & mask

pub fn local_map_get(self: ptr[LocalMap], name_id: u32) -> u32:
    if self.capacity == 0 as u32:
        return 0 as u32
    let mask = self.capacity - 1 as u32
    mut idx = local_map_hash(name_id) & mask
    let start_idx = idx
    while true:
        let entry = self.entries[idx]
        if entry.name_id == 0 as u32:
            return 0 as u32
        if entry.name_id == name_id:
            return entry.reg
        idx = (idx + 1 as u32) & mask
        if idx == start_idx:
            break
    return 0 as u32

fn local_map_grow(mut self: ptr[LocalMap]):
    let old_entries = self.entries
    let old_capacity = self.capacity
    let new_cap = old_capacity * 2 as u32
    self.capacity = new_cap
    self.entries = @alloc(new_cap as i64 * 8) as ptr[LocalMapEntry]
    mut i := 0 as i64
    while i < new_cap as i64:
        self.entries[i] = LocalMapEntry(name_id: 0 as u32, reg: 0 as u32)
        i = i + 1

    i = 0 as i64
    while i < old_capacity as i64:
        let entry = old_entries[i]
        if entry.name_id != 0 as u32:
            self.local_map_insert(entry.name_id, entry.reg)
        i = i + 1
    @free(old_entries as ptr[u8])

pub struct AirModuleBuilder:
    pub tree: ptr[AstTree]
    pub symbols: ptr[SymbolTable]
    pub typetable: ptr[TypeTable]
    pub pool: ptr[InternPool]
    pub module: AirModule
    pub node_types: ptr[u32]

pub fn new_air_module_builder(tree: ptr[AstTree], symbols: ptr[SymbolTable], typetable: ptr[TypeTable], pool: ptr[InternPool], node_types: ptr[u32]) -> ptr[AirModuleBuilder]:
    let amb = @alloc(@compiler_intrinsic("size_of")[AirModuleBuilder]()) as ptr[AirModuleBuilder]
    amb.tree = tree
    amb.symbols = symbols
    amb.typetable = typetable
    amb.pool = pool
    amb.module = AirModule(funcs: new_air_func_vec())
    amb.node_types = node_types
    return amb

pub fn free_air_module_builder(self: ptr[AirModuleBuilder]):
    free_air_module(self.module)

pub fn get_token_text(self: ptr[AirModuleBuilder], token_idx: u32) -> str:
    let tok = self.tree.tokens.data[token_idx as i64]
    if tok.len == 0 as u16:
        return alloc_str_from_raw(null as ptr[u8], 0)
    let start_ptr = ((get_str_ptr(self.tree.src)) as i64 + tok.offset as i64) as ptr[u8]
    return alloc_str_from_raw(start_ptr, tok.len as i64)

pub fn parse_int_from_str(s: str) -> i64:
    let len = std.string.len(s)
    if len == 0:
        return 0 as i64
    mut i := 0
    mut sign := 1 as i64
    if s[0] as u8 == '-' as u8:
        sign = -1 as i64
        i = 1
    elif s[0] as u8 == '+' as u8:
        i = 1

    mut base := 10 as i64
    if i + 1 < len and s[i] as u8 == '0' as u8:
        let next_char = s[i + 1] as u8
        if next_char == 'x' as u8 or next_char == 'X' as u8:
            base = 16 as i64
            i = i + 2
        elif next_char == 'o' as u8 or next_char == 'O' as u8:
            base = 8 as i64
            i = i + 2
        elif next_char == 'b' as u8 or next_char == 'B' as u8:
            base = 2 as i64
            i = i + 2

    mut val := 0 as i64
    while i < len:
        let c = s[i] as u8
        mut digit := -1 as i64
        if c >= '0' as u8 and c <= '9' as u8:
            digit = (c - '0' as u8) as i64
        elif c >= 'a' as u8 and c <= 'f' as u8:
            digit = (c - 'a' as u8 + 10 as u8) as i64
        elif c >= 'A' as u8 and c <= 'F' as u8:
            digit = (c - 'A' as u8 + 10 as u8) as i64

        if digit < 0 or digit >= base:
            break

        val = val * base + digit
        i = i + 1

    return val * sign

pub fn map_binary_op(op: str) -> u16:
    if op == "+":
        return OP_IADD
    if op == "-":
        return OP_ISUB
    if op == "*":
        return OP_IMUL
    if op == "/":
        return OP_IDIV
    if op == "%":
        return OP_IMOD
    if op == "==":
        return OP_EQ
    if op == "!=":
        return OP_NE
    if op == "<":
        return OP_LT
    if op == "<=":
        return OP_LE
    if op == ">":
        return OP_GT
    if op == ">=":
        return OP_GE
    if op == "and" or op == "&&" or op == "&":
        return OP_AND
    if op == "or" or op == "||" or op == "|":
        return OP_OR
    if op == "^":
        return OP_XOR
    if op == "<<":
        return OP_SHL
    if op == ">>":
        return OP_SHR
    return OP_NOP

pub struct FuncLowering:
    pub mb: ptr[AirModuleBuilder]
    pub fb: ptr[AirFuncBuilder]
    pub locals: ptr[LocalMap]
    pub params: U32Vec
    pub terminated: bool
    pub loop_conds: U32Vec
    pub loop_exits: U32Vec

pub fn new_func_lowering(mb: ptr[AirModuleBuilder], fb: ptr[AirFuncBuilder], params: U32Vec) -> ptr[FuncLowering]:
    let fl = @alloc(@compiler_intrinsic("size_of")[FuncLowering]()) as ptr[FuncLowering]
    fl.mb = mb
    fl.fb = fb
    fl.locals = new_local_map()
    fl.params = params
    fl.terminated = false
    fl.loop_conds = new_u32_vec()
    fl.loop_exits = new_u32_vec()
    return fl

pub fn free_func_lowering(mut self: ptr[FuncLowering]):
    free_local_map(self.locals)
    if self.params.data != null as ptr[u32]:
        @free(self.params.data as ptr[u8])
    if self.loop_conds.data != null as ptr[u32]:
        @free(self.loop_conds.data as ptr[u8])
    if self.loop_exits.data != null as ptr[u32]:
        @free(self.loop_exits.data as ptr[u8])

pub fn register_params(mut self: ptr[FuncLowering], func_idx: u32, func_node: AstNode):
    mut child := func_node.first_child
    mut param_idx := 0 as i64
    while child != 0 as u32:
        let cn = self.mb.tree.nodes.data[child as i64]
        if cn.kind == NODE_PARAM_DECL:
            mut name_id := cn.payload
            if name_id == 0 as u32:
                let tok_str = self.mb.get_token_text(cn.token_idx)
                name_id = self.mb.pool.intern(tok_str)
                @free(get_str_ptr(tok_str))

            let reg = self.fb.fresh_reg()
            mut type_id := 0 as u32
            if param_idx < self.params.len:
                type_id = self.params.data[param_idx] as u32

            self.fb.emit(AirInst(
                opcode: OP_COPY,
                type_id: type_id,
                dest: reg,
                src1: (param_idx + 1) as u32,
                src2: 0 as u32,
            ))

            self.locals.local_map_put(name_id, reg)
            param_idx = param_idx + 1
        child = cn.next_sibling

pub fn builder_type_size_and_align(table: ptr[TypeTable], type_id: u32, out_size: ptr[u32], out_align: ptr[u32]):
    if type_id == 0 as u32:
        out_size[0] = 8 as u32
        out_align[0] = 8 as u32
        return

    mut entry := &table.entries.data[type_id]
    if entry.size != 0 as u32:
        out_size[0] = entry.size
        out_align[0] = entry.align
        return

    if entry.kind == TYPE_KIND_PRIMITIVE:
        out_size[0] = entry.size
        out_align[0] = entry.align
        return
    elif entry.kind == TYPE_KIND_STRUCT or entry.kind == TYPE_KIND_GENERIC_INST:
        mut struct_idx := entry.extra
        if entry.kind == TYPE_KIND_GENERIC_INST:
            mut idx := 0 as i64
            while idx < table.entries.len:
                let e = table.entries.data[idx]
                if e.kind == TYPE_KIND_STRUCT and e.name_id == entry.name_id:
                    struct_idx = e.extra
                    break
                idx = idx + 1
        let info = table.structs.data[struct_idx]
        mut offset := 0 as u32
        mut max_align := 1 as u32
        mut i := 0 as i64
        while i < info.fields.len:
            let f = info.fields.data[i]
            mut f_size := 0 as u32
            mut f_align := 0 as u32
            builder_type_size_and_align(table, f.type_id, &f_size, &f_align)
            if f_align == 0 as u32:
                f_align = 8 as u32
            // Align offset
            offset = (offset + f_align - 1 as u32) & ~(f_align - 1 as u32)
            offset = offset + f_size
            if f_align > max_align:
                max_align = f_align
            i = i + 1
        
        mut size := (offset + max_align - 1 as u32) & ~(max_align - 1 as u32)
        if size == 0 as u32:
            size = 8 as u32
        entry.size = size
        entry.align = max_align
        out_size[0] = size
        out_align[0] = max_align
    elif entry.kind == TYPE_KIND_ARRAY:
        let elem_id = entry.extra
        let length = entry.name_id
        mut elem_size := 0 as u32
        mut elem_align := 0 as u32
        builder_type_size_and_align(table, elem_id, &elem_size, &elem_align)
        let size = elem_size * length
        entry.size = size
        entry.align = elem_align
        out_size[0] = size
        out_align[0] = elem_align
    else:
        out_size[0] = 8 as u32
        out_align[0] = 8 as u32

pub fn try_lower_sizeof(mut self: ptr[FuncLowering], idx: u32) -> u32:
    let node = self.mb.tree.nodes.data[idx as i64]
    if node.kind != NODE_CALL_EXPR:
        return 0 as u32
    
    let callee_idx = node.first_child
    if callee_idx == 0 as u32:
        return 0 as u32
    let callee_node = self.mb.tree.nodes.data[callee_idx as i64]
    if callee_node.kind != NODE_INDEX_EXPR:
        return 0 as u32
        
    let inner_call_idx = callee_node.first_child
    if inner_call_idx == 0 as u32:
        return 0 as u32
    let inner_call_node = self.mb.tree.nodes.data[inner_call_idx as i64]
    if inner_call_node.kind != NODE_CALL_EXPR:
        return 0 as u32
        
    let inner_callee_idx = inner_call_node.first_child
    if inner_callee_idx == 0 as u32:
        return 0 as u32
    let inner_callee_node = self.mb.tree.nodes.data[inner_callee_idx as i64]
    if inner_callee_node.kind != NODE_IDENT:
        return 0 as u32
        
    let inner_callee_name = self.mb.get_token_text(inner_callee_node.token_idx)
    let is_intrinsic = (inner_callee_name == "compiler_intrinsic" or inner_callee_name == "@compiler_intrinsic")
    @free(get_str_ptr(inner_callee_name))
    if not is_intrinsic:
        return 0 as u32
        
    // Check if the argument is "size_of"
    let arg_idx = self.mb.tree.nodes.data[inner_callee_idx as i64].next_sibling
    if arg_idx == 0 as u32:
        return 0 as u32
    let arg_node = self.mb.tree.nodes.data[arg_idx as i64]
    if arg_node.kind != NODE_STRING_LIT:
        return 0 as u32
        
    let arg_text = self.mb.get_token_text(arg_node.token_idx)
    let is_sizeof = (arg_text == "\"size_of\"" or arg_text == "'size_of'" or arg_text == "size_of")
    @free(get_str_ptr(arg_text))
    if not is_sizeof:
        return 0 as u32
        
    // The type node is the index of the index expr (next sibling of the inner call)
    let type_node_idx = self.mb.tree.nodes.data[inner_call_idx as i64].next_sibling
    if type_node_idx == 0 as u32 or type_node_idx == 0xffffffff as u32 or (type_node_idx as i64) >= self.mb.tree.nodes.len:
        return 0 as u32
        
    let type_node = self.mb.tree.nodes.data[type_node_idx as i64]
        
    mut target_type := 0 as u32
    if self.mb.node_types != null as ptr[u32]:
        target_type = self.mb.node_types[type_node_idx as i64]
    if target_type == 0 as u32:
        let sym_idx = type_node.payload
        if sym_idx != 0 as u32 and (sym_idx as i64) < self.mb.symbols.symbols.len:
            target_type = self.mb.symbols.symbols.data[sym_idx as i64].type_id
            
    mut size := 0 as u32
    mut align := 0 as u32
    if target_type == 0 as u32:
        size = 8 as u32
    elif (target_type as i64) >= self.mb.typetable.entries.len:
        size = 8 as u32
    else:
        builder_type_size_and_align(self.mb.typetable, target_type, &size, &align)
    
    // Emit an OP_ICONST with the evaluated size!
    let reg = self.fb.fresh_reg()
    self.fb.emit(AirInst(
        opcode: OP_ICONST,
        type_id: 4 as u32, // i64
        dest: reg,
        src1: size,
        src2: 0 as u32,
    ))
    return reg

pub fn lower_expr(mut self: ptr[FuncLowering], idx: u32) -> u32:
    if idx == 0 as u32:
        return 0 as u32
        
    let sizeof_reg = self.try_lower_sizeof(idx)
    if sizeof_reg != 0 as u32:
        return sizeof_reg
        
    let node = self.mb.tree.nodes.data[idx as i64]
    if node.kind == NODE_INT_LIT:
        return self.lower_int_lit(idx, node)
    if node.kind == NODE_FLOAT_LIT:
        return self.lower_float_lit(idx, node)
    if node.kind == NODE_BOOL_LIT:
        return self.lower_bool_lit(node)
    if node.kind == NODE_NIL_LIT:
        return self.lower_nil_lit()
    if node.kind == NODE_STRING_LIT:
        return self.lower_string_lit(node)
    if node.kind == NODE_CHAR_LIT:
        return self.lower_char_lit(node)
    if node.kind == NODE_IDENT:
        return self.lower_ident(node)
    if node.kind == NODE_BINARY_EXPR:
        return self.lower_binary_expr(idx, node)
    if node.kind == NODE_UNARY_EXPR:
        return self.lower_unary_expr(idx, node)
    if node.kind == NODE_CALL_EXPR:
        return self.lower_call_expr(idx, node)
    if node.kind == NODE_FIELD_EXPR:
        return self.lower_field_expr(idx, node)
    if node.kind == NODE_INDEX_EXPR:
        return self.lower_index_expr(idx, node)
    if node.kind == NODE_CAST_EXPR:
        return self.lower_cast_expr(idx, node)
    if node.kind == NODE_DEREF_EXPR:
        return self.lower_deref_expr(idx, node)
    if node.kind == NODE_SPAWN_EXPR:
        return self.lower_spawn_expr(idx, node)
    if node.kind == NODE_AWAIT_EXPR:
        return self.lower_await_expr(idx, node)
    if node.kind == NODE_STRUCT_LIT:
        return self.lower_struct_lit(idx, node)
    if node.kind == NODE_ARRAY_LIT:
        return self.lower_array_lit(idx, node)
    return 0 as u32

pub fn lower_int_lit(mut self: ptr[FuncLowering], idx: u32, node: AstNode) -> u32:
    let reg = self.fb.fresh_reg()
    let text = self.mb.get_token_text(node.token_idx)
    let val = parse_int_from_str(text)
    @free(get_str_ptr(text))

    mut type_id := 3 as u32 // default i32
    if self.mb.node_types != null as ptr[u32] and self.mb.node_types[idx as i64] != 0 as u32:
        type_id = self.mb.node_types[idx as i64] as u32

    self.fb.emit(AirInst(
        opcode: OP_ICONST,
        type_id: type_id,
        dest: reg,
        src1: val as u32,
        src2: 0 as u32,
    ))
    return reg

pub fn lower_float_lit(mut self: ptr[FuncLowering], idx: u32, node: AstNode) -> u32:
    let reg = self.fb.fresh_reg()
    let text = self.mb.get_token_text(node.token_idx)
    let val = atof(get_str_ptr(text))
    @free(get_str_ptr(text))

    mut type_id := 10 as u32 // default f64
    if self.mb.node_types != null as ptr[u32] and self.mb.node_types[idx as i64] != 0 as u32:
        type_id = self.mb.node_types[idx as i64] as u32

    self.fb.emit(AirInst(
        opcode: OP_FCONST,
        type_id: type_id,
        dest: reg,
        src1: val as u32,
        src2: 0 as u32,
    ))
    return reg

pub fn lower_bool_lit(mut self: ptr[FuncLowering], node: AstNode) -> u32:
    let reg = self.fb.fresh_reg()
    let text = self.mb.get_token_text(node.token_idx)
    mut val := 0 as u32
    if text == "true":
        val = 1 as u32
    @free(get_str_ptr(text))

    self.fb.emit(AirInst(
        opcode: OP_ICONST,
        type_id: 11 as u32, // bool
        dest: reg,
        src1: val,
        src2: 0 as u32,
    ))
    return reg

pub fn lower_nil_lit(mut self: ptr[FuncLowering]) -> u32:
    let reg = self.fb.fresh_reg()
    self.fb.emit(AirInst(
        opcode: OP_ICONST,
        type_id: 0 as u32,
        dest: reg,
        src1: 0 as u32,
        src2: 0 as u32,
    ))
    return reg

pub fn lower_string_lit(mut self: ptr[FuncLowering], node: AstNode) -> u32:
    let reg = self.fb.fresh_reg()
    let text = self.mb.get_token_text(node.token_idx)
    let str_id = self.mb.pool.intern(text)
    @free(get_str_ptr(text))

    self.fb.emit(AirInst(
        opcode: OP_ICONST,
        type_id: 12 as u32, // string
        dest: reg,
        src1: str_id,
        src2: 0 as u32,
    ))
    return reg

pub fn lower_char_lit(mut self: ptr[FuncLowering], node: AstNode) -> u32:
    let reg = self.fb.fresh_reg()
    let text = self.mb.get_token_text(node.token_idx)
    mut val := 0 as u32
    let length = std.string.len(text)
    if length > 0:
        if length >= 3 and text[0] as u8 == '\'' as u8 and text[length - 1] as u8 == '\'' as u8:
            if text[1] as u8 == '\\' as u8 and length >= 4:
                let esc = text[2] as u8
                if esc == 'n' as u8:
                    val = 10 as u32
                elif esc == 't' as u8:
                    val = 9 as u32
                elif esc == 'r' as u8:
                    val = 13 as u32
                elif esc == '\'' as u8:
                    val = 39 as u32
                elif esc == '\\' as u8:
                    val = 92 as u32
                elif esc == '0' as u8:
                    val = 0 as u32
                elif esc == 'b' as u8:
                    val = 8 as u32
                elif esc == 'f' as u8:
                    val = 12 as u32
                else:
                    val = esc as u32
            else:
                val = text[1] as u32
    @free(get_str_ptr(text))

    self.fb.emit(AirInst(
        opcode: OP_ICONST,
        type_id: 13 as u32, // char8
        dest: reg,
        src1: val,
        src2: 0 as u32,
    ))
    return reg

pub fn lower_ident(mut self: ptr[FuncLowering], node: AstNode) -> u32:
    let text = self.mb.get_token_text(node.token_idx)
    if text == "null" or text == "nil":
        @free(get_str_ptr(text))
        return self.lower_nil_lit()
    let actual_name_id = self.mb.pool.intern(text)
    @free(get_str_ptr(text))

    mut is_resolved := false
    mut sym_idx := 0 as u32
    if node.payload != 0 as u32 and (node.payload as i64) < self.mb.symbols.symbols.len:
        let sym = self.mb.symbols.symbols.data[node.payload as i64]
        if sym.name_id == actual_name_id:
            is_resolved = true
            sym_idx = node.payload

    if is_resolved:
        let sym = self.mb.symbols.symbols.data[sym_idx as i64]
        if sym.kind == SYM_CONST:
            mut init_expr := 0 as u32
            mut child := self.mb.tree.nodes.data[sym.decl_node as i64].first_child
            while child != 0 as u32:
                let child_node = self.mb.tree.nodes.data[child as i64]
                if child_node.kind != NODE_TYPE_EXPR and child_node.kind != NODE_GENERIC_TYPE:
                    init_expr = child
                child = child_node.next_sibling
            if init_expr != 0 as u32:
                return self.lower_expr(init_expr)
            return 0 as u32

        if sym.kind != SYM_VAR and sym.kind != SYM_PARAM:
            return 0 as u32
        let reg = self.locals.local_map_get(sym_idx)
        return reg

    return 0 as u32

pub fn lower_binary_expr(mut self: ptr[FuncLowering], idx: u32, node: AstNode) -> u32:
    let child = node.first_child
    if child == 0 as u32:
        return 0 as u32
    let lhs_reg = self.lower_expr(child)

    let rhs_idx = self.mb.tree.nodes.data[child as i64].next_sibling
    if rhs_idx == 0 as u32:
        return lhs_reg

    let rhs_reg = self.lower_expr(rhs_idx)

    let op_token = self.mb.get_token_text(node.token_idx)
    let opcode = map_binary_op(op_token)
    @free(get_str_ptr(op_token))

    mut type_id := 3 as u32 // default i32
    if self.mb.node_types != null as ptr[u32] and self.mb.node_types[idx as i64] != 0 as u32:
        type_id = self.mb.node_types[idx as i64] as u32

    let reg = self.fb.fresh_reg()
    self.fb.emit(AirInst(
        opcode: opcode,
        type_id: type_id,
        dest: reg,
        src1: lhs_reg,
        src2: rhs_reg,
    ))
    return reg

pub fn lower_unary_expr(mut self: ptr[FuncLowering], idx: u32, node: AstNode) -> u32:
    let child = node.first_child
    if child == 0 as u32:
        return 0 as u32
    let operand_reg = self.lower_expr(child)

    let op_token = self.mb.get_token_text(node.token_idx)
    mut opcode := OP_NOP
    if op_token == "-":
        opcode = OP_NEG
    elif op_token == "not" or op_token == "!":
        opcode = OP_NOT
    elif op_token == "~":
        opcode = OP_NOT
    elif op_token == "&":
        opcode = OP_MAKE_REF
    @free(get_str_ptr(op_token))

    mut type_id := 3 as u32 // default i32
    if self.mb.node_types != null as ptr[u32] and self.mb.node_types[idx as i64] != 0 as u32:
        type_id = self.mb.node_types[idx as i64] as u32

    let reg = self.fb.fresh_reg()
    self.fb.emit(AirInst(
        opcode: opcode,
        type_id: type_id,
        dest: reg,
        src1: operand_reg,
        src2: 0 as u32,
    ))
    return reg

fn air_starts_with(s: str, prefix: str) -> bool:
    let s_len = std.string.len(s)
    let p_len = std.string.len(prefix)
    if s_len < p_len:
        return false
    let s_ptr = get_str_ptr(s)
    let p_ptr = get_str_ptr(prefix)
    mut i := 0 as i64
    while i < p_len:
        if s_ptr[i] != p_ptr[i]:
            return false
        i = i + 1 as i64
    return true

fn match_mangled_method_raw_bytes(pool: ptr[InternPool], sym_id: u32, method_id: u32) -> bool:
    if sym_id == method_id:
        return true
    if sym_id == 0 as u32 or method_id == 0 as u32:
        return false
        
    let sym_entry = pool.ids[sym_id as i64 - 1]
    let method_entry = pool.ids[method_id as i64 - 1]
    
    let sym_bytes = (pool.arena as i64 + sym_entry.start as i64) as ptr[u8]
    let method_bytes = (pool.arena as i64 + method_entry.start as i64) as ptr[u8]
    
    let sym_len = sym_entry.len as i64
    let method_len = method_entry.len as i64
    
    let prefix_part1 = get_str_ptr("_AX_std_")
    let prefix_part1_len = 8 as i64
    let prefix_part2_len = method_len
    let suffix_len = 2 as i64 // "__"
    
    let expected_len = prefix_part1_len + prefix_part2_len + suffix_len
    if sym_len < expected_len:
        return false
        
    // 1. Check "_AX_std_"
    mut i := 0 as i64
    while i < prefix_part1_len:
        if sym_bytes[i] != prefix_part1[i]:
            return false
        i = i + 1 as i64
        
    // 2. Check method_bytes
    mut j := 0 as i64
    while j < method_len:
        if sym_bytes[prefix_part1_len + j] != method_bytes[j]:
            return false
        j = j + 1 as i64
        
    // 3. Check "__"
    if sym_bytes[prefix_part1_len + method_len] != 95 as u8 or sym_bytes[prefix_part1_len + method_len + 1 as i64] != 95 as u8:
        return false
        
    return true

fn match_mangled_method_name(sym_name: str, method_name: str) -> bool:
    if sym_name == method_name:
        return true
    let prefix = std.string.concat("_AX_std_", method_name)
    let full_prefix = std.string.concat(prefix, "__")
    let starts := air_starts_with(sym_name, full_prefix)
    @free(get_str_ptr(prefix))
    @free(get_str_ptr(full_prefix))
    return starts

pub fn lower_call_expr(mut self: ptr[FuncLowering], idx: u32, node: AstNode) -> u32:
    let child = node.first_child
    if child == 0 as u32:
        return 0 as u32

    let callee_node = self.mb.tree.nodes.data[child as i64]

    if callee_node.kind == NODE_FIELD_EXPR:
        let field_name_id = callee_node.payload
        let field_name = self.mb.pool.get(field_name_id)
        if field_name == "new":
            mut is_collection_new := false
            let rec_node = callee_node.first_child
            if rec_node != 0 as u32:
                mut ret_type := 0 as u32
                if self.mb.node_types != null as ptr[u32]:
                    ret_type = self.mb.node_types[idx as i64]
                if ret_type != 0 as u32 and (ret_type as i64) < self.mb.typetable.entries.len:
                    let entry = self.mb.typetable.entries.data[ret_type as i64]
                    if entry.kind == TYPE_KIND_STRUCT or entry.kind == TYPE_KIND_SUM or entry.kind == TYPE_KIND_GENERIC_INST or entry.kind == TYPE_KIND_OPTION or entry.kind == TYPE_KIND_RESULT:
                        is_collection_new = true
            
            if is_collection_new:
                mut ret_type := 0 as u32
                if self.mb.node_types != null as ptr[u32]:
                    ret_type = self.mb.node_types[idx as i64]
                return self.lower_struct_constructor_call(idx, node, ret_type)
    
    if callee_node.kind == NODE_IDENT:
        let sym_idx = callee_node.payload
        if sym_idx != 0 as u32 and (sym_idx as i64) < self.mb.symbols.symbols.len:
            let name_id = self.mb.symbols.symbols.data[sym_idx as i64].name_id
            let name = self.mb.pool.get(name_id)
            if name == "compiler_intrinsic":
                let arg_idx = callee_node.next_sibling
                if arg_idx != 0 as u32:
                    let arg_node = self.mb.tree.nodes.data[arg_idx as i64]
                    if arg_node.kind == NODE_STRING_LIT:
                        let arg_text = self.mb.get_token_text(arg_node.token_idx)
                        mut lower_to_const := false
                        mut const_type := 0 as u32
                        mut const_val := 0 as u32
                        
                        if arg_text == "\"is_windows\"" or arg_text == "'is_windows'" or arg_text == "is_windows":
                            lower_to_const = true
                            const_type = 11 as u32
                            const_val = 1 as u32
                        elif arg_text == "\"is_linux\"" or arg_text == "'is_linux'" or arg_text == "is_linux":
                            lower_to_const = true
                            const_type = 11 as u32
                            const_val = 0 as u32
                        elif arg_text == "\"is_macos\"" or arg_text == "'is_macos'" or arg_text == "is_macos":
                            lower_to_const = true
                            const_type = 11 as u32
                            const_val = 0 as u32
                        elif arg_text == "\"os_name\"" or arg_text == "'os_name'" or arg_text == "os_name":
                            lower_to_const = true
                            const_type = 12 as u32
                            const_val = self.mb.pool.intern("\"windows\"")
                        elif arg_text == "\"arch_name\"" or arg_text == "'arch_name'" or arg_text == "arch_name":
                            lower_to_const = true
                            const_type = 12 as u32
                            const_val = self.mb.pool.intern("\"x86_64\"")
                        elif arg_text == "\"path_separator\"" or arg_text == "'path_separator'" or arg_text == "path_separator":
                            lower_to_const = true
                            const_type = 12 as u32
                            const_val = self.mb.pool.intern("\"\\\\\"")
                        
                        if lower_to_const:
                            @free(get_str_ptr(arg_text))
                            let reg = self.fb.fresh_reg()
                            self.fb.emit(AirInst(
                                opcode: OP_ICONST,
                                type_id: const_type,
                                dest: reg,
                                src1: const_val,
                                src2: 0 as u32,
                            ))
                            return reg
                        @free(get_str_ptr(arg_text))
    
    // Check if callee is a constant â€” if so, inline the value rather than calling
    if callee_node.kind == NODE_IDENT:
        let const_sym_idx = callee_node.payload
        if const_sym_idx != 0 as u32 and (const_sym_idx as i64) < self.mb.symbols.symbols.len:
            let const_sym = self.mb.symbols.symbols.data[const_sym_idx as i64]
            if const_sym.kind == SYM_CONST:
                // Inline the constant value by lowering its initializer expression
                mut init_expr := 0 as u32
                mut const_child := self.mb.tree.nodes.data[const_sym.decl_node as i64].first_child
                while const_child != 0 as u32:
                    let const_child_node = self.mb.tree.nodes.data[const_child as i64]
                    if const_child_node.kind != NODE_TYPE_EXPR and const_child_node.kind != NODE_GENERIC_TYPE:
                        init_expr = const_child
                    const_child = const_child_node.next_sibling
                if init_expr != 0 as u32:
                    return self.lower_expr(init_expr)
                // Const with no initializer â€” return 0
                let zero_reg = self.fb.fresh_reg()
                self.fb.emit(AirInst(
                    opcode: OP_ICONST,
                    type_id: 3 as u32,
                    dest: zero_reg,
                    src1: 0 as u32,
                    src2: 0 as u32,
                ))
                return zero_reg
    
    // Check if callee is a method call on a struct
    mut is_method_call := false
    mut method_sym_idx := 0 as u32
    mut receiver_node_idx := 0 as u32
    if callee_node.kind == NODE_FIELD_EXPR:
        receiver_node_idx = callee_node.first_child
        
        if (callee_node.flags & 2048 as u16) != 0 as u16:
            let spec_sym_idx = callee_node.payload
            if spec_sym_idx != 0 as u32 and (spec_sym_idx as i64) < self.mb.symbols.symbols.len:
                let sym = self.mb.symbols.symbols.data[spec_sym_idx as i64]
                let sym_name = self.mb.pool.get(sym.name_id)
                if match_mangled_method_name(sym_name, "is_ok") or match_mangled_method_name(sym_name, "unwrap") or match_mangled_method_name(sym_name, "unwrap_err") or match_mangled_method_name(sym_name, "is_err"):
                    ax_puts_local("[CGEN-DEBUG-IS-OK-2] Found method symbol: ")
                    ax_puts_local(sym_name)
                    ax_puts_local(" | rec_type_kind=")
                    
                    mut rec_type := 0 as u32
                    if receiver_node_idx != 0 as u32:
                        if self.mb.node_types != null as ptr[u32]:
                            rec_type = self.mb.node_types[receiver_node_idx as i64]
                            
                    if rec_type != 0 as u32 and (rec_type as i64) < self.mb.typetable.entries.len:
                        let entry = self.mb.typetable.entries.data[rec_type as i64]
                        if entry.kind == TYPE_KIND_STRUCT:
                            ax_puts_local("STRUCT")
                        elif entry.kind == TYPE_KIND_SUM:
                            ax_puts_local("SUM")
                        elif entry.kind == TYPE_KIND_GENERIC_INST:
                            ax_puts_local("GENERIC_INST")
                        elif entry.kind == TYPE_KIND_OPTION:
                            ax_puts_local("OPTION")
                        elif entry.kind == TYPE_KIND_RESULT:
                            ax_puts_local("RESULT")
                        elif entry.kind == TYPE_KIND_POINTER:
                            ax_puts_local("POINTER")
                        else:
                            ax_puts_local("OTHER")
                    else:
                        ax_puts_local("UNKNOWN/0")
                    ax_puts_local("\n")
            
            mut is_real_method := false
            mut rec_type := 0 as u32
            if receiver_node_idx != 0 as u32:
                let receiver_node = self.mb.tree.nodes.data[receiver_node_idx as i64]
                mut is_module_rec := false
                mut rec_sym_idx := 0 as u32
                if receiver_node.kind == NODE_IDENT:
                    rec_sym_idx = receiver_node.payload
                elif receiver_node.kind == NODE_FIELD_EXPR:
                    if (receiver_node.flags & 2048 as u16) != 0 as u16:
                        rec_sym_idx = receiver_node.payload
                if rec_sym_idx != 0 as u32 and (rec_sym_idx as i64) < self.mb.symbols.symbols.len:
                    let rec_sym = self.mb.symbols.symbols.data[rec_sym_idx as i64]
                    if rec_sym.kind == SYM_MODULE:
                        is_module_rec = true
                if not is_module_rec:
                    if self.mb.node_types != null as ptr[u32]:
                        rec_type = self.mb.node_types[receiver_node_idx as i64]
                        if rec_type == 0 as u32:
                            is_real_method = true
                        elif (rec_type as i64) < self.mb.typetable.entries.len:
                            mut entry = self.mb.typetable.entries.data[rec_type as i64]
                            while (entry.kind == TYPE_KIND_POINTER or entry.kind == TYPE_KIND_REF) and (rec_type as i64) < self.mb.typetable.entries.len:
                                rec_type = entry.extra
                                if (rec_type as i64) < self.mb.typetable.entries.len:
                                    entry = self.mb.typetable.entries.data[rec_type as i64]
                            if entry.kind == TYPE_KIND_STRUCT or entry.kind == TYPE_KIND_SUM or entry.kind == TYPE_KIND_GENERIC_INST or entry.kind == TYPE_KIND_OPTION or entry.kind == TYPE_KIND_RESULT:
                                is_real_method = true
            
            if is_real_method:
                if spec_sym_idx != 0 as u32 and (spec_sym_idx as i64) < self.mb.symbols.symbols.len:
                    let sym = self.mb.symbols.symbols.data[spec_sym_idx as i64]
                    if sym.kind == SYM_FUNC:
                        let t_entry = self.mb.typetable.entries.data[sym.type_id as i64]
                        if t_entry.kind == TYPE_KIND_FUNC:
                            let fi = self.mb.typetable.funcs.data[t_entry.extra as i64]
                            if fi.params.len > 0 as i64:
                                is_method_call = true
                                method_sym_idx = spec_sym_idx
        else:
            mut resolved := false

            if not resolved:
                receiver_node_idx = callee_node.first_child
                if receiver_node_idx != 0 as u32 and self.mb.node_types != null as ptr[u32]:
                    mut rec_type := self.mb.node_types[receiver_node_idx as i64]
                    if rec_type != 0 as u32 and (rec_type as i64) < self.mb.typetable.entries.len:
                        mut entry = self.mb.typetable.entries.data[rec_type as i64]
                        while (entry.kind == TYPE_KIND_POINTER or entry.kind == TYPE_KIND_REF) and (rec_type as i64) < self.mb.typetable.entries.len:
                            rec_type = entry.extra
                            if (rec_type as i64) < self.mb.typetable.entries.len:
                                entry = self.mb.typetable.entries.data[rec_type as i64]
                        
                        if entry.kind == TYPE_KIND_STRUCT or entry.kind == TYPE_KIND_SUM or entry.kind == TYPE_KIND_GENERIC_INST or entry.kind == TYPE_KIND_OPTION or entry.kind == TYPE_KIND_RESULT:
                            let method_id = callee_node.payload
                            mut i := 0 as i64
                            while i < self.mb.symbols.symbols.len:
                                let sym = self.mb.symbols.symbols.data[i]
                                if sym.kind == SYM_FUNC:
                                    if match_mangled_method_raw_bytes(self.mb.pool, sym.name_id, method_id):
                                        let t_entry = self.mb.typetable.entries.data[sym.type_id as i64]
                                        if t_entry.kind == TYPE_KIND_FUNC:
                                            let fi = self.mb.typetable.funcs.data[t_entry.extra as i64]
                                            if fi.params.len > 0 as i64:
                                                mut first_param := fi.params.data[0]
                                                mut p_entry = self.mb.typetable.entries.data[first_param as i64]
                                                while p_entry.kind == TYPE_KIND_POINTER or p_entry.kind == TYPE_KIND_REF:
                                                    first_param = p_entry.extra
                                                    p_entry = self.mb.typetable.entries.data[first_param as i64]
                                                if first_param == rec_type:
                                                    method_sym_idx = i as u32
                                                    resolved = true
                                                    is_method_call = true
                                                    break
                                i = i + 1 as i64

    if not is_method_call and callee_node.kind == NODE_IDENT:
        let sym_idx = callee_node.payload
        if sym_idx != 0 as u32 and (sym_idx as i64) < self.mb.symbols.symbols.len:
            let sym = self.mb.symbols.symbols.data[sym_idx as i64]
            if sym.kind == SYM_STRUCT:
                return self.lower_struct_constructor_call(idx, node, sym.type_id)

    let temp_args = @alloc(128 * 4) as ptr[u32]
    mut temp_count := 0 as u32

    if is_method_call:
        let receiver_reg = self.lower_expr(receiver_node_idx)
        temp_args[temp_count as i64] = receiver_reg
        temp_count = temp_count + 1 as u32

    mut arg := callee_node.next_sibling
    while arg != 0 as u32:
        let arg_reg = self.lower_expr(arg)
        temp_args[temp_count as i64] = arg_reg
        temp_count = temp_count + 1 as u32
        arg = self.mb.tree.nodes.data[arg as i64].next_sibling

    let arg_start = self.fb.emit_extra(temp_count)
    mut i := 0 as u32
    while i < temp_count:
        self.fb.emit_extra(temp_args[i as i64])
        i = i + 1 as u32

    @free(temp_args as ptr[u8])

    mut type_id := 0 as u32
    mut callee_reg := 0 as u32

    if is_method_call:
        type_id = method_sym_idx as u32
        callee_reg = 0 as u32
    else:
        if callee_node.kind == NODE_IDENT:
            let call_sym_idx = callee_node.payload
            mut is_var_or_param := false
            if call_sym_idx != 0 as u32 and (call_sym_idx as i64) < self.mb.symbols.symbols.len:
                let call_sym = self.mb.symbols.symbols.data[call_sym_idx as i64]
                if call_sym.kind == SYM_VAR or call_sym.kind == SYM_PARAM:
                    is_var_or_param = true
            if is_var_or_param:
                // SYM_VAR/SYM_PARAM â€” indirect call through function pointer variable
                callee_reg = self.lower_ident(callee_node)
                if self.mb.node_types != null as ptr[u32] and self.mb.node_types[idx as i64] != 0 as u32:
                    type_id = self.mb.node_types[idx as i64] as u32
            else:
                callee_reg = 0 as u32
                type_id = callee_node.payload as u32
        elif callee_node.kind == NODE_FIELD_EXPR and (callee_node.flags & 2048 as u16) != 0 as u16:
            callee_reg = 0 as u32
            type_id = callee_node.payload as u32
        else:
            callee_reg = self.lower_expr(child)
            if self.mb.node_types != null as ptr[u32] and self.mb.node_types[idx as i64] != 0 as u32:
                type_id = self.mb.node_types[idx as i64] as u32
            else:
                if node.payload != 0 as u32 and (node.payload as i64) < self.mb.symbols.symbols.len:
                    let sym = self.mb.symbols.symbols.data[node.payload as i64]
                    if sym.type_id != 0 as u32:
                        type_id = sym.type_id as u32

    mut opcode := OP_CALL
    if not is_method_call and callee_node.kind == NODE_IDENT:
        let sym_idx = callee_node.payload
        if sym_idx != 0 as u32 and (sym_idx as i64) < self.mb.symbols.symbols.len:
            let name_id = self.mb.symbols.symbols.data[sym_idx as i64].name_id
            let name = self.mb.pool.get(name_id)
            if (name == "syscall0" or name == "syscall1" or name == "syscall2" or
                name == "syscall3" or name == "syscall4" or name == "syscall5" or
                name == "syscall6"):
                opcode = OP_SYSCALL

    let reg = self.fb.fresh_reg()
    self.fb.emit(AirInst(
        opcode: opcode,
        type_id: type_id,
        dest: reg,
        src1: callee_reg,
        src2: arg_start,
    ))
    return reg

pub fn lower_field_expr(mut self: ptr[FuncLowering], idx: u32, node: AstNode) -> u32:
    if (node.flags & 2048 as u16) != 0 as u16:
        let sym_idx = node.payload
        if self.mb.symbols != null as ptr[SymbolTable] and sym_idx != 0 as u32 and (sym_idx as i64) < self.mb.symbols.symbols.len:
            let sym = self.mb.symbols.symbols.data[sym_idx as i64]
            if sym.kind == SYM_CONST and sym.decl_node != 0 as u32:
                mut init_expr := 0 as u32
                
                mut imported_mod := null as ptr[ModuleInfo]
                if self.mb.symbols.lazy_resolver != null as ptr[void]:
                    imported_mod = lazy_resolver_find_module_of_symbol(self.mb.symbols.lazy_resolver as ptr[LazyResolver], sym_idx)
                
                let saved_tree = self.mb.tree
                let saved_node_types = self.mb.node_types
                if imported_mod != null as ptr[ModuleInfo] and imported_mod.ast_tree != null as ptr[AstTree]:
                    self.mb.tree = imported_mod.ast_tree
                    self.mb.node_types = imported_mod.node_types as ptr[u32]

                mut child_const := 0 as u32
                if (sym.decl_node as i64) < self.mb.tree.nodes.len:
                    child_const = self.mb.tree.nodes.data[sym.decl_node as i64].first_child
                while child_const != 0 as u32 and (child_const as i64) < self.mb.tree.nodes.len:
                    let child_const_node = self.mb.tree.nodes.data[child_const as i64]
                    if child_const_node.kind != NODE_TYPE_EXPR and child_const_node.kind != NODE_GENERIC_TYPE:
                        init_expr = child_const
                    child_const = child_const_node.next_sibling
                
                mut val_reg := 0 as u32
                if init_expr != 0 as u32:
                    val_reg = self.lower_expr(init_expr)
                
                self.mb.tree = saved_tree
                self.mb.node_types = saved_node_types
                
                return val_reg
            
            if sym.kind != SYM_VAR and sym.kind != SYM_PARAM:
                return 0 as u32
            let reg = self.locals.local_map_get(sym_idx)
            return reg
        return 0 as u32

    let child = node.first_child
    if child == 0 as u32:
        return 0 as u32

    let obj_reg = self.lower_expr(child)
    let field_idx = node.extra_idx

    mut type_id := 0 as u32
    if self.mb.node_types != null as ptr[u32] and self.mb.node_types[child as i64] != 0 as u32:
        type_id = self.mb.node_types[child as i64] as u32

    let reg = self.fb.fresh_reg()
    self.fb.emit(AirInst(
        opcode: OP_GET_FIELD,
        type_id: type_id,
        dest: reg,
        src1: obj_reg,
        src2: field_idx,
    ))
    return reg

pub fn lower_index_expr(mut self: ptr[FuncLowering], idx: u32, node: AstNode) -> u32:
    let child = node.first_child
    if child == 0 as u32:
        return 0 as u32

    let arr_reg = self.lower_expr(child)
    let idx_expr = self.mb.tree.nodes.data[child as i64].next_sibling
    mut idx_reg := 0 as u32
    if idx_expr != 0 as u32:
        idx_reg = self.lower_expr(idx_expr)

    mut type_id := 0 as u32
    if self.mb.node_types != null as ptr[u32] and self.mb.node_types[idx as i64] != 0 as u32:
        type_id = self.mb.node_types[idx as i64] as u32
    else:
        if node.payload != 0 as u32 and (node.payload as i64) < self.mb.symbols.symbols.len:
            let sym = self.mb.symbols.symbols.data[node.payload as i64]
            if sym.type_id != 0 as u32:
                type_id = sym.type_id as u32

    let reg = self.fb.fresh_reg()
    self.fb.emit(AirInst(
        opcode: OP_INDEX,
        type_id: type_id,
        dest: reg,
        src1: arr_reg,
        src2: idx_reg,
    ))
    return reg

pub fn lower_cast_expr(mut self: ptr[FuncLowering], idx: u32, node: AstNode) -> u32:
    let child = node.first_child
    if child == 0 as u32:
        return 0 as u32

    let src_reg = self.lower_expr(child)

    mut type_id := 0 as u32
    if self.mb.node_types != null as ptr[u32] and self.mb.node_types[idx as i64] != 0 as u32:
        type_id = self.mb.node_types[idx as i64] as u32
    else:
        if node.payload != 0 as u32 and (node.payload as i64) < self.mb.symbols.symbols.len:
            let sym = self.mb.symbols.symbols.data[node.payload as i64]
            if sym.type_id != 0 as u32:
                type_id = sym.type_id as u32

    let reg = self.fb.fresh_reg()
    self.fb.emit(AirInst(
        opcode: OP_CAST,
        type_id: type_id,
        dest: reg,
        src1: src_reg,
        src2: 0 as u32,
    ))
    return reg

pub fn lower_deref_expr(mut self: ptr[FuncLowering], idx: u32, node: AstNode) -> u32:
    let child = node.first_child
    if child == 0 as u32:
        return 0 as u32

    let ptr_reg = self.lower_expr(child)

    mut type_id := 0 as u32
    if self.mb.node_types != null as ptr[u32] and self.mb.node_types[idx as i64] != 0 as u32:
        type_id = self.mb.node_types[idx as i64] as u32
    else:
        if node.payload != 0 as u32 and (node.payload as i64) < self.mb.symbols.symbols.len:
            let sym = self.mb.symbols.symbols.data[node.payload as i64]
            if sym.type_id != 0 as u32:
                type_id = sym.type_id as u32

    let reg = self.fb.fresh_reg()
    self.fb.emit(AirInst(
        opcode: OP_DEREF,
        type_id: type_id,
        dest: reg,
        src1: ptr_reg,
        src2: 0 as u32,
    ))
    return reg

pub fn lower_spawn_expr(mut self: ptr[FuncLowering], idx: u32, node: AstNode) -> u32:
    let child = node.first_child
    if child == 0 as u32:
        return 0 as u32

    mut target_reg := 0 as u32
    mut type_id := 0 as u32
    let child_node = self.mb.tree.nodes.data[child as i64]
    if child_node.kind == NODE_CALL_EXPR:
        let callee_node_idx = child_node.first_child
        if callee_node_idx != 0 as u32:
            target_reg = self.lower_expr(callee_node_idx)
            let callee_node = self.mb.tree.nodes.data[callee_node_idx as i64]
            if callee_node.kind == NODE_IDENT:
                type_id = callee_node.payload as u32
    else:
        target_reg = self.lower_expr(child)

    let reg = self.fb.fresh_reg()
    self.fb.emit(AirInst(
        opcode: OP_SPAWN,
        type_id: type_id,
        dest: reg,
        src1: target_reg,
        src2: 0 as u32,
    ))
    return reg

pub fn lower_await_expr(mut self: ptr[FuncLowering], idx: u32, node: AstNode) -> u32:
    let child = node.first_child
    if child == 0 as u32:
        return 0 as u32

    let future_reg = self.lower_expr(child)

    mut type_id := 0 as u32
    if self.mb.node_types != null as ptr[u32] and self.mb.node_types[idx as i64] != 0 as u32:
        type_id = self.mb.node_types[idx as i64] as u32
    else:
        if node.payload != 0 as u32 and (node.payload as i64) < self.mb.symbols.symbols.len:
            let sym = self.mb.symbols.symbols.data[node.payload as i64]
            if sym.type_id != 0 as u32:
                type_id = sym.type_id as u32

    let reg = self.fb.fresh_reg()
    self.fb.emit(AirInst(
        opcode: OP_AWAIT,
        type_id: type_id,
        dest: reg,
        src1: future_reg,
        src2: 0 as u32,
    ))
    return reg

pub fn lower_struct_lit(mut self: ptr[FuncLowering], idx: u32, node: AstNode) -> u32:
    mut type_id := 0 as u32
    if self.mb.node_types != null as ptr[u32] and self.mb.node_types[idx as i64] != 0 as u32:
        type_id = self.mb.node_types[idx as i64] as u32
    else:
        if node.payload != 0 as u32 and (node.payload as i64) < self.mb.symbols.symbols.len:
            let sym = self.mb.symbols.symbols.data[node.payload as i64]
            if sym.type_id != 0 as u32:
                type_id = sym.type_id as u32

    let struct_reg = self.fb.fresh_reg()
    self.fb.emit(AirInst(
        opcode: OP_ALLOC,
        type_id: type_id,
        dest: struct_reg,
        src1: 0 as u32,
        src2: 0 as u32,
    ))

    mut child := node.first_child
    mut field_idx := 0 as u32
    while child != 0 as u32:
        let cn = self.mb.tree.nodes.data[child as i64]
        if cn.kind == NODE_NAMED_ARG:
            let val_child = cn.first_child
            if val_child != 0 as u32:
                let val_reg = self.lower_expr(val_child)
                self.fb.emit(AirInst(
                    opcode: OP_SET_FIELD,
                    type_id: type_id,
                    dest: val_reg,
                    src1: struct_reg,
                    src2: field_idx,
                ))
            field_idx = field_idx + 1 as u32
        child = cn.next_sibling
    return struct_reg

pub fn lower_array_lit(mut self: ptr[FuncLowering], idx: u32, node: AstNode) -> u32:
    mut type_id := 0 as u32
    if self.mb.node_types != null as ptr[u32] and self.mb.node_types[idx as i64] != 0 as u32:
        type_id = self.mb.node_types[idx as i64] as u32
    else:
        if node.payload != 0 as u32 and (node.payload as i64) < self.mb.symbols.symbols.len:
            let sym = self.mb.symbols.symbols.data[node.payload as i64]
            if sym.type_id != 0 as u32:
                type_id = sym.type_id as u32

    let arr_reg = self.fb.fresh_reg()
    self.fb.emit(AirInst(
        opcode: OP_ALLOC,
        type_id: type_id,
        dest: arr_reg,
        src1: 0 as u32,
        src2: 0 as u32,
    ))

    mut child := node.first_child
    mut elem_idx := 0 as u32
    while child != 0 as u32:
        let elem_reg = self.lower_expr(child)

        let idx_reg = self.fb.fresh_reg()
        self.fb.emit(AirInst(
            opcode: OP_ICONST,
            type_id: 3 as u32, // i32
            dest: idx_reg,
            src1: elem_idx,
            src2: 0 as u32,
        ))

        self.fb.emit(AirInst(
            opcode: OP_STORE,
            type_id: 0 as u32,
            dest: arr_reg,
            src1: elem_reg,
            src2: idx_reg,
        ))

        elem_idx = elem_idx + 1 as u32
        child = self.mb.tree.nodes.data[child as i64].next_sibling
    return arr_reg

pub fn lower_struct_constructor_call(mut self: ptr[FuncLowering], idx: u32, node: AstNode, type_id: u32) -> u32:
    let struct_reg = self.fb.fresh_reg()
    self.fb.emit(AirInst(
        opcode: OP_ALLOC,
        type_id: type_id as u32,
        dest: struct_reg,
        src1: 0 as u32,
        src2: 0 as u32,
    ))

    let callee = node.first_child
    if callee == 0 as u32:
        return struct_reg

    mut child := self.mb.tree.nodes.data[callee as i64].next_sibling
    mut field_idx := 0 as u32
    while child != 0 as u32:
        let cn = self.mb.tree.nodes.data[child as i64]
        if cn.kind == NODE_NAMED_ARG:
            let val_child = cn.first_child
            if val_child != 0 as u32:
                let val_reg = self.lower_expr(val_child)
                self.fb.emit(AirInst(
                    opcode: OP_SET_FIELD,
                    type_id: type_id as u32,
                    dest: val_reg,
                    src1: struct_reg,
                    src2: field_idx,
                ))
            field_idx = field_idx + 1 as u32
        else:
            let val_reg = self.lower_expr(child)
            self.fb.emit(AirInst(
                opcode: OP_SET_FIELD,
                type_id: type_id as u32,
                dest: val_reg,
                src1: struct_reg,
                src2: field_idx,
            ))
            field_idx = field_idx + 1 as u32
        child = cn.next_sibling
    return struct_reg

pub fn emit_heap_alloc(mut self: ptr[FuncLowering], type_id: u32) -> u32:
    let ptr_reg = self.fb.fresh_reg()
    self.fb.emit(AirInst(
        opcode: OP_ALLOC,
        type_id: type_id,
        dest: ptr_reg,
        src1: 0 as u32,
        src2: 0 as u32,
    ))

    let ref_reg = self.fb.fresh_reg()
    self.fb.emit(AirInst(
        opcode: OP_MAKE_REF,
        type_id: type_id,
        dest: ref_reg,
        src1: ptr_reg,
        src2: 0 as u32,
    ))
    return ref_reg

pub fn emit_deref(mut self: ptr[FuncLowering], ref_reg: u32, type_id: u32) -> u32:
    let ptr_reg = self.fb.fresh_reg()
    self.fb.emit(AirInst(
        opcode: OP_DEREF,
        type_id: type_id,
        dest: ptr_reg,
        src1: ref_reg,
        src2: 0 as u32,
    ))
    return ptr_reg

pub fn emit_move(mut self: ptr[FuncLowering], src_reg: u32, type_id: u32) -> u32:
    let dest_reg = self.fb.fresh_reg()
    self.fb.emit(AirInst(
        opcode: OP_MOVE,
        type_id: type_id,
        dest: dest_reg,
        src1: src_reg,
        src2: 0 as u32,
    ))
    return dest_reg

pub fn emit_free(mut self: ptr[FuncLowering], ptr_reg: u32):
    self.fb.emit(AirInst(
        opcode: OP_FREE,
        type_id: 0 as u32,
        dest: 0 as u32,
        src1: ptr_reg,
        src2: 0 as u32,
    ))

pub fn emit_arena_alloc(mut self: ptr[FuncLowering], arena_reg: u32, type_id: u32) -> u32:
    let ptr_reg = self.fb.fresh_reg()
    self.fb.emit(AirInst(
        opcode: OP_ARENA_ALLOC,
        type_id: type_id,
        dest: ptr_reg,
        src1: arena_reg,
        src2: 0 as u32,
    ))
    return ptr_reg

pub fn emit_alias_reuse(mut self: ptr[FuncLowering], ptr_reg: u32, type_id: u32) -> u32:
    let dest_reg = self.fb.fresh_reg()
    self.fb.emit(AirInst(
        opcode: OP_ALIAS_REUSE,
        type_id: type_id,
        dest: dest_reg,
        src1: ptr_reg,
        src2: 0 as u32,
    ))
    return dest_reg

pub fn lower_ownership_aware(mut self: ptr[FuncLowering], idx: u32, node: AstNode, init_reg: u32) -> u32:
    if node.flags & FLAG_ESCAPES_TO_HEAP != 0 as u16:
        mut type_id := 0 as u32
        if node.extra_idx != 0 as u32:
            type_id = node.extra_idx as u32
        let ref_reg = self.emit_heap_alloc(type_id)

        if init_reg != 0 as u32:
            let ptr_reg = self.emit_deref(ref_reg, type_id)
            self.fb.emit(AirInst(
                opcode: OP_STORE,
                type_id: 0 as u32,
                dest: ptr_reg,
                src1: init_reg,
                src2: 0 as u32,
            ))
        return ref_reg

    if node.flags & FLAG_USES_ARENA != 0 as u16:
        mut type_id := 0 as u32
        if node.extra_idx != 0 as u32:
            type_id = node.extra_idx as u32
        let ptr_reg = self.emit_arena_alloc(0 as u32, type_id)
        if init_reg != 0 as u32:
            self.fb.emit(AirInst(
                opcode: OP_STORE,
                type_id: 0 as u32,
                dest: ptr_reg,
                src1: init_reg,
                src2: 0 as u32,
            ))
        return ptr_reg

    if node.flags & FLAG_IS_MOVED != 0 as u16 and init_reg != 0 as u32:
        mut type_id := 0 as u32
        if node.extra_idx != 0 as u32:
            type_id = node.extra_idx as u32
        return self.emit_move(init_reg, type_id)

    return init_reg

pub fn lower_alias_stmt(mut self: ptr[FuncLowering], idx: u32, node: AstNode):
    if node.first_child != 0 as u32:
        let cn = self.mb.tree.nodes.data[node.first_child as i64]
        let src_reg = self.lower_expr(node.first_child)

        mut type_id := 0 as u32
        if node.extra_idx != 0 as u32:
            type_id = node.extra_idx as u32
        self.emit_alias_reuse(src_reg, type_id)

pub fn lower_block(mut self: ptr[FuncLowering], block_idx: u32):
    let node = self.mb.tree.nodes.data[block_idx as i64]
    mut child := node.first_child
    while child != 0 as u32:
        let cn = self.mb.tree.nodes.data[child as i64]
        self.lower_stmt(child, cn)
        child = cn.next_sibling

pub fn lower_stmt(mut self: ptr[FuncLowering], idx: u32, node: AstNode):
    if self.terminated:
        return

    if node.kind == NODE_VAR_DECL:
        self.lower_var_decl(idx, node)
    elif node.kind == NODE_ASSIGN_STMT:
        self.lower_assign(idx, node)
    elif node.kind == NODE_RETURN_STMT:
        self.lower_return(idx, node)
    elif node.kind == NODE_IF_STMT:
        self.lower_if(idx, node)
    elif node.kind == NODE_WHILE_STMT:
        self.lower_while(idx, node)
    elif node.kind == NODE_FOR_STMT:
        self.lower_for(idx, node)
    elif node.kind == NODE_BLOCK:
        self.lower_block(idx)
    elif node.kind == NODE_DESTROY_STMT:
        self.lower_destroy(idx, node)
    elif node.kind == NODE_ALIAS_STMT:
        self.lower_alias_stmt(idx, node)
    elif node.kind == NODE_DEFER_STMT:
        self.lower_defer(idx, node)
    elif node.kind == NODE_BREAK_STMT:
        self.lower_break(idx, node)
    elif node.kind == NODE_CONTINUE_STMT:
        self.lower_continue(idx, node)
    else:
        self.lower_expr(idx)

pub fn lower_break(mut self: ptr[FuncLowering], idx: u32, node: AstNode):
    if self.loop_exits.len == 0 as i64:
        return
    let target = self.loop_exits.data[self.loop_exits.len - 1]
    self.fb.emit(AirInst(
        opcode: OP_JUMP,
        type_id: 0 as u32,
        dest: 0 as u32,
        src1: target,
        src2: 0 as u32,
    ))
    self.fb.add_edge(self.fb.current_block(), target)
    self.terminated = true

pub fn lower_continue(mut self: ptr[FuncLowering], idx: u32, node: AstNode):
    if self.loop_conds.len == 0 as i64:
        return
    let target = self.loop_conds.data[self.loop_conds.len - 1]
    self.fb.emit(AirInst(
        opcode: OP_JUMP,
        type_id: 0 as u32,
        dest: 0 as u32,
        src1: target,
        src2: 0 as u32,
    ))
    self.fb.add_edge(self.fb.current_block(), target)
    self.terminated = true

pub fn lower_var_decl(mut self: ptr[FuncLowering], idx: u32, node: AstNode):
    let name_id = node.payload
    mut type_id := 0 as u32

    mut init_reg := 0 as u32
    mut child := node.first_child
    while child != 0 as u32:
        let cn = self.mb.tree.nodes.data[child as i64]
        if cn.kind != NODE_TYPE_EXPR and cn.kind != NODE_PTR_TYPE and cn.kind != NODE_SLICE_TYPE and cn.kind != NODE_ARRAY_TYPE and cn.kind != NODE_FUNC_TYPE and cn.kind != NODE_GENERIC_TYPE:
            init_reg = self.lower_expr(child)
        child = cn.next_sibling

    if init_reg != 0 as u32:
        mut src_reg := init_reg
        if node.flags & (FLAG_ESCAPES_TO_HEAP | FLAG_USES_ARENA | FLAG_IS_MOVED) != 0 as u16:
            src_reg = self.lower_ownership_aware(idx, node, init_reg)

        let reg = self.fb.fresh_reg()
        mut var_type_id := 0 as u32
        if node.payload != 0 as u32 and (node.payload as i64) < self.mb.symbols.symbols.len:
            let sym = self.mb.symbols.symbols.data[node.payload as i64]
            if sym.type_id != 0 as u32:
                var_type_id = sym.type_id as u32

        self.fb.emit(AirInst(
            opcode: OP_COPY,
            type_id: var_type_id,
            dest: reg,
            src1: src_reg,
            src2: 0 as u32,
        ))
        self.locals.local_map_put(name_id, reg)
    else:
        let reg = self.fb.fresh_reg()
        self.fb.emit(AirInst(
            opcode: OP_ICONST,
            type_id: type_id,
            dest: reg,
            src1: 0 as u32,
            src2: 0 as u32,
        ))
        self.locals.local_map_put(name_id, reg)

pub fn lower_assign(mut self: ptr[FuncLowering], idx: u32, node: AstNode):
    let lhs_idx = node.first_child
    if lhs_idx == 0 as u32:
        return
    let lhs_node = self.mb.tree.nodes.data[lhs_idx as i64]

    if lhs_node.kind == NODE_FIELD_EXPR:
        let obj_idx = lhs_node.first_child
        let obj_reg = self.lower_expr(obj_idx)
        let field_idx = lhs_node.extra_idx

        let rhs_idx = lhs_node.next_sibling
        if rhs_idx == 0 as u32:
            return
        let val_reg = self.lower_expr(rhs_idx)

        mut type_id := 0 as u32
        let obj_type = self.mb.node_types[obj_idx as i64]
        if obj_type != 0 as u32 and (obj_type as i64) < self.mb.typetable.entries.len:
            let entry = self.mb.typetable.entries.data[obj_type as i64]
            if entry.kind == TYPE_KIND_POINTER:
                type_id = entry.extra as u32
            else:
                type_id = obj_type as u32

        self.fb.emit(AirInst(
            opcode: OP_SET_FIELD,
            type_id: type_id,
            dest: val_reg,
            src1: obj_reg,
            src2: field_idx,
        ))
        return

    elif lhs_node.kind == NODE_INDEX_EXPR:
        let arr_idx = lhs_node.first_child
        let arr_reg = self.lower_expr(arr_idx)
        let index_idx = self.mb.tree.nodes.data[arr_idx as i64].next_sibling
        mut index_reg := 0 as u32
        if index_idx != 0 as u32:
            index_reg = self.lower_expr(index_idx)

        let rhs_idx = lhs_node.next_sibling
        if rhs_idx == 0 as u32:
            return
        let val_reg = self.lower_expr(rhs_idx)

        mut type_id := 0 as u32
        let arr_type = self.mb.node_types[arr_idx as i64]
        if arr_type != 0 as u32 and (arr_type as i64) < self.mb.typetable.entries.len:
            let entry = self.mb.typetable.entries.data[arr_type as i64]
            if entry.kind == TYPE_KIND_POINTER or entry.kind == TYPE_KIND_SLICE or entry.kind == TYPE_KIND_ARRAY:
                type_id = entry.extra as u32

        self.fb.emit(AirInst(
            opcode: OP_STORE,
            type_id: type_id,
            dest: arr_reg,
            src1: val_reg,
            src2: index_reg,
        ))
        return

    elif lhs_node.kind == NODE_DEREF_EXPR:
        let ptr_idx = lhs_node.first_child
        let ptr_reg = self.lower_expr(ptr_idx)

        let rhs_idx = lhs_node.next_sibling
        if rhs_idx == 0 as u32:
            return
        let val_reg = self.lower_expr(rhs_idx)

        mut type_id := 0 as u32
        let ptr_type = self.mb.node_types[ptr_idx as i64]
        if ptr_type != 0 as u32 and (ptr_type as i64) < self.mb.typetable.entries.len:
            let entry = self.mb.typetable.entries.data[ptr_type as i64]
            if entry.kind == TYPE_KIND_POINTER:
                type_id = entry.extra as u32

        self.fb.emit(AirInst(
            opcode: OP_STORE,
            type_id: type_id,
            dest: ptr_reg,
            src1: val_reg,
            src2: 0 as u32,
        ))
        return

    mut name_id := lhs_node.payload
    if name_id == 0 as u32:
        let text = self.mb.get_token_text(lhs_node.token_idx)
        name_id = self.mb.pool.intern(text)
        @free(get_str_ptr(text))

    let rhs_idx = lhs_node.next_sibling
    if rhs_idx == 0 as u32:
        return
    let rhs_node = self.mb.tree.nodes.data[rhs_idx as i64]
    let val_reg = self.lower_expr(rhs_idx)

    mut type_id := 3 as u32 // default i32
    if lhs_node.payload != 0 as u32 and (lhs_node.payload as i64) < self.mb.symbols.symbols.len:
        let sym = self.mb.symbols.symbols.data[lhs_node.payload as i64]
        if sym.type_id != 0 as u32:
            type_id = sym.type_id as u32

    let existing_reg = self.locals.local_map_get(name_id)
    if existing_reg != 0 as u32:
        self.fb.emit(AirInst(
            opcode: OP_COPY,
            type_id: type_id,
            dest: existing_reg,
            src1: val_reg,
            src2: 0 as u32,
        ))
    else:
        self.locals.local_map_put(name_id, val_reg)

pub fn lower_return(mut self: ptr[FuncLowering], idx: u32, node: AstNode):
    mut ret_val := 0 as u32
    if node.first_child != 0 as u32:
        ret_val = self.lower_expr(node.first_child)

    self.fb.emit(AirInst(
        opcode: OP_RETURN,
        type_id: 0 as u32,
        dest: 0 as u32,
        src1: ret_val,
        src2: 0 as u32,
    ))
    self.terminated = true

pub fn lower_if(mut self: ptr[FuncLowering], idx: u32, node: AstNode):
    let merge_block = self.fb.new_block()

    let cond_node_idx = node.first_child
    if cond_node_idx == 0 as u32:
        return
    let cond_node = self.mb.tree.nodes.data[cond_node_idx as i64]

    let body_node_idx = cond_node.next_sibling
    if body_node_idx == 0 as u32:
        return
    let body_node = self.mb.tree.nodes.data[body_node_idx as i64]

    let next_clause_idx = body_node.next_sibling

    self.lower_if_chain(cond_node_idx, cond_node, body_node_idx, body_node, next_clause_idx, merge_block)

    // Merge block
    self.fb.switch_to(merge_block)
    self.terminated = false

pub fn lower_if_chain(mut self: ptr[FuncLowering], cond_idx: u32, cond_node: AstNode, body_idx: u32, body_node: AstNode, next_clause_idx: u32, merge_block: u32):
    let then_block = self.fb.new_block()
    let else_block = self.fb.new_block()

    // Lower condition
    let cond_reg = self.lower_expr(cond_idx)

    // Branch
    self.fb.emit(AirInst(
        opcode: OP_BRANCH,
        type_id: 0 as u32,
        dest: else_block,
        src1: cond_reg,
        src2: then_block,
    ))
    let cur_block = self.fb.current_block()
    self.fb.add_edge(cur_block, then_block)
    self.fb.add_edge(cur_block, else_block)

    // Then block
    self.fb.switch_to(then_block)
    self.terminated = false
    if body_node.kind == NODE_BLOCK:
        self.lower_block(body_idx)
    if not self.terminated:
        self.fb.emit(AirInst(opcode: OP_JUMP, type_id: 0 as u32, dest: 0 as u32, src1: merge_block, src2: 0 as u32))
        self.fb.add_edge(self.fb.current_block(), merge_block)

    // Else block
    self.fb.switch_to(else_block)
    self.terminated = false
    mut delegated := false
    if next_clause_idx != 0 as u32:
        let cn = self.mb.tree.nodes.data[next_clause_idx as i64]
        if cn.kind == NODE_ELSE_CLAUSE:
            let else_body_idx = cn.first_child
            if else_body_idx != 0 as u32:
                let else_body_node = self.mb.tree.nodes.data[else_body_idx as i64]
                if else_body_node.kind == NODE_BLOCK:
                    self.lower_block(else_body_idx)
        elif cn.kind == NODE_ELIF_CLAUSE:
            let elif_cond_idx = cn.first_child
            if elif_cond_idx != 0 as u32:
                let elif_cond_node = self.mb.tree.nodes.data[elif_cond_idx as i64]
                let elif_body_idx = elif_cond_node.next_sibling
                if elif_body_idx != 0 as u32:
                    let elif_body_node = self.mb.tree.nodes.data[elif_body_idx as i64]
                    self.lower_if_chain(elif_cond_idx, elif_cond_node, elif_body_idx, elif_body_node, cn.next_sibling, merge_block)
                    delegated = true

    if not self.terminated and not delegated:
        self.fb.emit(AirInst(opcode: OP_JUMP, type_id: 0 as u32, dest: 0 as u32, src1: merge_block, src2: 0 as u32))
        self.fb.add_edge(self.fb.current_block(), merge_block)

pub fn lower_while(mut self: ptr[FuncLowering], idx: u32, node: AstNode):
    let cond_block = self.fb.new_block()
    let body_block = self.fb.new_block()
    let exit_block = self.fb.new_block()

    self.loop_conds.push(cond_block)
    self.loop_exits.push(exit_block)

    let cur_block = self.fb.current_block()
    self.fb.emit(AirInst(opcode: OP_JUMP, type_id: 0 as u32, dest: 0 as u32, src1: cond_block, src2: 0 as u32))
    self.fb.add_edge(cur_block, cond_block)

    // Condition
    self.fb.switch_to(cond_block)
    self.terminated = false
    let child = node.first_child
    if child == 0 as u32:
        self.loop_conds.pop()
        self.loop_exits.pop()
        return
    let cn = self.mb.tree.nodes.data[child as i64]
    let cond_reg = self.lower_expr(child)

    self.fb.emit(AirInst(
        opcode: OP_BRANCH,
        type_id: 0 as u32,
        dest: exit_block,
        src1: cond_reg,
        src2: body_block,
    ))
    self.fb.add_edge(cond_block, body_block)
    self.fb.add_edge(cond_block, exit_block)

    // Body
    self.fb.switch_to(body_block)
    self.terminated = false
    let body_child = cn.next_sibling
    if body_child != 0 as u32:
        let bcn = self.mb.tree.nodes.data[body_child as i64]
        if bcn.kind == NODE_BLOCK:
            self.lower_block(body_child)

    if not self.terminated:
        self.fb.emit(AirInst(opcode: OP_JUMP, type_id: 0 as u32, dest: 0 as u32, src1: cond_block, src2: 0 as u32))
        self.fb.add_edge(body_block, cond_block)

    // Exit
    self.fb.switch_to(exit_block)
    self.terminated = false

    self.loop_conds.pop()
    self.loop_exits.pop()

pub fn lower_for(mut self: ptr[FuncLowering], idx: u32, node: AstNode):
    let cond_block = self.fb.new_block()
    let body_block = self.fb.new_block()
    let exit_block = self.fb.new_block()

    self.loop_conds.push(cond_block)
    self.loop_exits.push(exit_block)

    let sym_idx = node.payload
    mut name_id := 0 as u32
    mut type_id := 3 as u32 // default i32

    if sym_idx != 0 as u32 and (sym_idx as i64) < self.mb.symbols.symbols.len:
        let sym = self.mb.symbols.symbols.data[sym_idx as i64]
        name_id = sym.name_id
        if sym.type_id != 0 as u32:
            type_id = sym.type_id as u32
    else:
        name_id = sym_idx

    let range_expr_idx = node.first_child
    mut start_reg := 0 as u32
    mut limit_reg := 0 as u32
    mut is_range := false

    if range_expr_idx != 0 as u32:
        let range_node = self.mb.tree.nodes.data[range_expr_idx as i64]
        if range_node.kind == NODE_BINARY_EXPR:
            let op_text = self.mb.get_token_text(range_node.token_idx)
            if op_text == "..":
                is_range = true
                let start_node_idx = range_node.first_child
                if start_node_idx != 0 as u32:
                    start_reg = self.lower_expr(start_node_idx)
                    let start_node = self.mb.tree.nodes.data[start_node_idx as i64]
                    let end_node_idx = start_node.next_sibling
                    if end_node_idx != 0 as u32:
                        limit_reg = self.lower_expr(end_node_idx)
            @free(get_str_ptr(op_text))

    let iter_reg = self.fb.fresh_reg()
    if is_range:
        self.fb.emit(AirInst(
            opcode: OP_COPY,
            type_id: type_id,
            dest: iter_reg,
            src1: start_reg,
            src2: 0 as u32,
        ))
    else:
        self.fb.emit(AirInst(
            opcode: OP_ICONST,
            type_id: type_id,
            dest: iter_reg,
            src1: 0 as u32,
            src2: 0 as u32,
        ))
        if range_expr_idx != 0 as u32:
            limit_reg = self.lower_expr(range_expr_idx)

    self.locals.local_map_put(name_id, iter_reg)

    let cur_block = self.fb.current_block()
    self.fb.emit(AirInst(opcode: OP_JUMP, type_id: 0 as u32, dest: 0 as u32, src1: cond_block, src2: 0 as u32))
    self.fb.add_edge(cur_block, cond_block)

    // Condition
    self.fb.switch_to(cond_block)
    self.terminated = false

    let cmp_reg = self.fb.fresh_reg()
    let current_iter = self.locals.local_map_get(name_id)
    self.fb.emit(AirInst(
        opcode: OP_LT,
        type_id: 11 as u32, // bool
        dest: cmp_reg,
        src1: current_iter,
        src2: limit_reg,
    ))

    self.fb.emit(AirInst(
        opcode: OP_BRANCH,
        type_id: 0 as u32,
        dest: exit_block,
        src1: cmp_reg,
        src2: body_block,
    ))
    self.fb.add_edge(cond_block, body_block)
    self.fb.add_edge(cond_block, exit_block)

    // Body
    self.fb.switch_to(body_block)
    self.terminated = false

    if range_expr_idx != 0 as u32:
        let range_node = self.mb.tree.nodes.data[range_expr_idx as i64]
        let body_node_idx = range_node.next_sibling
        if body_node_idx != 0 as u32:
            let body_node = self.mb.tree.nodes.data[body_node_idx as i64]
            if body_node.kind == NODE_BLOCK:
                self.lower_block(body_node_idx)

    if not self.terminated:
        let one_reg = self.fb.fresh_reg()
        self.fb.emit(AirInst(
            opcode: OP_ICONST,
            type_id: type_id,
            dest: one_reg,
            src1: 1 as u32,
            src2: 0 as u32,
        ))
        let current_iter2 = self.locals.local_map_get(name_id)
        let new_val_reg = self.fb.fresh_reg()
        self.fb.emit(AirInst(
            opcode: OP_IADD,
            type_id: type_id,
            dest: new_val_reg,
            src1: current_iter2,
            src2: one_reg,
        ))
        self.fb.emit(AirInst(
            opcode: OP_COPY,
            type_id: type_id,
            dest: current_iter2,
            src1: new_val_reg,
            src2: 0 as u32,
        ))

        self.fb.emit(AirInst(opcode: OP_JUMP, type_id: 0 as u32, dest: 0 as u32, src1: cond_block, src2: 0 as u32))
        self.fb.add_edge(body_block, cond_block)

    // Exit
    self.fb.switch_to(exit_block)
    self.terminated = false

    self.loop_conds.pop()
    self.loop_exits.pop()

pub fn lower_destroy(mut self: ptr[FuncLowering], idx: u32, node: AstNode):
    if node.first_child != 0 as u32:
        let val_reg = self.lower_expr(node.first_child)
        self.fb.emit(AirInst(
            opcode: OP_DESTROY,
            type_id: 0 as u32,
            dest: 0 as u32,
            src1: val_reg,
            src2: 0 as u32,
        ))
    else:
        let sym_id = node.payload
        if sym_id != 0 as u32 and (sym_id as i64) < self.mb.symbols.symbols.len:
            let sym = self.mb.symbols.symbols.data[sym_id as i64]
            let reg = self.locals.local_map_get(sym.name_id)
            if reg != 0 as u32:
                self.fb.emit(AirInst(
                    opcode: OP_DESTROY,
                    type_id: 0 as u32,
                    dest: 0 as u32,
                    src1: reg,
                    src2: 0 as u32,
                ))

pub fn lower_defer(mut self: ptr[FuncLowering], idx: u32, node: AstNode):
    if node.first_child != 0 as u32:
        self.lower_expr(node.first_child)

pub fn ensure_return(mut self: ptr[FuncLowering]):
    if not self.terminated:
        self.fb.emit(AirInst(
            opcode: OP_RETURN,
            type_id: 0 as u32,
            dest: 0 as u32,
            src1: 0 as u32,
            src2: 0 as u32,
        ))
        self.terminated = true

pub fn lower_func(self: ptr[AirModuleBuilder], idx: u32, node: AstNode) -> AirFunc:
    if node.flags & FLAG_IS_EXTERN != 0 as u16:
        return AirFunc(sym_id: 0 as u32, name: 0 as u32, params: new_u32_vec(), ret_type: 0 as u32, blocks: new_basic_block_vec(), insts: new_air_inst_vec(), extras: new_u32_vec(), is_async: false, is_extern: true, block_instrs: new_u32_vec(), block_succs: new_u32_vec(), block_preds: new_u32_vec())

    mut name_id := 0 as u32
    mut ret_type_id := 0 as u32
    mut param_types := new_u32_vec()

    let sym_idx = node.payload
    if sym_idx != 0 as u32 and (sym_idx as i64) < self.symbols.symbols.len:
        let sym = self.symbols.symbols.data[sym_idx as i64]
        name_id = sym.name_id
        if sym.type_id != 0 as u32 and (sym.type_id as i64) < self.typetable.entries.len:
            let entry = self.typetable.entries.data[sym.type_id as i64]
            if entry.kind == TYPE_KIND_FUNC:
                let fi = self.typetable.funcs.data[entry.extra as i64]
                ret_type_id = fi.ret
                mut i := 0 as i64
                while i < fi.params.len:
                    param_types.push(fi.params.data[i])
                    i = i + 1

    if name_id == 0 as u32:
        let text = self.get_token_text(node.token_idx)
        name_id = self.pool.intern(text)
        @free(get_str_ptr(text))

    mut fb := new_air_func_builder(name_id, ret_type_id)
    mut fl := new_func_lowering(self, fb, param_types)

    fl.register_params(idx, node)

    mut body_idx := 0 as u32
    mut child := node.first_child
    while child != 0 as u32:
        let cn = self.tree.nodes.data[child as i64]
        if cn.kind == NODE_BLOCK:
            body_idx = child
        child = cn.next_sibling

    if body_idx != 0 as u32:
        fl.lower_block(body_idx)

    fl.ensure_return()

    mut fn_built := fl.fb.build_func()
    fn_built.sym_id = sym_idx
    fn_built.is_async = (node.flags & FLAG_IS_ASYNC != 0 as u16)
    fn_built.params.data = fl.params.data
    fn_built.params.len = fl.params.len
    fn_built.params.cap = fl.params.cap

    fl.params.data = null as ptr[u32]

    free_func_lowering(fl)
    return fn_built

pub fn build_module(self: ptr[AirModuleBuilder]):
    let root = self.tree.nodes.data[0]
    mut child := root.first_child
    while child != 0 as u32:
        let node = self.tree.nodes.data[child as i64]
        if node.kind == NODE_FUNC_DECL:
            if node.flags & FLAG_IS_EXTERN == 0 as u16 and node.flags & FLAG_IS_GENERIC == 0 as u16:
                let fn_val = self.lower_func(child, node)
                self.module.funcs.push(fn_val)
        elif node.kind == NODE_STRUCT_DECL:
            if node.flags & FLAG_IS_GENERIC == 0 as u16:
                mut member := node.first_child
                while member != 0 as u32:
                    let member_node = self.tree.nodes.data[member as i64]
                    if member_node.kind == NODE_FUNC_DECL:
                        if member_node.flags & FLAG_IS_EXTERN == 0 as u16 and member_node.flags & FLAG_IS_GENERIC == 0 as u16:
                            let fn_val = self.lower_func(member, member_node)
                            self.module.funcs.push(fn_val)
                    member = member_node.next_sibling
        child = node.next_sibling

pub fn builder_str_to_null_terminated(self: ptr[AirModuleBuilder], s: str) -> ptr[u8]:
    let len = std.string.len(s)
    let p = @alloc(len + 1) as ptr[u8]
    @memcpy(p, s as ptr[u8], len)
    p[len] = 0 as u8
    return p
// bootstrap/stage1/ssa_opt.ax
// SSA linear Intermediate Representation (AIR) O1 optimization passes:
// Constant Folding, Copy Propagation, and Dead Code Elimination.


// extern "C" fn printf(fmt: str, a1: i64, a2: i64, a3: i64, a4: i64, a5: i64, a6: i64, a7: i64, a8: i64) -> i32
// extern "C" fn puts(s: str) -> i32

pub struct ConstVal:
    pub known: bool
    pub val: u32

pub struct SsaOptimizer:
    pub level: u8

pub fn new_ssa_optimizer() -> SsaOptimizer:
    return SsaOptimizer(level: 1 as u8)

pub fn max_reg_id(f: ptr[AirFunc]) -> u32:
    mut max_id := 0 as u32
    mut i := 0 as i64
    while i < f.insts.len:
        let inst = f.insts.data[i]
        if inst.dest > max_id:
            max_id = inst.dest
        // src1 is a register only if it is a register operand (not block target or immediate constant)
        // src2 is a register only if it is a register operand
        if inst.opcode != OP_ICONST and inst.opcode != OP_FCONST and inst.opcode != OP_JUMP:
            if inst.src1 > max_id:
                max_id = inst.src1
            if inst.src2 > max_id and inst.opcode != OP_BRANCH:
                max_id = inst.src2
        i = i + 1 as i64
    return max_id

pub fn is_unary_foldable(op: u16) -> bool:
    return op == OP_NEG or op == OP_NOT

pub fn has_side_effect(op: u16) -> bool:
    if op == OP_STORE or op == OP_FREE or op == OP_DESTROY or op == OP_ALIAS_REUSE:
        return true
    if op == OP_CALL or op == OP_SPAWN or op == OP_SEND:
        return true
    if op == OP_RETURN or op == OP_JUMP or op == OP_BRANCH:
        return true
    if op == OP_SET_FIELD:
        return true
    return false

pub fn opcode_is_control(op: u16) -> bool:
    if op == OP_JUMP or op == OP_BRANCH or op == OP_CALL or op == OP_RETURN:
        return true
    if op == OP_LOOP_BEGIN or op == OP_LOOP_END:
        return true
    return false

pub fn eval_binary(op: u16, a: u32, b: u32, out_val: ptr[u32]) -> bool:
    let ai = a as i32
    let bi = b as i32

    if op == OP_IADD:
        out_val[0] = (ai + bi) as u32
        return true
    elif op == OP_ISUB:
        out_val[0] = (ai - bi) as u32
        return true
    elif op == OP_IMUL:
        out_val[0] = (ai * bi) as u32
        return true
    elif op == OP_IDIV:
        if bi == 0:
            return false
        out_val[0] = (ai / bi) as u32
        return true
    elif op == OP_IMOD:
        if bi == 0:
            return false
        out_val[0] = (ai % bi) as u32
        return true
    elif op == OP_EQ:
        mut res := 0 as u32
        if ai == bi:
            res = 1 as u32
        out_val[0] = res
        return true
    elif op == OP_NE:
        mut res := 0 as u32
        if ai != bi:
            res = 1 as u32
        out_val[0] = res
        return true
    elif op == OP_LT:
        mut res := 0 as u32
        if ai < bi:
            res = 1 as u32
        out_val[0] = res
        return true
    elif op == OP_LE:
        mut res := 0 as u32
        if ai <= bi:
            res = 1 as u32
        out_val[0] = res
        return true
    elif op == OP_GT:
        mut res := 0 as u32
        if ai > bi:
            res = 1 as u32
        out_val[0] = res
        return true
    elif op == OP_GE:
        mut res := 0 as u32
        if ai >= bi:
            res = 1 as u32
        out_val[0] = res
        return true
    elif op == OP_AND:
        out_val[0] = a & b
        return true
    elif op == OP_OR:
        out_val[0] = a | b
        return true
    elif op == OP_XOR:
        out_val[0] = a ^ b
        return true
    elif op == OP_SHL:
        if b >= 32 as u32:
            out_val[0] = 0 as u32
            return true
        out_val[0] = a << b
        return true
    elif op == OP_SHR:
        if b >= 32 as u32:
            out_val[0] = 0 as u32
            return true
        out_val[0] = (ai >> (b as i32)) as u32
        return true

    return false

pub fn eval_unary(op: u16, a: u32, out_val: ptr[u32]) -> bool:
    if op == OP_NEG:
        out_val[0] = (-(a as i32)) as u32
        return true
    elif op == OP_NOT:
        mut res := 0 as u32
        if a == 0 as u32:
            res = 1 as u32
        out_val[0] = res
        return true
    return false

pub fn fold_func(f: ptr[AirFunc]) -> bool:
    let max_reg = max_reg_id(f)
    if max_reg == 0 as u32:
        return false

    let def_counts = @alloc((max_reg as i64 + 1 as i64) * 4 as i64) as ptr[u32]
    @memset(def_counts as ptr[void], 0 as u8, (max_reg as i64 + 1 as i64) * 4 as i64)

    mut i := 0 as i64
    while i < f.insts.len:
        let inst = f.insts.data[i]
        if inst.opcode != OP_NOP and inst.dest != 0 as u32 and inst.opcode != OP_BRANCH:
            def_counts[inst.dest] = def_counts[inst.dest] + 1 as u32
        i = i + 1 as i64

    let vals = @alloc((max_reg as i64 + 1 as i64) * 8 as i64) as ptr[ConstVal]
    mut reg_idx := 0 as u32
    while reg_idx <= max_reg:
        vals[reg_idx] = ConstVal(known: false, val: 0 as u32)
        reg_idx = reg_idx + 1 as u32

    mut changed := false
    let out_val = @alloc(4 as i64) as ptr[u32]

    i = 0 as i64
    while i < f.insts.len:
        mut inst := &f.insts.data[i]
        
        if inst.opcode == OP_ICONST or inst.opcode == OP_FCONST:
            if inst.dest != 0 as u32:
                if def_counts[inst.dest] <= 1 as u32:
                    vals[inst.dest] = ConstVal(known: true, val: inst.src1)
                else:
                    vals[inst.dest] = ConstVal(known: false, val: 0 as u32)
            i = i + 1 as i64
            continue

        if not opcode_is_binary_alu(inst.opcode) and not is_unary_foldable(inst.opcode):
            if inst.dest != 0 as u32:
                vals[inst.dest] = ConstVal(known: false, val: 0 as u32)
            i = i + 1 as i64
            continue

        if opcode_is_binary_alu(inst.opcode):
            let src1_val = vals[inst.src1]
            let src2_val = vals[inst.src2]
            if src1_val.known and src2_val.known:
                let ok = eval_binary(inst.opcode, src1_val.val, src2_val.val, out_val)
                if ok:
                    inst.opcode = OP_ICONST
                    inst.src1 = out_val[0]
                    inst.src2 = 0 as u32
                    if def_counts[inst.dest] <= 1 as u32:
                        vals[inst.dest] = ConstVal(known: true, val: out_val[0])
                    else:
                        vals[inst.dest] = ConstVal(known: false, val: 0 as u32)
                    changed = true
                    i = i + 1 as i64
                    continue

        if is_unary_foldable(inst.opcode):
            let src1_val = vals[inst.src1]
            if src1_val.known:
                let ok = eval_unary(inst.opcode, src1_val.val, out_val)
                if ok:
                    inst.opcode = OP_ICONST
                    inst.src1 = out_val[0]
                    inst.src2 = 0 as u32
                    if def_counts[inst.dest] <= 1 as u32:
                        vals[inst.dest] = ConstVal(known: true, val: out_val[0])
                    else:
                        vals[inst.dest] = ConstVal(known: false, val: 0 as u32)
                    changed = true
                    i = i + 1 as i64
                    continue

        if inst.dest != 0 as u32:
            vals[inst.dest] = ConstVal(known: false, val: 0 as u32)
        i = i + 1 as i64

    @free(def_counts as ptr[u8])
    @free(vals as ptr[u8])
    @free(out_val as ptr[u8])
    return changed

pub fn copy_prop_func(f: ptr[AirFunc]) -> bool:
    let max_reg = max_reg_id(f)
    if max_reg == 0 as u32:
        return false

    let def_counts = @alloc((max_reg as i64 + 1 as i64) * 4 as i64) as ptr[u32]
    @memset(def_counts as ptr[void], 0 as u8, (max_reg as i64 + 1 as i64) * 4 as i64)

    let copy_map = @alloc((max_reg as i64 + 1 as i64) * 4 as i64) as ptr[u32]
    @memset(copy_map as ptr[void], 0 as u8, (max_reg as i64 + 1 as i64) * 4 as i64)

    mut i := 0 as i64
    while i < f.insts.len:
        let inst = f.insts.data[i]
        if inst.opcode != OP_NOP and inst.dest != 0 as u32:
            if inst.dest <= max_reg:
                def_counts[inst.dest] = def_counts[inst.dest] + 1 as u32
        i = i + 1 as i64

    i = 0 as i64
    while i < f.insts.len:
        let inst = f.insts.data[i]
        if inst.opcode != OP_NOP:
            if (inst.opcode == OP_COPY or inst.opcode == OP_MOVE) and inst.dest != 0 as u32 and inst.src1 != 0 as u32:
                if inst.dest <= max_reg and inst.src1 <= max_reg:
                    if def_counts[inst.dest] == 1 as u32 and def_counts[inst.src1] == 1 as u32:
                        copy_map[inst.dest] = inst.src1
        i = i + 1 as i64

    mut changed := false
    i = 0 as i64
    while i < f.insts.len:
        mut inst := &f.insts.data[i]
        if inst.opcode == OP_NOP or inst.opcode == OP_ICONST or inst.opcode == OP_FCONST:
            i = i + 1 as i64
            continue

        if inst.src1 != 0 as u32 and inst.opcode != OP_JUMP:
            mut curr := inst.src1
            mut depth := 0
            while curr != 0 as u32 and depth < 100:
                let parent = copy_map[curr]
                if parent == 0 as u32:
                    break
                curr = parent
                depth = depth + 1
            
            if curr != inst.src1:
                inst.src1 = curr
                changed = true

        if inst.src2 != 0 as u32 and not opcode_is_control(inst.opcode):
            mut curr := inst.src2
            mut depth := 0
            while curr != 0 as u32 and depth < 100:
                let parent = copy_map[curr]
                if parent == 0 as u32:
                    break
                curr = parent
                depth = depth + 1
            
            if curr != inst.src2:
                inst.src2 = curr
                changed = true

        if inst.dest != 0 as u32 and (inst.opcode == OP_STORE or inst.opcode == OP_SET_FIELD):
            mut curr := inst.dest
            mut depth := 0
            while curr != 0 as u32 and depth < 100:
                let parent = copy_map[curr]
                if parent == 0 as u32:
                    break
                curr = parent
                depth = depth + 1
            
            if curr != inst.dest:
                inst.dest = curr
                changed = true

        if inst.opcode == OP_BRANCH and inst.src1 != 0 as u32:
            mut curr := inst.src1
            mut depth := 0
            while curr != 0 as u32 and depth < 100:
                let parent = copy_map[curr]
                if parent == 0 as u32:
                    break
                curr = parent
                depth = depth + 1
            
            if curr != inst.src1:
                inst.src1 = curr
                changed = true

        if inst.opcode == OP_RETURN and inst.src1 != 0 as u32:
            mut curr := inst.src1
            mut depth := 0
            while curr != 0 as u32 and depth < 100:
                let parent = copy_map[curr]
                if parent == 0 as u32:
                    break
                curr = parent
                depth = depth + 1
            
            if curr != inst.src1:
                inst.src1 = curr
                changed = true

        if inst.opcode == OP_CALL:
            let arg_start = inst.src2
            mut arg_count := 0 as u32
            if arg_start < f.extras.len as u32:
                arg_count = f.extras.data[arg_start]
            
            mut idx := 0 as u32
            while idx < arg_count:
                let arg_reg_idx = arg_start + 1 as u32 + idx
                let arg_reg = f.extras.data[arg_reg_idx]
                if arg_reg != 0 as u32:
                    mut curr := arg_reg
                    mut depth := 0
                    while curr != 0 as u32 and depth < 100:
                        let parent = copy_map[curr]
                        if parent == 0 as u32:
                            break
                        curr = parent
                        depth = depth + 1
                    
                    if curr != arg_reg:
                        f.extras.data[arg_reg_idx] = curr
                        changed = true
                idx = idx + 1 as u32

        i = i + 1 as i64

    @free(def_counts as ptr[u8])
    @free(copy_map as ptr[u8])
    return changed

pub fn remove_unreachable_blocks(f: ptr[AirFunc]) -> bool:
    if f.blocks.len <= 1 as i64:
        return false

    let reachable = @alloc(f.blocks.len) as ptr[bool]
    @memset(reachable as ptr[void], 0 as u8, f.blocks.len)
    reachable[0] = true

    let queue = @alloc(f.blocks.len * 4 as i64) as ptr[u32]
    mut head := 0 as i64
    mut tail := 0 as i64

    queue[tail] = 0 as u32
    tail = tail + 1 as i64

    while head < tail:
        let cur = queue[head]
        head = head + 1 as i64

        if (cur as i64) < f.blocks.len:
            let blk = f.blocks.data[cur]
            mut i := 0 as u32
            while i < blk.succs_len:
                let succ = f.block_succs.data[blk.succs_start + i]
                if (succ as i64) < f.blocks.len:
                    if not reachable[succ]:
                        reachable[succ] = true
                        queue[tail] = succ
                        tail = tail + 1 as i64
                i = i + 1 as u32

    if tail == f.blocks.len:
        @free(reachable as ptr[u8])
        @free(queue as ptr[u8])
        return false

    mut bi := 0 as i64
    while bi < f.blocks.len:
        if not reachable[bi]:
            mut blk := &f.blocks.data[bi]
            mut i := 0 as u32
            while i < blk.instrs_len:
                let inst_idx = f.block_instrs.data[blk.instrs_start + i]
                if (inst_idx as i64) < f.insts.len:
                    f.insts.data[inst_idx].opcode = OP_NOP
                    f.insts.data[inst_idx].type_id = 0 as u32
                    f.insts.data[inst_idx].dest = 0 as u32
                    f.insts.data[inst_idx].src1 = 0 as u32
                    f.insts.data[inst_idx].src2 = 0 as u32
                i = i + 1 as u32
            blk.instrs_len = 0 as u32
            blk.succs_len = 0 as u32
            blk.preds_len = 0 as u32
        bi = bi + 1 as i64

    @free(reachable as ptr[u8])
    @free(queue as ptr[u8])
    return true

pub fn dce_func(f: ptr[AirFunc]) -> bool:
    let max_reg = max_reg_id(f)
    if max_reg == 0 as u32:
        return false

    let use_count = @alloc((max_reg as i64 + 1 as i64) * 4 as i64) as ptr[u32]
    @memset(use_count as ptr[void], 0 as u8, (max_reg as i64 + 1 as i64) * 4 as i64)

    mut i := 0 as i64
    while i < f.insts.len:
        let inst = f.insts.data[i]
        if inst.opcode == OP_NOP:
            i = i + 1 as i64
            continue

        if inst.opcode == OP_CALL:
            let arg_start = inst.src2
            mut arg_count := 0 as u32
            if arg_start < f.extras.len as u32:
                arg_count = f.extras.data[arg_start]
            
            mut idx := 0 as u32
            while idx < arg_count:
                let arg_reg = f.extras.data[arg_start + 1 as u32 + idx]
                if arg_reg != 0 as u32:
                    use_count[arg_reg] = use_count[arg_reg] + 1 as u32
                idx = idx + 1 as u32
            i = i + 1 as i64
            continue

        if inst.opcode == OP_ICONST or inst.opcode == OP_FCONST or inst.opcode == OP_JUMP:
            i = i + 1 as i64
            continue

        if inst.opcode == OP_BRANCH:
            if inst.src1 != 0 as u32:
                use_count[inst.src1] = use_count[inst.src1] + 1 as u32
            i = i + 1 as i64
            continue

        if inst.dest != 0 as u32 and (inst.opcode == OP_STORE or inst.opcode == OP_SET_FIELD):
            use_count[inst.dest] = use_count[inst.dest] + 1 as u32

        if inst.src1 != 0 as u32:
            use_count[inst.src1] = use_count[inst.src1] + 1 as u32

        if inst.src2 != 0 as u32:
            use_count[inst.src2] = use_count[inst.src2] + 1 as u32

        i = i + 1 as i64

    mut changed := false
    i = 0 as i64
    while i < f.insts.len:
        mut inst := &f.insts.data[i]
        if inst.opcode != OP_NOP and inst.dest != 0 as u32:
            if not has_side_effect(inst.opcode):
                if use_count[inst.dest] == 0 as u32:
                    inst.opcode = OP_NOP
                    inst.type_id = 0 as u32
                    inst.dest = 0 as u32
                    inst.src1 = 0 as u32
                    inst.src2 = 0 as u32
                    changed = true
        i = i + 1 as i64

    @free(use_count as ptr[u8])

    if remove_unreachable_blocks(f):
        changed = true

    return changed

pub fn licm_func(f: ptr[AirFunc]) -> bool:
    let max_reg = max_reg_id(f)
    if max_reg == 0 as u32:
        return false

    let def_block = @alloc((max_reg as i64 + 1 as i64) * 4 as i64) as ptr[u32]
    @memset(def_block as ptr[void], 0xff as u8, (max_reg as i64 + 1 as i64) * 4 as i64)

    mut bi := 0 as i64
    while bi < f.blocks.len:
        let blk = f.blocks.data[bi]
        mut inst_i := 0 as u32
        while inst_i < blk.instrs_len:
            let inst_idx = f.block_instrs.data[blk.instrs_start + inst_i]
            let inst = f.insts.data[inst_idx]
            if inst.opcode != OP_NOP and inst.dest != 0 as u32:
                def_block[inst.dest] = bi as u32
            inst_i = inst_i + 1 as u32
        bi = bi + 1 as i64

    mut changed := false

    bi = 0 as i64
    while bi < f.blocks.len:
        let blk = f.blocks.data[bi]
        if blk.loop_depth > 0 as u8:
            mut pre_header_id := 0xffffffff as u32
            mut pred_i := 0 as u32
            while pred_i < blk.preds_len:
                let pred = f.block_preds.data[blk.preds_start + pred_i]
                if pred < f.blocks.len as u32:
                    if f.blocks.data[pred].loop_depth < blk.loop_depth:
                        pre_header_id = pred
                        break
                pred_i = pred_i + 1 as u32

            if pre_header_id != 0xffffffff as u32:
                mut inst_i := 0 as u32
                while inst_i < blk.instrs_len:
                    let inst_idx = f.block_instrs.data[blk.instrs_start + inst_i]
                    mut inst := &f.insts.data[inst_idx]
                    
                    if inst.opcode != OP_NOP and not has_side_effect(inst.opcode) and inst.dest != 0 as u32:
                        mut inv_src1 := true
                        if inst.src1 != 0 as u32 and inst.opcode != OP_ICONST and inst.opcode != OP_FCONST and inst.opcode != OP_JUMP:
                            let def_b = def_block[inst.src1]
                            if def_b != 0xffffffff as u32:
                                if f.blocks.data[def_b].loop_depth >= blk.loop_depth:
                                    inv_src1 = false
                        
                        mut inv_src2 := true
                        if inst.src2 != 0 as u32 and inst.opcode != OP_BRANCH:
                            let def_b = def_block[inst.src2]
                            if def_b != 0xffffffff as u32:
                                if f.blocks.data[def_b].loop_depth >= blk.loop_depth:
                                    inv_src2 = false
                                    
                        if inv_src1 and inv_src2:
                            let new_inst_idx = f.insts.push(AirInst(
                                opcode: inst.opcode,
                                type_id: inst.type_id,
                                dest: inst.dest,
                                src1: inst.src1,
                                src2: inst.src2
                            ))
                            
                            def_block[inst.dest] = pre_header_id
                            
                            let ph = &f.blocks.data[pre_header_id]
                            let insert_pos = ph.instrs_start + ph.instrs_len
                            
                            f.block_instrs.push(0 as u32)
                            mut shift_i := f.block_instrs.len - 1 as i64
                            while shift_i > insert_pos as i64:
                                f.block_instrs.data[shift_i] = f.block_instrs.data[shift_i - 1 as i64]
                                shift_i = shift_i - 1 as i64
                            f.block_instrs.data[insert_pos] = new_inst_idx
                            ph.instrs_len = ph.instrs_len + 1 as u32
                            
                            mut adjust_bi := pre_header_id as i64 + 1 as i64
                            while adjust_bi < f.blocks.len:
                                f.blocks.data[adjust_bi].instrs_start = f.blocks.data[adjust_bi].instrs_start + 1 as u32
                                adjust_bi = adjust_bi + 1 as i64
                                
                            inst.opcode = OP_NOP
                            inst.type_id = 0 as u32
                            inst.dest = 0 as u32
                            inst.src1 = 0 as u32
                            inst.src2 = 0 as u32
                            
                            changed = true
                    inst_i = inst_i + 1 as u32
        bi = bi + 1 as i64

    @free(def_block as ptr[u8])
    return changed

pub fn insert_inst_at(f: ptr[AirFunc], block_id: u32, pos_in_block: u32, inst: AirInst) -> u32:
    let new_inst_idx = f.insts.push(inst)
    let blk = &f.blocks.data[block_id]
    let insert_pos = blk.instrs_start + pos_in_block
    
    f.block_instrs.push(0 as u32)
    mut shift_i := f.block_instrs.len - 1 as i64
    while shift_i > insert_pos as i64:
        f.block_instrs.data[shift_i] = f.block_instrs.data[shift_i - 1 as i64]
        shift_i = shift_i - 1 as i64
    f.block_instrs.data[insert_pos] = new_inst_idx
    blk.instrs_len = blk.instrs_len + 1 as u32
    
    mut adjust_bi := block_id as i64 + 1 as i64
    while adjust_bi < f.blocks.len:
        f.blocks.data[adjust_bi].instrs_start = f.blocks.data[adjust_bi].instrs_start + 1 as u32
        adjust_bi = adjust_bi + 1 as i64
    return new_inst_idx

pub fn compute_loop_depths(f: ptr[AirFunc]) -> bool:
    mut bi := 0 as i64
    while bi < f.blocks.len:
        f.blocks.data[bi].loop_depth = 0 as u8
        bi = bi + 1 as i64

    mut changed := false
    let in_loop = @alloc(f.blocks.len) as ptr[bool]
    let queue = @alloc(f.blocks.len * 4 as i64) as ptr[u32]

    mut b := 0 as u32
    while b < f.blocks.len as u32:
        let blk = f.blocks.data[b]
        mut succ_i := 0 as u32
        while succ_i < blk.succs_len:
            let h = f.block_succs.data[blk.succs_start + succ_i]
            if h <= b and h < f.blocks.len as u32:
                @memset(in_loop as ptr[void], 0 as u8, f.blocks.len)
                in_loop[h] = true
                in_loop[b] = true

                mut head := 0 as i64
                mut tail := 0 as i64
                
                if h != b:
                    queue[tail] = b
                    tail = tail + 1 as i64

                while head < tail:
                    let curr = queue[head]
                    head = head + 1 as i64

                    let curr_blk = f.blocks.data[curr]
                    mut pred_i := 0 as u32
                    while pred_i < curr_blk.preds_len:
                        let pred = f.block_preds.data[curr_blk.preds_start + pred_i]
                        if pred < f.blocks.len as u32:
                            if not in_loop[pred]:
                                in_loop[pred] = true
                                queue[tail] = pred
                                tail = tail + 1 as i64
                        pred_i = pred_i + 1 as u32

                mut i := 0 as i64
                while i < f.blocks.len:
                    if in_loop[i]:
                        let old_depth = f.blocks.data[i].loop_depth
                        if old_depth < 255 as u8:
                            f.blocks.data[i].loop_depth = old_depth + 1 as u8
                            changed = true
                    i = i + 1 as i64
            succ_i = succ_i + 1 as u32
        b = b + 1 as u32

    @free(in_loop as ptr[u8])
    @free(queue as ptr[u8])
    return changed

pub fn strength_reduction_func(f: ptr[AirFunc]) -> bool:
    let max_reg = max_reg_id(f)
    if max_reg == 0 as u32:
        return false

    let def_block = @alloc((max_reg as i64 + 1 as i64) * 4 as i64) as ptr[u32]
    @memset(def_block as ptr[void], 0xff as u8, (max_reg as i64 + 1 as i64) * 4 as i64)

    mut bi := 0 as i64
    while bi < f.blocks.len:
        let blk = f.blocks.data[bi]
        mut inst_i := 0 as u32
        while inst_i < blk.instrs_len:
            let inst_idx = f.block_instrs.data[blk.instrs_start + inst_i]
            let inst = f.insts.data[inst_idx]
            if inst.opcode != OP_NOP and inst.dest != 0 as u32:
                def_block[inst.dest] = bi as u32
            inst_i = inst_i + 1 as u32
        bi = bi + 1 as i64

    mut changed := false
    mut next_reg := max_reg + 1 as u32

    bi = 0 as i64
    while bi < f.blocks.len:
        let blk = f.blocks.data[bi]
        if blk.loop_depth > 0 as u8:
            mut pre_header_id := 0xffffffff as u32
            mut pred_i := 0 as u32
            while pred_i < blk.preds_len:
                let pred = f.block_preds.data[blk.preds_start + pred_i]
                if pred < f.blocks.len as u32:
                    if f.blocks.data[pred].loop_depth < blk.loop_depth:
                        pre_header_id = pred
                        break
                pred_i = pred_i + 1 as u32

            if pre_header_id != 0xffffffff as u32:
                mut iv_reg := 0 as u32
                mut step_val := 0 as u32
                mut step_reg := 0 as u32
                mut is_add := true

                mut inst_i := 0 as u32
                while inst_i < blk.instrs_len:
                    let inst_idx = f.block_instrs.data[blk.instrs_start + inst_i]
                    let inst = f.insts.data[inst_idx]
                    if inst.opcode == OP_COPY and inst.dest != 0 as u32:
                        let src = inst.src1
                        let src_def_idx = f.block_instrs.data[blk.instrs_start + inst_i - 1 as u32]
                        let src_def = f.insts.data[src_def_idx]
                        if src_def.dest == src and (src_def.opcode == OP_IADD or src_def.opcode == OP_ISUB):
                            if src_def.src1 == inst.dest:
                                iv_reg = inst.dest
                                step_reg = src_def.src2
                                is_add = (src_def.opcode == OP_IADD)
                                break
                            elif src_def.src2 == inst.dest and src_def.opcode == OP_IADD:
                                iv_reg = inst.dest
                                step_reg = src_def.src1
                                is_add = true
                                break
                    inst_i = inst_i + 1 as u32

                if iv_reg != 0 as u32:
                    inst_i = 0 as u32
                    while inst_i < blk.instrs_len:
                        let inst_idx = f.block_instrs.data[blk.instrs_start + inst_i]
                        mut inst := &f.insts.data[inst_idx]
                        if inst.opcode == OP_IMUL and inst.dest != 0 as u32:
                            mut c_reg := 0 as u32
                            if inst.src1 == iv_reg:
                                c_reg = inst.src2
                            elif inst.src2 == iv_reg:
                                c_reg = inst.src1
                            
                            if c_reg != 0 as u32:
                                mut is_invariant := false
                                let c_def_b = def_block[c_reg]
                                if c_def_b == 0xffffffff as u32:
                                    is_invariant = true
                                else:
                                    if f.blocks.data[c_def_b].loop_depth < blk.loop_depth:
                                        is_invariant = true
                                        
                                if is_invariant:
                                    mut start_reg := 0 as u32
                                    let ph_blk = f.blocks.data[pre_header_id]
                                    mut ph_inst_i := 0 as u32
                                    while ph_inst_i < ph_blk.instrs_len:
                                        let ph_inst_idx = f.block_instrs.data[ph_blk.instrs_start + ph_inst_i]
                                        let ph_inst = f.insts.data[ph_inst_idx]
                                        if (ph_inst.opcode == OP_COPY or ph_inst.opcode == OP_MOVE) and ph_inst.dest == iv_reg:
                                            start_reg = ph_inst.src1
                                            break
                                        elif ph_inst.opcode == OP_ICONST and ph_inst.dest == iv_reg:
                                            start_reg = iv_reg
                                            break
                                        ph_inst_i = ph_inst_i + 1 as u32
                                        
                                    if start_reg != 0 as u32:
                                        let acc_reg = next_reg
                                        next_reg = next_reg + 1 as u32
                                        
                                        mut init_inst := AirInst(
                                            opcode: OP_IMUL,
                                            type_id: inst.type_id,
                                            dest: acc_reg,
                                            src1: start_reg,
                                            src2: c_reg
                                        )
                                        if start_reg == iv_reg:
                                            mut iv_const_val := 0 as u32
                                            let ph_blk2 = f.blocks.data[pre_header_id]
                                            mut ph_inst_i2 := 0 as u32
                                            while ph_inst_i2 < ph_blk2.instrs_len:
                                                let ph_inst_idx = f.block_instrs.data[ph_blk2.instrs_start + ph_inst_i2]
                                                let ph_inst = f.insts.data[ph_inst_idx]
                                                if ph_inst.opcode == OP_ICONST and ph_inst.dest == iv_reg:
                                                    iv_const_val = ph_inst.src1
                                                    break
                                                ph_inst_i2 = ph_inst_i2 + 1 as u32
                                            let temp_start_reg = next_reg
                                            next_reg = next_reg + 1 as u32
                                            insert_inst_at(f, pre_header_id, ph_blk2.instrs_len - 1 as u32, AirInst(
                                                opcode: OP_ICONST,
                                                type_id: inst.type_id,
                                                dest: temp_start_reg,
                                                src1: iv_const_val,
                                                src2: 0 as u32
                                            ))
                                            init_inst.src1 = temp_start_reg
                                        
                                        insert_inst_at(f, pre_header_id, f.blocks.data[pre_header_id].instrs_len - 1 as u32, init_inst)
                                        
                                        inst.opcode = OP_COPY
                                        inst.src1 = acc_reg
                                        inst.src2 = 0 as u32
                                        
                                        let step_mul_reg = next_reg
                                        next_reg = next_reg + 1 as u32
                                        
                                        let new_acc_reg = next_reg
                                        next_reg = next_reg + 1 as u32
                                        
                                        mut copy_pos := 0 as u32
                                        mut loop_inst_i := 0 as u32
                                        while loop_inst_i < blk.instrs_len:
                                            let loop_inst_idx = f.block_instrs.data[blk.instrs_start + loop_inst_i]
                                            let loop_inst = f.insts.data[loop_inst_idx]
                                            if loop_inst.opcode == OP_COPY and loop_inst.dest == iv_reg:
                                                copy_pos = loop_inst_i + 1 as u32
                                                break
                                            loop_inst_i = loop_inst_i + 1 as u32
                                            
                                        if copy_pos != 0 as u32:
                                            insert_inst_at(f, bi as u32, copy_pos, AirInst(
                                                opcode: OP_IMUL,
                                                type_id: inst.type_id,
                                                dest: step_mul_reg,
                                                src1: step_reg,
                                                src2: c_reg
                                            ))
                                            
                                            mut add_op := OP_IADD as u16
                                            if not is_add:
                                                add_op = OP_ISUB
                                                
                                            insert_inst_at(f, bi as u32, copy_pos + 1 as u32, AirInst(
                                                opcode: add_op,
                                                type_id: inst.type_id,
                                                dest: new_acc_reg,
                                                src1: acc_reg,
                                                src2: step_mul_reg
                                            ))
                                            
                                            insert_inst_at(f, bi as u32, copy_pos + 2 as u32, AirInst(
                                                opcode: OP_COPY,
                                                type_id: inst.type_id,
                                                dest: acc_reg,
                                                src1: new_acc_reg,
                                                src2: 0 as u32
                                            ))
                                            
                                            changed = true
                        inst_i = inst_i + 1 as u32
        bi = bi + 1 as i64

    @free(def_block as ptr[u8])
    return changed

pub fn loop_unroll_func(f: ptr[AirFunc]) -> bool:
    let max_reg = max_reg_id(f)
    if max_reg == 0 as u32:
        return false

    let def_block = @alloc((max_reg as i64 + 1 as i64) * 4 as i64) as ptr[u32]
    @memset(def_block as ptr[void], 0xff as u8, (max_reg as i64 + 1 as i64) * 4 as i64)

    mut bi := 0 as i64
    while bi < f.blocks.len:
        let blk = f.blocks.data[bi]
        mut inst_i := 0 as u32
        while inst_i < blk.instrs_len:
            let inst_idx = f.block_instrs.data[blk.instrs_start + inst_i]
            let inst = f.insts.data[inst_idx]
            if inst.opcode != OP_NOP and inst.dest != 0 as u32:
                def_block[inst.dest] = bi as u32
            inst_i = inst_i + 1 as u32
        bi = bi + 1 as i64

    let vals = @alloc((max_reg as i64 + 1 as i64) * 8 as i64) as ptr[ConstVal]
    mut reg_idx := 0 as u32
    while reg_idx <= max_reg:
        vals[reg_idx] = ConstVal(known: false, val: 0 as u32)
        reg_idx = reg_idx + 1 as u32

    mut i := 0 as i64
    while i < f.insts.len:
        let inst = f.insts.data[i]
        if inst.opcode == OP_ICONST and inst.dest != 0 as u32:
            vals[inst.dest] = ConstVal(known: true, val: inst.src1)
        i = i + 1 as i64

    mut changed := false
    mut next_reg := max_reg + 1 as u32

    bi = 0 as i64
    while bi < f.blocks.len:
        let blk = f.blocks.data[bi]
        if blk.loop_depth > 0 as u8:
            mut pre_header_id := 0xffffffff as u32
            mut pred_i := 0 as u32
            while pred_i < blk.preds_len:
                let pred = f.block_preds.data[blk.preds_start + pred_i]
                if pred < f.blocks.len as u32:
                    if f.blocks.data[pred].loop_depth < blk.loop_depth:
                        pre_header_id = pred
                        break
                pred_i = pred_i + 1 as u32

            if pre_header_id != 0xffffffff as u32:
                mut cond_inst_idx := 0xffffffff as u32
                mut loop_body_block_id := 0xffffffff as u32
                mut exit_block_id := 0xffffffff as u32

                if blk.instrs_len > 0 as u32:
                    let final_inst_idx = f.block_instrs.data[blk.instrs_start + blk.instrs_len - 1 as u32]
                    let final_inst = f.insts.data[final_inst_idx]
                    if final_inst.opcode == OP_BRANCH:
                        cond_inst_idx = final_inst_idx
                        exit_block_id = final_inst.dest
                        loop_body_block_id = final_inst.src2

                if cond_inst_idx != 0xffffffff as u32 and loop_body_block_id < f.blocks.len as u32 and loop_body_block_id != bi as u32:
                    let cond_inst = f.insts.data[cond_inst_idx]
                    mut cmp_inst_idx := 0xffffffff as u32
                    mut inst_idx_i := blk.instrs_start
                    while inst_idx_i < blk.instrs_start + blk.instrs_len:
                        let idx = f.block_instrs.data[inst_idx_i]
                        let inst = f.insts.data[idx]
                        if inst.dest == cond_inst.src1 and (inst.opcode == OP_LT or inst.opcode == OP_LE):
                            cmp_inst_idx = idx
                            break
                        inst_idx_i = inst_idx_i + 1 as u32

                    if cmp_inst_idx != 0xffffffff as u32:
                        let cmp_inst = f.insts.data[cmp_inst_idx]
                        let iv_reg = cmp_inst.src1
                        let limit_reg = cmp_inst.src2

                        let limit_val_const = vals[limit_reg]
                        if limit_val_const.known:
                            let limit_val = limit_val_const.val
                            mut start_reg := 0 as u32
                            let ph_blk = f.blocks.data[pre_header_id]
                            mut ph_inst_i := 0 as u32
                            while ph_inst_i < ph_blk.instrs_len:
                                let ph_inst_idx = f.block_instrs.data[ph_blk.instrs_start + ph_inst_i]
                                let ph_inst = f.insts.data[ph_inst_idx]
                                if (ph_inst.opcode == OP_COPY or ph_inst.opcode == OP_MOVE) and ph_inst.dest == iv_reg:
                                    start_reg = ph_inst.src1
                                    break
                                elif ph_inst.opcode == OP_ICONST and ph_inst.dest == iv_reg:
                                    start_reg = iv_reg
                                    break
                                ph_inst_i = ph_inst_i + 1 as u32

                            if start_reg != 0 as u32:
                                mut start_val := 0 as u32
                                mut start_known := false
                                if start_reg == iv_reg:
                                    let ph_blk2 = f.blocks.data[pre_header_id]
                                    mut ph_inst_i2 := 0 as u32
                                    while ph_inst_i2 < ph_blk2.instrs_len:
                                        let ph_inst_idx = f.block_instrs.data[ph_blk2.instrs_start + ph_inst_i2]
                                        let ph_inst = f.insts.data[ph_inst_idx]
                                        if ph_inst.opcode == OP_ICONST and ph_inst.dest == iv_reg:
                                            start_val = ph_inst.src1
                                            start_known = true
                                            break
                                        ph_inst_i2 = ph_inst_i2 + 1 as u32
                                else:
                                    let start_val_const = vals[start_reg]
                                    if start_val_const.known:
                                        start_val = start_val_const.val
                                        start_known = true

                                if start_known:
                                    mut step_val := 1 as u32
                                    let body_blk = f.blocks.data[loop_body_block_id]
                                    mut body_inst_i := 0 as u32
                                    while body_inst_i < body_blk.instrs_len:
                                        let b_inst_idx = f.block_instrs.data[body_blk.instrs_start + body_inst_i]
                                        let b_inst = f.insts.data[b_inst_idx]
                                        if b_inst.opcode == OP_IADD and (b_inst.src1 == iv_reg or b_inst.src2 == iv_reg):
                                            mut step_reg := b_inst.src2
                                            if b_inst.src2 == iv_reg:
                                                step_reg = b_inst.src1
                                            let step_val_const = vals[step_reg]
                                            if step_val_const.known:
                                                step_val = step_val_const.val
                                                break
                                        body_inst_i = body_inst_i + 1 as u32

                                    let cmp_op = cmp_inst.opcode
                                    mut trip_count := 0 as u32
                                    if cmp_op == OP_LT:
                                        if limit_val > start_val and step_val > 0 as u32:
                                            trip_count = (limit_val - start_val) / step_val
                                    elif cmp_op == OP_LE:
                                        if limit_val >= start_val and step_val > 0 as u32:
                                            trip_count = (limit_val - start_val) / step_val + 1 as u32

                                    if trip_count > 0 as u32 and trip_count <= 4 as u32:
                                        let renamed_map = @alloc((max_reg as i64 + 1 as i64) * 4 as i64) as ptr[u32]

                                        mut iter := 0 as u32
                                        while iter < trip_count:
                                            let curr_iv_val = start_val + iter * step_val
                                            @memset(renamed_map as ptr[void], 0 as u8, (max_reg as i64 + 1 as i64) * 4 as i64)

                                            mut body_inst_i2 := 0 as u32
                                            while body_inst_i2 < body_blk.instrs_len:
                                                let b_inst_idx = f.block_instrs.data[body_blk.instrs_start + body_inst_i2]
                                                let b_inst = f.insts.data[b_inst_idx]
                                                if b_inst.opcode != OP_NOP and b_inst.dest != 0 as u32 and b_inst.dest != iv_reg:
                                                    let new_reg = next_reg
                                                    next_reg = next_reg + 1 as u32
                                                    renamed_map[b_inst.dest] = new_reg
                                                body_inst_i2 = body_inst_i2 + 1 as u32

                                            let temp_iv_reg = next_reg
                                            next_reg = next_reg + 1 as u32
                                            insert_inst_at(f, pre_header_id, f.blocks.data[pre_header_id].instrs_len - 1 as u32, AirInst(
                                                opcode: OP_ICONST,
                                                type_id: 3 as u32,
                                                dest: temp_iv_reg,
                                                src1: curr_iv_val,
                                                src2: 0 as u32
                                            ))

                                            body_inst_i2 = 0 as u32
                                            while body_inst_i2 < body_blk.instrs_len:
                                                let b_inst_idx = f.block_instrs.data[body_blk.instrs_start + body_inst_i2]
                                                let b_inst = f.insts.data[b_inst_idx]
                                                if b_inst.opcode == OP_JUMP or b_inst.opcode == OP_BRANCH or b_inst.opcode == OP_NOP:
                                                    body_inst_i2 = body_inst_i2 + 1 as u32
                                                    continue

                                                mut src1 := b_inst.src1
                                                if src1 == iv_reg and b_inst.opcode != OP_ICONST and b_inst.opcode != OP_FCONST:
                                                    src1 = temp_iv_reg
                                                elif src1 != 0 as u32 and src1 <= max_reg:
                                                    if renamed_map[src1] != 0 as u32:
                                                        src1 = renamed_map[src1]

                                                mut src2 := b_inst.src2
                                                if src2 == iv_reg and b_inst.opcode != OP_BRANCH:
                                                    src2 = temp_iv_reg
                                                elif src2 != 0 as u32 and src2 <= max_reg:
                                                    if renamed_map[src2] != 0 as u32:
                                                        src2 = renamed_map[src2]

                                                mut dest := b_inst.dest
                                                if dest == iv_reg:
                                                    dest = temp_iv_reg
                                                elif dest != 0 as u32 and dest <= max_reg:
                                                    if renamed_map[dest] != 0 as u32:
                                                        dest = renamed_map[dest]

                                                insert_inst_at(f, pre_header_id, f.blocks.data[pre_header_id].instrs_len - 1 as u32, AirInst(
                                                    opcode: b_inst.opcode,
                                                    type_id: b_inst.type_id,
                                                    dest: dest,
                                                    src1: src1,
                                                    src2: src2
                                                ))
                                                body_inst_i2 = body_inst_i2 + 1 as u32

                                            if iter == trip_count - 1 as u32:
                                                body_inst_i2 = 0 as u32
                                                while body_inst_i2 < body_blk.instrs_len:
                                                    let b_inst_idx = f.block_instrs.data[body_blk.instrs_start + body_inst_i2]
                                                    let b_inst = f.insts.data[b_inst_idx]
                                                    if b_inst.opcode != OP_NOP and b_inst.dest != 0 as u32 and b_inst.dest != iv_reg:
                                                        let original_dest = b_inst.dest
                                                        let original_def_b = def_block[original_dest]
                                                        if original_def_b != loop_body_block_id and original_def_b != 0xffffffff as u32:
                                                            insert_inst_at(f, pre_header_id, f.blocks.data[pre_header_id].instrs_len - 1 as u32, AirInst(
                                                                opcode: OP_COPY,
                                                                type_id: b_inst.type_id,
                                                                dest: original_dest,
                                                                src1: renamed_map[original_dest],
                                                                src2: 0 as u32
                                                            ))
                                                    body_inst_i2 = body_inst_i2 + 1 as u32

                                            iter = iter + 1 as u32

                                        @free(renamed_map as ptr[u8])

                                        let ph_blk3 = &f.blocks.data[pre_header_id]
                                        let ph_final_idx = f.block_instrs.data[ph_blk3.instrs_start + ph_blk3.instrs_len - 1 as u32]
                                        mut ph_final := &f.insts.data[ph_final_idx]
                                        ph_final.opcode = OP_JUMP
                                        ph_final.src1 = exit_block_id
                                        ph_final.src2 = 0 as u32

                                        f.block_succs.data[ph_blk3.succs_start] = exit_block_id
                                        ph_blk3.succs_len = 1 as u32

                                        changed = true
                                        break
        bi = bi + 1 as i64

    @free(def_block as ptr[u8])
    @free(vals as ptr[u8])
    return changed

pub fn run(mut self: SsaOptimizer, mut m: ptr[AirModule]):
    mut fi := 0 as i64
    while fi < m.funcs.len:
        mut f := &m.funcs.data[fi]
        if not f.is_extern:
            if self.level >= 2 as u8:
                compute_loop_depths(f)
            mut iter := 0
            while iter < 10:
                mut changed := false
                
                if fold_func(f):
                    changed = true
                if copy_prop_func(f):
                    changed = true
                if self.level >= 2 as u8:
                    if licm_func(f):
                        changed = true
                    if strength_reduction_func(f):
                        changed = true
                    if loop_unroll_func(f):
                        changed = true
                if dce_func(f):
                    changed = true

                if not changed:
                    break
                iter = iter + 1
        fi = fi + 1 as i64
// bootstrap/stage1/cgen.ax
// SSA AIR to C11 Code Generator.


extern "C" fn fopen(filename: ptr[void], mode: ptr[u8]) -> ptr[void]
extern "C" fn fclose(stream: ptr[void]) -> i32
extern "C" fn fputs(s: ptr[u8], stream: ptr[void]) -> i32
// extern "C" fn fprintf(stream: ptr[void], fmt: str, a1: i64, a2: i64, a3: i64, a4: i64, a5: i64, a6: i64, a7: i64, a8: i64) -> i32

fn normalize_struct_cast(t_name: str) -> str:
    let len = std.string.len(t_name)
    mut i := len
    let ptr = get_str_ptr(t_name)
    while i > 0 and ptr[i - 1] == '*' as u8:
        i = i - 1
    let base = std.string.slice(t_name, 0, i)
    let res = @alloc(std.string.len(base) + 2) as ptr[u8]
    @memcpy(res, get_str_ptr(base), std.string.len(base))
    res[std.string.len(base)] = '*' as u8
    res[std.string.len(base) + 1] = 0 as u8
    if std.string.len(base) > 0 as i64 and get_str_ptr(base) != get_str_ptr(t_name):
        @free(get_str_ptr(base))
    return res as str

fn opcode_defines_dest(op: u16) -> bool:
    if op == 0 as u16: // OP_NOP
        return false
    if op == 0x0102 as u32: // OP_FREE
        return false
    if op == 0x010B as u16: // OP_DESTROY
        return false
    if op == 0x0104 as u16: // OP_STORE
        return false
    if op == 0x010E as u16: // OP_SET_FIELD
        return false
    if op == 0x0301 as u16: // OP_JUMP
        return false
    if op == 0x0302 as u16: // OP_BRANCH
        return false
    if op == 0x0304 as u16: // OP_RETURN
        return false
    return true

pub struct CGenerator:
    pub module: AirModule
    pub tree: ptr[AstTree]
    pub pool: ptr[InternPool]
    pub symtable: ptr[SymbolTable]
    pub typetable: ptr[TypeTable]
    pub file: ptr[void]
    pub reg_types: ptr[u32]

pub fn new_c_generator(mod: AirModule, tree: ptr[AstTree], pool: ptr[InternPool], symtable: ptr[SymbolTable], typetable: ptr[TypeTable]) -> ptr[CGenerator]:
    let cg = @alloc(@compiler_intrinsic("size_of")[CGenerator]()) as ptr[CGenerator]
    cg.module = mod
    cg.tree = tree
    cg.pool = pool
    cg.symtable = symtable
    cg.typetable = typetable
    cg.file = null as ptr[void]
    cg.reg_types = null as ptr[u32]
    return cg

pub fn get_c_type(self: ptr[CGenerator], type_id: u32) -> str:
    if type_id == 1 as u32:
        return alloc_str("ax_i8")
    if type_id == 2 as u32:
        return alloc_str("ax_i16")
    if type_id == 3 as u32:
        return alloc_str("ax_i32")
    if type_id == 4 as u32:
        return alloc_str("ax_i64")
    if type_id == 5 as u32:
        return alloc_str("ax_u8")
    if type_id == 6 as u32:
        return alloc_str("ax_u16")
    if type_id == 7 as u32:
        return alloc_str("ax_u32")
    if type_id == 8 as u32:
        return alloc_str("ax_u64")
    if type_id == 9 as u32:
        return alloc_str("ax_f32")
    if type_id == 10 as u32:
        return alloc_str("ax_f64")
    if type_id == 11 as u32:
        return alloc_str("ax_bool")
    if type_id == 12 as u32:
        return alloc_str("ax_string")
    if type_id == 13 as u32:
        return alloc_str("ax_char")
    if type_id == 14 as u32:
        return alloc_str("void")
    if type_id == 15 as u32:
        return alloc_str("ax_isize")
    if type_id == 16 as u32:
        return alloc_str("ax_usize")
    if type_id == 21 as u32:
        return alloc_str("AxActorID")
    
    if (type_id as i64) < self.typetable.entries.len:
        let entry = self.typetable.entries.data[type_id]
        if entry.kind == TYPE_KIND_REF:
            return alloc_str("AxRef")
        if entry.kind == TYPE_KIND_POINTER:
            return alloc_str("void*")
        if entry.kind == TYPE_KIND_STRUCT or entry.kind == TYPE_KIND_GENERIC_INST:
            if entry.name_id != 0 as u32:
                let name = self.pool.get(entry.name_id)
                mut is_sum := false
                if entry.kind == TYPE_KIND_GENERIC_INST:
                    mut idx := 0 as i64
                    mut found_struct := false
                    while idx < self.typetable.entries.len:
                        let e = self.typetable.entries.data[idx]
                        if e.name_id == entry.name_id:
                            if e.kind == TYPE_KIND_STRUCT:
                                found_struct = true
                                break
                            elif e.kind == TYPE_KIND_SUM or e.kind == TYPE_KIND_OPTION or e.kind == TYPE_KIND_RESULT:
                                is_sum = true
                        idx = idx + 1
                    if is_sum and not found_struct:
                        return alloc_str("void*")
                
                // Return struct pointer name
                mut res := @alloc(std.string.len(name) + 2) as ptr[u8]
                @memcpy(res, get_str_ptr(name), std.string.len(name))
                res[std.string.len(name)] = '*' as u8
                res[std.string.len(name) + 1] = 0 as u8
                return res as str
            return alloc_str("void*")
        if entry.kind == TYPE_KIND_SUM or entry.kind == TYPE_KIND_OPTION or entry.kind == TYPE_KIND_RESULT:
            return alloc_str("void*")
        if entry.kind == TYPE_KIND_SLICE:
            return alloc_str("ax_slice_void")
    return alloc_str("void*")

pub fn is_stdlib_func(self: ptr[CGenerator], name: str) -> bool:
    if name == "system" or name == "remove" or name == "fopen" or name == "fclose" or name == "fseek" or name == "ftell" or name == "rewind" or name == "fread" or name == "fwrite" or name == "printf" or name == "puts" or name == "putchar" or name == "getchar" or name == "fgetc" or name == "fgets" or name == "fputc" or name == "fputs" or name == "sprintf" or name == "snprintf" or name == "fprintf" or name == "scanf" or name == "fscanf" or name == "sscanf" or name == "malloc" or name == "free" or name == "realloc" or name == "calloc" or name == "exit" or name == "abort" or name == "memset" or name == "memcpy" or name == "memmove" or name == "println" or name == "print" or name == "eprint" or name == "eprintln" or name == "assert" or name == "fflush":
        return true
    
    let name_ptr = get_str_ptr(name)
    let len = std.string.len(name)
    if len >= 3 and name_ptr[0] == 'a' as u8 and name_ptr[1] == 'x' as u8 and name_ptr[2] == '_' as u8:
        if name == "ax_driver_load_module":
            return false
        return true
            
    return false

fn starts_with_std_string(s: str) -> bool:
    let len = std.string.len(s)
    if len < 11:
        return false
    let ptr = get_str_ptr(s)
    if ptr[0] == 's' as u8 and ptr[1] == 't' as u8 and ptr[2] == 'd' as u8 and ptr[3] == '.' as u8 and ptr[4] == 's' as u8 and ptr[5] == 't' as u8 and ptr[6] == 'r' as u8 and ptr[7] == 'i' as u8 and ptr[8] == 'n' as u8 and ptr[9] == 'g' as u8 and ptr[10] == '.' as u8:
        return true
    return false

fn cgen_starts_with(s: str, prefix: str) -> bool:
    let s_len = std.string.len(s)
    let p_len = std.string.len(prefix)
    if s_len < p_len:
        return false
    let s_ptr = get_str_ptr(s)
    let p_ptr = get_str_ptr(prefix)
    mut i := 0 as i64
    while i < p_len:
        if s_ptr[i] != p_ptr[i]:
            return false
        i = i + 1
    return true

fn alloc_str(s: str) -> str:
    let len = std.string.len(s)
    let buf = @alloc(len + 1) as ptr[u8]
    @memcpy(buf, get_str_ptr(s), len)
    buf[len] = 0 as u8
    return buf as str

fn cgen_contains(s: str, sub: str) -> bool:
    let s_len = std.string.len(s)
    let sub_len = std.string.len(sub)
    if s_len < sub_len:
        return false
    let s_ptr = get_str_ptr(s)
    let sub_ptr = get_str_ptr(sub)
    mut i := 0 as i64
    while i <= s_len - sub_len:
        mut j := 0 as i64
        mut matched := true
        while j < sub_len:
            if s_ptr[i + j] != sub_ptr[j]:
                matched = false
                break
            j = j + 1
        if matched:
            return true
        i = i + 1
    return false

fn get_base_sum_name(sum_name: str) -> str:
    if cgen_contains(sum_name, "Result"):
        return "Result"
    if cgen_contains(sum_name, "Option"):
        return "Option"
    return sum_name

pub fn get_mangled_name_by_sym(self: ptr[CGenerator], sym_idx: u32) -> str:
    mut fn_name := "func"
    if sym_idx != 0 as u32 and (sym_idx as i64) < self.symtable.symbols.len:
        let sym = self.symtable.symbols.data[sym_idx as i64]
        fn_name = self.pool.get(sym.name_id)
        

        if fn_name == "main":
            return alloc_str("ax_main_usr")

        if fn_name == "free":
            let is_extern = ((sym.flags & 4 as u16) != 0 as u16)
            if is_extern:
                return alloc_str("free")
            return alloc_str("ax_free")

        if starts_with_std_string(fn_name):
            let rest = std.string.slice(fn_name, 11, std.string.len(fn_name))
            let res_str = std.string.concat("ax_str_", rest)
            let ret_str = alloc_str(res_str)
            @free(get_str_ptr(res_str))
            return ret_str

        if self.is_stdlib_func(fn_name):
            let mangled = std.string.replace(fn_name, ".", "_")
            return alloc_str(mangled)

        let is_extern = ((sym.flags & 4 as u16) != 0 as u16)
        if is_extern:
            let mangled = std.string.replace(fn_name, ".", "_")
            return alloc_str(mangled)

        if sym.type_id != 0 as u32 and (sym.type_id as i64) < self.typetable.entries.len:
            let entry = self.typetable.entries.data[sym.type_id as i64]
            
            // Check if it is a variant constructor first (SYM_VARIANT is 5)
            if sym.kind == 5 as u8 or sym.kind == SYM_VARIANT:
                if (entry.kind == TYPE_KIND_SUM or entry.kind == TYPE_KIND_GENERIC_INST or entry.kind == TYPE_KIND_OPTION or entry.kind == TYPE_KIND_RESULT) and entry.name_id != 0 as u32:
                    let raw_sum_name = self.pool.get(entry.name_id)
                    let sum_name = get_base_sum_name(raw_sum_name)
                    mut lower_variant := ""
                    if fn_name == "Some" or cgen_starts_with(fn_name, "Some_"):
                        lower_variant = "some"
                    elif fn_name == "None" or cgen_starts_with(fn_name, "None_"):
                        lower_variant = "none"
                    elif fn_name == "Ok" or cgen_starts_with(fn_name, "Ok_"):
                        lower_variant = "ok"
                    elif fn_name == "Err" or cgen_starts_with(fn_name, "Err_"):
                        lower_variant = "err"
                    
                    if std.string.len(lower_variant) > 0 as i64:
                        let sum_len = std.string.len(sum_name)
                        let v_len = std.string.len(lower_variant)
                        let total_len = 3 + sum_len + 1 + v_len
                        mut res := @alloc(total_len + 1) as ptr[u8]
                        @memcpy(res, "ax_" as ptr[u8], 3)
                        let dest1 = ((res as u64) + 3 as u64) as ptr[u8]
                        @memcpy(dest1, get_str_ptr(sum_name), sum_len)
                        res[3 + sum_len] = '_' as u8
                        let dest2 = ((res as u64) + 3 as u64 + sum_len as u64 + 1 as u64) as ptr[u8]
                        @memcpy(dest2, lower_variant as ptr[u8], v_len)
                        res[total_len] = 0 as u8
                        
                        let res_str = res as str
                        let mangled = std.string.replace(res_str, ".", "_")
                        let ret_str = alloc_str(mangled)
                        @free(res)
                        return ret_str

            if entry.kind == TYPE_KIND_FUNC:
                let fi = self.typetable.funcs.data[entry.extra as i64]
                
                // Mangle sum type variant constructors (Ok, Err, Some, None) to avoid conflicts
                mut ret_type := fi.ret
                if (ret_type as i64) < self.typetable.entries.len:
                    mut r_entry := self.typetable.entries.data[ret_type as i64]
                    while r_entry.kind == TYPE_KIND_POINTER or r_entry.kind == TYPE_KIND_REF:
                        ret_type = r_entry.extra
                        r_entry = self.typetable.entries.data[ret_type as i64]
                    
                    if (r_entry.kind == TYPE_KIND_SUM or r_entry.kind == TYPE_KIND_GENERIC_INST or r_entry.kind == TYPE_KIND_OPTION or r_entry.kind == TYPE_KIND_RESULT) and r_entry.name_id != 0 as u32:
                        let raw_sum_name = self.pool.get(r_entry.name_id)
                        let sum_name = get_base_sum_name(raw_sum_name)
                        mut lower_variant := ""
                        if fn_name == "Some" or cgen_starts_with(fn_name, "Some_"):
                            lower_variant = "some"
                        elif fn_name == "None" or cgen_starts_with(fn_name, "None_"):
                            lower_variant = "none"
                        elif fn_name == "Ok" or cgen_starts_with(fn_name, "Ok_"):
                            lower_variant = "ok"
                        elif fn_name == "Err" or cgen_starts_with(fn_name, "Err_"):
                            lower_variant = "err"
                        
                        if std.string.len(lower_variant) > 0 as i64:
                            let sum_len = std.string.len(sum_name)
                            let v_len = std.string.len(lower_variant)
                            let total_len = 3 + sum_len + 1 + v_len
                            mut res := @alloc(total_len + 1) as ptr[u8]
                            @memcpy(res, "ax_" as ptr[u8], 3)
                            let dest1 = ((res as u64) + 3 as u64) as ptr[u8]
                            @memcpy(dest1, get_str_ptr(sum_name), sum_len)
                            res[3 + sum_len] = '_' as u8
                            let dest2 = ((res as u64) + 3 as u64 + sum_len as u64 + 1 as u64) as ptr[u8]
                            @memcpy(dest2, lower_variant as ptr[u8], v_len)
                            res[total_len] = 0 as u8
                            
                            let res_str = res as str
                            let mangled = std.string.replace(res_str, ".", "_")
                            let ret_str = alloc_str(mangled)
                            @free(res)
                            return ret_str

                if fi.params.len > 0 as i64:
                    mut first_param_type = fi.params.data[0]
                    mut p_entry = self.typetable.entries.data[first_param_type as i64]
                    while p_entry.kind == TYPE_KIND_POINTER or p_entry.kind == TYPE_KIND_REF:
                        first_param_type = p_entry.extra
                        p_entry = self.typetable.entries.data[first_param_type as i64]
                    
                    if (p_entry.kind == TYPE_KIND_STRUCT or p_entry.kind == TYPE_KIND_SUM or p_entry.kind == TYPE_KIND_GENERIC_INST or p_entry.kind == TYPE_KIND_OPTION or p_entry.kind == TYPE_KIND_RESULT) and p_entry.name_id != 0 as u32:
                        let struct_name = self.pool.get(p_entry.name_id)
                        let struct_len = std.string.len(struct_name)
                        let fn_len = std.string.len(fn_name)
                        let total_len = 3 + struct_len + 1 + fn_len
                        mut res := @alloc(total_len + 1) as ptr[u8]
                        @memcpy(res, "ax_" as ptr[u8], 3)
                        
                        let dest1 = ((res as u64) + 3 as u64) as ptr[u8]
                        @memcpy(dest1, get_str_ptr(struct_name), struct_len)
                        
                        res[3 + struct_len] = '_' as u8
                        
                        let dest2 = ((res as u64) + 3 as u64 + struct_len as u64 + 1 as u64) as ptr[u8]
                        @memcpy(dest2, get_str_ptr(fn_name), fn_len)
                        
                        res[total_len] = 0 as u8
                        
                        let res_str = res as str
                        let mangled = std.string.replace(res_str, ".", "_")
                        let ret_str = alloc_str(mangled)
                        @free(res)
                        return ret_str

    let fn_len = std.string.len(fn_name)
    mut res := @alloc(3 + fn_len + 1) as ptr[u8]
    @memcpy(res, "ax_" as ptr[u8], 3)
    let dest = ((res as u64) + 3 as u64) as ptr[u8]
    @memcpy(dest, get_str_ptr(fn_name), fn_len)
    res[3 + fn_len] = 0 as u8
    
    let res_str = res as str
    let mangled = std.string.replace(res_str, ".", "_")
    let ret_str = alloc_str(mangled)
    @free(res)
    return ret_str

fn str_to_null_terminated(s: str) -> ptr[u8]:
    let len = std.string.len(s)
    let buf = @alloc(len + 1) as ptr[u8]
    @memcpy(buf, s as ptr[u8], len)
    buf[len] = 0 as u8
    return buf

pub fn generate(mut self: ptr[CGenerator], out_filename: str) -> bool:
    let filename_nt = str_to_null_terminated(out_filename)
    self.file = fopen(filename_nt as ptr[void], get_str_ptr("w"))
    @free(filename_nt)
    if self.file == null as ptr[void]:
        return false

    mut has_main := false
    mut main_has_args := false
    mut main_param_count := 0 as i64
    mut fn_idx := 0 as i64
    while fn_idx < self.module.funcs.len:
        let f = self.module.funcs.data[fn_idx]
        let original_name = self.pool.get(f.name)
        if original_name == "main":
            has_main = true
            main_param_count = f.params.len
            if f.params.len > 0 as i64:
                main_has_args = true
        fn_idx = fn_idx + 1 as i64

    fputs(get_str_ptr("// Generated automatically by AXIOM AirCGen Stage 1\n"), self.file)
    fputs(get_str_ptr("#define AXIOM_SUMLAYOUT_POINTER\n"), self.file)
    if has_main:
        fputs(get_str_ptr("#define AX_EMIT_MAIN\n"), self.file)
        if main_has_args:
            fputs(get_str_ptr("#define AX_MAIN_WITH_ARGS\n"), self.file)
    fputs(get_str_ptr("#include \"ax_runtime.h\"\n"), self.file)
    fputs(get_str_ptr("#include \"ax_stdlib.h\"\n\n"), self.file)
    fputs(get_str_ptr("extern ax_i64 syscall(ax_u64 num, ...);\n\n"), self.file)
    fputs(get_str_ptr("#define ax_cast_to_void_ptr(v) ({ union { __typeof__(v) _val; void* _ptr; } _u; _u._val = (v); _u._ptr; })\n"), self.file)
    fputs(get_str_ptr("#define ax_Result_ok(v) ax_cast_to_void_ptr(v)\n"), self.file)
    fputs(get_str_ptr("#define ax_Result_err(v) ((void*)((ax_u64)ax_cast_to_void_ptr(v) | 1ULL))\n"), self.file)
    fputs(get_str_ptr("#define ax_Option_some(v) ax_cast_to_void_ptr(v)\n"), self.file)
    fputs(get_str_ptr("#define ax_Option_none() ((void*)0)\n\n"), self.file)
    fputs(get_str_ptr("#define r_0 0\n\n"), self.file)

    // 1. Forward declare all structs
    fputs(get_str_ptr("// Forward Declarations\n"), self.file)
    mut i := 0 as i64
    while i < self.typetable.entries.len:
        let entry = self.typetable.entries.data[i]
        if (entry.kind == TYPE_KIND_STRUCT or entry.kind == TYPE_KIND_GENERIC_INST) and entry.name_id != 0 as u32:
            let name = self.pool.get(entry.name_id)
            
            mut already_declared := false
            mut prev_i := 0 as i64
            while prev_i < i:
                let prev_entry = self.typetable.entries.data[prev_i]
                if (prev_entry.kind == TYPE_KIND_STRUCT or prev_entry.kind == TYPE_KIND_GENERIC_INST) and prev_entry.name_id != 0 as u32:
                    let prev_name = self.pool.get(prev_entry.name_id)
                    if prev_name == name:
                        already_declared = true
                        break
                prev_i = prev_i + 1 as i64
                
            if not already_declared:
                ax_fprintf_local(self.file, "typedef struct %s %s;\n", (get_str_ptr(name)) as i64, (get_str_ptr(name)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        i = i + 1
    fputs(get_str_ptr("\n"), self.file)
 
    // 2. Define structures
    fputs(get_str_ptr("// Struct Definitions\n"), self.file)
    i = 0 as i64
    while i < self.typetable.entries.len:
        let entry = self.typetable.entries.data[i]
        if (entry.kind == TYPE_KIND_STRUCT or entry.kind == TYPE_KIND_GENERIC_INST) and entry.name_id != 0 as u32:
            let name = self.pool.get(entry.name_id)
            
            mut already_defined := false
            mut prev_i := 0 as i64
            while prev_i < i:
                let prev_entry = self.typetable.entries.data[prev_i]
                if (prev_entry.kind == TYPE_KIND_STRUCT or prev_entry.kind == TYPE_KIND_GENERIC_INST) and prev_entry.name_id != 0 as u32:
                    let prev_name = self.pool.get(prev_entry.name_id)
                    if prev_name == name:
                        already_defined = true
                        break
                prev_i = prev_i + 1 as i64
                
            if not already_defined:
                ax_fprintf_local(self.file, "struct %s {\n", (get_str_ptr(name)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                mut struct_extra := entry.extra
                if entry.kind == TYPE_KIND_GENERIC_INST:
                    mut idx := 0 as i64
                    while idx < self.typetable.entries.len:
                        let e = self.typetable.entries.data[idx]
                        if e.kind == TYPE_KIND_STRUCT and e.name_id == entry.name_id:
                            struct_extra = e.extra
                            break
                        idx = idx + 1
                let si = self.typetable.structs.data[struct_extra as i64]
                mut f_idx := 0 as i64
                while f_idx < si.fields.len:
                    let field = si.fields.data[f_idx]
                    let field_type = self.get_c_type(field.type_id)
                    ax_fprintf_local(self.file, "    %s f_%d;\n", (field_type as ptr[u8]) as i64, f_idx, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                    f_idx = f_idx + 1 as i64
                fputs(get_str_ptr("};\n\n"), self.file)
        i = i + 1

    // 3. Function prototypes
    fputs(get_str_ptr("// Function Prototypes\n"), self.file)
    
    // Emit prototypes for all user-defined extern functions (like syscall) from the symbol table
    mut sym_idx_proto := 0 as i64
    while sym_idx_proto < self.symtable.symbols.len:
        let sym = self.symtable.symbols.data[sym_idx_proto]
        if sym.kind == 3 as u8: // SYM_FUNC
            let is_extern = ((sym.flags & 4 as u16) != 0 as u16)
            if is_extern:
                let original_name = self.pool.get(sym.name_id)
                if not self.is_stdlib_func(original_name):
                    if sym.type_id != 0 as u32 and (sym.type_id as i64) < self.typetable.entries.len:
                        let entry = self.typetable.entries.data[sym.type_id]
                        if entry.kind == TYPE_KIND_FUNC:
                            let fi = self.typetable.funcs.data[entry.extra as i64]
                            let ret_type = self.get_c_type(fi.ret)
                            ax_fprintf_local(self.file, "%s %s(", (get_str_ptr(ret_type)) as i64, (get_str_ptr(original_name)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                            if fi.params.len == 0 as i64:
                                fputs(get_str_ptr("void"), self.file)
                            else:
                                mut p_idx := 0 as i64
                                while p_idx < fi.params.len:
                                    if p_idx > 0:
                                        fputs(get_str_ptr(", "), self.file)
                                    let param_type = self.get_c_type(fi.params.data[p_idx])
                                    ax_fprintf_local(self.file, "%s p_%d", (get_str_ptr(param_type)) as i64, p_idx, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                                    p_idx = p_idx + 1 as i64
                            fputs(get_str_ptr(");\n"), self.file)
                            @free(get_str_ptr(ret_type))
        sym_idx_proto = sym_idx_proto + 1 as i64

    mut f_idx := 0 as i64
    while f_idx < self.module.funcs.len:
        let f = self.module.funcs.data[f_idx]
        mut is_generic := false
        if f.sym_id != 0 as u32 and (f.sym_id as i64) < self.symtable.symbols.len:
            let sym = self.symtable.symbols.data[f.sym_id as i64]
            if (sym.flags & 1024 as u16) != 0 as u16 or (sym.decl_node != 0 as u32 and (self.tree.nodes.data[sym.decl_node].flags & 512 as u16) != 0 as u16):
                is_generic = true
        mut skip_proto := is_generic
        if f.is_extern:
            let original_name = self.pool.get(f.name)
            if self.is_stdlib_func(original_name):
                if original_name != "ax_ax_driver_load_module":
                    skip_proto = true
        if skip_proto:
            f_idx = f_idx + 1 as i64
        else:
            let original_name = self.pool.get(f.name)
            let mangled_name = self.get_mangled_name_by_sym(f.sym_id)
            let ret_type = self.get_c_type(f.ret_type)
            ax_fprintf_local(self.file, "%s %s(", (get_str_ptr(ret_type)) as i64, (get_str_ptr(mangled_name)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            if f.params.len == 0 as i64:
                fputs(get_str_ptr("void"), self.file)
            else:
                mut p_idx := 0 as i64
                while p_idx < f.params.len:
                    if p_idx > 0:
                        fputs(get_str_ptr(", "), self.file)
                    mut param_type := self.get_c_type(f.params.data[p_idx])
                    if original_name == "main" and p_idx == 1 as i64:
                        param_type = "ax_u8**"
                    ax_fprintf_local(self.file, "%s p_%d", (get_str_ptr(param_type)) as i64, p_idx, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                    p_idx = p_idx + 1 as i64
            fputs(get_str_ptr(");\n"), self.file)
            @free(get_str_ptr(mangled_name))
            f_idx = f_idx + 1 as i64
    fputs(get_str_ptr("\n"), self.file)

    // 4. Function definitions
    fputs(get_str_ptr("// Function Definitions\n"), self.file)
    f_idx = 0
    while f_idx < self.module.funcs.len:
        let f = self.module.funcs.data[f_idx]
        mut is_generic := false
        if f.sym_id != 0 as u32 and (f.sym_id as i64) < self.symtable.symbols.len:
            let sym = self.symtable.symbols.data[f.sym_id as i64]
            if (sym.flags & 1024 as u16) != 0 as u16 or (sym.decl_node != 0 as u32 and (self.tree.nodes.data[sym.decl_node].flags & 512 as u16) != 0 as u16):
                is_generic = true
        if f.is_extern or is_generic:
            f_idx = f_idx + 1 as i64
        else:
            let original_name = self.pool.get(f.name)
            let mangled_name = self.get_mangled_name_by_sym(f.sym_id)
            let ret_type = self.get_c_type(f.ret_type)
            
            ax_fprintf_local(self.file, "%s %s(", (get_str_ptr(ret_type)) as i64, (get_str_ptr(mangled_name)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            if f.params.len == 0 as i64:
                fputs(get_str_ptr("void"), self.file)
            else:
                mut p_idx := 0 as i64
                while p_idx < f.params.len:
                    if p_idx > 0:
                        fputs(get_str_ptr(", "), self.file)
                    mut param_type := self.get_c_type(f.params.data[p_idx])
                    if original_name == "main" and p_idx == 1 as i64:
                        param_type = "ax_u8**"
                    ax_fprintf_local(self.file, "%s p_%d", (get_str_ptr(param_type)) as i64, p_idx, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                    p_idx = p_idx + 1 as i64
            fputs(get_str_ptr(") {\n"), self.file)
            @free(get_str_ptr(mangled_name))

            // Declare all SSA registers
            // First scan to collect maximum registers
            mut max_reg := 0 as u32
            mut inst_idx := 0 as i64
            while inst_idx < f.insts.len:
                let inst = f.insts.data[inst_idx]
                if inst.dest > max_reg:
                    max_reg = inst.dest
                inst_idx = inst_idx + 1

            // Initialize register array types dynamically
            if max_reg > 0 as u32:
                self.reg_types = @alloc((max_reg as i64 + 1) * 4) as ptr[u32]
                mut r := 0 as i64
                while r <= max_reg as i64:
                    self.reg_types[r] = 0 as u32
                    r = r + 1

                // Pre-populate parameter register types
                if f.params.data != null as ptr[u32]:
                    mut p_idx := 0 as i64
                    while p_idx < f.params.len:
                        let p_reg = (p_idx + 1) as u32
                        if p_reg <= max_reg:
                            self.reg_types[p_reg] = f.params.data[p_idx]
                        p_idx = p_idx + 1

                inst_idx = 0
                while inst_idx < f.insts.len:
                    let inst = f.insts.data[inst_idx]
                    if opcode_defines_dest(inst.opcode) and inst.dest > 0 as u32:
                        mut t_id := inst.type_id as u32
                        if inst.opcode == 0x010D as u16: // OP_GET_FIELD
                            mut obj_type_id = inst.type_id as u32
                            if obj_type_id == 0 as u32 and inst.src1 > 0 as u32:
                                obj_type_id = self.reg_types[inst.src1]
                            if obj_type_id == 12 as u32:
                                if inst.src2 == 0 as u32:
                                    t_id = 0 as u32
                                else:
                                    t_id = 4 as u32
                            elif (obj_type_id as i64) < self.typetable.entries.len:
                                mut entry = self.typetable.entries.data[obj_type_id]
                                if entry.kind == TYPE_KIND_POINTER or entry.kind == TYPE_KIND_REF:
                                    let pointee_id = entry.extra
                                    if pointee_id != 0 as u32 and (pointee_id as i64) < self.typetable.entries.len:
                                        entry = self.typetable.entries.data[pointee_id]
                                if entry.kind == TYPE_KIND_STRUCT or entry.kind == TYPE_KIND_GENERIC_INST:
                                    mut struct_extra := entry.extra
                                    if entry.kind == TYPE_KIND_GENERIC_INST:
                                        mut idx := 0 as i64
                                        while idx < self.typetable.entries.len:
                                            let e = self.typetable.entries.data[idx]
                                            if e.kind == TYPE_KIND_STRUCT and e.name_id == entry.name_id:
                                                struct_extra = e.extra
                                                break
                                            idx = idx + 1
                                    let si = self.typetable.structs.data[struct_extra as i64]
                                    if (inst.src2 as i64) < si.fields.len:
                                        t_id = si.fields.data[inst.src2 as i64].type_id
                                else:
                                    t_id = 0 as u32
                        elif (inst.opcode == 0x0105 as u16 or inst.opcode == 0x0109 as u16 or inst.opcode == 0x010F as u16) and t_id == 0 as u32: // OP_INDEX, OP_GEP or OP_DEREF
                            if inst.src1 > 0 as u32 and self.reg_types[inst.src1] != 0 as u32:
                                let src_type = self.reg_types[inst.src1]
                                if src_type == 12 as u32: // str
                                    t_id = 5 as u32 // u8
                                elif (src_type as i64) < self.typetable.entries.len:
                                    let entry = self.typetable.entries.data[src_type]
                                    if entry.kind == TYPE_KIND_POINTER or entry.kind == TYPE_KIND_SLICE or entry.kind == TYPE_KIND_ARRAY:
                                        t_id = entry.extra
                        elif inst.opcode == 0x0103 as u16: // OP_LOAD
                            if inst.src1 > 0 as u32 and self.reg_types[inst.src1] != 0 as u32:
                                let src_type = self.reg_types[inst.src1]
                                if (src_type as i64) < self.typetable.entries.len:
                                    let entry = self.typetable.entries.data[src_type]
                                    if entry.kind == TYPE_KIND_POINTER:
                                        t_id = entry.extra
                        elif inst.opcode == 0x0105 as u16: // OP_GEP
                            if inst.src1 > 0 as u32:
                                t_id = self.reg_types[inst.src1]
                        elif inst.opcode == 0x0106 as u16 or inst.opcode == 0x0107 as u16 or inst.opcode == 0x010C as u16: // OP_COPY, OP_MOVE, OP_ALIAS_REUSE
                            if inst.src1 > 0 as u32:
                                t_id = self.reg_types[inst.src1]
                        elif inst.opcode >= 0x020C as u16 and inst.opcode <= 0x0211 as u16: // OP_EQ to OP_GE (comparisons)
                            t_id = 11 as u32 // TYPE_BOOL (11)
                        elif inst.opcode >= 0x0203 as u16 and inst.opcode <= 0x0216 as u16: // OP_IADD to OP_SHR (binary ALU)
                            if inst.src1 > 0 as u32:
                                t_id = self.reg_types[inst.src1]
                        elif inst.opcode == 0x0217 as u16 or inst.opcode == 0x021D as u16: // OP_NOT, OP_NEG (unary ALU)
                            if inst.src1 > 0 as u32:
                                t_id = self.reg_types[inst.src1]
                        elif inst.opcode == 0x0223 as u16: // OP_CAST
                            t_id = inst.type_id as u32
                        elif inst.opcode == OP_CALL: // OP_CALL
                            if inst.src1 > 0 as u32:
                                t_id = inst.type_id as u32
                            else:
                                let sym_idx = inst.type_id as u32
                                if sym_idx != 0 as u32 and (sym_idx as i64) < self.symtable.symbols.len:
                                    let sym = self.symtable.symbols.data[sym_idx as i64]
                                    let fn_name = self.pool.get(sym.name_id)
                                    if fn_name == "println" or fn_name == "print" or fn_name == "eprint" or fn_name == "eprintln" or fn_name == "assert" or fn_name == "free":
                                        t_id = 14 as u32
                                    elif fn_name == "compiler_intrinsic":
                                        t_id = f.ret_type
                                    elif fn_name == "memcpy" or fn_name == "memmove" or fn_name == "memset" or fn_name == "ax_alloc" or fn_name == "alloc" or fn_name == "malloc" or fn_name == "realloc" or fn_name == "calloc":
                                        t_id = 0 as u32
                                    elif fn_name == "std.string.slice" or fn_name == "std.string.concat" or fn_name == "std.string.replace" or fn_name == "str_slice" or fn_name == "str_concat" or fn_name == "str_trim" or fn_name == "to_str":
                                        t_id = 12 as u32 // TYPE_STR (12)
                                    elif fn_name == "str_contains" or fn_name == "str_starts_with" or fn_name == "str_ends_with" or fn_name == "str_eq":
                                        t_id = 11 as u32 // TYPE_BOOL (11)
                                    elif fn_name == "len" or fn_name == "std.string.len" or fn_name == "strlen" or fn_name == "std.string.len_str" or fn_name == "str_len" or fn_name == "str_char_count" or fn_name == "str_index_of":
                                        t_id = 4 as u32 // TYPE_I64
                                    elif fn_name == "ax_puts_local" or fn_name == "fputs" or fn_name == "fclose" or fn_name == "fflush":
                                        t_id = 3 as u32 // TYPE_I32
                                    else:
                                        let fn_type_id = sym.type_id
                                        if fn_type_id != 0 as u32 and (fn_type_id as i64) < self.typetable.entries.len:
                                            let entry = self.typetable.entries.data[fn_type_id]
                                            if entry.kind == TYPE_KIND_FUNC:
                                                let fi = self.typetable.funcs.data[entry.extra as i64]
                                                t_id = fi.ret
                        self.reg_types[inst.dest] = t_id
                    inst_idx = inst_idx + 1

                // Print register declarations
                r = 1
                while r <= max_reg as i64:
                    if self.reg_types[r] != 14 as u32:
                        let t_name = self.get_c_type(self.reg_types[r])
                        ax_fprintf_local(self.file, "    %s r_%d = {0};\n", (get_str_ptr(t_name)) as i64, r, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                    r = r + 1

                // Copy parameters to registers
                if f.params.data != null as ptr[u32]:
                    mut p_idx := 0 as i64
                    while p_idx < f.params.len:
                        let r_idx = (p_idx + 1) as i64
                        ax_fprintf_local(self.file, "    r_%d = p_%d;\n", r_idx, p_idx, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                        p_idx = p_idx + 1

            // Generate C statements block-by-block
            mut b_idx := 0 as i64
            while b_idx < f.blocks.len:
                let bb = f.blocks.data[b_idx]
                ax_fprintf_local(self.file, "block_%d: ;\n", bb.id as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

                mut inst_offset := 0 as i64
                while inst_offset < bb.instrs_len as i64:
                    let inst_pos = f.block_instrs.data[bb.instrs_start as i64 + inst_offset]
                    let inst = f.insts.data[inst_pos as i64]
                    self.translate_inst(f, inst)
                    inst_offset = inst_offset + 1 as i64
                b_idx = b_idx + 1 as i64

            if max_reg > 0 as u32:
                @free(self.reg_types as ptr[u8])
                self.reg_types = null as ptr[u32]

            fputs(get_str_ptr("}\n\n"), self.file)
            f_idx = f_idx + 1 as i64

    if has_main:
        fputs(get_str_ptr("\n/* Entry point wrapper */\n"), self.file)
        if main_has_args:
            ax_fprintf_local(self.file, "ax_i32 ax_main(ax_i32 argc, ax_u8** argv) {\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            if main_param_count == 1 as i64:
                ax_fprintf_local(self.file, "    ax_main_usr(argc);\n    return 0;\n}\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            else:
                ax_fprintf_local(self.file, "    ax_main_usr(argc, argv);\n    return 0;\n}\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        else:
            ax_fprintf_local(self.file, "ax_i32 ax_main(void) {\n    ax_main_usr();\n    return 0;\n}\n", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    fclose(self.file)
    return true

fn cgen_escape_string(s: str) -> str:
    let len = std.string.len(s)
    let s_ptr = get_str_ptr(s)
    let buf = @alloc(len * 2 + 1) as ptr[u8]
    mut i := 0 as i64
    mut dest_idx := 0 as i64
    while i < len:
        let c = s_ptr[i]
        if c == 10 as u8:
            buf[dest_idx] = '\\' as u8
            buf[dest_idx + 1] = 'n' as u8
            dest_idx = dest_idx + 2
        elif c == 13 as u8:
            buf[dest_idx] = '\\' as u8
            buf[dest_idx + 1] = 'r' as u8
            dest_idx = dest_idx + 2
        elif c == 9 as u8:
            buf[dest_idx] = '\\' as u8
            buf[dest_idx + 1] = 't' as u8
            dest_idx = dest_idx + 2
        elif c == 34 as u8:
            buf[dest_idx] = '\\' as u8
            buf[dest_idx + 1] = '"' as u8
            dest_idx = dest_idx + 2
        elif c == 92 as u8:
            buf[dest_idx] = '\\' as u8
            buf[dest_idx + 1] = '\\' as u8
            dest_idx = dest_idx + 2
        else:
            buf[dest_idx] = c
            dest_idx = dest_idx + 1
        i = i + 1
    buf[dest_idx] = 0 as u8
    return buf as str

pub fn translate_inst(mut self: ptr[CGenerator], f: AirFunc, inst: AirInst):
    let op = inst.opcode
    if op == OP_NOP:
        return

    if op == OP_ICONST:
        if inst.type_id == 12 as u32: // string
            let str_val = self.pool.get(inst.src1)
            mut val_ptr = str_val as ptr[u8]
            mut val_len = std.string.len(str_val)
            mut is_stripped := false
            if val_len >= 2 as i64 and val_ptr[0] == '"' as u8 and val_ptr[val_len - 1] == '"' as u8:
                val_ptr = ((val_ptr as u64) + 1 as u64) as ptr[u8]
                val_len = val_len - 2 as i64
                is_stripped = true
            
            mut print_buf := val_ptr
            if is_stripped:
                print_buf = @alloc(val_len + 1) as ptr[u8]
                @memcpy(print_buf, val_ptr, val_len)
                print_buf[val_len] = 0 as u8

            let escaped_str = cgen_escape_string(print_buf as str)
            ax_fprintf_local(self.file, "    r_%d = AX_STR(\"%s\");\n", inst.dest as i64, get_str_ptr(escaped_str) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            @free(get_str_ptr(escaped_str))

            if is_stripped:
                @free(print_buf)
        else:
            ax_fprintf_local(self.file, "    r_%d = %d;\n", inst.dest as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    elif op == OP_FCONST:
        ax_fprintf_local(self.file, "    r_%d = %d.0;\n", inst.dest as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    elif op == OP_IADD:
        mut is_str := false
        if self.reg_types != null as ptr[u32] and inst.src1 > 0 as u32:
            if self.reg_types[inst.src1] == 12 as u32:
                is_str = true
        if is_str:
            ax_fprintf_local(self.file, "    r_%d = ax_str_concat(r_%d, r_%d);\n", inst.dest as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        else:
            mut s1_cast := ""
            mut s2_cast := ""
            if self.reg_types != null as ptr[u32]:
                if inst.src1 > 0 as u32:
                    let t1 = self.reg_types[inst.src1]
                    if t1 == 0 as u32 or t1 == 14 as u32 or (t1 as i64) >= self.typetable.entries.len or self.typetable.entries.data[t1].kind == TYPE_KIND_POINTER:
                        s1_cast = "(ax_i64)"
                if inst.src2 > 0 as u32:
                    let t2 = self.reg_types[inst.src2]
                    if t2 == 0 as u32 or t2 == 14 as u32 or (t2 as i64) >= self.typetable.entries.len or self.typetable.entries.data[t2].kind == TYPE_KIND_POINTER:
                        s2_cast = "(ax_i64)"
            ax_fprintf_local(self.file, "    r_%d = %sr_%d + %sr_%d;\n", inst.dest as i64, (get_str_ptr(s1_cast)) as i64, inst.src1 as i64, (get_str_ptr(s2_cast)) as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_ISUB:
        mut s1_cast := ""
        mut s2_cast := ""
        if self.reg_types != null as ptr[u32]:
            if inst.src1 > 0 as u32:
                let t1 = self.reg_types[inst.src1]
                if t1 == 0 as u32 or t1 == 14 as u32 or (t1 as i64) >= self.typetable.entries.len or self.typetable.entries.data[t1].kind == TYPE_KIND_POINTER:
                    s1_cast = "(ax_i64)"
            if inst.src2 > 0 as u32:
                let t2 = self.reg_types[inst.src2]
                if t2 == 0 as u32 or t2 == 14 as u32 or (t2 as i64) >= self.typetable.entries.len or self.typetable.entries.data[t2].kind == TYPE_KIND_POINTER:
                    s2_cast = "(ax_i64)"
        ax_fprintf_local(self.file, "    r_%d = %sr_%d - %sr_%d;\n", inst.dest as i64, (get_str_ptr(s1_cast)) as i64, inst.src1 as i64, (get_str_ptr(s2_cast)) as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_IMUL:
        ax_fprintf_local(self.file, "    r_%d = r_%d * r_%d;\n", inst.dest as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_IDIV:
        ax_fprintf_local(self.file, "    r_%d = r_%d / r_%d;\n", inst.dest as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_IMOD:
        ax_fprintf_local(self.file, "    r_%d = r_%d %% r_%d;\n", inst.dest as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    elif op == OP_EQ:
        if self.reg_types != null as ptr[u32] and inst.src1 > 0 as u32 and self.reg_types[inst.src1] == 12 as u32:
            ax_fprintf_local(self.file, "    r_%d = ax_str_eq(r_%d, r_%d);\n", inst.dest as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        else:
            ax_fprintf_local(self.file, "    r_%d = r_%d == r_%d;\n", inst.dest as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_NE:
        if self.reg_types != null as ptr[u32] and inst.src1 > 0 as u32 and self.reg_types[inst.src1] == 12 as u32:
            ax_fprintf_local(self.file, "    r_%d = !ax_str_eq(r_%d, r_%d);\n", inst.dest as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        else:
            ax_fprintf_local(self.file, "    r_%d = r_%d != r_%d;\n", inst.dest as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_LT:
        ax_fprintf_local(self.file, "    r_%d = r_%d < r_%d;\n", inst.dest as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_LE:
        ax_fprintf_local(self.file, "    r_%d = r_%d <= r_%d;\n", inst.dest as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_GT:
        ax_fprintf_local(self.file, "    r_%d = r_%d > r_%d;\n", inst.dest as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_GE:
        ax_fprintf_local(self.file, "    r_%d = r_%d >= r_%d;\n", inst.dest as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    elif op == OP_AND:
        ax_fprintf_local(self.file, "    r_%d = r_%d & r_%d;\n", inst.dest as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_OR:
        ax_fprintf_local(self.file, "    r_%d = r_%d | r_%d;\n", inst.dest as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_XOR:
        ax_fprintf_local(self.file, "    r_%d = r_%d ^ r_%d;\n", inst.dest as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_SHL:
        ax_fprintf_local(self.file, "    r_%d = r_%d << r_%d;\n", inst.dest as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_SHR:
        ax_fprintf_local(self.file, "    r_%d = r_%d >> r_%d;\n", inst.dest as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    elif op == OP_NOT:
        if inst.type_id == 11 as u32: // TYPE_BOOL = 11
            ax_fprintf_local(self.file, "    r_%d = !r_%d;\n", inst.dest as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        else:
            ax_fprintf_local(self.file, "    r_%d = ~r_%d;\n", inst.dest as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_NEG:
        ax_fprintf_local(self.file, "    r_%d = -r_%d;\n", inst.dest as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    elif op == OP_COPY or op == OP_MOVE or op == OP_ALIAS_REUSE:
        ax_fprintf_local(self.file, "    r_%d = r_%d;\n", inst.dest as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    elif op == OP_CAST:
        if inst.type_id == 12 as u32:
            ax_fprintf_local(self.file, "    r_%d = (ax_string){.ptr = (const ax_u8*)r_%d, .len = strlen((const char*)r_%d)};\n", inst.dest as i64, inst.src1 as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        else:
            let t_name = self.get_c_type(inst.type_id as u32)
            mut is_str_src := false
            if self.reg_types != null as ptr[u32] and inst.src1 > 0 as u32:
                let src_type = self.reg_types[inst.src1]
                if src_type == 12 as u32:
                    is_str_src = true
            if is_str_src:
                ax_fprintf_local(self.file, "    r_%d = (%s)r_%d.ptr;\n", inst.dest as i64, (get_str_ptr(t_name)) as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            else:
                ax_fprintf_local(self.file, "    r_%d = (%s)r_%d;\n", inst.dest as i64, (get_str_ptr(t_name)) as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    elif op == OP_ALLOC:
        let entry = self.typetable.entries.data[inst.type_id as i64]
        if (entry.kind == TYPE_KIND_STRUCT or entry.kind == TYPE_KIND_GENERIC_INST) and entry.name_id != 0 as u32:
            let name = self.pool.get(entry.name_id)
            ax_fprintf_local(self.file, "    r_%d = (%s*)ax_alloc(sizeof(%s));\n", inst.dest as i64, (get_str_ptr(name)) as i64, (get_str_ptr(name)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        else:
            ax_fprintf_local(self.file, "    r_%d = ax_alloc(%d);\n", inst.dest as i64, entry.size as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    elif op == OP_FREE or op == OP_DESTROY:
        ax_fprintf_local(self.file, "    ax_free(r_%d);\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    elif op == OP_SPAWN:
        ax_fprintf_local(self.file, "    r_%d = (void*)ax_actor_spawn((AxHandlerFn)r_%d, NULL, 0);\n", inst.dest as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    elif op == OP_MAKE_REF:
        mut is_raw_ptr := false
        if self.reg_types != null as ptr[u32] and inst.dest > 0 as u32:
            let dest_t = self.reg_types[inst.dest]
            if dest_t != 0 as u32 and (dest_t as i64) < self.typetable.entries.len:
                let entry = self.typetable.entries.data[dest_t]
                if entry.kind == TYPE_KIND_POINTER:
                    is_raw_ptr = true
        
        if is_raw_ptr:
            mut is_struct := false
            if self.reg_types != null as ptr[u32] and inst.src1 > 0 as u32:
                let src_t = self.reg_types[inst.src1]
                if src_t != 0 as u32 and (src_t as i64) < self.typetable.entries.len:
                    let entry = self.typetable.entries.data[src_t]
                    if entry.kind == TYPE_KIND_STRUCT or entry.kind == TYPE_KIND_GENERIC_INST:
                        is_struct = true
            
            if is_struct:
                ax_fprintf_local(self.file, "    r_%d = r_%d;\n", inst.dest as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            else:
                ax_fprintf_local(self.file, "    r_%d = &r_%d;\n", inst.dest as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        else:
            ax_fprintf_local(self.file, "    r_%d = ax_make_ref(r_%d);\n", inst.dest as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    elif op == OP_DEREF:
        mut is_ref := false
        mut is_raw_ref := false
        if self.reg_types != null as ptr[u32] and inst.src1 > 0 as u32:
            let src_t = self.reg_types[inst.src1]
            if src_t != 0 as u32 and (src_t as i64) < self.typetable.entries.len:
                let entry = self.typetable.entries.data[src_t]
                if entry.kind == TYPE_KIND_REF:
                    let c_type_name = self.get_c_type(src_t)
                    if c_type_name == "AxRef":
                        is_ref = true
                    else:
                        is_raw_ref = true
                    @free(get_str_ptr(c_type_name))
        if is_ref:
            ax_fprintf_local(self.file, "    r_%d = ax_deref(r_%d);\n", inst.dest as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        elif is_raw_ref:
            ax_fprintf_local(self.file, "    r_%d = r_%d;\n", inst.dest as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        else:
            mut dest_t_id := 0 as u32
            if self.reg_types != null as ptr[u32] and inst.dest > 0 as u32:
                dest_t_id = self.reg_types[inst.dest]
            
            mut is_struct := false
            if dest_t_id != 0 as u32 and (dest_t_id as i64) < self.typetable.entries.len:
                let entry = self.typetable.entries.data[dest_t_id]
                if entry.kind == TYPE_KIND_STRUCT or entry.kind == TYPE_KIND_GENERIC_INST:
                    is_struct = true

            if is_struct:
                ax_fprintf_local(self.file, "    r_%d = r_%d;\n", inst.dest as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            elif dest_t_id != 0 as u32 and dest_t_id != 14 as u32:
                let dest_type_name = self.get_c_type(dest_t_id)
                ax_fprintf_local(self.file, "    r_%d = *( (%s*)r_%d );\n", inst.dest as i64, (get_str_ptr(dest_type_name)) as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                @free(get_str_ptr(dest_type_name))
            else:
                ax_fprintf_local(self.file, "    r_%d = *r_%d;\n", inst.dest as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    elif op == OP_GET_FIELD:
        mut obj_type_id := inst.type_id as u32
        if obj_type_id == 0 as u32 and self.reg_types != null as ptr[u32] and inst.src1 > 0 as u32:
            obj_type_id = self.reg_types[inst.src1]
        mut s_name := "void"
        mut is_void := true
        if obj_type_id != 0 as u32 and (obj_type_id as i64) < self.typetable.entries.len:
            mut entry = self.typetable.entries.data[obj_type_id]
            if entry.kind == TYPE_KIND_POINTER or entry.kind == TYPE_KIND_REF:
                let pointee_id = entry.extra
                if pointee_id != 0 as u32 and (pointee_id as i64) < self.typetable.entries.len:
                    entry = self.typetable.entries.data[pointee_id]
            if (entry.kind == TYPE_KIND_STRUCT or entry.kind == TYPE_KIND_GENERIC_INST) and entry.name_id != 0 as u32:
                let struct_name = self.pool.get(entry.name_id)
                if struct_name != "void" and struct_name != "":
                    s_name = struct_name
                    is_void = false
        if is_void:
            mut is_ptr := true
            if self.reg_types != null as ptr[u32] and inst.src1 > 0 as u32:
                let r_type = self.reg_types[inst.src1]
                if r_type != 0 as u32 and (r_type as i64) < self.typetable.entries.len:
                    let r_entry = self.typetable.entries.data[r_type]
                    if r_entry.kind == TYPE_KIND_SUM or r_type == 12 as u32:
                        is_ptr = false
            let t_name = self.get_c_type(self.reg_types[inst.dest])
            if is_ptr:
                ax_fprintf_local(self.file, "    r_%d = (%s)(((void**)r_%d)[%d]);\n", inst.dest as i64, (get_str_ptr(t_name)) as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            else:
                ax_fprintf_local(self.file, "    r_%d = (%s)(((void**)&r_%d)[%d]);\n", inst.dest as i64, (get_str_ptr(t_name)) as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        else:
            mut is_ptr := true
            if self.reg_types != null as ptr[u32] and inst.src1 > 0 as u32:
                let r_type = self.reg_types[inst.src1]
                if r_type != 0 as u32 and (r_type as i64) < self.typetable.entries.len:
                    let r_entry = self.typetable.entries.data[r_type]
                    if r_entry.kind == TYPE_KIND_SUM or r_type == 12 as u32:
                        is_ptr = false
            
            if is_ptr:
                ax_fprintf_local(self.file, "    r_%d = ((struct %s*)r_%d)->f_%d;\n", inst.dest as i64, (get_str_ptr(s_name)) as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            else:
                ax_fprintf_local(self.file, "    r_%d = ((struct %s*)&r_%d)->f_%d;\n", inst.dest as i64, (get_str_ptr(s_name)) as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    elif op == OP_SET_FIELD:
        mut obj_type_id := inst.type_id as u32
        if obj_type_id == 0 as u32 and self.reg_types != null as ptr[u32] and inst.src1 > 0 as u32:
            obj_type_id = self.reg_types[inst.src1]
        mut s_name := "void"
        mut is_void := true
        if obj_type_id != 0 as u32 and (obj_type_id as i64) < self.typetable.entries.len:
            mut entry = self.typetable.entries.data[obj_type_id]
            if entry.kind == TYPE_KIND_POINTER or entry.kind == TYPE_KIND_REF:
                let pointee_id = entry.extra
                if pointee_id != 0 as u32 and (pointee_id as i64) < self.typetable.entries.len:
                    entry = self.typetable.entries.data[pointee_id]
            if (entry.kind == TYPE_KIND_STRUCT or entry.kind == TYPE_KIND_GENERIC_INST) and entry.name_id != 0 as u32:
                let struct_name = self.pool.get(entry.name_id)
                if struct_name != "void" and struct_name != "":
                    s_name = struct_name
                    is_void = false
        if is_void:
            ax_fprintf_local(self.file, "    ((void**)r_%d)[%d] = (void*)r_%d;\n", inst.src1 as i64, inst.src2 as i64, inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        else:
            mut is_ptr := true
            if self.reg_types != null as ptr[u32] and inst.src1 > 0 as u32:
                let r_type = self.reg_types[inst.src1]
                if r_type != 0 as u32 and (r_type as i64) < self.typetable.entries.len:
                    let r_entry = self.typetable.entries.data[r_type]
                    if r_entry.kind == TYPE_KIND_SUM or r_type == 12 as u32:
                        is_ptr = false
            
            if is_ptr:
                ax_fprintf_local(self.file, "    ((struct %s*)r_%d)->f_%d = r_%d;\n", (get_str_ptr(s_name)) as i64, inst.src1 as i64, inst.src2 as i64, inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            else:
                ax_fprintf_local(self.file, "    ((struct %s*)&r_%d)->f_%d = r_%d;\n", (get_str_ptr(s_name)) as i64, inst.src1 as i64, inst.src2 as i64, inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    elif op == OP_INDEX:
        mut t_name := "void*"
        mut is_struct_ptr_access := false
        if self.reg_types != null as ptr[u32] and inst.src1 > 0 as u32:
            let t_id = self.reg_types[inst.src1]
            if t_id == 12 as u32: // string
                is_struct_ptr_access = true
                t_name = "ax_u8"
            elif t_id != 0 as u32 and (t_id as i64) < self.typetable.entries.len:
                let entry = self.typetable.entries.data[t_id]
                if entry.kind == TYPE_KIND_SLICE:
                    is_struct_ptr_access = true
                    t_name = self.get_c_type(entry.extra)
                elif entry.kind == TYPE_KIND_POINTER:
                    let pointee = entry.extra
                    t_name = self.get_c_type(pointee)
        if t_name == "void" or t_name == "void*":
            if self.reg_types != null as ptr[u32] and inst.dest > 0 as u32:
                let dest_t = self.reg_types[inst.dest]
                if dest_t != 0 as u32:
                    t_name = self.get_c_type(dest_t)
        if t_name == "void":
            t_name = "void*"
        mut is_struct := false
        let t_len = std.string.len(t_name)
        if t_len > 0:
            let last_char = std.string.slice(t_name, t_len - 1, t_len)
            if last_char == "*" and t_name != "void*":
                is_struct = true

        if is_struct_ptr_access:
            if is_struct:
                let t_base = normalize_struct_cast(t_name)
                ax_fprintf_local(self.file, "    r_%d = &((%s)r_%d.ptr)[(ax_i64)r_%d];\n", inst.dest as i64, (get_str_ptr(t_base)) as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                @free(get_str_ptr(t_base))
            else:
                ax_fprintf_local(self.file, "    r_%d = ((%s*)r_%d.ptr)[(ax_i64)r_%d];\n", inst.dest as i64, (get_str_ptr(t_name)) as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        else:
            if is_struct:
                let t_base = normalize_struct_cast(t_name)
                ax_fprintf_local(self.file, "    r_%d = &((%s)r_%d)[(ax_i64)r_%d];\n", inst.dest as i64, (get_str_ptr(t_base)) as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                @free(get_str_ptr(t_base))
            else:
                ax_fprintf_local(self.file, "    r_%d = ((%s*)r_%d)[(ax_i64)r_%d];\n", inst.dest as i64, (get_str_ptr(t_name)) as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    elif op == OP_STORE:
        if inst.src2 != 0 as u32:
            mut t_name := "void*"
            mut is_struct_ptr_access := false
            if self.reg_types != null as ptr[u32] and inst.dest > 0 as u32:
                let t_id = self.reg_types[inst.dest]
                if t_id == 12 as u32: // string
                    is_struct_ptr_access = true
                    t_name = "ax_u8"
                elif t_id != 0 as u32 and (t_id as i64) < self.typetable.entries.len:
                    let entry = self.typetable.entries.data[t_id]
                    if entry.kind == TYPE_KIND_SLICE:
                        is_struct_ptr_access = true
                        t_name = self.get_c_type(entry.extra)
                    elif entry.kind == TYPE_KIND_POINTER:
                        let pointee = entry.extra
                        t_name = self.get_c_type(pointee)
            if t_name == "void*" or t_name == "void":
                if self.reg_types != null as ptr[u32] and inst.src1 > 0 as u32:
                    let src_t = self.reg_types[inst.src1]
                    if src_t != 0 as u32:
                        t_name = self.get_c_type(src_t)
            if t_name == "void":
                t_name = "void*"
            mut is_struct := false
            let t_len = std.string.len(t_name)
            if t_len > 0:
                let last_char = std.string.slice(t_name, t_len - 1, t_len)
                if last_char == "*" and t_name != "void*":
                    is_struct = true

            if is_struct_ptr_access:
                if is_struct:
                    let t_base = normalize_struct_cast(t_name)
                    ax_fprintf_local(self.file, "    ((%s)r_%d.ptr)[(ax_i64)r_%d] = *r_%d;\n", (get_str_ptr(t_base)) as i64, inst.dest as i64, inst.src2 as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                    @free(get_str_ptr(t_base))
                else:
                    ax_fprintf_local(self.file, "    ((%s*)r_%d.ptr)[(ax_i64)r_%d] = r_%d;\n", (get_str_ptr(t_name)) as i64, inst.dest as i64, inst.src2 as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            else:
                if is_struct:
                    let t_base = normalize_struct_cast(t_name)
                    ax_fprintf_local(self.file, "    ((%s)r_%d)[(ax_i64)r_%d] = *r_%d;\n", (get_str_ptr(t_base)) as i64, inst.dest as i64, inst.src2 as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                    @free(get_str_ptr(t_base))
                else:
                    ax_fprintf_local(self.file, "    ((%s*)r_%d)[(ax_i64)r_%d] = r_%d;\n", (get_str_ptr(t_name)) as i64, inst.dest as i64, inst.src2 as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        else:
            mut val_t_id := 0 as u32
            if self.reg_types != null as ptr[u32] and inst.src1 > 0 as u32:
                val_t_id = self.reg_types[inst.src1]
            if val_t_id != 0 as u32 and val_t_id != 14 as u32:
                let val_type_name = self.get_c_type(val_t_id)
                ax_fprintf_local(self.file, "    *( (%s*)r_%d ) = r_%d;\n", (get_str_ptr(val_type_name)) as i64, inst.dest as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                @free(get_str_ptr(val_type_name))
            else:
                ax_fprintf_local(self.file, "    *r_%d = r_%d;\n", inst.dest as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    elif op == OP_JUMP:
        ax_fprintf_local(self.file, "    goto block_%d;\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    elif op == OP_BRANCH:
        ax_fprintf_local(self.file, "    if (r_%d) goto block_%d; else goto block_%d;\n", inst.src1 as i64, inst.src2 as i64, inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    elif op == OP_RETURN:
        if inst.src1 != 0 as u32:
            ax_fprintf_local(self.file, "    return r_%d;\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        else:
            if f.ret_type != 14 as u32: // not void
                let t_name = self.get_c_type(f.ret_type)
                ax_fprintf_local(self.file, "    return (%s){0};\n", (get_str_ptr(t_name)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            else:
                fputs(get_str_ptr("    return;\n"), self.file)

    elif op == OP_CALL or op == OP_SYSCALL:
        // Handle argument list
        let arg_start = inst.src2
        let arg_count = f.extras.data[arg_start as i64]
        mut is_assert := false
        mut is_extern := false
        mut is_intrinsic_mapped := false
        mut mapped_param_count := 0 as i64

        // Look up FuncInfo for expected types of arguments
        mut has_fi := false
        mut fi_params_len := 0 as i64
        mut fi_params_data := null as ptr[u32]
        
        mut builtin_params := null as ptr[u32]

        if op == OP_CALL:
            if inst.src1 == 0 as u32:
                // Direct call
                let sym_idx = inst.type_id as u32
                if sym_idx != 0 as u32 and (sym_idx as i64) < self.symtable.symbols.len:
                    let sym = self.symtable.symbols.data[sym_idx as i64]
                    let fn_name = self.pool.get(sym.name_id)
                    if fn_name == "memcpy" or fn_name == "memmove":
                        let builtin_len = 3 as i64
                        builtin_params = @alloc(3 * 4) as ptr[u32]
                        builtin_params[0] = 0x1f as u32 // void*
                        builtin_params[1] = 0x1f as u32 // void*
                        builtin_params[2] = 8 as u32    // u64/usize
                        has_fi = true
                        fi_params_len = builtin_len
                        fi_params_data = builtin_params
                    elif fn_name == "fwrite" or fn_name == "fread":
                        let builtin_len = 4 as i64
                        builtin_params = @alloc(4 * 4) as ptr[u32]
                        builtin_params[0] = 0x1f as u32 // void*
                        builtin_params[1] = 8 as u32    // size_t
                        builtin_params[2] = 8 as u32    // size_t
                        builtin_params[3] = 0x1f as u32 // FILE*
                        has_fi = true
                        fi_params_len = builtin_len
                        fi_params_data = builtin_params
                    elif fn_name == "ax_alloc" or fn_name == "alloc":
                        let builtin_len = 1 as i64
                        builtin_params = @alloc(1 * 4) as ptr[u32]
                        builtin_params[0] = 4 as u32 // i64
                        has_fi = true
                        fi_params_len = builtin_len
                        fi_params_data = builtin_params
                    else:
                        let fn_type_id = sym.type_id
                        if fn_type_id != 0 as u32 and (fn_type_id as i64) < self.typetable.entries.len:
                            let entry = self.typetable.entries.data[fn_type_id]
                            if entry.kind == TYPE_KIND_FUNC:
                                let fi = self.typetable.funcs.data[entry.extra as i64]
                                has_fi = true
                                fi_params_len = fi.params.len
                                fi_params_data = fi.params.data
            else:
                // Indirect call
                if self.reg_types != null as ptr[u32] and inst.src1 > 0 as u32:
                    let r_type = self.reg_types[inst.src1]
                    if r_type != 0 as u32 and (r_type as i64) < self.typetable.entries.len:
                        mut entry = self.typetable.entries.data[r_type]
                        if entry.kind == TYPE_KIND_POINTER:
                            let pointee_id = entry.extra
                            if pointee_id != 0 as u32 and (pointee_id as i64) < self.typetable.entries.len:
                                entry = self.typetable.entries.data[pointee_id]
                        if entry.kind == TYPE_KIND_FUNC:
                            let fi = self.typetable.funcs.data[entry.extra as i64]
                            has_fi = true
                            fi_params_len = fi.params.len
                            fi_params_data = fi.params.data
        
        // Print callee
        mut fn_name := "func"
        mut is_allocated := false
        if op == OP_SYSCALL:
            fn_name = "ax_syscall"
        elif inst.src1 == 0 as u32:
            // Direct function call
            // We find the function name from type_id (which is symbol idx in this case or typetable extra)
            let sym_idx = inst.type_id as u32
            if sym_idx != 0 as u32 and (sym_idx as i64) < self.symtable.symbols.len:
                fn_name = self.get_mangled_name_by_sym(sym_idx)
                is_allocated = true
                let s_flags = self.symtable.symbols.data[sym_idx as i64].flags
                if (s_flags & 4 as u16) != 0 as u16:
                    is_extern = true
                
                if fn_name == "ax_compiler_intrinsic":
                    let arg_reg = f.extras.data[arg_start as i64 + 1]
                    mut str_val := ""
                    mut found_sconst := false
                    mut search_idx := 0 as i64
                    while search_idx < f.insts.len:
                        let prev_inst = f.insts.data[search_idx]
                        if prev_inst.dest == arg_reg and prev_inst.opcode == 0x0201 as u32 and prev_inst.type_id == 12 as u32:
                            str_val = self.pool.get(prev_inst.src1)
                            found_sconst = true
                        search_idx = search_idx + 1
                    
                    if found_sconst:
                        mut mapped_name := ""
                        mut param_count := 0 as i64
                        if str_val == "\"str_char_count\"" or str_val == "'str_char_count'" or str_val == "str_char_count":
                            mapped_name = "ax_str_char_count"
                            param_count = 1
                        elif str_val == "\"str_concat\"" or str_val == "'str_concat'" or str_val == "str_concat":
                            mapped_name = "ax_str_concat"
                            param_count = 2
                        elif str_val == "\"str_slice\"" or str_val == "'str_slice'" or str_val == "str_slice":
                            mapped_name = "ax_str_slice"
                            param_count = 3
                        elif str_val == "\"str_contains\"" or str_val == "'str_contains'" or str_val == "str_contains":
                            mapped_name = "ax_str_contains"
                            param_count = 2
                        elif str_val == "\"str_starts_with\"" or str_val == "'str_starts_with'" or str_val == "str_starts_with":
                            mapped_name = "ax_str_starts_with"
                            param_count = 2
                        elif str_val == "\"str_ends_with\"" or str_val == "'str_ends_with'" or str_val == "str_ends_with":
                            mapped_name = "ax_str_ends_with"
                            param_count = 2
                        elif str_val == "\"str_index_of\"" or str_val == "'str_index_of'" or str_val == "str_index_of":
                            mapped_name = "ax_str_index_of"
                            param_count = 2
                        elif str_val == "\"str_split\"" or str_val == "'str_split'" or str_val == "str_split":
                            mapped_name = "ax_str_split"
                            param_count = 2
                        elif str_val == "\"str_trim\"" or str_val == "'str_trim'" or str_val == "str_trim":
                            mapped_name = "ax_str_trim"
                            param_count = 1
                        elif str_val == "\"str_to_upper\"" or str_val == "'str_to_upper'" or str_val == "str_to_upper":
                            mapped_name = "ax_str_to_upper"
                            param_count = 1
                        elif str_val == "\"str_to_lower\"" or str_val == "'str_to_lower'" or str_val == "str_to_lower":
                            mapped_name = "ax_str_to_lower"
                            param_count = 1
                        elif str_val == "\"str_repeat\"" or str_val == "'str_repeat'" or str_val == "str_repeat":
                            mapped_name = "ax_str_repeat"
                            param_count = 2
                        elif str_val == "\"str_replace\"" or str_val == "'str_replace'" or str_val == "str_replace":
                            mapped_name = "ax_str_replace"
                            param_count = 3
                        elif str_val == "\"str_to_i64\"" or str_val == "'str_to_i64'" or str_val == "str_to_i64":
                            mapped_name = "ax_str_to_i64"
                            param_count = 1
                        elif str_val == "\"str_to_f64\"" or str_val == "'str_to_f64'" or str_val == "str_to_f64":
                            mapped_name = "ax_str_to_f64"
                            param_count = 1
                        elif str_val == "\"str_is_valid_utf8\"" or str_val == "'str_is_valid_utf8'" or str_val == "str_is_valid_utf8":
                            mapped_name = "ax_str_is_valid_utf8"
                            param_count = 1
                        
                        if param_count > 0:
                            if is_allocated:
                                @free(get_str_ptr(fn_name))
                            fn_name = alloc_str(mapped_name)
                            is_allocated = true
                            is_intrinsic_mapped = true
                            mapped_param_count = param_count
            if fn_name == "assert":
                if is_allocated:
                    @free(get_str_ptr(fn_name))
                fn_name = "ax_assert_axiom"
                is_allocated = false
                is_assert = true
            elif fn_name == "println" or fn_name == "print" or fn_name == "eprint" or fn_name == "eprintln":
                // Map to typed builtin
                mut suffix := "_str"
                if arg_count > 0 as u32:
                    let first_arg_reg = f.extras.data[arg_start as i64 + 1]
                    if self.reg_types != null as ptr[u32] and first_arg_reg > 0 as u32:
                        let t_id = self.reg_types[first_arg_reg]
                        if t_id == 3 as u32 or t_id == 4 as u32 or t_id == 7 as u32 or t_id == 8 as u32:
                            suffix = "_i64"
                        elif t_id == 9 as u32 or t_id == 10 as u32:
                            suffix = "_f64"
                        elif t_id == 11 as u32:
                            suffix = "_bool"
                
                // Mangle to ax_<func_name><suffix>
                let fn_len = std.string.len(fn_name)
                let suffix_len = std.string.len(suffix)
                mut mapped_name := @alloc(fn_len + suffix_len + 4) as ptr[u8]
                @memcpy(mapped_name, "ax_" as ptr[u8], 3)
                
                let dest1 = ((mapped_name as u64) + 3 as u64) as ptr[u8]
                @memcpy(dest1, get_str_ptr(fn_name), fn_len)
                
                let dest2 = ((mapped_name as u64) + 3 as u64 + fn_len as u64) as ptr[u8]
                @memcpy(dest2, suffix as ptr[u8], suffix_len)
                
                let term_idx = 3 + fn_len + suffix_len
                mapped_name[term_idx] = 0 as u8
                
                let old_fn_name = fn_name
                fn_name = mapped_name as str
                if is_allocated:
                    @free(get_str_ptr(old_fn_name))
                is_allocated = true
 
            if inst.dest != 0 as u32 and (self.reg_types == null as ptr[u32] or self.reg_types[inst.dest] != 14 as u32):
                if self.reg_types[inst.dest] == 0 as u32:
                    ax_fprintf_local(self.file, "    r_%d = (void*)%s(", inst.dest as i64, (get_str_ptr(fn_name)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                else:
                    ax_fprintf_local(self.file, "    r_%d = %s(", inst.dest as i64, (get_str_ptr(fn_name)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            else:
                ax_fprintf_local(self.file, "    %s(", (get_str_ptr(fn_name)) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            
            if is_allocated:
                @free(get_str_ptr(fn_name))
        else:
            // Indirect function call
            if inst.dest != 0 as u32 and (self.reg_types == null as ptr[u32] or self.reg_types[inst.dest] != 14 as u32):
                if self.reg_types[inst.dest] == 0 as u32:
                    ax_fprintf_local(self.file, "    r_%d = (void*)((void*(*)(", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                else:
                    ax_fprintf_local(self.file, "    r_%d = ((void*(*)(", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            else:
                fputs(get_str_ptr("    ((void(*)("), self.file)

            mut p_i := 0 as u32
            while p_i < arg_count:
                if p_i > 0 as u32:
                    fputs(get_str_ptr(", "), self.file)
                
                mut p_type_name := "void*"
                if has_fi and p_i < fi_params_len as u32:
                    let p_t = fi_params_data[p_i]
                    if p_t != 0 as u32:
                        p_type_name = self.get_c_type(p_t)
                        if p_type_name == "void":
                            p_type_name = "void*"
                else:
                    let arg_reg = f.extras.data[arg_start as i64 + 1 + p_i as i64]
                    if self.reg_types != null as ptr[u32] and arg_reg > 0 as u32:
                        let arg_t = self.reg_types[arg_reg]
                        if arg_t != 0 as u32:
                            p_type_name = self.get_c_type(arg_t)
                            if p_type_name == "void":
                                p_type_name = "void*"
                
                fputs(get_str_ptr(p_type_name), self.file)
                if p_type_name != "void*" and p_type_name != "void" and p_type_name != "ax_string" and not std.string.ends_with(p_type_name, "*"):
                    @free(get_str_ptr(p_type_name))
                p_i = p_i + 1 as u32

            ax_fprintf_local(self.file, "))r_%d)(", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

        if is_intrinsic_mapped:
            mut p_i := 0 as i64
            while p_i < mapped_param_count:
                if p_i > 0:
                    fputs(get_str_ptr(", "), self.file)
                ax_fprintf_local(self.file, "p_%d", p_i, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                p_i = p_i + 1
        else:
            mut i := 0 as i64
            while i < arg_count as i64:
                if i > 0:
                    fputs(get_str_ptr(", "), self.file)
                let arg_reg = f.extras.data[arg_start as i64 + 1 + i]
                mut is_str := false
                mut actual_t := 0 as u32
                if self.reg_types != null as ptr[u32] and arg_reg > 0 as u32:
                    actual_t = self.reg_types[arg_reg]
                    if actual_t == 12 as u32:
                        is_str = true
                
                mut needs_cast := false
                mut cast_type := "void*"
                if has_fi and i < fi_params_len:
                    let expected_t = fi_params_data[i]
                    if expected_t != 0 as u32 and expected_t != actual_t:
                        needs_cast = true
                        cast_type = self.get_c_type(expected_t)
                        if cast_type == "void":
                            cast_type = "void*"

                if (is_extern or fn_name == "ax_panic") and is_str:
                    ax_fprintf_local(self.file, "(const char*)(r_%d).ptr", arg_reg as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                else:
                    if needs_cast:
                        mut is_struct_val := false
                        if actual_t != 0 as u32 and (actual_t as i64) < self.typetable.entries.len:
                            let a_entry = self.typetable.entries.data[actual_t]
                            if a_entry.kind == TYPE_KIND_SUM or actual_t == 12 as u32:
                                is_struct_val = true
                        if is_struct_val:
                            ax_fprintf_local(self.file, "(%s)&r_%d", (get_str_ptr(cast_type)) as i64, arg_reg as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                        else:
                            ax_fprintf_local(self.file, "(%s)r_%d", (get_str_ptr(cast_type)) as i64, arg_reg as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                    else:
                        ax_fprintf_local(self.file, "r_%d", arg_reg as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                i = i + 1
        if is_assert:
            fputs(get_str_ptr(", AX_STR(\"assertion failed\")"), self.file)
        fputs(get_str_ptr(");\n"), self.file)

        if builtin_params != null as ptr[u32]:
            @free(builtin_params as ptr[u8])
// bootstrap/stage1/wasm.ax
// SSA AIR to WebAssembly Text (WAT) Code Generator.


extern "C" fn fopen(filename: ptr[void], mode: ptr[u8]) -> ptr[void]
extern "C" fn fclose(stream: ptr[void]) -> i32
extern "C" fn fputs(s: ptr[u8], stream: ptr[void]) -> i32
// extern "C" fn ax_fprintf_local(stream: ptr[void], fmt: str, a1: i64, a2: i64, a3: i64, a4: i64, a5: i64, a6: i64, a7: i64, a8: i64) -> i32
// extern "C" fn ax_snprintf_local(buf: ptr[void], size: i64, format: ptr[u8], a1: ptr[void], a2: ptr[void]) -> i32

fn is_type_unsigned(type_id: u32) -> bool:
    if type_id == 5 as u32 or type_id == 6 as u32 or type_id == 7 as u32 or type_id == 8 as u32 or type_id == 16 as u32:
        return true
    return false

fn map_wasm_type(typetable: ptr[TypeTable], type_id: u32) -> str:
    if type_id == 4 as u32 or type_id == 8 as u32: // i64, u64
        return "i64"
    if type_id == 9 as u32: // f32
        return "f32"
    if type_id == 10 as u32: // f64
        return "f64"
    if type_id == 14 as u32: // void
        return ""
    // all other integers and pointers map to i32 in wasm32
    return "i32"

fn wasm_opcode_defines_dest(op: u16) -> bool:
    if op == 0 as u16: // OP_NOP
        return false
    if op == 0x0102 as u32: // OP_FREE
        return false
    if op == 0x010B as u16: // OP_DESTROY
        return false
    if op == 0x0104 as u16: // OP_STORE
        return false
    if op == 0x010E as u16: // OP_SET_FIELD
        return false
    if op == 0x0301 as u16: // OP_JUMP
        return false
    if op == 0x0302 as u16: // OP_BRANCH
        return false
    if op == 0x0304 as u16: // OP_RETURN
        return false
    return true

pub struct WasmGenerator:
    pub module: AirModule
    pub tree: ptr[AstTree]
    pub pool: ptr[InternPool]
    pub symtable: ptr[SymbolTable]
    pub typetable: ptr[TypeTable]
    pub file: ptr[void]
    pub reg_types: ptr[u32]

pub fn new_wasm_generator(mod: AirModule, tree: ptr[AstTree], pool: ptr[InternPool], symtable: ptr[SymbolTable], typetable: ptr[TypeTable]) -> ptr[WasmGenerator]:
    let wg = @alloc(@compiler_intrinsic("size_of")[WasmGenerator]()) as ptr[WasmGenerator]
    wg.module = mod
    wg.tree = tree
    wg.pool = pool
    wg.symtable = symtable
    wg.typetable = typetable
    wg.file = null as ptr[void]
    wg.reg_types = null as ptr[u32]
    return wg

pub fn resolve_sym_name(self: ptr[WasmGenerator], sym_id: u32, name_id: u32) -> str:
    if sym_id == 0 as u32:
        return "main"
    if sym_id == 4294967295 as u32:
        return "malloc"
    if sym_id == 4294967294 as u32:
        return "free"
    
    let name = self.pool.get(name_id)
    if std.string.len(name) > 0:
        if name == "main" or name == "printf" or name == "malloc" or name == "free":
            return name
        
        let ptr_name = name as ptr[u8]
        if std.string.len(name) >= 4 and ptr_name[0] == '_' as u8 and ptr_name[1] == 'A' as u8 and ptr_name[2] == 'X' as u8 and ptr_name[3] == '_' as u8:
            return name
        
        let new_len = 4 + std.string.len(name)
        let buf = @alloc(new_len + 1) as ptr[u8]
        @memcpy(buf, "_AX_" as ptr[u8], 4)
        @memcpy(((buf as u64) + 4 as u64) as ptr[u8], name as ptr[u8], std.string.len(name))
        buf[new_len] = 0 as u8
        return buf as str
    
    let buf = @alloc(32) as ptr[u8]
    ax_snprintf_local(buf as ptr[void], 32, "_AX_f%d" as ptr[u8], sym_id as u64 as ptr[void], null as ptr[void])
    return buf as str

fn wasm_str_to_null_terminated(s: str) -> ptr[u8]:
    let len = std.string.len(s)
    let buf = @alloc(len + 1) as ptr[u8]
    @memcpy(buf, s as ptr[u8], len)
    buf[len] = 0 as u8
    return buf

pub fn generate(mut self: ptr[WasmGenerator], out_filename: str) -> bool:
    let filename_nt = wasm_str_to_null_terminated(out_filename)
    self.file = fopen(filename_nt as ptr[void], get_str_ptr("w"))
    @free(filename_nt)
    if self.file == null as ptr[void]:
        return false

    fputs(get_str_ptr("(module\n"), self.file)
    fputs(get_str_ptr("  (memory (export \"memory\") 1)\n\n"), self.file)

    // 1. Declare all external functions as imports
    mut f_idx := 0 as i64
    while f_idx < self.module.funcs.len:
        let f = self.module.funcs.data[f_idx]
        if f.is_extern:
            let callee = self.resolve_sym_name(f.sym_id, f.name)
            ax_fprintf_local(self.file, "  (import \"env\" \"%s\" (func $%s", (callee as ptr[u8]) as i64, (callee as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            
            mut p_idx := 0 as i64
            while p_idx < f.params.len:
                let p_type = map_wasm_type(self.typetable, f.params.data[p_idx])
                ax_fprintf_local(self.file, " (param %s)", (p_type as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                p_idx = p_idx + 1
            
            if f.ret_type != 0 as u32 and f.ret_type != 14 as u32:
                let r_type = map_wasm_type(self.typetable, f.ret_type)
                ax_fprintf_local(self.file, " (result %s)", (r_type as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            
            fputs(get_str_ptr("))\n"), self.file)
            @free(callee as ptr[u8])
        f_idx = f_idx + 1
    
    // Always import malloc and free if not already declared by externs
    mut has_malloc := false
    mut has_free := false
    f_idx = 0
    while f_idx < self.module.funcs.len:
        let f = self.module.funcs.data[f_idx]
        if f.is_extern:
            let name = self.pool.get(f.name)
            if name == "malloc":
                has_malloc = true
            if name == "free":
                has_free = true
        f_idx = f_idx + 1
    
    if not has_malloc:
        fputs(get_str_ptr("  (import \"env\" \"malloc\" (func $malloc (param i32) (result i32)))\n"), self.file)
    if not has_free:
        fputs(get_str_ptr("  (import \"env\" \"free\" (func $free (param i32)))\n"), self.file)
    
    fputs(get_str_ptr("\n"), self.file)

    // 2. Compile functions
    f_idx = 0
    while f_idx < self.module.funcs.len:
        let f = self.module.funcs.data[f_idx]
        if not f.is_extern:
            self.compile_func(f)
        f_idx = f_idx + 1
    
    fputs(get_str_ptr(")\n"), self.file)
    fclose(self.file)
    return true

pub fn compile_func(mut self: ptr[WasmGenerator], f: AirFunc):
    let mangled_name = self.resolve_sym_name(f.sym_id, f.name)
    ax_fprintf_local(self.file, "  (func $%s (export \"%s\")", (mangled_name as ptr[u8]) as i64, (mangled_name as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    @free(mangled_name as ptr[u8])

    mut p_idx := 0 as i64
    while p_idx < f.params.len:
        let param_type = map_wasm_type(self.typetable, f.params.data[p_idx])
        ax_fprintf_local(self.file, " (param $p%d %s)", (p_idx + 1) as i64, (param_type as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        p_idx = p_idx + 1
    
    if f.ret_type != 0 as u32 and f.ret_type != 14 as u32:
        let r_type = map_wasm_type(self.typetable, f.ret_type)
        ax_fprintf_local(self.file, " (result %s)", (r_type as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    
    fputs(get_str_ptr("\n"), self.file)
    fputs(get_str_ptr("    (local $state i32)\n"), self.file)

    // Declare SSA registers
    mut max_reg := 0 as u32
    mut inst_idx := 0 as i64
    while inst_idx < f.insts.len:
        let inst = f.insts.data[inst_idx]
        if inst.dest > max_reg:
            max_reg = inst.dest
        inst_idx = inst_idx + 1

    if max_reg > 0 as u32:
        self.reg_types = @alloc((max_reg as i64 + 1) * 4) as ptr[u32]
        mut r := 0 as i64
        while r <= max_reg as i64:
            self.reg_types[r] = 0 as u32
            r = r + 1

        if f.params.data != null as ptr[u32]:
            mut p_idx := 0 as i64
            while p_idx < f.params.len:
                let p_reg = (p_idx + 1) as u32
                if p_reg <= max_reg:
                    self.reg_types[p_reg] = f.params.data[p_idx]
                p_idx = p_idx + 1

        inst_idx = 0
        while inst_idx < f.insts.len:
            let inst = f.insts.data[inst_idx]
            if wasm_opcode_defines_dest(inst.opcode) and inst.dest > 0 as u32:
                mut t_id := inst.type_id as u32
                if inst.opcode == 0x010D as u16: // OP_GET_FIELD
                    mut obj_type_id = inst.type_id as u32
                    if obj_type_id == 0 as u32 and inst.src1 > 0 as u32:
                        obj_type_id = self.reg_types[inst.src1]
                    if (obj_type_id as i64) < self.typetable.entries.len:
                        mut entry = self.typetable.entries.data[obj_type_id]
                        if entry.kind == TYPE_KIND_POINTER:
                            let pointee_id = entry.extra
                            if pointee_id != 0 as u32 and (pointee_id as i64) < self.typetable.entries.len:
                                entry = self.typetable.entries.data[pointee_id]
                        if entry.kind == TYPE_KIND_STRUCT:
                            let si = self.typetable.structs.data[entry.extra as i64]
                            if (inst.src2 as i64) < si.fields.len:
                                t_id = si.fields.data[inst.src2 as i64].type_id
                elif (inst.opcode == 0x0105 as u16 or inst.opcode == 0x0109 as u16 or inst.opcode == 0x010F as u16) and t_id == 0 as u32: // OP_INDEX, OP_GEP, OP_DEREF
                    if inst.src1 > 0 as u32 and self.reg_types[inst.src1] != 0 as u32:
                        let src_type = self.reg_types[inst.src1]
                        if (src_type as i64) < self.typetable.entries.len:
                            let entry = self.typetable.entries.data[src_type]
                            if entry.kind == TYPE_KIND_POINTER or entry.kind == TYPE_KIND_SLICE or entry.kind == TYPE_KIND_ARRAY:
                                t_id = entry.extra
                elif inst.opcode == OP_CALL: // OP_CALL
                    let sym_idx = inst.type_id as u32
                    if sym_idx != 0 as u32 and (sym_idx as i64) < self.symtable.symbols.len:
                        let sym = self.symtable.symbols.data[sym_idx as i64]
                        let fn_name = self.pool.get(sym.name_id)
                        if fn_name == "println" or fn_name == "print" or fn_name == "eprint" or fn_name == "eprintln" or fn_name == "assert" or fn_name == "free":
                            t_id = 14 as u32
                        else:
                            let fn_type_id = sym.type_id
                            if fn_type_id != 0 as u32 and (fn_type_id as i64) < self.typetable.entries.len:
                                let entry = self.typetable.entries.data[fn_type_id]
                                if entry.kind == TYPE_KIND_FUNC:
                                    let fi = self.typetable.funcs.data[entry.extra as i64]
                                    t_id = fi.ret
                self.reg_types[inst.dest] = t_id
            inst_idx = inst_idx + 1

        r = 1 as i64
        while r <= max_reg as i64:
            if self.reg_types[r] != 14 as u32:
                let t_name = map_wasm_type(self.typetable, self.reg_types[r])
                ax_fprintf_local(self.file, "    (local $r%d %s)\n", r, (t_name as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            r = r + 1

    if f.blocks.len == 0 as i64:
        fputs(get_str_ptr("    return\n  )\n\n"), self.file)
        if max_reg > 0 as u32:
            @free(self.reg_types as ptr[u8])
            self.reg_types = null as ptr[u32]
        return

    fputs(get_str_ptr("    (local.set $state (i32.const 0))\n\n"), self.file)
    fputs(get_str_ptr("    (block $outer\n"), self.file)
    fputs(get_str_ptr("      (loop $loop\n"), self.file)

    // Open all blocks hierarchically (N down to 0)
    mut bi := f.blocks.len - 1
    while bi >= 0:
        let bb = f.blocks.data[bi]
        ax_fprintf_local(self.file, "        (block $b_%d\n", bb.id as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        bi = bi - 1
    
    // Emit br_table dispatcher
    fputs(get_str_ptr("          (br_table"), self.file)
    bi = 0
    while bi < f.blocks.len:
        let bb = f.blocks.data[bi]
        ax_fprintf_local(self.file, " $b_%d", bb.id as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        bi = bi + 1
    fputs(get_str_ptr(" $b_0 (local.get $state))\n"), self.file)

    // Close each block and emit its instructions
    bi = 0
    while bi < f.blocks.len:
        let bb = f.blocks.data[bi]
        ax_fprintf_local(self.file, "        ) ;; end $b_%d\n", bb.id as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        ax_fprintf_local(self.file, "        ;; --- block_%d body ---\n", bb.id as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        
        mut inst_offset := 0 as i64
        while inst_offset < bb.instrs_len as i64:
            let inst_pos = f.block_instrs.data[bb.instrs_start as i64 + inst_offset]
            let inst = f.insts.data[inst_pos as i64]
            self.lower_inst(f, inst)
            inst_offset = inst_offset + 1
        bi = bi + 1
    
    fputs(get_str_ptr("      )\n"), self.file)
    fputs(get_str_ptr("    )\n"), self.file)

    if f.ret_type != 0 as u32 and f.ret_type != 14 as u32:
        let r_type = map_wasm_type(self.typetable, f.ret_type)
        ax_fprintf_local(self.file, "    (%s.const 0)\n", (r_type as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    
    fputs(get_str_ptr("  )\n\n"), self.file)

    if max_reg > 0 as u32:
        @free(self.reg_types as ptr[u8])
        self.reg_types = null as ptr[u32]

pub fn lower_inst(mut self: ptr[WasmGenerator], f: AirFunc, inst: AirInst):
    let op = inst.opcode
    if op == OP_NOP:
        return

    if op == OP_ICONST:
        let t = map_wasm_type(self.typetable, inst.type_id as u32)
        ax_fprintf_local(self.file, "        (%s.const %d)\n", (t as ptr[u8]) as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        ax_fprintf_local(self.file, "        (local.set $r%d)\n", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_FCONST:
        let t = map_wasm_type(self.typetable, inst.type_id as u32)
        ax_fprintf_local(self.file, "        (%s.const %d)\n", (t as ptr[u8]) as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        ax_fprintf_local(self.file, "        (local.set $r%d)\n", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_COPY or op == OP_MOVE or op == OP_ALIAS_REUSE:
        if inst.src1 <= f.params.len as u32 and inst.src1 > 0 as u32:
            ax_fprintf_local(self.file, "        (local.get $p%d)\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        else:
            ax_fprintf_local(self.file, "        (local.get $r%d)\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        ax_fprintf_local(self.file, "        (local.set $r%d)\n", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_IADD or op == OP_ISUB or op == OP_IMUL or op == OP_IDIV or op == OP_IMOD or op == OP_FADD or op == OP_FSUB or op == OP_FMUL or op == OP_FDIV:
        let t = map_wasm_type(self.typetable, inst.type_id as u32)
        ax_fprintf_local(self.file, "        (local.get $r%d)\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        ax_fprintf_local(self.file, "        (local.get $r%d)\n", inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        
        mut op_str := "add"
        if op == OP_IADD or op == OP_FADD:
            op_str = "add"
        elif op == OP_ISUB or op == OP_FSUB:
            op_str = "sub"
        elif op == OP_IMUL or op == OP_FMUL:
            op_str = "mul"
        elif op == OP_IDIV:
            if is_type_unsigned(inst.type_id as u32):
                op_str = "div_u"
            else:
                op_str = "div_s"
        elif op == OP_FDIV:
            op_str = "div"
        elif op == OP_IMOD:
            if is_type_unsigned(inst.type_id as u32):
                op_str = "rem_u"
            else:
                op_str = "rem_s"
        
        ax_fprintf_local(self.file, "        %s.%s\n", (t as ptr[u8]) as i64, (op_str as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        ax_fprintf_local(self.file, "        (local.set $r%d)\n", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_EQ or op == OP_NE or op == OP_LT or op == OP_LE or op == OP_GT or op == OP_GE:
        mut src_type := "i32"
        mut is_unsigned_cmp := false
        if inst.src1 > 0 as u32 and self.reg_types != null as ptr[u32]:
            let src1_type = self.reg_types[inst.src1]
            src_type = map_wasm_type(self.typetable, src1_type)
            is_unsigned_cmp = is_type_unsigned(src1_type)
        
        ax_fprintf_local(self.file, "        (local.get $r%d)\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        ax_fprintf_local(self.file, "        (local.get $r%d)\n", inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        
        mut cmp_op := "eq"
        if op == OP_EQ:
            cmp_op = "eq"
        elif op == OP_NE:
            cmp_op = "ne"
        elif op == OP_LT:
            if src_type == "f32" or src_type == "f64":
                cmp_op = "lt"
            elif is_unsigned_cmp:
                cmp_op = "lt_u"
            else:
                cmp_op = "lt_s"
        elif op == OP_LE:
            if src_type == "f32" or src_type == "f64":
                cmp_op = "le"
            elif is_unsigned_cmp:
                cmp_op = "le_u"
            else:
                cmp_op = "le_s"
        elif op == OP_GT:
            if src_type == "f32" or src_type == "f64":
                cmp_op = "gt"
            elif is_unsigned_cmp:
                cmp_op = "gt_u"
            else:
                cmp_op = "gt_s"
        elif op == OP_GE:
            if src_type == "f32" or src_type == "f64":
                cmp_op = "ge"
            elif is_unsigned_cmp:
                cmp_op = "ge_u"
            else:
                cmp_op = "ge_s"
        
        ax_fprintf_local(self.file, "        %s.%s\n", (src_type as ptr[u8]) as i64, (cmp_op as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        ax_fprintf_local(self.file, "        (local.set $r%d)\n", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_AND or op == OP_OR or op == OP_XOR or op == OP_SHL or op == OP_SHR:
        let t = map_wasm_type(self.typetable, inst.type_id as u32)
        ax_fprintf_local(self.file, "        (local.get $r%d)\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        ax_fprintf_local(self.file, "        (local.get $r%d)\n", inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        
        mut bit_op := "and"
        if op == OP_AND:
            bit_op = "and"
        elif op == OP_OR:
            bit_op = "or"
        elif op == OP_XOR:
            bit_op = "xor"
        elif op == OP_SHL:
            bit_op = "shl"
        elif op == OP_SHR:
            if is_type_unsigned(inst.type_id as u32):
                bit_op = "shr_u"
            else:
                bit_op = "shr_s"
        
        ax_fprintf_local(self.file, "        %s.%s\n", (t as ptr[u8]) as i64, (bit_op as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        ax_fprintf_local(self.file, "        (local.set $r%d)\n", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_NEG:
        let t = map_wasm_type(self.typetable, inst.type_id as u32)
        if t == "f32" or t == "f64":
            ax_fprintf_local(self.file, "        (local.get $r%d)\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            ax_fprintf_local(self.file, "        %s.neg\n", (t as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        else:
            ax_fprintf_local(self.file, "        (%s.const 0)\n", (t as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            ax_fprintf_local(self.file, "        (local.get $r%d)\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            ax_fprintf_local(self.file, "        %s.sub\n", (t as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        ax_fprintf_local(self.file, "        (local.set $r%d)\n", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_NOT:
        let t = map_wasm_type(self.typetable, inst.type_id as u32)
        ax_fprintf_local(self.file, "        (local.get $r%d)\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        if t == "i64":
            fputs(get_str_ptr("        (i64.const -1)\n"), self.file)
        else:
            fputs(get_str_ptr("        (i32.const -1)\n"), self.file)
        ax_fprintf_local(self.file, "        %s.xor\n", (t as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        ax_fprintf_local(self.file, "        (local.set $r%d)\n", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_ALLOC or op == OP_ARENA_ALLOC:
        mut size := 8 as u32
        if inst.type_id != 0 as u32 and (inst.type_id as i64) < self.typetable.entries.len:
            let entry = self.typetable.entries.data[inst.type_id]
            if entry.size != 0 as u32:
                size = entry.size
        ax_fprintf_local(self.file, "        (i32.const %d)\n", size as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fputs(get_str_ptr("        (call $malloc)\n"), self.file)
        ax_fprintf_local(self.file, "        (local.set $r%d)\n", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_FREE or op == OP_DESTROY:
        ax_fprintf_local(self.file, "        (local.get $r%d)\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fputs(get_str_ptr("        (call $free)\n"), self.file)
    elif op == OP_LOAD:
        let t = map_wasm_type(self.typetable, inst.type_id as u32)
        ax_fprintf_local(self.file, "        (local.get $r%d)\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        ax_fprintf_local(self.file, "        %s.load\n", (t as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        ax_fprintf_local(self.file, "        (local.set $r%d)\n", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_STORE:
        mut t := "i32"
        if inst.src2 != 0 as u32:
            // Store to pointer: src2 = index register, dest = base pointer register, src1 = value register
            if inst.src1 > 0 as u32 and self.reg_types != null as ptr[u32]:
                let val_type = self.reg_types[inst.src1]
                t = map_wasm_type(self.typetable, val_type)
            ax_fprintf_local(self.file, "        (local.get $r%d)\n", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64) // address base
            ax_fprintf_local(self.file, "        (local.get $r%d)\n", inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64) // index or offset
            fputs(get_str_ptr("        i32.add\n"), self.file)
            ax_fprintf_local(self.file, "        (local.get $r%d)\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64) // value
        else:
            // Dereference store: *dest = src1
            if inst.src1 > 0 as u32 and self.reg_types != null as ptr[u32]:
                let val_type = self.reg_types[inst.src1]
                t = map_wasm_type(self.typetable, val_type)
            ax_fprintf_local(self.file, "        (local.get $r%d)\n", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64) // address
            ax_fprintf_local(self.file, "        (local.get $r%d)\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64) // value
        ax_fprintf_local(self.file, "        %s.store\n", (t as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_GEP:
        mut elem_size := 8 as u32
        if inst.type_id != 0 as u32 and (inst.type_id as i64) < self.typetable.entries.len:
            let entry = self.typetable.entries.data[inst.type_id]
            if entry.size != 0 as u32:
                elem_size = entry.size
        ax_fprintf_local(self.file, "        (local.get $r%d)\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        ax_fprintf_local(self.file, "        (local.get $r%d)\n", inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        ax_fprintf_local(self.file, "        (i32.const %d)\n", elem_size as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fputs(get_str_ptr("        i32.mul\n"), self.file)
        fputs(get_str_ptr("        i32.add\n"), self.file)
        ax_fprintf_local(self.file, "        (local.set $r%d)\n", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_GET_FIELD:
        let offset = inst.src2 * 8 as u32
        ax_fprintf_local(self.file, "        (local.get $r%d)\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        ax_fprintf_local(self.file, "        (i32.const %d)\n", offset as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fputs(get_str_ptr("        i32.add\n"), self.file)
        let t = map_wasm_type(self.typetable, inst.type_id as u32)
        ax_fprintf_local(self.file, "        %s.load\n", (t as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        ax_fprintf_local(self.file, "        (local.set $r%d)\n", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_SET_FIELD:
        let offset = inst.src2 * 8 as u32
        ax_fprintf_local(self.file, "        (local.get $r%d)\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        ax_fprintf_local(self.file, "        (i32.const %d)\n", offset as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fputs(get_str_ptr("        i32.add\n"), self.file)
        ax_fprintf_local(self.file, "        (local.get $r%d)\n", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        mut t := "i32"
        if inst.dest > 0 as u32 and self.reg_types != null as ptr[u32]:
            let dest_type = self.reg_types[inst.dest]
            t = map_wasm_type(self.typetable, dest_type)
        ax_fprintf_local(self.file, "        %s.store\n", (t as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_INDEX:
        ax_fprintf_local(self.file, "        (local.get $r%d)\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        ax_fprintf_local(self.file, "        (local.get $r%d)\n", inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fputs(get_str_ptr("        i32.add\n"), self.file)
        let t = map_wasm_type(self.typetable, inst.type_id as u32)
        ax_fprintf_local(self.file, "        %s.load\n", (t as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        ax_fprintf_local(self.file, "        (local.set $r%d)\n", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_CALL:
        let arg_start = inst.src2 as i64
        mut arg_count := 0 as u32
        if arg_start < f.extras.len:
            arg_count = f.extras.data[arg_start]
        
        mut j := 0 as i64
        while j < arg_count as i64:
            let arg_reg = f.extras.data[arg_start + 1 + j]
            ax_fprintf_local(self.file, "        (local.get $r%d)\n", arg_reg as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            j = j + 1
        
        mut callee := ""
        if inst.src1 == 0 as u32:
            let sym_idx = inst.type_id as u32
            if sym_idx != 0 as u32 and (sym_idx as i64) < self.symtable.symbols.len:
                let sym = self.symtable.symbols.data[sym_idx as i64]
                callee = self.resolve_sym_name(sym_idx, sym.name_id)
            else:
                callee = self.resolve_sym_name(0 as u32, 0 as u32)
        else:
            callee = self.resolve_sym_name(0 as u32, 0 as u32)
        
        ax_fprintf_local(self.file, "        (call $%s)\n", (callee as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        if inst.dest != 0 as u32:
            ax_fprintf_local(self.file, "        (local.set $r%d)\n", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        @free(callee as ptr[u8])
    elif op == OP_CAST or op == OP_ZEXT or op == OP_SEXT or op == OP_TRUNC:
        let dst_t = map_wasm_type(self.typetable, inst.type_id as u32)
        mut src_t := "i32"
        if inst.src1 > 0 as u32 and self.reg_types != null as ptr[u32]:
            let src_type = self.reg_types[inst.src1]
            src_t = map_wasm_type(self.typetable, src_type)
        
        ax_fprintf_local(self.file, "        (local.get $r%d)\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        if src_t == "i64" and dst_t == "i32":
            fputs(get_str_ptr("        i32.wrap_i64\n"), self.file)
        elif src_t == "i32" and dst_t == "i64":
            if op == OP_ZEXT:
                fputs(get_str_ptr("        i64.extend_i32_u\n"), self.file)
            else:
                fputs(get_str_ptr("        i64.extend_i32_s\n"), self.file)
        
        ax_fprintf_local(self.file, "        (local.set $r%d)\n", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_JUMP:
        ax_fprintf_local(self.file, "        (local.set $state (i32.const %d))\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fputs(get_str_ptr("        (br $loop)\n"), self.file)
    elif op == OP_BRANCH:
        ax_fprintf_local(self.file, "        (local.get $r%d)\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fputs(get_str_ptr("        (if\n"), self.file)
        fputs(get_str_ptr("          (then\n"), self.file)
        ax_fprintf_local(self.file, "            (local.set $state (i32.const %d))\n", inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fputs(get_str_ptr("          )\n"), self.file)
        fputs(get_str_ptr("          (else\n"), self.file)
        ax_fprintf_local(self.file, "            (local.set $state (i32.const %d))\n", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fputs(get_str_ptr("          )\n"), self.file)
        fputs(get_str_ptr("        )\n"), self.file)
        fputs(get_str_ptr("        (br $loop)\n"), self.file)
    elif op == OP_RETURN:
        if inst.src1 != 0 as u32:
            ax_fprintf_local(self.file, "        (local.get $r%d)\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fputs(get_str_ptr("        return\n"), self.file)
    else:
        fputs(get_str_ptr("        nop\n"), self.file)
// bootstrap/stage1/x86_regs.ax
// Physical register file and classifications for x86-64 in self-hosted AXIOM.

pub const REG_RAX: u8 = 0
pub const REG_RCX: u8 = 1
pub const REG_RDX: u8 = 2
pub const REG_RBX: u8 = 3
pub const REG_RSP: u8 = 4
pub const REG_RBP: u8 = 5
pub const REG_RSI: u8 = 6
pub const REG_RDI: u8 = 7
pub const REG_R8:  u8 = 8
pub const REG_R9:  u8 = 9
pub const REG_R10: u8 = 10
pub const REG_R11: u8 = 11
pub const REG_R12: u8 = 12
pub const REG_R13: u8 = 13
pub const REG_R14: u8 = 14
pub const REG_R15: u8 = 15

pub const REG_XMM0:  u8 = 16
pub const REG_XMM1:  u8 = 17
pub const REG_XMM2:  u8 = 18
pub const REG_XMM3:  u8 = 19
pub const REG_XMM4:  u8 = 20
pub const REG_XMM5:  u8 = 21
pub const REG_XMM6:  u8 = 22
pub const REG_XMM7:  u8 = 23
pub const REG_XMM8:  u8 = 24
pub const REG_XMM9:  u8 = 25
pub const REG_XMM10: u8 = 26
pub const REG_XMM11: u8 = 27
pub const REG_XMM12: u8 = 28
pub const REG_XMM13: u8 = 29
pub const REG_XMM14: u8 = 30
pub const REG_XMM15: u8 = 31

pub const REG_NONE: u8 = 255

pub fn reg_is_gpr(r: u8) -> bool:
    return r < 16 as u8

pub fn reg_is_xmm(r: u8) -> bool:
    return r >= 16 as u8 and r < 32 as u8

pub fn reg_hw_reg(r: u8) -> u8:
    if reg_is_xmm(r):
        return r - 16 as u8
    return r & 15 as u8

pub fn reg_needs_rex(r: u8) -> bool:
    return reg_hw_reg(r) >= 8 as u8

pub fn reg_to_str(r: u8) -> str:
    if r == REG_RAX:
        return "rax"
    if r == REG_RCX:
        return "rcx"
    if r == REG_RDX:
        return "rdx"
    if r == REG_RBX:
        return "rbx"
    if r == REG_RSP:
        return "rsp"
    if r == REG_RBP:
        return "rbp"
    if r == REG_RSI:
        return "rsi"
    if r == REG_RDI:
        return "rdi"
    if r == REG_R8:
        return "r8"
    if r == REG_R9:
        return "r9"
    if r == REG_R10:
        return "r10"
    if r == REG_R11:
        return "r11"
    if r == REG_R12:
        return "r12"
    if r == REG_R13:
        return "r13"
    if r == REG_R14:
        return "r14"
    if r == REG_R15:
        return "r15"
    if r == REG_XMM0:
        return "xmm0"
    if r == REG_XMM1:
        return "xmm1"
    if r == REG_XMM2:
        return "xmm2"
    if r == REG_XMM3:
        return "xmm3"
    if r == REG_XMM4:
        return "xmm4"
    if r == REG_XMM5:
        return "xmm5"
    if r == REG_XMM6:
        return "xmm6"
    if r == REG_XMM7:
        return "xmm7"
    if r == REG_XMM8:
        return "xmm8"
    if r == REG_XMM9:
        return "xmm9"
    if r == REG_XMM10:
        return "xmm10"
    if r == REG_XMM11:
        return "xmm11"
    if r == REG_XMM12:
        return "xmm12"
    if r == REG_XMM13:
        return "xmm13"
    if r == REG_XMM14:
        return "xmm14"
    if r == REG_XMM15:
        return "xmm15"
    return "none"

// System V AMD64 ABI Integer Argument Registers
pub fn get_sysv_arg_reg(idx: i64) -> u8:
    if idx == 0:
        return REG_RDI
    if idx == 1:
        return REG_RSI
    if idx == 2:
        return REG_RDX
    if idx == 3:
        return REG_RCX
    if idx == 4:
        return REG_R8
    if idx == 5:
        return REG_R9
    return REG_NONE

// Windows x64 ABI Integer Argument Registers
pub fn get_win64_arg_reg(idx: i64) -> u8:
    if idx == 0:
        return REG_RCX
    if idx == 1:
        return REG_RDX
    if idx == 2:
        return REG_R8
    if idx == 3:
        return REG_R9
    return REG_NONE

pub fn get_sysv_float_arg_reg(idx: i64) -> u8:
    if idx == 0:
        return REG_XMM0
    if idx == 1:
        return REG_XMM1
    if idx == 2:
        return REG_XMM2
    if idx == 3:
        return REG_XMM3
    if idx == 4:
        return REG_XMM4
    if idx == 5:
        return REG_XMM5
    if idx == 6:
        return REG_XMM6
    if idx == 7:
        return REG_XMM7
    return REG_NONE

pub fn get_win64_float_arg_reg(idx: i64) -> u8:
    if idx == 0:
        return REG_XMM0
    if idx == 1:
        return REG_XMM1
    if idx == 2:
        return REG_XMM2
    if idx == 3:
        return REG_XMM3
    return REG_NONE

// Caller-saved GPRs (System V)
pub fn reg_is_sysv_caller_saved(r: u8) -> bool:
    if r == REG_RAX or r == REG_RCX or r == REG_RDX or r == REG_RSI or r == REG_RDI or r == REG_R8 or r == REG_R9 or r == REG_R10 or r == REG_R11:
        return true
    return false

// Callee-saved GPRs (System V)
pub fn reg_is_sysv_callee_saved(r: u8) -> bool:
    if r == REG_RBX or r == REG_R12 or r == REG_R13 or r == REG_R14 or r == REG_R15:
        return true
    return false

// Callee-saved GPRs (Windows x64)
pub fn reg_is_win64_callee_saved(r: u8) -> bool:
    if r == REG_RBX or r == REG_RBP or r == REG_RDI or r == REG_RSI or r == REG_R12 or r == REG_R13 or r == REG_R14 or r == REG_R15:
        return true
    return false

pub fn x86_resolve_sym_name(sym_idx: u32, symbols: ptr[SymbolTable], pool: ptr[InternPool], table: ptr[TypeTable]) -> str:
    if sym_idx == 0 as u32:
        return ""
    if sym_idx as i64 >= symbols.symbols.len:
        return ""
    let sym = &symbols.symbols.data[sym_idx as i64]
    if sym.kind != 1 as u8 and sym.kind != 10 as u8 and sym.kind != 0 as u8 and sym.kind != 12 as u8 and sym.kind != 5 as u8:
        return ""
    let fn_name = pool.get(sym.name_id)
    
    if fn_name == "main" or fn_name == "_AX_main_main_v_v":
        return fn_name
        
    if fn_name == "memcpy" or fn_name == "memset" or fn_name == "memmove" or fn_name == "realloc":
        return fn_name
        
    if fn_name == "free":
        let is_extern = ((sym.flags & 4 as u16) != 0 as u16)
        if is_extern:
            return "free"
        return "ax_free"

    if fn_name == "alloc":
        let is_extern = ((sym.flags & 4 as u16) != 0 as u16)
        if is_extern:
            return "malloc"
        return "ax_alloc"

    if fn_name == "malloc":
        let is_extern = ((sym.flags & 4 as u16) != 0 as u16)
        if is_extern:
            return "malloc"
        return "ax_alloc"

    let is_extern = ((sym.flags & 4 as u16) != 0 as u16)
    if is_extern:
        return fn_name

    if sym.type_id != 0 as u32 and table != null as ptr[TypeTable] and (sym.type_id as i64) < table.entries.len:
        let entry = table.entries.data[sym.type_id as i64]
        if entry.kind == TYPE_KIND_FUNC:
            let fi = table.funcs.data[entry.extra as i64]
            if fi.params.len > 0 as i64:
                mut first_param_type = fi.params.data[0]
                mut p_entry = table.entries.data[first_param_type as i64]
                if p_entry.kind == TYPE_KIND_POINTER:
                    first_param_type = p_entry.extra
                    p_entry = table.entries.data[first_param_type as i64]
                
                if (p_entry.kind == TYPE_KIND_STRUCT or p_entry.kind == TYPE_KIND_SUM) and p_entry.name_id != 0 as u32:
                    let struct_name = pool.get(p_entry.name_id)
                    let struct_len = std.string.len(struct_name)
                    let fn_len = std.string.len(fn_name)
                    let total_len = 3 + struct_len + 1 + fn_len
                    mut res := @alloc(total_len + 1) as ptr[u8]
                    @memcpy(res, "ax_" as ptr[u8], 3)
                    
                    let dest1 = ((res as u64) + 3 as u64) as ptr[u8]
                    @memcpy(dest1, get_str_ptr(struct_name), struct_len)
                    
                    res[3 + struct_len] = '_' as u8
                    
                    let dest2 = ((res as u64) + 3 as u64 + struct_len as u64 + 1 as u64) as ptr[u8]
                    @memcpy(dest2, get_str_ptr(fn_name), fn_len)
                    
                    res[total_len] = 0 as u8
                    let s_val = AxiomString(ptr: res, len: total_len)
                    return (&s_val as ptr[str])[0]

    let fn_len = std.string.len(fn_name)
    mut res := @alloc(3 + fn_len + 1) as ptr[u8]
    @memcpy(res, "ax_" as ptr[u8], 3)
    let dest = ((res as u64) + 3 as u64) as ptr[u8]
    @memcpy(dest, get_str_ptr(fn_name), fn_len)
    res[3 + fn_len] = 0 as u8
    let s_val = AxiomString(ptr: res, len: 3 + fn_len)
    return (&s_val as ptr[str])[0]


// bootstrap/stage1/x86_selector.ax
// Instruction selector for x86-64 in self-hosted AXIOM.
// Translates flat/block AIR instructions into virtual-register machine instructions (MachInst).


pub const MACH_NOP: u16 = 0
pub const MACH_MOV: u16 = 1
pub const MACH_MOV_IMM: u16 = 2
pub const MACH_ADD: u16 = 3
pub const MACH_SUB: u16 = 4
pub const MACH_IMUL: u16 = 5
pub const MACH_IDIV: u16 = 6
pub const MACH_CQO: u16 = 7
pub const MACH_NEG: u16 = 8
pub const MACH_NOT: u16 = 9
pub const MACH_AND: u16 = 10
pub const MACH_OR: u16 = 11
pub const MACH_XOR: u16 = 12
pub const MACH_SHL: u16 = 13
pub const MACH_SAR: u16 = 14
pub const MACH_CMP: u16 = 15
pub const MACH_TEST: u16 = 16
pub const MACH_SETCC: u16 = 17
pub const MACH_MOVZX_B: u16 = 18
pub const MACH_JMP: u16 = 19
pub const MACH_JCC: u16 = 20
pub const MACH_CALL: u16 = 21
pub const MACH_CALL_INDIRECT: u16 = 22
pub const MACH_RET: u16 = 23
pub const MACH_PUSH: u16 = 24
pub const MACH_POP: u16 = 25
pub const MACH_LEA: u16 = 26
pub const MACH_LOAD: u16 = 27
pub const MACH_STORE: u16 = 28
pub const MACH_XOR_ZERO: u16 = 29
pub const MACH_LABEL: u16 = 30
pub const MACH_SYSCALL: u16 = 31
pub const MACH_SHR: u16 = 32
pub const MACH_FADD: u16 = 33
pub const MACH_FSUB: u16 = 34
pub const MACH_FMUL: u16 = 35
pub const MACH_FDIV: u16 = 36
pub const MACH_FCMP: u16 = 37
pub const MACH_ITOF: u16 = 38
pub const MACH_FTOI: u16 = 39
pub const MACH_MOVDQ: u16 = 40
pub const MACH_MOVQD: u16 = 41

pub const OPND_NONE: u8 = 0
pub const OPND_VREG: u8 = 1
pub const OPND_PHYS: u8 = 2
pub const OPND_IMM: u8 = 3
pub const OPND_LABEL: u8 = 4
pub const OPND_MEM: u8 = 5

pub const CC_O: u8 = 0x00
pub const CC_NO: u8 = 0x01
pub const CC_B: u8 = 0x02
pub const CC_AE: u8 = 0x03
pub const CC_E: u8 = 0x04
pub const CC_NE: u8 = 0x05
pub const CC_BE: u8 = 0x06
pub const CC_A: u8 = 0x07
pub const CC_S: u8 = 0x08
pub const CC_NS: u8 = 0x09
pub const CC_PE: u8 = 0x0A
pub const CC_PO: u8 = 0x0B
pub const CC_L: u8 = 0x0C
pub const CC_GE: u8 = 0x0D
pub const CC_LE: u8 = 0x0E
pub const CC_G: u8 = 0x0F

pub fn cond_code_to_str(cc: u8) -> str:
    if cc == CC_O:
        return "o"
    if cc == CC_NO:
        return "no"
    if cc == CC_B:
        return "b"
    if cc == CC_AE:
        return "ae"
    if cc == CC_E:
        return "e"
    if cc == CC_NE:
        return "ne"
    if cc == CC_BE:
        return "be"
    if cc == CC_A:
        return "a"
    if cc == CC_S:
        return "s"
    if cc == CC_NS:
        return "ns"
    if cc == CC_PE:
        return "pe"
    if cc == CC_PO:
        return "po"
    if cc == CC_L:
        return "l"
    if cc == CC_GE:
        return "ge"
    if cc == CC_LE:
        return "le"
    if cc == CC_G:
        return "g"
    return "??"

pub struct MachOperand:
    pub kind: u8
    pub phys: u8
    pub padding: u16
    pub vreg: u32
    pub label: u32
    pub imm: i64

pub struct MachInst:
    pub op: u16
    pub cc: u8
    pub padding: u8
    pub dst: MachOperand
    pub src1: MachOperand
    pub src2: MachOperand

pub struct MachInstVec:
    pub data: ptr[MachInst]
    pub len: i64
    pub cap: i64

pub fn new_mach_inst_vec() -> MachInstVec:
    return MachInstVec(data: null as ptr[MachInst], len: 0, cap: 0)

pub fn push(mut self: MachInstVec, inst: MachInst) -> u32:
    if self.len == self.cap:
        mut new_cap := 16 as i64
        if self.cap != 0:
            new_cap = self.cap * 2
        let new_data = @alloc(new_cap * 80) as ptr[MachInst]
        if self.data != null as ptr[MachInst]:
            @memcpy(new_data as ptr[u8], self.data as ptr[u8], self.len * 80)
            @free(self.data as ptr[u8])
        self.data = new_data
        self.cap = new_cap
    let idx = self.len as u32
    self.data[self.len] = inst
    self.len = self.len + 1
    return idx

pub fn type_size_and_align(table: ptr[TypeTable], type_id: u32, out_size: ptr[u32], out_align: ptr[u32]):
    if type_id == 0 as u32:
        out_size[0] = 8 as u32
        out_align[0] = 8 as u32
        return

    mut entry := &table.entries.data[type_id]
    if entry.size != 0 as u32:
        out_size[0] = entry.size
        out_align[0] = entry.align
        return

    if entry.kind == TYPE_KIND_PRIMITIVE:
        out_size[0] = entry.size
        out_align[0] = entry.align
        return
    elif entry.kind == TYPE_KIND_STRUCT:
        let struct_idx = entry.extra
        let info = table.structs.data[struct_idx]
        mut offset := 0 as u32
        mut max_align := 1 as u32
        mut i := 0 as i64
        while i < info.fields.len:
            let f = info.fields.data[i]
            mut f_size := 0 as u32
            mut f_align := 0 as u32
            type_size_and_align(table, f.type_id, &f_size, &f_align)
            if f_align == 0 as u32:
                f_align = 8 as u32
            // Align offset
            offset = (offset + f_align - 1 as u32) & ~(f_align - 1 as u32)
            offset = offset + f_size
            if f_align > max_align:
                max_align = f_align
            i = i + 1
        
        mut size := (offset + max_align - 1 as u32) & ~(max_align - 1 as u32)
        if size == 0 as u32:
            size = 8 as u32
        entry.size = size
        entry.align = max_align
        out_size[0] = size
        out_align[0] = max_align
    elif entry.kind == TYPE_KIND_ARRAY:
        let elem_id = entry.extra
        let length = entry.name_id
        mut elem_size := 0 as u32
        mut elem_align := 0 as u32
        type_size_and_align(table, elem_id, &elem_size, &elem_align)
        if elem_align == 0 as u32:
            elem_align = 8 as u32
        let size = length * elem_size
        entry.size = size
        entry.align = elem_align
        out_size[0] = size
        out_align[0] = elem_align
    else:
        out_size[0] = 8 as u32
        out_align[0] = 8 as u32

pub fn field_offset(table: ptr[TypeTable], struct_type_id: u32, field_idx: u32) -> u32:
    if struct_type_id == 0 as u32:
        return field_idx * 8 as u32
    ax_printf_local("[Debug field_offset] struct_type_id=%d, table.entries.len=%d\n", struct_type_id as i64, table.entries.len as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    fflush(null as ptr[void])
    mut real_type_id := struct_type_id
    mut entry = table.entries.data[real_type_id]
    if entry.kind == 9 as u8: // TYPE_KIND_POINTER = 9
        real_type_id = entry.extra
        entry = table.entries.data[real_type_id]
    ax_printf_local("[field_offset] struct_type_id=%d, entry.kind=%d, entry.extra=%d, entry.size=%d\n", real_type_id as i64, entry.kind as i64, entry.extra as i64, entry.size as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    fflush(null as ptr[void])
    if entry.kind != 1 as u8: // TYPE_KIND_STRUCT = 1
        return field_idx * 8 as u32
    
    let struct_idx = entry.extra
    let info = table.structs.data[struct_idx]
    ax_printf_local("[field_offset] info.fields.len=%d, info.fields.data=%x\n", info.fields.len as i64, (info.fields.data as i64) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    fflush(null as ptr[void])
    mut offset := 0 as u32
    mut i := 0 as i64
    while i < info.fields.len:
        let f = info.fields.data[i]
        mut f_size := 0 as u32
        mut f_align := 0 as u32
        type_size_and_align(table, f.type_id, &f_size, &f_align)
        if f_align == 0 as u32:
            f_align = 8 as u32
        // Align offset
        offset = (offset + f_align - 1 as u32) & ~(f_align - 1 as u32)
        ax_printf_local("[field_offset]   field %d: name_id=%d, type_id=%d, f_size=%d, f_align=%d, aligned_offset=%d\n", i as i64, f.name_id as i64, f.type_id as i64, f_size as i64, f_align as i64, offset as i64, 0 as i64, 0 as i64)
        fflush(null as ptr[void])
        if i as u32 == field_idx:
            return offset
        offset = offset + f_size
        i = i + 1
    return field_idx * 8 as u32

pub fn field_size(table: ptr[TypeTable], struct_type_id: u32, field_idx: u32) -> u32:
    if struct_type_id == 0 as u32:
        return 8 as u32
    ax_printf_local("[Debug field_size] struct_type_id=%d, table.entries.len=%d\n", struct_type_id as i64, table.entries.len as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    fflush(null as ptr[void])
    mut real_type_id := struct_type_id
    mut entry = table.entries.data[real_type_id]
    if entry.kind == 9 as u8: // TYPE_KIND_POINTER = 9
        real_type_id = entry.extra
        entry = table.entries.data[real_type_id]
    if entry.kind != 1 as u8: // TYPE_KIND_STRUCT = 1
        return 8 as u32
    
    let struct_idx = entry.extra
    let info = table.structs.data[struct_idx]
    if field_idx as i64 >= info.fields.len:
        return 8 as u32
    let f = info.fields.data[field_idx]
    mut f_size := 0 as u32
    mut f_align := 0 as u32
    type_size_and_align(table, f.type_id, &f_size, &f_align)
    if f_size == 0 as u32:
        return 8 as u32
    return f_size

pub fn abi_int_arg_reg(abi: str, idx: i64) -> u8:
    if abi == "win64":
        return get_win64_arg_reg(idx)
    return get_sysv_arg_reg(idx)

pub fn abi_float_arg_reg(abi: str, idx: i64) -> u8:
    if abi == "win64":
        return get_win64_float_arg_reg(idx)
    return get_sysv_float_arg_reg(idx)

pub fn abi_return_reg(abi: str) -> u8:
    return REG_RAX

pub struct InstructionSelector:
    pub fn_ptr: ptr[AirFunc]
    pub abi_name: str
    pub table: ptr[TypeTable]
    pub param_idx_processed: i32
    pub symbols: ptr[SymbolTable]
    pub pool: ptr[InternPool]
    pub max_vreg: u32
    pub max_label: u32

pub fn next_vreg(sel: ptr[InstructionSelector]) -> u32:
    sel.max_vreg = sel.max_vreg + 1 as u32
    return sel.max_vreg

pub fn next_label(sel: ptr[InstructionSelector]) -> u32:
    sel.max_label = sel.max_label + 1 as u32
    return sel.max_label

pub fn get_register_type(sel: ptr[InstructionSelector], reg: u32) -> u32:
    if reg == 0:
        return 0 as u32
    if reg >= 1 as u32 and reg <= sel.fn_ptr.params.len as u32:
        return sel.fn_ptr.params.data[reg as i64 - 1 as i64] as u32
    mut i := 0 as i64
    while i < sel.fn_ptr.insts.len:
        let inst = &sel.fn_ptr.insts.data[i]
        if inst.dest == reg:
            if inst.opcode == OP_CALL and inst.src1 == 0 as u32:
                let sym_idx = inst.type_id as u32
                if sym_idx != 0 as u32 and (sym_idx as i64) < sel.symbols.symbols.len:
                    let sym = sel.symbols.symbols.data[sym_idx as i64]
                    if sym.kind == SYM_FUNC:
                        let func_type = sym.type_id
                        if func_type != 0 as u32 and (func_type as i64) < sel.table.entries.len:
                            let entry = sel.table.entries.data[func_type as i64]
                            if entry.kind == TYPE_KIND_FUNC:
                                let fi_idx = entry.extra
                                if (fi_idx as i64) < sel.table.funcs.len:
                                    let fi = sel.table.funcs.data[fi_idx as i64]
                                    return fi.ret
                    elif sym.kind == SYM_STRUCT:
                        return sym.type_id
                return 0 as u32
            return inst.type_id as u32
        i = i + 1
    return 0 as u32

pub fn regalloc_is_16byte(vreg: u32, fn_ptr: ptr[AirFunc], table: ptr[TypeTable], symbols: ptr[SymbolTable]) -> bool:
    if vreg == 0:
        return false
    if vreg >= 1 as u32 and vreg <= fn_ptr.params.len as u32:
        let type_id = fn_ptr.params.data[vreg as i64 - 1 as i64] as u32
        if type_id < table.entries.len as u32:
            let size = table.entries.data[type_id].size
            if size == 16 as u32:
                return true
        return false
    mut i := 0 as i64
    while i < fn_ptr.insts.len:
        let inst = &fn_ptr.insts.data[i]
        if inst.dest == vreg:
            let op = inst.opcode
            // Ignore control-flow, store, and other instructions that don't actually define a destination register
            if op != OP_BRANCH and op != OP_JUMP and op != OP_RETURN and op != OP_STORE and op != OP_SET_FIELD and op != OP_FREE and op != OP_DESTROY and op != OP_LOOP_BEGIN and op != OP_LOOP_END and op != OP_SEND:
                if op == OP_CALL:
                    if inst.src1 == 0 as u32: // Direct function call
                        let sym_idx = inst.type_id as u32
                        if symbols != null as ptr[SymbolTable] and sym_idx != 0 as u32 and (sym_idx as i64) < symbols.symbols.len:
                            let sym = &symbols.symbols.data[sym_idx as i64]
                            if sym.kind == 1 as u8 or sym.kind == 10 as u8: // SYM_FUNC or other func symbol kinds
                                let fn_type_id = sym.type_id as u32
                                if fn_type_id < table.entries.len as u32:
                                    let entry = &table.entries.data[fn_type_id]
                                    if entry.kind == 2 as u8: // TYPE_KIND_FUNC = 2
                                        let fi = &table.funcs.data[entry.extra as i64]
                                        let ret_type_id = fi.ret
                                        if ret_type_id < table.entries.len as u32:
                                            let size = table.entries.data[ret_type_id].size
                                            if size == 16 as u32:
                                                return true
                    else: // Dynamic function call
                        let type_id = inst.type_id as u32
                        if type_id < table.entries.len as u32:
                            let size = table.entries.data[type_id].size
                            if size == 16 as u32:
                                return true
                    return false
                elif op == OP_ALLOC or op == OP_ARENA_ALLOC or op == OP_SYSCALL:
                    return false
                elif op == OP_COPY or op == OP_MOVE or op == OP_CAST:
                    let type_id = inst.type_id as u32
                    if type_id < table.entries.len as u32:
                        let size = table.entries.data[type_id].size
                        if size == 16 as u32:
                            return true
                    // Recursively check src1 for type size
                    return regalloc_is_16byte(inst.src1, fn_ptr, table, symbols)
                else:
                    let type_id = inst.type_id as u32
                    if type_id < table.entries.len as u32:
                        let size = table.entries.data[type_id].size
                        if size == 16 as u32:
                            return true
                    return false
        i = i + 1
    return false


pub fn select_comparison(sel: ptr[InstructionSelector], inst: ptr[AirInst], int_cc: u8, float_cc: u8, out_insts: ptr[MachInstVec]):
    let src_type = get_register_type(sel, inst.src1)
    if src_type == 9 as u32 or src_type == 10 as u32:
        out_insts.push(MachInst(op: MACH_FCMP, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.src1, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.src2, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
        out_insts.push(MachInst(op: MACH_SETCC, cc: float_cc, padding: 0 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.dest, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
    else:
        out_insts.push(MachInst(op: MACH_CMP, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.src1, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.src2, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
        out_insts.push(MachInst(op: MACH_SETCC, cc: int_cc, padding: 0 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.dest, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
    out_insts.push(MachInst(op: MACH_MOVZX_B, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.dest, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.dest, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))

pub fn emit_block_copy_ext(sel: ptr[InstructionSelector], dst_reg: u32, dst_disp: u32, src_reg: u32, src_disp: u32, size: u32, out_insts: ptr[MachInstVec]):
    mut offset := 0 as u32
    mut remaining := size
    while remaining >= 8 as u32:
        let tmp_val = next_vreg(sel)
        out_insts.push(MachInst(op: MACH_LOAD, cc: 0 as u8, padding: 8 as u8, 
            dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_val, label: 0 as u32, imm: 0 as i64), 
            src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: src_reg, label: 0 as u32, imm: 0 as i64), 
            src2: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: (src_disp + offset) as i64)))
        out_insts.push(MachInst(op: MACH_STORE, cc: 0 as u8, padding: 8 as u8, 
            dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: dst_reg, label: 0 as u32, imm: 0 as i64), 
            src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_val, label: 0 as u32, imm: 0 as i64), 
            src2: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: (dst_disp + offset) as i64)))
        offset = offset + 8 as u32
        remaining = remaining - 8 as u32
        
    if remaining >= 4 as u32:
        let tmp_val = next_vreg(sel)
        out_insts.push(MachInst(op: MACH_LOAD, cc: 0 as u8, padding: 4 as u8, 
            dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_val, label: 0 as u32, imm: 0 as i64), 
            src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: src_reg, label: 0 as u32, imm: 0 as i64), 
            src2: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: (src_disp + offset) as i64)))
        out_insts.push(MachInst(op: MACH_STORE, cc: 0 as u8, padding: 4 as u8, 
            dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: dst_reg, label: 0 as u32, imm: 0 as i64), 
            src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_val, label: 0 as u32, imm: 0 as i64), 
            src2: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: (dst_disp + offset) as i64)))
        offset = offset + 4 as u32
        remaining = remaining - 4 as u32
        
    if remaining >= 2 as u32:
        let tmp_val = next_vreg(sel)
        out_insts.push(MachInst(op: MACH_LOAD, cc: 0 as u8, padding: 2 as u8, 
            dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_val, label: 0 as u32, imm: 0 as i64), 
            src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: src_reg, label: 0 as u32, imm: 0 as i64), 
            src2: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: (src_disp + offset) as i64)))
        out_insts.push(MachInst(op: MACH_STORE, cc: 0 as u8, padding: 2 as u8, 
            dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: dst_reg, label: 0 as u32, imm: 0 as i64), 
            src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_val, label: 0 as u32, imm: 0 as i64), 
            src2: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: (dst_disp + offset) as i64)))
        offset = offset + 2 as u32
        remaining = remaining - 2 as u32
        
    if remaining >= 1 as u32:
        let tmp_val = next_vreg(sel)
        out_insts.push(MachInst(op: MACH_LOAD, cc: 0 as u8, padding: 1 as u8, 
            dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_val, label: 0 as u32, imm: 0 as i64), 
            src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: src_reg, label: 0 as u32, imm: 0 as i64), 
            src2: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: (src_disp + offset) as i64)))
        out_insts.push(MachInst(op: MACH_STORE, cc: 0 as u8, padding: 1 as u8, 
            dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: dst_reg, label: 0 as u32, imm: 0 as i64), 
            src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_val, label: 0 as u32, imm: 0 as i64), 
            src2: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: (dst_disp + offset) as i64)))

pub fn emit_block_copy(sel: ptr[InstructionSelector], dst_reg: u32, dst_disp: u32, src_reg: u32, size: u32, out_insts: ptr[MachInstVec]):
    mut final_src_reg := src_reg
    if regalloc_is_16byte(src_reg, sel.fn_ptr, sel.table, sel.symbols):
        final_src_reg = next_vreg(sel)
        out_insts.push(MachInst(op: MACH_LEA, cc: 0 as u8, padding: 0 as u8, 
            dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: final_src_reg, label: 0 as u32, imm: 0 as i64), 
            src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: src_reg, label: 0 as u32, imm: 0 as i64), 
            src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
    emit_block_copy_ext(sel, dst_reg, dst_disp, final_src_reg, 0 as u32, size, out_insts)

pub fn select_inst(mut sel: ptr[InstructionSelector], inst: ptr[AirInst], mut out_insts: ptr[MachInstVec]):
    let op = inst.opcode
    if op == OP_NOP:
        return

    if op == OP_ICONST:
        let t_id = inst.type_id as u32
        mut is_str := (t_id == 12 as u32)
        if t_id < sel.table.entries.len as u32:
            if sel.table.entries.data[t_id].size == 16 as u32:
                is_str = true
        if inst.src1 == 0 as u32 and not is_str:
            out_insts.push(MachInst(op: MACH_XOR_ZERO, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.dest, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
        else:
            let val = inst.src1 as i64
            mut vreg_flag := 0 as u32
            if is_str:
                vreg_flag = 2 as u32
            ax_printf_local("[Debug select_inst] OP_ICONST dest=%d, type_id=%d, src1=%d, is_str=%d, vreg_flag=%d\n", inst.dest as i64, inst.type_id as i64, inst.src1 as i64, is_str as i64, vreg_flag as i64, 0 as i64, 0 as i64, 0 as i64)
            fflush(null as ptr[void])
            if is_str:
                let tmp_struct_addr = next_vreg(sel)
                out_insts.push(MachInst(op: MACH_MOV_IMM, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_struct_addr, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: vreg_flag, label: 0 as u32, imm: val), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
                let tmp_dest_addr = next_vreg(sel)
                out_insts.push(MachInst(op: MACH_LEA, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_dest_addr, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.dest, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
                emit_block_copy(sel, tmp_dest_addr, 0 as u32, tmp_struct_addr, 16 as u32, out_insts)
            else:
                out_insts.push(MachInst(op: MACH_MOV_IMM, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.dest, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: vreg_flag, label: 0 as u32, imm: val), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))



    elif op == OP_FCONST:
        let val = inst.src1 as i64
        out_insts.push(MachInst(op: MACH_MOV_IMM, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.dest, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: val), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))

    elif op == OP_COPY or op == OP_MOVE:
        if sel.param_idx_processed < sel.fn_ptr.params.len as i32 and inst.src1 == (sel.param_idx_processed + 1) as u32:
            let param_idx = sel.param_idx_processed
            sel.param_idx_processed = sel.param_idx_processed + 1
            let phys = abi_int_arg_reg(sel.abi_name, param_idx as i64)
            if phys != REG_NONE:
                let dest_type = get_register_type(sel, inst.dest)
                mut dest_size := 8 as u32
                if dest_type < sel.table.entries.len as u32:
                    dest_size = sel.table.entries.data[dest_type].size
                
                if dest_size == 16 as u32:
                    let tmp_val1 = next_vreg(sel)
                    out_insts.push(MachInst(op: MACH_LOAD, cc: 0 as u8, padding: 8 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_val1, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_PHYS, phys: phys, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
                    
                    let tmp_val2 = next_vreg(sel)
                    out_insts.push(MachInst(op: MACH_LOAD, cc: 0 as u8, padding: 8 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_val2, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_PHYS, phys: phys, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 8 as i64)))

                    let tmp_dest_addr = next_vreg(sel)
                    out_insts.push(MachInst(op: MACH_LEA, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_dest_addr, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.dest, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))

                    out_insts.push(MachInst(op: MACH_STORE, cc: 0 as u8, padding: 8 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_dest_addr, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_val1, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
                    out_insts.push(MachInst(op: MACH_STORE, cc: 0 as u8, padding: 8 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_dest_addr, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_val2, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 8 as i64)))
                else:
                    out_insts.push(MachInst(op: MACH_MOV, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.dest, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_PHYS, phys: phys, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
                return
            else:
                mut offset := 0 as i64
                if sel.abi_name == "win64":
                    offset = 48 as i64 + (param_idx as i64 - 4 as i64) * 8 as i64
                else:
                    offset = 16 as i64 + (param_idx as i64 - 6 as i64) * 8 as i64
                out_insts.push(MachInst(op: MACH_LOAD, cc: 0 as u8, padding: 8 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.dest, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_PHYS, phys: REG_RBP, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: offset)))
                return
        if regalloc_is_16byte(inst.dest, sel.fn_ptr, sel.table, sel.symbols):
            let tmp_dest_addr = next_vreg(sel)
            out_insts.push(MachInst(op: MACH_LEA, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_dest_addr, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.dest, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
            let tmp_src_addr = next_vreg(sel)
            out_insts.push(MachInst(op: MACH_LEA, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_src_addr, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.src1, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
            emit_block_copy(sel, tmp_dest_addr, 0 as u32, tmp_src_addr, 16 as u32, out_insts)
        else:
            out_insts.push(MachInst(op: MACH_MOV, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.dest, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.src1, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))


    elif op == OP_CAST:
        let t_id = inst.type_id as u32
        mut is_str := (t_id == 12 as u32)
        if t_id < sel.table.entries.len as u32:
            if sel.table.entries.data[t_id].size == 16 as u32:
                is_str = true
        if is_str:
            let tmp_len = next_vreg(sel)
            let arg0 = abi_int_arg_reg(sel.abi_name, 0)
            
            if sel.abi_name == "win64":
                out_insts.push(MachInst(op: MACH_SUB, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_PHYS, phys: REG_RSP, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 32 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
            
            out_insts.push(MachInst(op: MACH_MOV, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_PHYS, phys: arg0, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.src1, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
            out_insts.push(MachInst(op: MACH_CALL, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: -21 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
            
            if sel.abi_name == "win64":
                out_insts.push(MachInst(op: MACH_ADD, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_PHYS, phys: REG_RSP, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 32 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
                
            out_insts.push(MachInst(op: MACH_MOV, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_len, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_PHYS, phys: REG_RAX, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))

            let tmp_dest_addr = next_vreg(sel)
            out_insts.push(MachInst(op: MACH_LEA, cc: 0 as u8, padding: 0 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_dest_addr, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.dest, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
            out_insts.push(MachInst(op: MACH_STORE, cc: 0 as u8, padding: 8 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_dest_addr, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: inst.src1, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
            out_insts.push(MachInst(op: MACH_STORE, cc: 0 as u8, padding: 8 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_dest_addr, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_len, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_IMM, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 8 as i64)))
        else:
            let src_type = get_register_type(sel, inst.src1)
            mut is_16byte := (src_type == 12 as u32)
            if src_type != 0 as u32 and src_type < sel.table.entries.len as u32:
                if sel.table.entries.data[src_type as i64].size == 16 as u32:
                    is_16byte = true
            if is_16byte:
                if sel.param_idx_processed < sel.fn_ptr.params.len as i32 and inst.src1 == (sel.param_idx_processed + 1) as u32:
                    let param_idx = sel.param_idx_processed
                    sel.param_idx_processed = sel.param_idx_processed + 1
                    let phys = abi_int_arg_reg(sel.abi_name, param_idx as i64)
                    let dest_type = get_register_type(sel, inst.dest)
                    mut dest_size := 8 as u32
                    if dest_type < sel.table.entries.len as u32:
                        dest_size = sel.table.entries.data[dest_type].size
                    
                    if phys != REG_NONE:
                        if dest_size == 16 as u32:
                            let tmp_val1 = next_vreg(sel)
                            out_insts.push(MachInst(op: MACH_LOAD, cc: 0 as u8, padding: 8 as u8, dst: MachOperand(kind: OPND_VREG, phys: 0 as u8, padding: 0 as u16, vreg: tmp_val1, label: 0 as u32, imm: 0 as i64), src1: MachOperand(kind: OPND_PHYS, phys: phys, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64), src2: MachOperand(kind: OPND_NONE, phys: 0 as u8, padding: 0 as u16, vreg: 0 as u32, label: 0 as u32, imm: 0 as i64)))
                            let tmp_val2 = next_vreg(sel)
