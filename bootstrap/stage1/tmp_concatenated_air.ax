// bootstrap/stage1/air_builder.ax
// SSA-form Intermediate Representation (AIR) builder for self-hosted AXIOM frontend.


extern "C" fn printf(fmt: str, a1: i64, a2: i64, a3: i64, a4: i64, a5: i64, a6: i64, a7: i64, a8: i64) -> i32
extern "C" fn atof(s: str) -> f64

pub struct LocalMapEntry:
    pub name_id: u32
    pub reg: u32

pub struct LocalMap:
    pub entries: ptr[LocalMapEntry]
    pub count: u32
    pub capacity: u32

pub fn new_local_map() -> LocalMap:
    let capacity = 16 as u32
    let entries = @alloc(capacity as i64 * 8) as ptr[LocalMapEntry]
    mut i := 0 as i64
    while i < capacity as i64:
        entries[i] = LocalMapEntry(name_id: 0 as u32, reg: 0 as u32)
        i = i + 1
    return LocalMap(entries: entries, count: 0 as u32, capacity: capacity)

pub fn free_local_map(mut self: LocalMap):
    if self.entries != null as ptr[LocalMapEntry]:
        @free(self.entries as ptr[u8])

fn local_map_hash(v: u32) -> u32:
    mut hash := 2166136261 as u32
    hash = hash ^ (v & 255 as u32)
    hash = hash * 16777619 as u32
    hash = hash ^ ((v >> 8 as u32) & 255 as u32)
    hash = hash * 16777619 as u32
    hash = hash ^ ((v >> 16 as u32) & 255 as u32)
    hash = hash * 16777619 as u32
    hash = hash ^ ((v >> 24 as u32) & 255 as u32)
    hash = hash * 16777619 as u32
    return hash

pub fn local_map_put(mut self: LocalMap, name_id: u32, reg: u32):
    if self.count * 4 as u32 > self.capacity * 3 as u32:
        self.local_map_grow()
    self.local_map_insert(name_id, reg)
    self.count = self.count + 1 as u32

fn local_map_insert(self: LocalMap, name_id: u32, reg: u32):
    let mask = self.capacity - 1 as u32
    mut idx = local_map_hash(name_id) & mask
    while true:
        if self.entries[idx].name_id == 0 as u32 or self.entries[idx].name_id == name_id:
            self.entries[idx].name_id = name_id
            self.entries[idx].reg = reg
            return
        idx = (idx + 1 as u32) & mask

pub fn local_map_get(self: LocalMap, name_id: u32) -> u32:
    if self.capacity == 0 as u32:
        return 0 as u32
    let mask = self.capacity - 1 as u32
    mut idx = local_map_hash(name_id) & mask
    let start_idx = idx
    while true:
        let entry = self.entries[idx]
        if entry.name_id == 0 as u32:
            return 0 as u32
        if entry.name_id == name_id:
            return entry.reg
        idx = (idx + 1 as u32) & mask
        if idx == start_idx:
            break
    return 0 as u32

fn local_map_grow(mut self: LocalMap):
    let old_entries = self.entries
    let old_capacity = self.capacity
    let new_cap = old_capacity * 2 as u32
    self.capacity = new_cap
    self.entries = @alloc(new_cap as i64 * 8) as ptr[LocalMapEntry]
    mut i := 0 as i64
    while i < new_cap as i64:
        self.entries[i] = LocalMapEntry(name_id: 0 as u32, reg: 0 as u32)
        i = i + 1

    i = 0 as i64
    while i < old_capacity as i64:
        let entry = old_entries[i]
        if entry.name_id != 0 as u32:
            self.local_map_insert(entry.name_id, entry.reg)
        i = i + 1
    @free(old_entries as ptr[u8])

pub struct AirModuleBuilder:
    pub tree: AstTree
    pub symbols: SymbolTable
    pub typetable: TypeTable
    pub pool: InternPool
    pub module: AirModule
    pub node_types: ptr[u32]

pub fn new_air_module_builder(tree: AstTree, symbols: SymbolTable, typetable: TypeTable, pool: InternPool, node_types: ptr[u32]) -> AirModuleBuilder:
    return AirModuleBuilder(
        tree: tree,
        symbols: symbols,
        typetable: typetable,
        pool: pool,
        module: AirModule(funcs: new_air_func_vec()),
        node_types: node_types,
    )

pub fn free_air_module_builder(self: ptr[AirModuleBuilder]):
    free_air_module(self.module)

pub fn get_token_text(self: ptr[AirModuleBuilder], token_idx: u32) -> str:
    let tok = self.tree.tokens.data[token_idx as i64]
    if tok.len == 0 as u16:
        return ""
    let start_ptr = ((self.tree.src as ptr[u8]) as i64 + tok.offset as i64) as ptr[u8]
    return alloc_str_from_raw(start_ptr, tok.len as i64)

pub fn parse_int_from_str(s: str) -> i64:
    let len = std.string.len(s)
    if len == 0:
        return 0 as i64
    mut i := 0
    mut sign := 1 as i64
    if s[0] as u8 == '-' as u8:
        sign = -1 as i64
        i = 1
    elif s[0] as u8 == '+' as u8:
        i = 1

    mut base := 10 as i64
    if i + 1 < len and s[i] as u8 == '0' as u8:
        let next_char = s[i + 1] as u8
        if next_char == 'x' as u8 or next_char == 'X' as u8:
            base = 16 as i64
            i = i + 2
        elif next_char == 'o' as u8 or next_char == 'O' as u8:
            base = 8 as i64
            i = i + 2
        elif next_char == 'b' as u8 or next_char == 'B' as u8:
            base = 2 as i64
            i = i + 2

    mut val := 0 as i64
    while i < len:
        let c = s[i] as u8
        mut digit := -1 as i64
        if c >= '0' as u8 and c <= '9' as u8:
            digit = (c - '0' as u8) as i64
        elif c >= 'a' as u8 and c <= 'f' as u8:
            digit = (c - 'a' as u8 + 10 as u8) as i64
        elif c >= 'A' as u8 and c <= 'F' as u8:
            digit = (c - 'A' as u8 + 10 as u8) as i64

        if digit < 0 or digit >= base:
            break

        val = val * base + digit
        i = i + 1

    return val * sign

pub fn map_binary_op(op: str) -> u16:
    if op == "+":
        return OP_IADD
    if op == "-":
        return OP_ISUB
    if op == "*":
        return OP_IMUL
    if op == "/":
        return OP_IDIV
    if op == "%":
        return OP_IMOD
    if op == "==":
        return OP_EQ
    if op == "!=":
        return OP_NE
    if op == "<":
        return OP_LT
    if op == "<=":
        return OP_LE
    if op == ">":
        return OP_GT
    if op == ">=":
        return OP_GE
    if op == "and" or op == "&&":
        return OP_AND
    if op == "or" or op == "||":
        return OP_OR
    if op == "^":
        return OP_XOR
    if op == "<<":
        return OP_SHL
    if op == ">>":
        return OP_SHR
    return OP_NOP

pub struct FuncLowering:
    pub mb: ptr[AirModuleBuilder]
    pub fb: AirFuncBuilder
    pub locals: LocalMap
    pub params: U32Vec
    pub terminated: bool

pub fn new_func_lowering(mb: ptr[AirModuleBuilder], fb: AirFuncBuilder, params: U32Vec) -> FuncLowering:
    return FuncLowering(
        mb: mb,
        fb: fb,
        locals: new_local_map(),
        params: params,
        terminated: false,
    )

pub fn free_func_lowering(mut self: FuncLowering):
    free_local_map(self.locals)
    if self.params.data != null as ptr[u32]:
        @free(self.params.data as ptr[u8])

pub fn register_params(mut self: FuncLowering, func_idx: u32, func_node: AstNode):
    mut child := func_node.first_child
    mut param_idx := 0 as i64
    while child != 0 as u32:
        let cn = self.mb.tree.nodes.data[child as i64]
        if cn.kind == NODE_PARAM_DECL:
            mut name_id := cn.payload
            if name_id == 0 as u32:
                let tok_str = self.mb.get_token_text(cn.token_idx)
                name_id = self.mb.pool.intern(tok_str)
                @free(tok_str as ptr[u8])

            let reg = self.fb.fresh_reg()
            mut type_id := 0 as u16
            if param_idx < self.params.len:
                type_id = self.params.data[param_idx] as u16

            self.fb.emit(AirInst(
                opcode: OP_COPY,
                type_id: type_id,
                dest: reg,
                src1: (param_idx + 1) as u32,
                src2: 0 as u32,
            ))

            self.locals.local_map_put(name_id, reg)
            param_idx = param_idx + 1
        child = cn.next_sibling

pub fn lower_expr(mut self: FuncLowering, idx: u32) -> u32:
    if idx == 0 as u32:
        return 0 as u32
    let node = self.mb.tree.nodes.data[idx as i64]
    if node.kind == NODE_INT_LIT:
        return self.lower_int_lit(idx, node)
    if node.kind == NODE_FLOAT_LIT:
        return self.lower_float_lit(idx, node)
    if node.kind == NODE_BOOL_LIT:
        return self.lower_bool_lit(node)
    if node.kind == NODE_NIL_LIT:
        return self.lower_nil_lit()
    if node.kind == NODE_STRING_LIT:
        return self.lower_string_lit(node)
    if node.kind == NODE_CHAR_LIT:
        return self.lower_char_lit(node)
    if node.kind == NODE_IDENT:
        return self.lower_ident(node)
    if node.kind == NODE_BINARY_EXPR:
        return self.lower_binary_expr(idx, node)
    if node.kind == NODE_UNARY_EXPR:
        return self.lower_unary_expr(idx, node)
    if node.kind == NODE_CALL_EXPR:
        return self.lower_call_expr(idx, node)
    if node.kind == NODE_FIELD_EXPR:
        return self.lower_field_expr(idx, node)
    if node.kind == NODE_INDEX_EXPR:
        return self.lower_index_expr(idx, node)
    if node.kind == NODE_CAST_EXPR:
        return self.lower_cast_expr(idx, node)
    if node.kind == NODE_DEREF_EXPR:
        return self.lower_deref_expr(idx, node)
    if node.kind == NODE_SPAWN_EXPR:
        return self.lower_spawn_expr(idx, node)
    if node.kind == NODE_AWAIT_EXPR:
        return self.lower_await_expr(idx, node)
    if node.kind == NODE_STRUCT_LIT:
        return self.lower_struct_lit(idx, node)
    if node.kind == NODE_ARRAY_LIT:
        return self.lower_array_lit(idx, node)
    return 0 as u32

pub fn lower_int_lit(mut self: FuncLowering, idx: u32, node: AstNode) -> u32:
    let reg = self.fb.fresh_reg()
    let text = self.mb.get_token_text(node.token_idx)
    let val = parse_int_from_str(text)
    @free(text as ptr[u8])

    mut type_id := 3 as u16 // default i32
    if self.mb.node_types != null as ptr[u32] and self.mb.node_types[idx as i64] != 0 as u32:
        type_id = self.mb.node_types[idx as i64] as u16

    self.fb.emit(AirInst(
        opcode: OP_ICONST,
        type_id: type_id,
        dest: reg,
        src1: val as u32,
        src2: 0 as u32,
    ))
    return reg

pub fn lower_float_lit(mut self: FuncLowering, idx: u32, node: AstNode) -> u32:
    let reg = self.fb.fresh_reg()
    let text = self.mb.get_token_text(node.token_idx)
    let val = atof(text)
    @free(text as ptr[u8])

    mut type_id := 10 as u16 // default f64
    if self.mb.node_types != null as ptr[u32] and self.mb.node_types[idx as i64] != 0 as u32:
        type_id = self.mb.node_types[idx as i64] as u16

    self.fb.emit(AirInst(
        opcode: OP_FCONST,
        type_id: type_id,
        dest: reg,
        src1: val as u32,
        src2: 0 as u32,
    ))
    return reg

pub fn lower_bool_lit(mut self: FuncLowering, node: AstNode) -> u32:
    let reg = self.fb.fresh_reg()
    let text = self.mb.get_token_text(node.token_idx)
    mut val := 0 as u32
    if text == "true":
        val = 1 as u32
    @free(text as ptr[u8])

    self.fb.emit(AirInst(
        opcode: OP_ICONST,
        type_id: 11 as u16, // bool
        dest: reg,
        src1: val,
        src2: 0 as u32,
    ))
    return reg

pub fn lower_nil_lit(mut self: FuncLowering) -> u32:
    let reg = self.fb.fresh_reg()
    self.fb.emit(AirInst(
        opcode: OP_ICONST,
        type_id: 0 as u16,
        dest: reg,
        src1: 0 as u32,
        src2: 0 as u32,
    ))
    return reg

pub fn lower_string_lit(mut self: FuncLowering, node: AstNode) -> u32:
    let reg = self.fb.fresh_reg()
    let text = self.mb.get_token_text(node.token_idx)
    let str_id = self.mb.pool.intern(text)
    @free(text as ptr[u8])

    self.fb.emit(AirInst(
        opcode: OP_ICONST,
        type_id: 12 as u16, // string
        dest: reg,
        src1: str_id,
        src2: 0 as u32,
    ))
    return reg

pub fn lower_char_lit(mut self: FuncLowering, node: AstNode) -> u32:
    let reg = self.fb.fresh_reg()
    let text = self.mb.get_token_text(node.token_idx)
    mut val := 0 as u32
    let length = std.string.len(text)
    if length > 0:
        if length >= 3 and text[0] as u8 == '\'' as u8 and text[length - 1] as u8 == '\'' as u8:
            val = text[1] as u32
    @free(text as ptr[u8])

    self.fb.emit(AirInst(
        opcode: OP_ICONST,
        type_id: 13 as u16, // char8
        dest: reg,
        src1: val,
        src2: 0 as u32,
    ))
    return reg

pub fn lower_ident(mut self: FuncLowering, node: AstNode) -> u32:
    mut name_id := node.payload
    if name_id == 0 as u32:
        let text = self.mb.get_token_text(node.token_idx)
        name_id = self.mb.pool.intern(text)
        @free(text as ptr[u8])

    if node.payload != 0 as u32 and (node.payload as i64) < self.mb.symbols.symbols.len:
        let sym = self.mb.symbols.symbols.data[node.payload as i64]
        if sym.kind != SYM_VAR and sym.kind != SYM_PARAM and sym.kind != SYM_CONST:
            return 0 as u32

    let reg = self.locals.local_map_get(name_id)
    return reg

pub fn lower_binary_expr(mut self: FuncLowering, idx: u32, node: AstNode) -> u32:
    let child = node.first_child
    if child == 0 as u32:
        return 0 as u32
    let lhs_reg = self.lower_expr(child)

    let rhs_idx = self.mb.tree.nodes.data[child as i64].next_sibling
    if rhs_idx == 0 as u32:
        return lhs_reg

    let rhs_reg = self.lower_expr(rhs_idx)

    let op_token = self.mb.get_token_text(node.token_idx)
    let opcode = map_binary_op(op_token)
    @free(op_token as ptr[u8])

    mut type_id := 3 as u16 // default i32
    if node.payload != 0 as u32 and (node.payload as i64) < self.mb.symbols.symbols.len:
        let sym = self.mb.symbols.symbols.data[node.payload as i64]
        if sym.type_id != 0 as u32:
            type_id = sym.type_id as u16

    let reg = self.fb.fresh_reg()
    self.fb.emit(AirInst(
        opcode: opcode,
        type_id: type_id,
        dest: reg,
        src1: lhs_reg,
        src2: rhs_reg,
    ))
    return reg

pub fn lower_unary_expr(mut self: FuncLowering, idx: u32, node: AstNode) -> u32:
    let child = node.first_child
    if child == 0 as u32:
        return 0 as u32
    let operand_reg = self.lower_expr(child)

    let op_token = self.mb.get_token_text(node.token_idx)
    mut opcode := OP_NOP
    if op_token == "-":
        opcode = OP_NEG
    elif op_token == "not" or op_token == "!":
        opcode = OP_NOT
    elif op_token == "~":
        opcode = OP_NOT
    @free(op_token as ptr[u8])

    mut type_id := 3 as u16 // default i32
    if node.payload != 0 as u32 and (node.payload as i64) < self.mb.symbols.symbols.len:
        let sym = self.mb.symbols.symbols.data[node.payload as i64]
        if sym.type_id != 0 as u32:
            type_id = sym.type_id as u16

    let reg = self.fb.fresh_reg()
    self.fb.emit(AirInst(
        opcode: opcode,
        type_id: type_id,
        dest: reg,
        src1: operand_reg,
        src2: 0 as u32,
    ))
    return reg

pub fn lower_call_expr(mut self: FuncLowering, idx: u32, node: AstNode) -> u32:
    let child = node.first_child
    if child == 0 as u32:
        return 0 as u32

    let callee_node = self.mb.tree.nodes.data[child as i64]
    
    // Check if callee is a method call on a struct
    mut is_method_call := false
    mut method_sym_idx := 0 as u32
    mut receiver_node_idx := 0 as u32
    if callee_node.kind == NODE_FIELD_EXPR:
        mut resolved := false

        if not resolved:
            receiver_node_idx = callee_node.first_child
            if receiver_node_idx != 0 as u32 and self.mb.node_types != null as ptr[u32]:
                mut rec_type := self.mb.node_types[receiver_node_idx as i64]
                if rec_type != 0 as u32:
                    mut entry = self.mb.typetable.entries.data[rec_type as i64]
                    if entry.kind == TYPE_KIND_POINTER:
                        rec_type = entry.extra
                        entry = self.mb.typetable.entries.data[rec_type as i64]
                    
                    if entry.kind == TYPE_KIND_STRUCT:
                        let method_name = self.mb.pool.get(callee_node.payload)
                        mut i := 0 as i64
                        while i < self.mb.symbols.symbols.len:
                            let sym = self.mb.symbols.symbols.data[i]
                            if sym.kind == SYM_FUNC:
                                let sym_name = self.mb.pool.get(sym.name_id)
                                if sym_name == method_name:
                                    let t_entry = self.mb.typetable.entries.data[sym.type_id as i64]
                                    if t_entry.kind == TYPE_KIND_FUNC:
                                        let fi = self.mb.typetable.funcs.data[t_entry.extra as i64]
                                        if fi.params.len > 0 as i64:
                                            mut first_param := fi.params.data[0]
                                            mut p_entry = self.mb.typetable.entries.data[first_param as i64]
                                            if p_entry.kind == TYPE_KIND_POINTER:
                                                first_param = p_entry.extra
                                            if first_param == rec_type:
                                                is_method_call = true
                                                method_sym_idx = i as u32
                                                resolved = true
                                                break
                            i = i + 1 as i64

    if not is_method_call and callee_node.kind == NODE_IDENT:
        let sym_idx = callee_node.payload
        if sym_idx != 0 as u32 and (sym_idx as i64) < self.mb.symbols.symbols.len:
            let sym = self.mb.symbols.symbols.data[sym_idx as i64]
            if sym.kind == SYM_STRUCT:
                return self.lower_struct_constructor_call(idx, node, sym.type_id)

    let temp_args = @alloc(128 * 4) as ptr[u32]
    mut temp_count := 0 as u32

    if is_method_call:
        let receiver_reg = self.lower_expr(receiver_node_idx)
        temp_args[temp_count as i64] = receiver_reg
        temp_count = temp_count + 1 as u32

    mut arg := callee_node.next_sibling
    while arg != 0 as u32:
        let arg_reg = self.lower_expr(arg)
        temp_args[temp_count as i64] = arg_reg
        temp_count = temp_count + 1 as u32
        arg = self.mb.tree.nodes.data[arg as i64].next_sibling

    let arg_start = self.fb.emit_extra(temp_count)
    mut i := 0 as u32
    while i < temp_count:
        self.fb.emit_extra(temp_args[i as i64])
        i = i + 1 as u32

    @free(temp_args as ptr[u8])

    mut type_id := 0 as u16
    mut callee_reg := 0 as u32

    if is_method_call:
        type_id = method_sym_idx as u16
        callee_reg = 0 as u32
    else:
        callee_reg = self.lower_expr(child)
        if callee_node.kind == NODE_IDENT:
            type_id = callee_node.payload as u16
        else:
            if self.mb.node_types != null as ptr[u32] and self.mb.node_types[idx as i64] != 0 as u32:
                type_id = self.mb.node_types[idx as i64] as u16
            else:
                if node.payload != 0 as u32 and (node.payload as i64) < self.mb.symbols.symbols.len:
                    let sym = self.mb.symbols.symbols.data[node.payload as i64]
                    if sym.type_id != 0 as u32:
                        type_id = sym.type_id as u16

    let reg = self.fb.fresh_reg()
    self.fb.emit(AirInst(
        opcode: OP_CALL,
        type_id: type_id,
        dest: reg,
        src1: callee_reg,
        src2: arg_start,
    ))
    return reg

pub fn lower_field_expr(mut self: FuncLowering, idx: u32, node: AstNode) -> u32:
    let child = node.first_child
    if child == 0 as u32:
        return 0 as u32

    let obj_reg = self.lower_expr(child)
    let field_idx = node.extra_idx

    mut type_id := 0 as u16
    let obj_type = self.mb.node_types[child as i64]
    if obj_type != 0 as u32:
        let entry = self.mb.typetable.entries.data[obj_type as i64]
        if entry.kind == TYPE_KIND_POINTER:
            type_id = entry.extra as u16
        else:
            type_id = obj_type as u16

    let reg = self.fb.fresh_reg()
    self.fb.emit(AirInst(
        opcode: OP_GET_FIELD,
        type_id: type_id,
        dest: reg,
        src1: obj_reg,
        src2: field_idx,
    ))
    return reg

pub fn lower_index_expr(mut self: FuncLowering, idx: u32, node: AstNode) -> u32:
    let child = node.first_child
    if child == 0 as u32:
        return 0 as u32

    let arr_reg = self.lower_expr(child)
    let idx_expr = self.mb.tree.nodes.data[child as i64].next_sibling
    mut idx_reg := 0 as u32
    if idx_expr != 0 as u32:
        idx_reg = self.lower_expr(idx_expr)

    mut type_id := 0 as u16
    if self.mb.node_types != null as ptr[u32] and self.mb.node_types[idx as i64] != 0 as u32:
        type_id = self.mb.node_types[idx as i64] as u16
    else:
        if node.payload != 0 as u32 and (node.payload as i64) < self.mb.symbols.symbols.len:
            let sym = self.mb.symbols.symbols.data[node.payload as i64]
            if sym.type_id != 0 as u32:
                type_id = sym.type_id as u16

    let reg = self.fb.fresh_reg()
    self.fb.emit(AirInst(
        opcode: OP_INDEX,
        type_id: type_id,
        dest: reg,
        src1: arr_reg,
        src2: idx_reg,
    ))
    return reg

pub fn lower_cast_expr(mut self: FuncLowering, idx: u32, node: AstNode) -> u32:
    let child = node.first_child
    if child == 0 as u32:
        return 0 as u32

    let src_reg = self.lower_expr(child)

    mut type_id := 0 as u16
    if self.mb.node_types != null as ptr[u32] and self.mb.node_types[idx as i64] != 0 as u32:
        type_id = self.mb.node_types[idx as i64] as u16
    else:
        if node.payload != 0 as u32 and (node.payload as i64) < self.mb.symbols.symbols.len:
            let sym = self.mb.symbols.symbols.data[node.payload as i64]
            if sym.type_id != 0 as u32:
                type_id = sym.type_id as u16

    let reg = self.fb.fresh_reg()
    self.fb.emit(AirInst(
        opcode: OP_CAST,
        type_id: type_id,
        dest: reg,
        src1: src_reg,
        src2: 0 as u32,
    ))
    return reg

pub fn lower_deref_expr(mut self: FuncLowering, idx: u32, node: AstNode) -> u32:
    let child = node.first_child
    if child == 0 as u32:
        return 0 as u32

    let ptr_reg = self.lower_expr(child)

    mut type_id := 0 as u16
    if self.mb.node_types != null as ptr[u32] and self.mb.node_types[idx as i64] != 0 as u32:
        type_id = self.mb.node_types[idx as i64] as u16
    else:
        if node.payload != 0 as u32 and (node.payload as i64) < self.mb.symbols.symbols.len:
            let sym = self.mb.symbols.symbols.data[node.payload as i64]
            if sym.type_id != 0 as u32:
                type_id = sym.type_id as u16

    let reg = self.fb.fresh_reg()
    self.fb.emit(AirInst(
        opcode: OP_DEREF,
        type_id: type_id,
        dest: reg,
        src1: ptr_reg,
        src2: 0 as u32,
    ))
    return reg

pub fn lower_spawn_expr(mut self: FuncLowering, idx: u32, node: AstNode) -> u32:
    let child = node.first_child
    if child == 0 as u32:
        return 0 as u32

    let target_reg = self.lower_expr(child)

    let reg = self.fb.fresh_reg()
    self.fb.emit(AirInst(
        opcode: OP_SPAWN,
        type_id: 0 as u16,
        dest: reg,
        src1: target_reg,
        src2: 0 as u32,
    ))
    return reg

pub fn lower_await_expr(mut self: FuncLowering, idx: u32, node: AstNode) -> u32:
    let child = node.first_child
    if child == 0 as u32:
        return 0 as u32

    let future_reg = self.lower_expr(child)

    mut type_id := 0 as u16
    if self.mb.node_types != null as ptr[u32] and self.mb.node_types[idx as i64] != 0 as u32:
        type_id = self.mb.node_types[idx as i64] as u16
    else:
        if node.payload != 0 as u32 and (node.payload as i64) < self.mb.symbols.symbols.len:
            let sym = self.mb.symbols.symbols.data[node.payload as i64]
            if sym.type_id != 0 as u32:
                type_id = sym.type_id as u16

    let reg = self.fb.fresh_reg()
    self.fb.emit(AirInst(
        opcode: OP_AWAIT,
        type_id: type_id,
        dest: reg,
        src1: future_reg,
        src2: 0 as u32,
    ))
    return reg

pub fn lower_struct_lit(mut self: FuncLowering, idx: u32, node: AstNode) -> u32:
    mut type_id := 0 as u16
    if self.mb.node_types != null as ptr[u32] and self.mb.node_types[idx as i64] != 0 as u32:
        type_id = self.mb.node_types[idx as i64] as u16
    else:
        if node.payload != 0 as u32 and (node.payload as i64) < self.mb.symbols.symbols.len:
            let sym = self.mb.symbols.symbols.data[node.payload as i64]
            if sym.type_id != 0 as u32:
                type_id = sym.type_id as u16

    let struct_reg = self.fb.fresh_reg()
    self.fb.emit(AirInst(
        opcode: OP_ALLOC,
        type_id: type_id,
        dest: struct_reg,
        src1: 0 as u32,
        src2: 0 as u32,
    ))

    mut child := node.first_child
    mut field_idx := 0 as u32
    while child != 0 as u32:
        let cn = self.mb.tree.nodes.data[child as i64]
        if cn.kind == NODE_NAMED_ARG:
            let val_child = cn.first_child
            if val_child != 0 as u32:
                let val_reg = self.lower_expr(val_child)
                self.fb.emit(AirInst(
                    opcode: OP_SET_FIELD,
                    type_id: type_id,
                    dest: val_reg,
                    src1: struct_reg,
                    src2: field_idx,
                ))
            field_idx = field_idx + 1 as u32
        child = cn.next_sibling
    return struct_reg

pub fn lower_array_lit(mut self: FuncLowering, idx: u32, node: AstNode) -> u32:
    mut type_id := 0 as u16
    if self.mb.node_types != null as ptr[u32] and self.mb.node_types[idx as i64] != 0 as u32:
        type_id = self.mb.node_types[idx as i64] as u16
    else:
        if node.payload != 0 as u32 and (node.payload as i64) < self.mb.symbols.symbols.len:
            let sym = self.mb.symbols.symbols.data[node.payload as i64]
            if sym.type_id != 0 as u32:
                type_id = sym.type_id as u16

    let arr_reg = self.fb.fresh_reg()
    self.fb.emit(AirInst(
        opcode: OP_ALLOC,
        type_id: type_id,
        dest: arr_reg,
        src1: 0 as u32,
        src2: 0 as u32,
    ))

    mut child := node.first_child
    mut elem_idx := 0 as u32
    while child != 0 as u32:
        let elem_reg = self.lower_expr(child)

        let idx_reg = self.fb.fresh_reg()
        self.fb.emit(AirInst(
            opcode: OP_ICONST,
            type_id: 3 as u16, // i32
            dest: idx_reg,
            src1: elem_idx,
            src2: 0 as u32,
        ))

        self.fb.emit(AirInst(
            opcode: OP_STORE,
            type_id: 0 as u16,
            dest: arr_reg,
            src1: elem_reg,
            src2: idx_reg,
        ))

        elem_idx = elem_idx + 1 as u32
        child = self.mb.tree.nodes.data[child as i64].next_sibling
    return arr_reg

pub fn lower_struct_constructor_call(mut self: FuncLowering, idx: u32, node: AstNode, type_id: u32) -> u32:
    let struct_reg = self.fb.fresh_reg()
    self.fb.emit(AirInst(
        opcode: OP_ALLOC,
        type_id: type_id as u16,
        dest: struct_reg,
        src1: 0 as u32,
        src2: 0 as u32,
    ))

    let callee = node.first_child
    if callee == 0 as u32:
        return struct_reg

    mut child := self.mb.tree.nodes.data[callee as i64].next_sibling
    mut field_idx := 0 as u32
    while child != 0 as u32:
        let cn = self.mb.tree.nodes.data[child as i64]
        if cn.kind == NODE_NAMED_ARG:
            let val_child = cn.first_child
            if val_child != 0 as u32:
                let val_reg = self.lower_expr(val_child)
                self.fb.emit(AirInst(
                    opcode: OP_SET_FIELD,
                    type_id: type_id as u16,
                    dest: val_reg,
                    src1: struct_reg,
                    src2: field_idx,
                ))
            field_idx = field_idx + 1 as u32
        else:
            let val_reg = self.lower_expr(child)
            self.fb.emit(AirInst(
                opcode: OP_SET_FIELD,
                type_id: type_id as u16,
                dest: val_reg,
                src1: struct_reg,
                src2: field_idx,
            ))
            field_idx = field_idx + 1 as u32
        child = cn.next_sibling
    return struct_reg

pub fn emit_heap_alloc(mut self: FuncLowering, type_id: u16) -> u32:
    let ptr_reg = self.fb.fresh_reg()
    self.fb.emit(AirInst(
        opcode: OP_ALLOC,
        type_id: type_id,
        dest: ptr_reg,
        src1: 0 as u32,
        src2: 0 as u32,
    ))

    let ref_reg = self.fb.fresh_reg()
    self.fb.emit(AirInst(
        opcode: OP_MAKE_REF,
        type_id: type_id,
        dest: ref_reg,
        src1: ptr_reg,
        src2: 0 as u32,
    ))
    return ref_reg

pub fn emit_deref(mut self: FuncLowering, ref_reg: u32, type_id: u16) -> u32:
    let ptr_reg = self.fb.fresh_reg()
    self.fb.emit(AirInst(
        opcode: OP_DEREF,
        type_id: type_id,
        dest: ptr_reg,
        src1: ref_reg,
        src2: 0 as u32,
    ))
    return ptr_reg

pub fn emit_move(mut self: FuncLowering, src_reg: u32, type_id: u16) -> u32:
    let dest_reg = self.fb.fresh_reg()
    self.fb.emit(AirInst(
        opcode: OP_MOVE,
        type_id: type_id,
        dest: dest_reg,
        src1: src_reg,
        src2: 0 as u32,
    ))
    return dest_reg

pub fn emit_free(mut self: FuncLowering, ptr_reg: u32):
    self.fb.emit(AirInst(
        opcode: OP_FREE,
        type_id: 0 as u16,
        dest: 0 as u32,
        src1: ptr_reg,
        src2: 0 as u32,
    ))

pub fn emit_arena_alloc(mut self: FuncLowering, arena_reg: u32, type_id: u16) -> u32:
    let ptr_reg = self.fb.fresh_reg()
    self.fb.emit(AirInst(
        opcode: OP_ARENA_ALLOC,
        type_id: type_id,
        dest: ptr_reg,
        src1: arena_reg,
        src2: 0 as u32,
    ))
    return ptr_reg

pub fn emit_alias_reuse(mut self: FuncLowering, ptr_reg: u32, type_id: u16) -> u32:
    let dest_reg = self.fb.fresh_reg()
    self.fb.emit(AirInst(
        opcode: OP_ALIAS_REUSE,
        type_id: type_id,
        dest: dest_reg,
        src1: ptr_reg,
        src2: 0 as u32,
    ))
    return dest_reg

pub fn lower_ownership_aware(mut self: FuncLowering, idx: u32, node: AstNode, init_reg: u32) -> u32:
    if node.flags & FLAG_ESCAPES_TO_HEAP != 0 as u16:
        mut type_id := 0 as u16
        if node.extra_idx != 0 as u32:
            type_id = node.extra_idx as u16
        let ref_reg = self.emit_heap_alloc(type_id)

        if init_reg != 0 as u32:
            let ptr_reg = self.emit_deref(ref_reg, type_id)
            self.fb.emit(AirInst(
                opcode: OP_STORE,
                type_id: 0 as u16,
                dest: ptr_reg,
                src1: init_reg,
                src2: 0 as u32,
            ))
        return ref_reg

    if node.flags & FLAG_USES_ARENA != 0 as u16:
        mut type_id := 0 as u16
        if node.extra_idx != 0 as u32:
            type_id = node.extra_idx as u16
        let ptr_reg = self.emit_arena_alloc(0 as u32, type_id)
        if init_reg != 0 as u32:
            self.fb.emit(AirInst(
                opcode: OP_STORE,
                type_id: 0 as u16,
                dest: ptr_reg,
                src1: init_reg,
                src2: 0 as u32,
            ))
        return ptr_reg

    if node.flags & FLAG_IS_MOVED != 0 as u16 and init_reg != 0 as u32:
        mut type_id := 0 as u16
        if node.extra_idx != 0 as u32:
            type_id = node.extra_idx as u16
        return self.emit_move(init_reg, type_id)

    return init_reg

pub fn lower_alias_stmt(mut self: FuncLowering, idx: u32, node: AstNode):
    if node.first_child != 0 as u32:
        let cn = self.mb.tree.nodes.data[node.first_child as i64]
        let src_reg = self.lower_expr(node.first_child)

        mut type_id := 0 as u16
        if node.extra_idx != 0 as u32:
            type_id = node.extra_idx as u16
        self.emit_alias_reuse(src_reg, type_id)

pub fn lower_block(mut self: FuncLowering, block_idx: u32):
    let node = self.mb.tree.nodes.data[block_idx as i64]
    mut child := node.first_child
    while child != 0 as u32:
        let cn = self.mb.tree.nodes.data[child as i64]
        self.lower_stmt(child, cn)
        child = cn.next_sibling

pub fn lower_stmt(mut self: FuncLowering, idx: u32, node: AstNode):
    if self.terminated:
        return

    if node.kind == NODE_VAR_DECL:
        self.lower_var_decl(idx, node)
    elif node.kind == NODE_ASSIGN_STMT:
        self.lower_assign(idx, node)
    elif node.kind == NODE_RETURN_STMT:
        self.lower_return(idx, node)
    elif node.kind == NODE_IF_STMT:
        self.lower_if(idx, node)
    elif node.kind == NODE_WHILE_STMT:
        self.lower_while(idx, node)
    elif node.kind == NODE_FOR_STMT:
        self.lower_for(idx, node)
    elif node.kind == NODE_BLOCK:
        self.lower_block(idx)
    elif node.kind == NODE_DESTROY_STMT:
        self.lower_destroy(idx, node)
    elif node.kind == NODE_ALIAS_STMT:
        self.lower_alias_stmt(idx, node)
    elif node.kind == NODE_DEFER_STMT:
        self.lower_defer(idx, node)
    else:
        self.lower_expr(idx)

pub fn lower_var_decl(mut self: FuncLowering, idx: u32, node: AstNode):
    let name_id = node.payload
    mut type_id := 0 as u16

    mut init_reg := 0 as u32
    mut child := node.first_child
    while child != 0 as u32:
        let cn = self.mb.tree.nodes.data[child as i64]
        if cn.kind != NODE_TYPE_EXPR and cn.kind != NODE_PTR_TYPE and cn.kind != NODE_SLICE_TYPE and cn.kind != NODE_ARRAY_TYPE and cn.kind != NODE_FUNC_TYPE and cn.kind != NODE_GENERIC_TYPE:
            init_reg = self.lower_expr(child)
        child = cn.next_sibling

    if init_reg != 0 as u32:
        if node.flags & (FLAG_ESCAPES_TO_HEAP | FLAG_USES_ARENA | FLAG_IS_MOVED) != 0 as u16:
            let owner_reg = self.lower_ownership_aware(idx, node, init_reg)
            self.locals.local_map_put(name_id, owner_reg)
        else:
            self.locals.local_map_put(name_id, init_reg)
    else:
        let reg = self.fb.fresh_reg()
        self.fb.emit(AirInst(
            opcode: OP_ICONST,
            type_id: type_id,
            dest: reg,
            src1: 0 as u32,
            src2: 0 as u32,
        ))
        self.locals.local_map_put(name_id, reg)

pub fn lower_assign(mut self: FuncLowering, idx: u32, node: AstNode):
    let lhs_idx = node.first_child
    if lhs_idx == 0 as u32:
        return
    let lhs_node = self.mb.tree.nodes.data[lhs_idx as i64]

    if lhs_node.kind == NODE_FIELD_EXPR:
        let obj_idx = lhs_node.first_child
        let obj_reg = self.lower_expr(obj_idx)
        let field_idx = lhs_node.extra_idx

        let rhs_idx = lhs_node.next_sibling
        if rhs_idx == 0 as u32:
            return
        let val_reg = self.lower_expr(rhs_idx)

        mut type_id := 0 as u16
        let obj_type = self.mb.node_types[obj_idx as i64]
        if obj_type != 0 as u32:
            let entry = self.mb.typetable.entries.data[obj_type as i64]
            if entry.kind == TYPE_KIND_POINTER:
                type_id = entry.extra as u16
            else:
                type_id = obj_type as u16

        self.fb.emit(AirInst(
            opcode: OP_SET_FIELD,
            type_id: type_id,
            dest: val_reg,
            src1: obj_reg,
            src2: field_idx,
        ))
        return

    elif lhs_node.kind == NODE_INDEX_EXPR:
        let arr_idx = lhs_node.first_child
        let arr_reg = self.lower_expr(arr_idx)
        let index_idx = self.mb.tree.nodes.data[arr_idx as i64].next_sibling
        mut index_reg := 0 as u32
        if index_idx != 0 as u32:
            index_reg = self.lower_expr(index_idx)

        let rhs_idx = lhs_node.next_sibling
        if rhs_idx == 0 as u32:
            return
        let val_reg = self.lower_expr(rhs_idx)

        mut type_id := 0 as u16
        let arr_type = self.mb.node_types[arr_idx as i64]
        if arr_type != 0 as u32:
            let entry = self.mb.typetable.entries.data[arr_type as i64]
            if entry.kind == TYPE_KIND_POINTER or entry.kind == TYPE_KIND_SLICE or entry.kind == TYPE_KIND_ARRAY:
                type_id = entry.extra as u16

        self.fb.emit(AirInst(
            opcode: OP_STORE,
            type_id: type_id,
            dest: arr_reg,
            src1: val_reg,
            src2: index_reg,
        ))
        return

    elif lhs_node.kind == NODE_DEREF_EXPR:
        let ptr_idx = lhs_node.first_child
        let ptr_reg = self.lower_expr(ptr_idx)

        let rhs_idx = lhs_node.next_sibling
        if rhs_idx == 0 as u32:
            return
        let val_reg = self.lower_expr(rhs_idx)

        mut type_id := 0 as u16
        let ptr_type = self.mb.node_types[ptr_idx as i64]
        if ptr_type != 0 as u32:
            let entry = self.mb.typetable.entries.data[ptr_type as i64]
            if entry.kind == TYPE_KIND_POINTER:
                type_id = entry.extra as u16

        self.fb.emit(AirInst(
            opcode: OP_STORE,
            type_id: type_id,
            dest: ptr_reg,
            src1: val_reg,
            src2: 0 as u32,
        ))
        return

    mut name_id := lhs_node.payload
    if name_id == 0 as u32:
        let text = self.mb.get_token_text(lhs_node.token_idx)
        name_id = self.mb.pool.intern(text)
        @free(text as ptr[u8])

    let rhs_idx = lhs_node.next_sibling
    if rhs_idx == 0 as u32:
        return
    let rhs_node = self.mb.tree.nodes.data[rhs_idx as i64]
    let val_reg = self.lower_expr(rhs_idx)

    mut type_id := 3 as u16 // default i32
    if lhs_node.payload != 0 as u32 and (lhs_node.payload as i64) < self.mb.symbols.symbols.len:
        let sym = self.mb.symbols.symbols.data[lhs_node.payload as i64]
        if sym.type_id != 0 as u32:
            type_id = sym.type_id as u16

    let existing_reg = self.locals.local_map_get(name_id)
    if existing_reg != 0 as u32:
        self.fb.emit(AirInst(
            opcode: OP_COPY,
            type_id: type_id,
            dest: existing_reg,
            src1: val_reg,
            src2: 0 as u32,
        ))
    else:
        self.locals.local_map_put(name_id, val_reg)

pub fn lower_return(mut self: FuncLowering, idx: u32, node: AstNode):
    mut ret_val := 0 as u32
    if node.first_child != 0 as u32:
        ret_val = self.lower_expr(node.first_child)

    self.fb.emit(AirInst(
        opcode: OP_RETURN,
        type_id: 0 as u16,
        dest: 0 as u32,
        src1: ret_val,
        src2: 0 as u32,
    ))
    self.terminated = true

pub fn lower_if(mut self: FuncLowering, idx: u32, node: AstNode):
    let then_block = self.fb.new_block()
    let else_block = self.fb.new_block()
    let merge_block = self.fb.new_block()

    mut child := node.first_child
    if child == 0 as u32:
        return
    let cn = self.mb.tree.nodes.data[child as i64]
    let cond_reg = self.lower_expr(child)

    self.fb.emit(AirInst(
        opcode: OP_BRANCH,
        type_id: 0 as u16,
        dest: else_block,
        src1: cond_reg,
        src2: then_block,
    ))
    let cur_block = self.fb.current_block()
    self.fb.add_edge(cur_block, then_block)
    self.fb.add_edge(cur_block, else_block)

    // Then block
    self.fb.switch_to(then_block)
    self.terminated = false
    child = cn.next_sibling
    if child != 0 as u32:
        let tcn = self.mb.tree.nodes.data[child as i64]
        if tcn.kind == NODE_BLOCK:
            self.lower_block(child)
        child = tcn.next_sibling

    if not self.terminated:
        self.fb.emit(AirInst(opcode: OP_JUMP, type_id: 0 as u16, dest: 0 as u32, src1: merge_block, src2: 0 as u32))
        self.fb.add_edge(then_block, merge_block)

    // Else block
    self.fb.switch_to(else_block)
    self.terminated = false
    while child != 0 as u32:
        let ecn = self.mb.tree.nodes.data[child as i64]
        if ecn.kind == NODE_ELSE_CLAUSE or ecn.kind == NODE_ELIF_CLAUSE:
            let else_body = ecn.first_child
            if else_body != 0 as u32:
                let eecn = self.mb.tree.nodes.data[else_body as i64]
                if eecn.kind == NODE_BLOCK:
                    self.lower_block(else_body)
                elif ecn.kind == NODE_ELIF_CLAUSE:
                    self.lower_if(child, ecn)
        child = ecn.next_sibling

    if not self.terminated:
        self.fb.emit(AirInst(opcode: OP_JUMP, type_id: 0 as u16, dest: 0 as u32, src1: merge_block, src2: 0 as u32))
        self.fb.add_edge(else_block, merge_block)

    // Merge block
    self.fb.switch_to(merge_block)
    self.terminated = false

pub fn lower_while(mut self: FuncLowering, idx: u32, node: AstNode):
    let cond_block = self.fb.new_block()
    let body_block = self.fb.new_block()
    let exit_block = self.fb.new_block()

    let cur_block = self.fb.current_block()
    self.fb.emit(AirInst(opcode: OP_JUMP, type_id: 0 as u16, dest: 0 as u32, src1: cond_block, src2: 0 as u32))
    self.fb.add_edge(cur_block, cond_block)

    // Condition
    self.fb.switch_to(cond_block)
    self.terminated = false
    let child = node.first_child
    if child == 0 as u32:
        return
    let cn = self.mb.tree.nodes.data[child as i64]
    let cond_reg = self.lower_expr(child)

    self.fb.emit(AirInst(
        opcode: OP_BRANCH,
        type_id: 0 as u16,
        dest: exit_block,
        src1: cond_reg,
        src2: body_block,
    ))
    self.fb.add_edge(cond_block, body_block)
    self.fb.add_edge(cond_block, exit_block)

    // Body
    self.fb.switch_to(body_block)
    self.terminated = false
    let body_child = cn.next_sibling
    if body_child != 0 as u32:
        let bcn = self.mb.tree.nodes.data[body_child as i64]
        if bcn.kind == NODE_BLOCK:
            self.lower_block(body_child)

    if not self.terminated:
        self.fb.emit(AirInst(opcode: OP_JUMP, type_id: 0 as u16, dest: 0 as u32, src1: cond_block, src2: 0 as u32))
        self.fb.add_edge(body_block, cond_block)

    // Exit
    self.fb.switch_to(exit_block)
    self.terminated = false

pub fn lower_for(mut self: FuncLowering, idx: u32, node: AstNode):
    let cond_block = self.fb.new_block()
    let body_block = self.fb.new_block()
    let exit_block = self.fb.new_block()

    let sym_idx = node.payload
    mut name_id := 0 as u32
    mut type_id := 3 as u16 // default i32

    if sym_idx != 0 as u32 and (sym_idx as i64) < self.mb.symbols.symbols.len:
        let sym = self.mb.symbols.symbols.data[sym_idx as i64]
        name_id = sym.name_id
        if sym.type_id != 0 as u32:
            type_id = sym.type_id as u16
    else:
        name_id = sym_idx

    // Initialize loop variable to 0
    let iter_reg = self.fb.fresh_reg()
    self.fb.emit(AirInst(
        opcode: OP_ICONST,
        type_id: type_id,
        dest: iter_reg,
        src1: 0 as u32,
        src2: 0 as u32,
    ))
    self.locals.local_map_put(name_id, iter_reg)

    let cur_block = self.fb.current_block()
    self.fb.emit(AirInst(opcode: OP_JUMP, type_id: 0 as u16, dest: 0 as u32, src1: cond_block, src2: 0 as u32))
    self.fb.add_edge(cur_block, cond_block)

    // Condition
    self.fb.switch_to(cond_block)
    self.terminated = false

    mut limit_reg := 0 as u32
    mut child := node.first_child
    if child != 0 as u32:
        let cn = self.mb.tree.nodes.data[child as i64]
        child = cn.next_sibling
        if child != 0 as u32:
            let rcn = self.mb.tree.nodes.data[child as i64]
            limit_reg = self.lower_expr(child)

    let cmp_reg = self.fb.fresh_reg()
    let current_iter = self.locals.local_map_get(name_id)
    self.fb.emit(AirInst(
        opcode: OP_LT,
        type_id: 11 as u16, // bool
        dest: cmp_reg,
        src1: current_iter,
        src2: limit_reg,
    ))

    self.fb.emit(AirInst(
        opcode: OP_BRANCH,
        type_id: 0 as u16,
        dest: exit_block,
        src1: cmp_reg,
        src2: body_block,
    ))
    self.fb.add_edge(cond_block, body_block)
    self.fb.add_edge(cond_block, exit_block)

    // Body
    self.fb.switch_to(body_block)
    self.terminated = false

    if child != 0 as u32:
        let cn = self.mb.tree.nodes.data[child as i64]
        child = cn.next_sibling
        if child != 0 as u32:
            let bcn = self.mb.tree.nodes.data[child as i64]
            if bcn.kind == NODE_BLOCK:
                self.lower_block(child)

    if not self.terminated:
        let one_reg = self.fb.fresh_reg()
        self.fb.emit(AirInst(
            opcode: OP_ICONST,
            type_id: type_id,
            dest: one_reg,
            src1: 1 as u32,
            src2: 0 as u32,
        ))
        let current_iter2 = self.locals.local_map_get(name_id)
        self.fb.emit(AirInst(
            opcode: OP_IADD,
            type_id: type_id,
            dest: current_iter2,
            src1: current_iter2,
            src2: one_reg,
        ))

        self.fb.emit(AirInst(opcode: OP_JUMP, type_id: 0 as u16, dest: 0 as u32, src1: cond_block, src2: 0 as u32))
        self.fb.add_edge(body_block, cond_block)

    // Exit
    self.fb.switch_to(exit_block)
    self.terminated = false

pub fn lower_destroy(mut self: FuncLowering, idx: u32, node: AstNode):
    if node.first_child != 0 as u32:
        let val_reg = self.lower_expr(node.first_child)
        self.fb.emit(AirInst(
            opcode: OP_DESTROY,
            type_id: 0 as u16,
            dest: 0 as u32,
            src1: val_reg,
            src2: 0 as u32,
        ))
    else:
        let sym_id = node.payload
        if sym_id != 0 as u32 and (sym_id as i64) < self.mb.symbols.symbols.len:
            let sym = self.mb.symbols.symbols.data[sym_id as i64]
            let reg = self.locals.local_map_get(sym.name_id)
            if reg != 0 as u32:
                self.fb.emit(AirInst(
                    opcode: OP_DESTROY,
                    type_id: 0 as u16,
                    dest: 0 as u32,
                    src1: reg,
                    src2: 0 as u32,
                ))

pub fn lower_defer(mut self: FuncLowering, idx: u32, node: AstNode):
    if node.first_child != 0 as u32:
        self.lower_expr(node.first_child)

pub fn ensure_return(mut self: FuncLowering):
    if not self.terminated:
        self.fb.emit(AirInst(
            opcode: OP_RETURN,
            type_id: 0 as u16,
            dest: 0 as u32,
            src1: 0 as u32,
            src2: 0 as u32,
        ))
        self.terminated = true

pub fn lower_func(self: ptr[AirModuleBuilder], idx: u32, node: AstNode) -> ptr[AirFunc]:
    if node.flags & FLAG_IS_EXTERN != 0 as u16:
        return null as ptr[AirFunc]

    mut name_id := 0 as u32
    mut ret_type_id := 0 as u32
    mut param_types := new_u32_vec()

    let sym_idx = node.payload
    if sym_idx != 0 as u32 and (sym_idx as i64) < self.symbols.symbols.len:
        let sym = self.symbols.symbols.data[sym_idx as i64]
        name_id = sym.name_id
        if sym.type_id != 0 as u32:
            let entry = self.typetable.entries.data[sym.type_id as i64]
            if entry.kind == TYPE_KIND_FUNC:
                let fi = self.typetable.funcs.data[entry.extra as i64]
                ret_type_id = fi.ret
                mut i := 0 as i64
                while i < fi.params.len:
                    param_types.push(fi.params.data[i])
                    i = i + 1

    if name_id == 0 as u32:
        let text = self.get_token_text(node.token_idx)
        name_id = self.pool.intern(text)
        @free(text as ptr[u8])

    mut fb := new_air_func_builder(name_id, ret_type_id)
    mut fl := new_func_lowering(self, fb, param_types)

    fl.register_params(idx, node)

    mut body_idx := 0 as u32
    mut child := node.first_child
    while child != 0 as u32:
        let cn = self.tree.nodes.data[child as i64]
        if cn.kind == NODE_BLOCK:
            body_idx = child
        child = cn.next_sibling

    if body_idx != 0 as u32:
        fl.lower_block(body_idx)

    fl.ensure_return()

    let fn_built = fl.fb.build_func()
    
    let fn_ptr = @alloc(192) as ptr[AirFunc]
    fn_ptr[0] = fn_built
    fn_ptr.sym_id = sym_idx
    fn_ptr.is_async = (node.flags & FLAG_IS_ASYNC != 0 as u16)
    fn_ptr.params = fl.params
    fl.params.data = null as ptr[u32]

    free_func_lowering(fl)
    return fn_ptr

pub fn build_module(self: ptr[AirModuleBuilder]):
    let root = self.tree.nodes.data[0]
    mut child := root.first_child
    while child != 0 as u32:
        let node = self.tree.nodes.data[child as i64]
        if node.kind == NODE_FUNC_DECL:
            let fn_ptr = self.lower_func(child, node)
            if fn_ptr != null as ptr[AirFunc]:
                self.module.funcs.push(fn_ptr[0])
                @free(fn_ptr as ptr[u8])
        elif node.kind == NODE_STRUCT_DECL:
            mut member := node.first_child
            while member != 0 as u32:
                let member_node = self.tree.nodes.data[member as i64]
                if member_node.kind == NODE_FUNC_DECL:
                    let fn_ptr = self.lower_func(member, member_node)
                    if fn_ptr != null as ptr[AirFunc]:
                        self.module.funcs.push(fn_ptr[0])
                        @free(fn_ptr as ptr[u8])
                member = member_node.next_sibling
        child = node.next_sibling
// bootstrap/stage1/cgen.ax
// SSA AIR to C11 Code Generator.


extern "C" fn fopen(filename: ptr[void], mode: str) -> ptr[void]
extern "C" fn fclose(stream: ptr[void]) -> i32
extern "C" fn fputs(s: str, stream: ptr[void]) -> i32
extern "C" fn fprintf(stream: ptr[void], fmt: str, a1: i64, a2: i64, a3: i64, a4: i64, a5: i64, a6: i64, a7: i64, a8: i64) -> i32

fn opcode_defines_dest(op: u16) -> bool:
    if op == 0 as u16: // OP_NOP
        return false
    if op == 0x0102 as u16: // OP_FREE
        return false
    if op == 0x010B as u16: // OP_DESTROY
        return false
    if op == 0x0104 as u16: // OP_STORE
        return false
    if op == 0x010E as u16: // OP_SET_FIELD
        return false
    if op == 0x0301 as u16: // OP_JUMP
        return false
    if op == 0x0302 as u16: // OP_BRANCH
        return false
    if op == 0x0304 as u16: // OP_RETURN
        return false
    return true

pub struct CGenerator:
    pub module: AirModule
    pub tree: AstTree
    pub pool: InternPool
    pub symtable: SymbolTable
    pub typetable: TypeTable
    pub file: ptr[void]
    pub reg_types: ptr[u32]

pub fn new_c_generator(mod: AirModule, tree: AstTree, pool: InternPool, symtable: SymbolTable, typetable: TypeTable) -> CGenerator:
    return CGenerator(
        module: mod,
        tree: tree,
        pool: pool,
        symtable: symtable,
        typetable: typetable,
        file: null as ptr[void],
        reg_types: null as ptr[u32],
    )

pub fn get_c_type(self: CGenerator, type_id: u32) -> str:
    if type_id == 1 as u32:
        return "ax_i8"
    if type_id == 2 as u32:
        return "ax_i16"
    if type_id == 3 as u32:
        return "ax_i32"
    if type_id == 4 as u32:
        return "ax_i64"
    if type_id == 5 as u32:
        return "ax_u8"
    if type_id == 6 as u32:
        return "ax_u16"
    if type_id == 7 as u32:
        return "ax_u32"
    if type_id == 8 as u32:
        return "ax_u64"
    if type_id == 9 as u32:
        return "ax_f32"
    if type_id == 10 as u32:
        return "ax_f64"
    if type_id == 11 as u32:
        return "ax_bool"
    if type_id == 12 as u32:
        return "ax_string"
    if type_id == 13 as u32:
        return "ax_char"
    if type_id == 14 as u32:
        return "void"
    if type_id == 15 as u32:
        return "ax_isize"
    if type_id == 16 as u32:
        return "ax_usize"
    
    if (type_id as i64) < self.typetable.entries.len:
        let entry = self.typetable.entries.data[type_id]
        if entry.kind == TYPE_KIND_POINTER:
            return "void*"
        if entry.kind == TYPE_KIND_STRUCT:
            if entry.name_id != 0 as u32:
                let name = self.pool.get(entry.name_id)
                // Return struct pointer name
                mut res := @alloc(std.string.len(name) + 2) as ptr[u8]
                @memcpy(res, name as ptr[u8], std.string.len(name))
                res[std.string.len(name)] = '*' as u8
                res[std.string.len(name) + 1] = 0 as u8
                return res as str
            return "void*"
        if entry.kind == TYPE_KIND_SUM:
            return "ax_i32"
        if entry.kind == TYPE_KIND_SLICE:
            return "ax_slice_void"
    return "void*"

pub fn is_stdlib_func(self: CGenerator, name: str) -> bool:
    if name == "system" or name == "remove" or name == "fopen" or name == "fclose" or name == "fseek" or name == "ftell" or name == "rewind" or name == "fread" or name == "fwrite" or name == "printf" or name == "puts" or name == "putchar" or name == "getchar" or name == "fgetc" or name == "fgets" or name == "fputc" or name == "fputs" or name == "sprintf" or name == "snprintf" or name == "fprintf" or name == "scanf" or name == "fscanf" or name == "sscanf" or name == "malloc" or name == "free" or name == "realloc" or name == "calloc" or name == "exit" or name == "abort" or name == "memset" or name == "memcpy" or name == "memmove" or name == "println" or name == "print" or name == "eprint" or name == "eprintln" or name == "assert":
        return true
    
    let name_ptr = name as ptr[u8]
    let len = std.string.len(name)
    if len >= 3 and name_ptr[0] == 'a' as u8 and name_ptr[1] == 'x' as u8 and name_ptr[2] == '_' as u8:
        return true
            
    return false

pub fn get_mangled_name_by_sym(self: CGenerator, sym_idx: u32) -> str:
    mut fn_name := "func"
    if sym_idx != 0 as u32 and (sym_idx as i64) < self.symtable.symbols.len:
        let sym = self.symtable.symbols.data[sym_idx as i64]
        fn_name = self.pool.get(sym.name_id)
        
        if fn_name == "free":
            let is_extern = ((sym.flags & 4 as u16) != 0 as u16)
            if is_extern:
                return "free"
            return "ax_free"

        if self.is_stdlib_func(fn_name):
            return fn_name

        let is_extern = ((sym.flags & 4 as u16) != 0 as u16)
        if is_extern:
            return fn_name

        if sym.type_id != 0 as u32 and (sym.type_id as i64) < self.typetable.entries.len:
            let entry = self.typetable.entries.data[sym.type_id as i64]
            if entry.kind == TYPE_KIND_FUNC:
                let fi = self.typetable.funcs.data[entry.extra as i64]
                if fi.params.len > 0 as i64:
                    mut first_param_type = fi.params.data[0]
                    mut p_entry = self.typetable.entries.data[first_param_type as i64]
                    if p_entry.kind == TYPE_KIND_POINTER:
                        first_param_type = p_entry.extra
                        p_entry = self.typetable.entries.data[first_param_type as i64]
                    
                    if p_entry.kind == TYPE_KIND_STRUCT and p_entry.name_id != 0 as u32:
                        let struct_name = self.pool.get(p_entry.name_id)
                        let struct_len = std.string.len(struct_name)
                        let fn_len = std.string.len(fn_name)
                        let total_len = 3 + struct_len + 1 + fn_len
                        mut res := @alloc(total_len + 1) as ptr[u8]
                        @memcpy(res, "ax_" as ptr[u8], 3)
                        
                        let dest1 = ((res as u64) + 3 as u64) as ptr[u8]
                        @memcpy(dest1, struct_name as ptr[u8], struct_len)
                        
                        res[3 + struct_len] = '_' as u8
                        
                        let dest2 = ((res as u64) + 3 as u64 + struct_len as u64 + 1 as u64) as ptr[u8]
                        @memcpy(dest2, fn_name as ptr[u8], fn_len)
                        
                        res[total_len] = 0 as u8
                        return res as str

    let fn_len = std.string.len(fn_name)
    mut res := @alloc(3 + fn_len + 1) as ptr[u8]
    @memcpy(res, "ax_" as ptr[u8], 3)
    let dest = ((res as u64) + 3 as u64) as ptr[u8]
    @memcpy(dest, fn_name as ptr[u8], fn_len)
    res[3 + fn_len] = 0 as u8
    return res as str

fn str_to_null_terminated(s: str) -> ptr[u8]:
    let len = std.string.len(s)
    let buf = @alloc(len + 1) as ptr[u8]
    @memcpy(buf, s as ptr[u8], len)
    buf[len] = 0 as u8
    return buf

pub fn generate(mut self: CGenerator, out_filename: str) -> bool:
    let filename_nt = str_to_null_terminated(out_filename)
    self.file = fopen(filename_nt as ptr[void], "w")
    @free(filename_nt)
    if self.file == null as ptr[void]:
        return false

    mut has_main := false
    mut main_has_args := false
    mut fn_idx := 0 as i64
    while fn_idx < self.module.funcs.len:
        let f = self.module.funcs.data[fn_idx]
        let original_name = self.pool.get(f.name)
        if original_name == "main":
            has_main = true
            if f.params.len > 0 as i64:
                main_has_args = true
        fn_idx = fn_idx + 1 as i64

    fputs("// Generated automatically by AXIOM AirCGen Stage 1\n", self.file)
    if has_main:
        fputs("#define AX_EMIT_MAIN\n", self.file)
        if main_has_args:
            fputs("#define AX_MAIN_WITH_ARGS\n", self.file)
    fputs("#include \"ax_runtime.h\"\n", self.file)
    fputs("#include \"ax_stdlib.h\"\n\n", self.file)
    fputs("#define r_0 0\n\n", self.file)

    // 1. Forward declare all structs
    fputs("// Forward Declarations\n", self.file)
    mut i := 0 as i64
    while i < self.typetable.entries.len:
        let entry = self.typetable.entries.data[i]
        if entry.kind == TYPE_KIND_STRUCT and entry.name_id != 0 as u32:
            let name = self.pool.get(entry.name_id)
            fprintf(self.file, "typedef struct %s %s;\n", (name as ptr[u8]) as i64, (name as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        i = i + 1
    fputs("\n", self.file)

    // 2. Define structures
    fputs("// Struct Definitions\n", self.file)
    i = 0
    while i < self.typetable.entries.len:
        let entry = self.typetable.entries.data[i]
        if entry.kind == TYPE_KIND_STRUCT and entry.name_id != 0 as u32:
            let name = self.pool.get(entry.name_id)
            fprintf(self.file, "struct %s {\n", (name as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            let si = self.typetable.structs.data[entry.extra as i64]
            mut f_idx := 0 as i64
            while f_idx < si.fields.len:
                let field = si.fields.data[f_idx]
                let field_type = self.get_c_type(field.type_id)
                // Declare field
                fprintf(self.file, "    %s f_%d;\n", (field_type as ptr[u8]) as i64, f_idx, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                f_idx = f_idx + 1 as i64
            fputs("};\n\n", self.file)
        i = i + 1

    // 3. Function prototypes
    fputs("// Function Prototypes\n", self.file)
    mut f_idx := 0 as i64
    while f_idx < self.module.funcs.len:
        let f = self.module.funcs.data[f_idx]
        if f.is_extern:
            f_idx = f_idx + 1 as i64
        else:
            let original_name = self.pool.get(f.name)
            let mangled_name = self.get_mangled_name_by_sym(f.sym_id)
            let ret_type = self.get_c_type(f.ret_type)
            fprintf(self.file, "%s %s(", (ret_type as ptr[u8]) as i64, (mangled_name as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            mut p_idx := 0 as i64
            while p_idx < f.params.len:
                if p_idx > 0:
                    fputs(", ", self.file)
                mut param_type := self.get_c_type(f.params.data[p_idx])
                if original_name == "main" and p_idx == 1 as i64:
                    param_type = "ax_u8**"
                fprintf(self.file, "%s p_%d", (param_type as ptr[u8]) as i64, p_idx, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                p_idx = p_idx + 1 as i64
            fputs(");\n", self.file)
            if mangled_name != original_name and mangled_name != "free" and mangled_name != "ax_free":
                @free(mangled_name as ptr[u8])
            f_idx = f_idx + 1 as i64
    fputs("\n", self.file)

    // 4. Function definitions
    fputs("// Function Definitions\n", self.file)
    f_idx = 0
    while f_idx < self.module.funcs.len:
        let f = self.module.funcs.data[f_idx]
        if f.is_extern:
            f_idx = f_idx + 1 as i64
        else:
            let original_name = self.pool.get(f.name)
            let mangled_name = self.get_mangled_name_by_sym(f.sym_id)
            let ret_type = self.get_c_type(f.ret_type)
            
            fprintf(self.file, "%s %s(", (ret_type as ptr[u8]) as i64, (mangled_name as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            mut p_idx := 0 as i64
            while p_idx < f.params.len:
                if p_idx > 0:
                    fputs(", ", self.file)
                mut param_type := self.get_c_type(f.params.data[p_idx])
                if original_name == "main" and p_idx == 1 as i64:
                    param_type = "ax_u8**"
                fprintf(self.file, "%s p_%d", (param_type as ptr[u8]) as i64, p_idx, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                p_idx = p_idx + 1 as i64
            fputs(") {\n", self.file)
            if mangled_name != original_name and mangled_name != "free" and mangled_name != "ax_free":
                @free(mangled_name as ptr[u8])

            // Declare all SSA registers
            // First scan to collect maximum registers
            mut max_reg := 0 as u32
            mut inst_idx := 0 as i64
            while inst_idx < f.insts.len:
                let inst = f.insts.data[inst_idx]
                if inst.dest > max_reg:
                    max_reg = inst.dest
                inst_idx = inst_idx + 1

            // Initialize register array types dynamically
            if max_reg > 0 as u32:
                self.reg_types = @alloc((max_reg as i64 + 1) * 4) as ptr[u32]
                mut r := 0 as i64
                while r <= max_reg as i64:
                    self.reg_types[r] = 0 as u32
                    r = r + 1

                // Pre-populate parameter register types
                if f.params.data != null as ptr[u32]:
                    mut p_idx := 0 as i64
                    while p_idx < f.params.len:
                        let p_reg = (p_idx + 1) as u32
                        if p_reg <= max_reg:
                            self.reg_types[p_reg] = f.params.data[p_idx]
                        p_idx = p_idx + 1

                inst_idx = 0
                while inst_idx < f.insts.len:
                    let inst = f.insts.data[inst_idx]
                    if opcode_defines_dest(inst.opcode) and inst.dest > 0 as u32:
                        mut t_id := inst.type_id as u32
                        if inst.opcode == 0x010D as u16: // OP_GET_FIELD
                            mut obj_type_id = inst.type_id as u32
                            if obj_type_id == 0 as u32 and inst.src1 > 0 as u32:
                                obj_type_id = self.reg_types[inst.src1]
                            if (obj_type_id as i64) < self.typetable.entries.len:
                                mut entry = self.typetable.entries.data[obj_type_id]
                                if entry.kind == TYPE_KIND_POINTER:
                                    let pointee_id = entry.extra
                                    if pointee_id != 0 as u32 and (pointee_id as i64) < self.typetable.entries.len:
                                        entry = self.typetable.entries.data[pointee_id]
                                if entry.kind == TYPE_KIND_STRUCT:
                                    let si = self.typetable.structs.data[entry.extra as i64]
                                    if (inst.src2 as i64) < si.fields.len:
                                        t_id = si.fields.data[inst.src2 as i64].type_id
                        elif (inst.opcode == 0x0105 as u16 or inst.opcode == 0x0109 as u16 or inst.opcode == 0x010F as u16) and t_id == 0 as u32: // OP_INDEX, OP_GEP or OP_DEREF
                            if inst.src1 > 0 as u32 and self.reg_types[inst.src1] != 0 as u32:
                                let src_type = self.reg_types[inst.src1]
                                if (src_type as i64) < self.typetable.entries.len:
                                    let entry = self.typetable.entries.data[src_type]
                                    if entry.kind == TYPE_KIND_POINTER or entry.kind == TYPE_KIND_SLICE or entry.kind == TYPE_KIND_ARRAY:
                                        t_id = entry.extra
                        elif inst.opcode == OP_CALL: // OP_CALL
                            let sym_idx = inst.type_id as u32
                            if sym_idx != 0 as u32 and (sym_idx as i64) < self.symtable.symbols.len:
                                let sym = self.symtable.symbols.data[sym_idx as i64]
                                let fn_name = self.pool.get(sym.name_id)
                                if fn_name == "println" or fn_name == "print" or fn_name == "eprint" or fn_name == "eprintln" or fn_name == "assert" or fn_name == "free":
                                    t_id = 14 as u32
                                else:
                                    let fn_type_id = sym.type_id
                                    if fn_type_id != 0 as u32 and (fn_type_id as i64) < self.typetable.entries.len:
                                        let entry = self.typetable.entries.data[fn_type_id]
                                        if entry.kind == TYPE_KIND_FUNC:
                                            let fi = self.typetable.funcs.data[entry.extra as i64]
                                            t_id = fi.ret
                        self.reg_types[inst.dest] = t_id
                    inst_idx = inst_idx + 1

                // Print register declarations
                r = 1
                while r <= max_reg as i64:
                    if self.reg_types[r] != 14 as u32:
                        let t_name = self.get_c_type(self.reg_types[r])
                        fprintf(self.file, "    %s r_%d = {0};\n", (t_name as ptr[u8]) as i64, r, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                    r = r + 1

                // Copy parameters to registers
                if f.params.data != null as ptr[u32]:
                    mut p_idx := 0 as i64
                    while p_idx < f.params.len:
                        let r_idx = (p_idx + 1) as i64
                        fprintf(self.file, "    r_%d = p_%d;\n", r_idx, p_idx, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                        p_idx = p_idx + 1

            // Generate C statements block-by-block
            mut b_idx := 0 as i64
            while b_idx < f.blocks.len:
                let bb = f.blocks.data[b_idx]
                fprintf(self.file, "block_%d: ;\n", bb.id as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

                mut inst_offset := 0 as i64
                while inst_offset < bb.instrs_len as i64:
                    let inst_pos = f.block_instrs.data[bb.instrs_start as i64 + inst_offset]
                    let inst = f.insts.data[inst_pos as i64]
                    self.translate_inst(f, inst)
                    inst_offset = inst_offset + 1 as i64
                b_idx = b_idx + 1 as i64

            if max_reg > 0 as u32:
                @free(self.reg_types as ptr[u8])
                self.reg_types = null as ptr[u32]

            fputs("}\n\n", self.file)
            f_idx = f_idx + 1 as i64

    fclose(self.file)
    return true

pub fn translate_inst(mut self: CGenerator, f: AirFunc, inst: AirInst):
    let op = inst.opcode
    if op == OP_NOP:
        return

    if op == OP_ICONST:
        if inst.type_id == 12 as u16: // string
            let str_val = self.pool.get(inst.src1)
            mut val_ptr = str_val as ptr[u8]
            mut val_len = std.string.len(str_val)
            mut is_stripped := false
            if val_len >= 2 as i64 and val_ptr[0] == '"' as u8 and val_ptr[val_len - 1] == '"' as u8:
                val_ptr = ((val_ptr as u64) + 1 as u64) as ptr[u8]
                val_len = val_len - 2 as i64
                is_stripped = true
            
            mut print_buf := val_ptr
            if is_stripped:
                print_buf = @alloc(val_len + 1) as ptr[u8]
                @memcpy(print_buf, val_ptr, val_len)
                print_buf[val_len] = 0 as u8

            // Emit AX_STR macro
            fprintf(self.file, "    r_%d = AX_STR(\"%s\");\n", inst.dest as i64, (print_buf as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            if is_stripped:
                @free(print_buf)
        else:
            fprintf(self.file, "    r_%d = %d;\n", inst.dest as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    elif op == OP_FCONST:
        fprintf(self.file, "    r_%d = %d.0;\n", inst.dest as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    elif op == OP_IADD:
        fprintf(self.file, "    r_%d = r_%d + r_%d;\n", inst.dest as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_ISUB:
        fprintf(self.file, "    r_%d = r_%d - r_%d;\n", inst.dest as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_IMUL:
        fprintf(self.file, "    r_%d = r_%d * r_%d;\n", inst.dest as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_IDIV:
        fprintf(self.file, "    r_%d = r_%d / r_%d;\n", inst.dest as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_IMOD:
        fprintf(self.file, "    r_%d = r_%d %% r_%d;\n", inst.dest as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    elif op == OP_EQ:
        if self.reg_types != null as ptr[u32] and inst.src1 > 0 as u32 and self.reg_types[inst.src1] == 12 as u32:
            fprintf(self.file, "    r_%d = ax_str_eq(r_%d, r_%d);\n", inst.dest as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        else:
            fprintf(self.file, "    r_%d = r_%d == r_%d;\n", inst.dest as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_NE:
        if self.reg_types != null as ptr[u32] and inst.src1 > 0 as u32 and self.reg_types[inst.src1] == 12 as u32:
            fprintf(self.file, "    r_%d = !ax_str_eq(r_%d, r_%d);\n", inst.dest as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        else:
            fprintf(self.file, "    r_%d = r_%d != r_%d;\n", inst.dest as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_LT:
        fprintf(self.file, "    r_%d = r_%d < r_%d;\n", inst.dest as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_LE:
        fprintf(self.file, "    r_%d = r_%d <= r_%d;\n", inst.dest as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_GT:
        fprintf(self.file, "    r_%d = r_%d > r_%d;\n", inst.dest as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_GE:
        fprintf(self.file, "    r_%d = r_%d >= r_%d;\n", inst.dest as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    elif op == OP_AND:
        fprintf(self.file, "    r_%d = r_%d && r_%d;\n", inst.dest as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_OR:
        fprintf(self.file, "    r_%d = r_%d || r_%d;\n", inst.dest as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_XOR:
        fprintf(self.file, "    r_%d = r_%d ^ r_%d;\n", inst.dest as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_SHL:
        fprintf(self.file, "    r_%d = r_%d << r_%d;\n", inst.dest as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_SHR:
        fprintf(self.file, "    r_%d = r_%d >> r_%d;\n", inst.dest as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    elif op == OP_NOT:
        fprintf(self.file, "    r_%d = !r_%d;\n", inst.dest as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_NEG:
        fprintf(self.file, "    r_%d = -r_%d;\n", inst.dest as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    elif op == OP_COPY or op == OP_MOVE or op == OP_ALIAS_REUSE:
        fprintf(self.file, "    r_%d = r_%d;\n", inst.dest as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    elif op == OP_CAST:
        if inst.type_id == 12 as u16:
            fprintf(self.file, "    r_%d = (ax_string){.ptr = (const ax_u8*)r_%d, .len = strlen((const char*)r_%d)};\n", inst.dest as i64, inst.src1 as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        else:
            let t_name = self.get_c_type(inst.type_id as u32)
            mut is_str_src := false
            if self.reg_types != null as ptr[u32] and inst.src1 > 0 as u32:
                let src_type = self.reg_types[inst.src1]
                if src_type == 12 as u32:
                    is_str_src = true
            if is_str_src:
                fprintf(self.file, "    r_%d = (%s)r_%d.ptr;\n", inst.dest as i64, (t_name as ptr[u8]) as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            else:
                fprintf(self.file, "    r_%d = (%s)r_%d;\n", inst.dest as i64, (t_name as ptr[u8]) as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    elif op == OP_ALLOC:
        let entry = self.typetable.entries.data[inst.type_id as i64]
        if entry.kind == TYPE_KIND_STRUCT and entry.name_id != 0 as u32:
            let name = self.pool.get(entry.name_id)
            fprintf(self.file, "    r_%d = (%s*)ax_alloc(sizeof(%s));\n", inst.dest as i64, (name as ptr[u8]) as i64, (name as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        else:
            fprintf(self.file, "    r_%d = ax_alloc(%d);\n", inst.dest as i64, entry.size as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    elif op == OP_FREE or op == OP_DESTROY:
        fprintf(self.file, "    ax_free(r_%d);\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    elif op == OP_MAKE_REF:
        fprintf(self.file, "    r_%d = ax_make_ref(r_%d);\n", inst.dest as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    elif op == OP_DEREF:
        fprintf(self.file, "    r_%d = ax_deref(r_%d);\n", inst.dest as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    elif op == OP_GET_FIELD:
        mut obj_type_id := inst.type_id as u32
        if obj_type_id == 0 as u32 and self.reg_types != null as ptr[u32] and inst.src1 > 0 as u32:
            obj_type_id = self.reg_types[inst.src1]
        mut s_name := "void"
        if obj_type_id != 0 as u32 and (obj_type_id as i64) < self.typetable.entries.len:
            mut entry = self.typetable.entries.data[obj_type_id]
            if entry.kind == TYPE_KIND_POINTER:
                let pointee_id = entry.extra
                if pointee_id != 0 as u32 and (pointee_id as i64) < self.typetable.entries.len:
                    entry = self.typetable.entries.data[pointee_id]
            if entry.kind == TYPE_KIND_STRUCT and entry.name_id != 0 as u32:
                s_name = self.pool.get(entry.name_id)
        fprintf(self.file, "    r_%d = ((struct %s*)r_%d)->f_%d;\n", inst.dest as i64, (s_name as ptr[u8]) as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    elif op == OP_SET_FIELD:
        mut obj_type_id := inst.type_id as u32
        if obj_type_id == 0 as u32 and self.reg_types != null as ptr[u32] and inst.src1 > 0 as u32:
            obj_type_id = self.reg_types[inst.src1]
        mut s_name := "void"
        if obj_type_id != 0 as u32 and (obj_type_id as i64) < self.typetable.entries.len:
            mut entry = self.typetable.entries.data[obj_type_id]
            if entry.kind == TYPE_KIND_POINTER:
                let pointee_id = entry.extra
                if pointee_id != 0 as u32 and (pointee_id as i64) < self.typetable.entries.len:
                    entry = self.typetable.entries.data[pointee_id]
            if entry.kind == TYPE_KIND_STRUCT and entry.name_id != 0 as u32:
                s_name = self.pool.get(entry.name_id)
        fprintf(self.file, "    ((struct %s*)r_%d)->f_%d = r_%d;\n", (s_name as ptr[u8]) as i64, inst.src1 as i64, inst.src2 as i64, inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    elif op == OP_INDEX:
        mut t_name := "void*"
        if self.reg_types != null as ptr[u32] and inst.src1 > 0 as u32:
            let t_id = self.reg_types[inst.src1]
            if t_id != 0 as u32 and (t_id as i64) < self.typetable.entries.len:
                let entry = self.typetable.entries.data[t_id]
                if entry.kind == TYPE_KIND_POINTER:
                    let pointee = entry.extra
                    t_name = self.get_c_type(pointee)
        if t_name == "void*" or t_name == "void":
            if self.reg_types != null as ptr[u32] and inst.dest > 0 as u32:
                let dest_t = self.reg_types[inst.dest]
                if dest_t != 0 as u32:
                    t_name = self.get_c_type(dest_t)
        if t_name == "void":
            t_name = "void*"
        fprintf(self.file, "    r_%d = ((%s*)r_%d)[r_%d];\n", inst.dest as i64, (t_name as ptr[u8]) as i64, inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    elif op == OP_STORE:
        if inst.src2 != 0 as u32:
            mut t_name := "void*"
            if self.reg_types != null as ptr[u32] and inst.dest > 0 as u32:
                let t_id = self.reg_types[inst.dest]
                if t_id != 0 as u32 and (t_id as i64) < self.typetable.entries.len:
                    let entry = self.typetable.entries.data[t_id]
                    if entry.kind == TYPE_KIND_POINTER:
                        let pointee = entry.extra
                        t_name = self.get_c_type(pointee)
            if t_name == "void*" or t_name == "void":
                if self.reg_types != null as ptr[u32] and inst.src1 > 0 as u32:
                    let src_t = self.reg_types[inst.src1]
                    if src_t != 0 as u32:
                        t_name = self.get_c_type(src_t)
            if t_name == "void":
                t_name = "void*"
            fprintf(self.file, "    ((%s*)r_%d)[r_%d] = r_%d;\n", (t_name as ptr[u8]) as i64, inst.dest as i64, inst.src2 as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        else:
            fprintf(self.file, "    *r_%d = r_%d;\n", inst.dest as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    elif op == OP_JUMP:
        fprintf(self.file, "    goto block_%d;\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    elif op == OP_BRANCH:
        fprintf(self.file, "    if (r_%d) goto block_%d; else goto block_%d;\n", inst.src1 as i64, inst.src2 as i64, inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

    elif op == OP_RETURN:
        if inst.src1 != 0 as u32:
            fprintf(self.file, "    return r_%d;\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        else:
            if f.ret_type != 14 as u32: // not void
                let t_name = self.get_c_type(f.ret_type)
                fprintf(self.file, "    return (%s){0};\n", (t_name as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            else:
                fputs("    return;\n", self.file)

    elif op == OP_CALL:
        // Handle argument list
        let arg_start = inst.src2
        let arg_count = f.extras.data[arg_start as i64]
        mut is_assert := false
        mut is_extern := false
        
        // Print callee
        if inst.src1 == 0 as u32:
            // Direct function call
            // We find the function name from type_id (which is symbol idx in this case or typetable extra)
            mut fn_name := "func"
            let sym_idx = inst.type_id as u32
            mut is_allocated := false
            if sym_idx != 0 as u32 and (sym_idx as i64) < self.symtable.symbols.len:
                fn_name = self.get_mangled_name_by_sym(sym_idx)
                let original_name = self.pool.get(self.symtable.symbols.data[sym_idx as i64].name_id)
                if fn_name != original_name and fn_name != "free" and fn_name != "ax_free":
                    is_allocated = true
                let s_flags = self.symtable.symbols.data[sym_idx as i64].flags
                if (s_flags & 4 as u16) != 0 as u16:
                    is_extern = true
            if fn_name == "assert":
                fn_name = "ax_assert_axiom"
                is_assert = true
            elif fn_name == "println" or fn_name == "print" or fn_name == "eprint" or fn_name == "eprintln":
                // Map to typed builtin
                mut suffix := "_str"
                if arg_count > 0 as u32:
                    let first_arg_reg = f.extras.data[arg_start as i64 + 1]
                    if self.reg_types != null as ptr[u32] and first_arg_reg > 0 as u32:
                        let t_id = self.reg_types[first_arg_reg]
                        if t_id == 3 as u32 or t_id == 4 as u32 or t_id == 7 as u32 or t_id == 8 as u32:
                            suffix = "_i64"
                        elif t_id == 9 as u32 or t_id == 10 as u32:
                            suffix = "_f64"
                        elif t_id == 11 as u32:
                            suffix = "_bool"
                
                // Mangle to ax_<func_name><suffix>
                let fn_len = std.string.len(fn_name)
                let suffix_len = std.string.len(suffix)
                mut mapped_name := @alloc(fn_len + suffix_len + 4) as ptr[u8]
                @memcpy(mapped_name, "ax_" as ptr[u8], 3)
                
                let dest1 = ((mapped_name as u64) + 3 as u64) as ptr[u8]
                @memcpy(dest1, fn_name as ptr[u8], fn_len)
                
                let dest2 = ((mapped_name as u64) + 3 as u64 + fn_len as u64) as ptr[u8]
                @memcpy(dest2, suffix as ptr[u8], suffix_len)
                
                let term_idx = 3 + fn_len + suffix_len
                mapped_name[term_idx] = 0 as u8
                
                fn_name = mapped_name as str
                is_allocated = true

            if inst.dest != 0 as u32 and (self.reg_types == null as ptr[u32] or self.reg_types[inst.dest] != 14 as u32):
                if self.reg_types[inst.dest] == 0 as u32:
                    fprintf(self.file, "    r_%d = (void*)%s(", inst.dest as i64, (fn_name as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                else:
                    fprintf(self.file, "    r_%d = %s(", inst.dest as i64, (fn_name as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            else:
                fprintf(self.file, "    %s(", (fn_name as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            
            if is_allocated:
                @free(fn_name as ptr[u8])
        else:
            // Indirect function call
            if inst.dest != 0 as u32 and (self.reg_types == null as ptr[u32] or self.reg_types[inst.dest] != 14 as u32):
                if self.reg_types[inst.dest] == 0 as u32:
                    fprintf(self.file, "    r_%d = (void*)((void*(*)())r_%d)(", inst.dest as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                else:
                    fprintf(self.file, "    r_%d = ((void*(*)())r_%d)(", inst.dest as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            else:
                fprintf(self.file, "    ((void(*)())r_%d)(", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

        mut i := 0 as i64
        while i < arg_count as i64:
            if i > 0:
                fputs(", ", self.file)
            let arg_reg = f.extras.data[arg_start as i64 + 1 + i]
            mut is_str := false
            if self.reg_types != null as ptr[u32] and arg_reg > 0 as u32:
                let t_id = self.reg_types[arg_reg]
                if t_id == 12 as u32:
                    is_str = true
            if is_extern and is_str:
                fprintf(self.file, "(const char*)(r_%d).ptr", arg_reg as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            else:
                fprintf(self.file, "r_%d", arg_reg as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            i = i + 1
        if is_assert:
            fputs(", AX_STR(\"assertion failed\")", self.file)
        fputs(");\n", self.file)
// bootstrap/stage1/wasm.ax
// SSA AIR to WebAssembly Text (WAT) Code Generator.


extern "C" fn fopen(filename: ptr[void], mode: str) -> ptr[void]
extern "C" fn fclose(stream: ptr[void]) -> i32
extern "C" fn fputs(s: str, stream: ptr[void]) -> i32
extern "C" fn fprintf(stream: ptr[void], fmt: str, a1: i64, a2: i64, a3: i64, a4: i64, a5: i64, a6: i64, a7: i64, a8: i64) -> i32
extern "C" fn snprintf(buf: ptr[void], size: i64, format: str, a1: ptr[void], a2: ptr[void]) -> i32

fn is_type_unsigned(type_id: u32) -> bool:
    if type_id == 5 as u32 or type_id == 6 as u32 or type_id == 7 as u32 or type_id == 8 as u32 or type_id == 16 as u32:
        return true
    return false

fn map_wasm_type(typetable: TypeTable, type_id: u32) -> str:
    if type_id == 4 as u32 or type_id == 8 as u32: // i64, u64
        return "i64"
    if type_id == 9 as u32: // f32
        return "f32"
    if type_id == 10 as u32: // f64
        return "f64"
    if type_id == 14 as u32: // void
        return ""
    // all other integers and pointers map to i32 in wasm32
    return "i32"

fn wasm_opcode_defines_dest(op: u16) -> bool:
    if op == 0 as u16: // OP_NOP
        return false
    if op == 0x0102 as u16: // OP_FREE
        return false
    if op == 0x010B as u16: // OP_DESTROY
        return false
    if op == 0x0104 as u16: // OP_STORE
        return false
    if op == 0x010E as u16: // OP_SET_FIELD
        return false
    if op == 0x0301 as u16: // OP_JUMP
        return false
    if op == 0x0302 as u16: // OP_BRANCH
        return false
    if op == 0x0304 as u16: // OP_RETURN
        return false
    return true

pub struct WasmGenerator:
    pub module: AirModule
    pub tree: AstTree
    pub pool: InternPool
    pub symtable: SymbolTable
    pub typetable: TypeTable
    pub file: ptr[void]
    pub reg_types: ptr[u32]

pub fn new_wasm_generator(mod: AirModule, tree: AstTree, pool: InternPool, symtable: SymbolTable, typetable: TypeTable) -> WasmGenerator:
    return WasmGenerator(
        module: mod,
        tree: tree,
        pool: pool,
        symtable: symtable,
        typetable: typetable,
        file: null as ptr[void],
        reg_types: null as ptr[u32],
    )

pub fn resolve_sym_name(self: WasmGenerator, sym_id: u32, name_id: u32) -> str:
    if sym_id == 0 as u32:
        return "main"
    if sym_id == 4294967295 as u32:
        return "malloc"
    if sym_id == 4294967294 as u32:
        return "free"
    
    let name = self.pool.get(name_id)
    if std.string.len(name) > 0:
        if name == "main" or name == "printf" or name == "malloc" or name == "free":
            return name
        
        let ptr_name = name as ptr[u8]
        if std.string.len(name) >= 4 and ptr_name[0] == '_' as u8 and ptr_name[1] == 'A' as u8 and ptr_name[2] == 'X' as u8 and ptr_name[3] == '_' as u8:
            return name
        
        let new_len = 4 + std.string.len(name)
        let buf = @alloc(new_len + 1) as ptr[u8]
        @memcpy(buf, "_AX_" as ptr[u8], 4)
        @memcpy(((buf as u64) + 4 as u64) as ptr[u8], name as ptr[u8], std.string.len(name))
        buf[new_len] = 0 as u8
        return buf as str
    
    let buf = @alloc(32) as ptr[u8]
    snprintf(buf as ptr[void], 32, "_AX_f%d", sym_id as ptr[void], null as ptr[void])
    return buf as str

fn wasm_str_to_null_terminated(s: str) -> ptr[u8]:
    let len = std.string.len(s)
    let buf = @alloc(len + 1) as ptr[u8]
    @memcpy(buf, s as ptr[u8], len)
    buf[len] = 0 as u8
    return buf

pub fn generate(mut self: WasmGenerator, out_filename: str) -> bool:
    let filename_nt = wasm_str_to_null_terminated(out_filename)
    self.file = fopen(filename_nt as ptr[void], "w")
    @free(filename_nt)
    if self.file == null as ptr[void]:
        return false

    fputs("(module\n", self.file)
    fputs("  (memory (export \"memory\") 1)\n\n", self.file)

    // 1. Declare all external functions as imports
    mut f_idx := 0 as i64
    while f_idx < self.module.funcs.len:
        let f = self.module.funcs.data[f_idx]
        if f.is_extern:
            let callee = self.resolve_sym_name(f.sym_id, f.name)
            fprintf(self.file, "  (import \"env\" \"%s\" (func $%s", (callee as ptr[u8]) as i64, (callee as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            
            mut p_idx := 0 as i64
            while p_idx < f.params.len:
                let p_type = map_wasm_type(self.typetable, f.params.data[p_idx])
                fprintf(self.file, " (param %s)", (p_type as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
                p_idx = p_idx + 1
            
            if f.ret_type != 0 as u32 and f.ret_type != 14 as u32:
                let r_type = map_wasm_type(self.typetable, f.ret_type)
                fprintf(self.file, " (result %s)", (r_type as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            
            fputs("))\n", self.file)
            @free(callee as ptr[u8])
        f_idx = f_idx + 1
    
    // Always import malloc and free if not already declared by externs
    mut has_malloc := false
    mut has_free := false
    f_idx = 0
    while f_idx < self.module.funcs.len:
        let f = self.module.funcs.data[f_idx]
        if f.is_extern:
            let name = self.pool.get(f.name)
            if name == "malloc":
                has_malloc = true
            if name == "free":
                has_free = true
        f_idx = f_idx + 1
    
    if not has_malloc:
        fputs("  (import \"env\" \"malloc\" (func $malloc (param i32) (result i32)))\n", self.file)
    if not has_free:
        fputs("  (import \"env\" \"free\" (func $free (param i32)))\n", self.file)
    
    fputs("\n", self.file)

    // 2. Compile functions
    f_idx = 0
    while f_idx < self.module.funcs.len:
        let f = self.module.funcs.data[f_idx]
        if not f.is_extern:
            self.compile_func(f)
        f_idx = f_idx + 1
    
    fputs(")\n", self.file)
    fclose(self.file)
    return true

pub fn compile_func(mut self: WasmGenerator, f: AirFunc):
    let mangled_name = self.resolve_sym_name(f.sym_id, f.name)
    fprintf(self.file, "  (func $%s (export \"%s\")", (mangled_name as ptr[u8]) as i64, (mangled_name as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    @free(mangled_name as ptr[u8])

    mut p_idx := 0 as i64
    while p_idx < f.params.len:
        let param_type = map_wasm_type(self.typetable, f.params.data[p_idx])
        fprintf(self.file, " (param $p%d %s)", (p_idx + 1) as i64, (param_type as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        p_idx = p_idx + 1
    
    if f.ret_type != 0 as u32 and f.ret_type != 14 as u32:
        let r_type = map_wasm_type(self.typetable, f.ret_type)
        fprintf(self.file, " (result %s)", (r_type as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    
    fputs("\n", self.file)
    fputs("    (local $state i32)\n", self.file)

    // Declare SSA registers
    mut max_reg := 0 as u32
    mut inst_idx := 0 as i64
    while inst_idx < f.insts.len:
        let inst = f.insts.data[inst_idx]
        if inst.dest > max_reg:
            max_reg = inst.dest
        inst_idx = inst_idx + 1

    if max_reg > 0 as u32:
        self.reg_types = @alloc((max_reg as i64 + 1) * 4) as ptr[u32]
        mut r := 0 as i64
        while r <= max_reg as i64:
            self.reg_types[r] = 0 as u32
            r = r + 1

        if f.params.data != null as ptr[u32]:
            mut p_idx := 0 as i64
            while p_idx < f.params.len:
                let p_reg = (p_idx + 1) as u32
                if p_reg <= max_reg:
                    self.reg_types[p_reg] = f.params.data[p_idx]
                p_idx = p_idx + 1

        inst_idx = 0
        while inst_idx < f.insts.len:
            let inst = f.insts.data[inst_idx]
            if wasm_opcode_defines_dest(inst.opcode) and inst.dest > 0 as u32:
                mut t_id := inst.type_id as u32
                if inst.opcode == 0x010D as u16: // OP_GET_FIELD
                    mut obj_type_id = inst.type_id as u32
                    if obj_type_id == 0 as u32 and inst.src1 > 0 as u32:
                        obj_type_id = self.reg_types[inst.src1]
                    if (obj_type_id as i64) < self.typetable.entries.len:
                        mut entry = self.typetable.entries.data[obj_type_id]
                        if entry.kind == TYPE_KIND_POINTER:
                            let pointee_id = entry.extra
                            if pointee_id != 0 as u32 and (pointee_id as i64) < self.typetable.entries.len:
                                entry = self.typetable.entries.data[pointee_id]
                        if entry.kind == TYPE_KIND_STRUCT:
                            let si = self.typetable.structs.data[entry.extra as i64]
                            if (inst.src2 as i64) < si.fields.len:
                                t_id = si.fields.data[inst.src2 as i64].type_id
                elif (inst.opcode == 0x0105 as u16 or inst.opcode == 0x0109 as u16 or inst.opcode == 0x010F as u16) and t_id == 0 as u32: // OP_INDEX, OP_GEP, OP_DEREF
                    if inst.src1 > 0 as u32 and self.reg_types[inst.src1] != 0 as u32:
                        let src_type = self.reg_types[inst.src1]
                        if (src_type as i64) < self.typetable.entries.len:
                            let entry = self.typetable.entries.data[src_type]
                            if entry.kind == TYPE_KIND_POINTER or entry.kind == TYPE_KIND_SLICE or entry.kind == TYPE_KIND_ARRAY:
                                t_id = entry.extra
                elif inst.opcode == OP_CALL: // OP_CALL
                    let sym_idx = inst.type_id as u32
                    if sym_idx != 0 as u32 and (sym_idx as i64) < self.symtable.symbols.len:
                        let sym = self.symtable.symbols.data[sym_idx as i64]
                        let fn_name = self.pool.get(sym.name_id)
                        if fn_name == "println" or fn_name == "print" or fn_name == "eprint" or fn_name == "eprintln" or fn_name == "assert" or fn_name == "free":
                            t_id = 14 as u32
                        else:
                            let fn_type_id = sym.type_id
                            if fn_type_id != 0 as u32 and (fn_type_id as i64) < self.typetable.entries.len:
                                let entry = self.typetable.entries.data[fn_type_id]
                                if entry.kind == TYPE_KIND_FUNC:
                                    let fi = self.typetable.funcs.data[entry.extra as i64]
                                    t_id = fi.ret
                self.reg_types[inst.dest] = t_id
            inst_idx = inst_idx + 1

        r = 1 as i64
        while r <= max_reg as i64:
            if self.reg_types[r] != 14 as u32:
                let t_name = map_wasm_type(self.typetable, self.reg_types[r])
                fprintf(self.file, "    (local $r%d %s)\n", r, (t_name as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            r = r + 1

    if f.blocks.len == 0 as i64:
        fputs("    return\n  )\n\n", self.file)
        if max_reg > 0 as u32:
            @free(self.reg_types as ptr[u8])
            self.reg_types = null as ptr[u32]
        return

    fputs("    (local.set $state (i32.const 0))\n\n", self.file)
    fputs("    (block $outer\n", self.file)
    fputs("      (loop $loop\n", self.file)

    // Open all blocks hierarchically (N down to 0)
    mut bi := f.blocks.len - 1
    while bi >= 0:
        let bb = f.blocks.data[bi]
        fprintf(self.file, "        (block $b_%d\n", bb.id as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        bi = bi - 1
    
    // Emit br_table dispatcher
    fputs("          (br_table", self.file)
    bi = 0
    while bi < f.blocks.len:
        let bb = f.blocks.data[bi]
        fprintf(self.file, " $b_%d", bb.id as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        bi = bi + 1
    fputs(" $b_0 (local.get $state))\n", self.file)

    // Close each block and emit its instructions
    bi = 0
    while bi < f.blocks.len:
        let bb = f.blocks.data[bi]
        fprintf(self.file, "        ) ;; end $b_%d\n", bb.id as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fprintf(self.file, "        ;; --- block_%d body ---\n", bb.id as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        
        mut inst_offset := 0 as i64
        while inst_offset < bb.instrs_len as i64:
            let inst_pos = f.block_instrs.data[bb.instrs_start as i64 + inst_offset]
            let inst = f.insts.data[inst_pos as i64]
            self.lower_inst(f, inst)
            inst_offset = inst_offset + 1
        bi = bi + 1
    
    fputs("      )\n", self.file)
    fputs("    )\n", self.file)

    if f.ret_type != 0 as u32 and f.ret_type != 14 as u32:
        let r_type = map_wasm_type(self.typetable, f.ret_type)
        fprintf(self.file, "    (%s.const 0)\n", (r_type as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    
    fputs("  )\n\n", self.file)

    if max_reg > 0 as u32:
        @free(self.reg_types as ptr[u8])
        self.reg_types = null as ptr[u32]

pub fn lower_inst(mut self: WasmGenerator, f: AirFunc, inst: AirInst):
    let op = inst.opcode
    if op == OP_NOP:
        return

    if op == OP_ICONST:
        let t = map_wasm_type(self.typetable, inst.type_id as u32)
        fprintf(self.file, "        (%s.const %d)\n", (t as ptr[u8]) as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fprintf(self.file, "        (local.set $r%d)\n", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_FCONST:
        let t = map_wasm_type(self.typetable, inst.type_id as u32)
        fprintf(self.file, "        (%s.const %d)\n", (t as ptr[u8]) as i64, inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fprintf(self.file, "        (local.set $r%d)\n", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_COPY or op == OP_MOVE or op == OP_ALIAS_REUSE:
        if inst.src1 <= f.params.len as u32 and inst.src1 > 0 as u32:
            fprintf(self.file, "        (local.get $p%d)\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        else:
            fprintf(self.file, "        (local.get $r%d)\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fprintf(self.file, "        (local.set $r%d)\n", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_IADD or op == OP_ISUB or op == OP_IMUL or op == OP_IDIV or op == OP_IMOD or op == OP_FADD or op == OP_FSUB or op == OP_FMUL or op == OP_FDIV:
        let t = map_wasm_type(self.typetable, inst.type_id as u32)
        fprintf(self.file, "        (local.get $r%d)\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fprintf(self.file, "        (local.get $r%d)\n", inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        
        mut op_str := "add"
        if op == OP_IADD or op == OP_FADD:
            op_str = "add"
        elif op == OP_ISUB or op == OP_FSUB:
            op_str = "sub"
        elif op == OP_IMUL or op == OP_FMUL:
            op_str = "mul"
        elif op == OP_IDIV:
            if is_type_unsigned(inst.type_id as u32):
                op_str = "div_u"
            else:
                op_str = "div_s"
        elif op == OP_FDIV:
            op_str = "div"
        elif op == OP_IMOD:
            if is_type_unsigned(inst.type_id as u32):
                op_str = "rem_u"
            else:
                op_str = "rem_s"
        
        fprintf(self.file, "        %s.%s\n", (t as ptr[u8]) as i64, (op_str as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fprintf(self.file, "        (local.set $r%d)\n", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_EQ or op == OP_NE or op == OP_LT or op == OP_LE or op == OP_GT or op == OP_GE:
        mut src_type := "i32"
        mut is_unsigned_cmp := false
        if inst.src1 > 0 as u32 and self.reg_types != null as ptr[u32]:
            let src1_type = self.reg_types[inst.src1]
            src_type = map_wasm_type(self.typetable, src1_type)
            is_unsigned_cmp = is_type_unsigned(src1_type)
        
        fprintf(self.file, "        (local.get $r%d)\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fprintf(self.file, "        (local.get $r%d)\n", inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        
        mut cmp_op := "eq"
        if op == OP_EQ:
            cmp_op = "eq"
        elif op == OP_NE:
            cmp_op = "ne"
        elif op == OP_LT:
            if src_type == "f32" or src_type == "f64":
                cmp_op = "lt"
            elif is_unsigned_cmp:
                cmp_op = "lt_u"
            else:
                cmp_op = "lt_s"
        elif op == OP_LE:
            if src_type == "f32" or src_type == "f64":
                cmp_op = "le"
            elif is_unsigned_cmp:
                cmp_op = "le_u"
            else:
                cmp_op = "le_s"
        elif op == OP_GT:
            if src_type == "f32" or src_type == "f64":
                cmp_op = "gt"
            elif is_unsigned_cmp:
                cmp_op = "gt_u"
            else:
                cmp_op = "gt_s"
        elif op == OP_GE:
            if src_type == "f32" or src_type == "f64":
                cmp_op = "ge"
            elif is_unsigned_cmp:
                cmp_op = "ge_u"
            else:
                cmp_op = "ge_s"
        
        fprintf(self.file, "        %s.%s\n", (src_type as ptr[u8]) as i64, (cmp_op as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fprintf(self.file, "        (local.set $r%d)\n", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_AND or op == OP_OR or op == OP_XOR or op == OP_SHL or op == OP_SHR:
        let t = map_wasm_type(self.typetable, inst.type_id as u32)
        fprintf(self.file, "        (local.get $r%d)\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fprintf(self.file, "        (local.get $r%d)\n", inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        
        mut bit_op := "and"
        if op == OP_AND:
            bit_op = "and"
        elif op == OP_OR:
            bit_op = "or"
        elif op == OP_XOR:
            bit_op = "xor"
        elif op == OP_SHL:
            bit_op = "shl"
        elif op == OP_SHR:
            if is_type_unsigned(inst.type_id as u32):
                bit_op = "shr_u"
            else:
                bit_op = "shr_s"
        
        fprintf(self.file, "        %s.%s\n", (t as ptr[u8]) as i64, (bit_op as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fprintf(self.file, "        (local.set $r%d)\n", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_NEG:
        let t = map_wasm_type(self.typetable, inst.type_id as u32)
        if t == "f32" or t == "f64":
            fprintf(self.file, "        (local.get $r%d)\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            fprintf(self.file, "        %s.neg\n", (t as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        else:
            fprintf(self.file, "        (%s.const 0)\n", (t as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            fprintf(self.file, "        (local.get $r%d)\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            fprintf(self.file, "        %s.sub\n", (t as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fprintf(self.file, "        (local.set $r%d)\n", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_NOT:
        let t = map_wasm_type(self.typetable, inst.type_id as u32)
        fprintf(self.file, "        (local.get $r%d)\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        if t == "i64":
            fputs("        (i64.const -1)\n", self.file)
        else:
            fputs("        (i32.const -1)\n", self.file)
        fprintf(self.file, "        %s.xor\n", (t as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fprintf(self.file, "        (local.set $r%d)\n", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_ALLOC or op == OP_ARENA_ALLOC:
        mut size := 8 as u32
        if inst.type_id != 0 as u16 and (inst.type_id as i64) < self.typetable.entries.len:
            let entry = self.typetable.entries.data[inst.type_id]
            if entry.size != 0 as u32:
                size = entry.size
        fprintf(self.file, "        (i32.const %d)\n", size as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fputs("        (call $malloc)\n", self.file)
        fprintf(self.file, "        (local.set $r%d)\n", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_FREE or op == OP_DESTROY:
        fprintf(self.file, "        (local.get $r%d)\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fputs("        (call $free)\n", self.file)
    elif op == OP_LOAD:
        let t = map_wasm_type(self.typetable, inst.type_id as u32)
        fprintf(self.file, "        (local.get $r%d)\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fprintf(self.file, "        %s.load\n", (t as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fprintf(self.file, "        (local.set $r%d)\n", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_STORE:
        mut t := "i32"
        if inst.src2 != 0 as u32:
            // Store to pointer: src2 = index register, dest = base pointer register, src1 = value register
            if inst.src1 > 0 as u32 and self.reg_types != null as ptr[u32]:
                let val_type = self.reg_types[inst.src1]
                t = map_wasm_type(self.typetable, val_type)
            fprintf(self.file, "        (local.get $r%d)\n", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64) // address base
            fprintf(self.file, "        (local.get $r%d)\n", inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64) // index or offset
            fputs("        i32.add\n", self.file)
            fprintf(self.file, "        (local.get $r%d)\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64) // value
        else:
            // Dereference store: *dest = src1
            if inst.src1 > 0 as u32 and self.reg_types != null as ptr[u32]:
                let val_type = self.reg_types[inst.src1]
                t = map_wasm_type(self.typetable, val_type)
            fprintf(self.file, "        (local.get $r%d)\n", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64) // address
            fprintf(self.file, "        (local.get $r%d)\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64) // value
        fprintf(self.file, "        %s.store\n", (t as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_GEP:
        mut elem_size := 8 as u32
        if inst.type_id != 0 as u16 and (inst.type_id as i64) < self.typetable.entries.len:
            let entry = self.typetable.entries.data[inst.type_id]
            if entry.size != 0 as u32:
                elem_size = entry.size
        fprintf(self.file, "        (local.get $r%d)\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fprintf(self.file, "        (local.get $r%d)\n", inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fprintf(self.file, "        (i32.const %d)\n", elem_size as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fputs("        i32.mul\n", self.file)
        fputs("        i32.add\n", self.file)
        fprintf(self.file, "        (local.set $r%d)\n", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_GET_FIELD:
        let offset = inst.src2 * 8 as u32
        fprintf(self.file, "        (local.get $r%d)\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fprintf(self.file, "        (i32.const %d)\n", offset as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fputs("        i32.add\n", self.file)
        let t = map_wasm_type(self.typetable, inst.type_id as u32)
        fprintf(self.file, "        %s.load\n", (t as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fprintf(self.file, "        (local.set $r%d)\n", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_SET_FIELD:
        let offset = inst.src2 * 8 as u32
        fprintf(self.file, "        (local.get $r%d)\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fprintf(self.file, "        (i32.const %d)\n", offset as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fputs("        i32.add\n", self.file)
        fprintf(self.file, "        (local.get $r%d)\n", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        mut t := "i32"
        if inst.dest > 0 as u32 and self.reg_types != null as ptr[u32]:
            let dest_type = self.reg_types[inst.dest]
            t = map_wasm_type(self.typetable, dest_type)
        fprintf(self.file, "        %s.store\n", (t as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_INDEX:
        fprintf(self.file, "        (local.get $r%d)\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fprintf(self.file, "        (local.get $r%d)\n", inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fputs("        i32.add\n", self.file)
        let t = map_wasm_type(self.typetable, inst.type_id as u32)
        fprintf(self.file, "        %s.load\n", (t as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fprintf(self.file, "        (local.set $r%d)\n", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_CALL:
        let arg_start = inst.src2 as i64
        mut arg_count := 0 as u32
        if arg_start < f.extras.len:
            arg_count = f.extras.data[arg_start]
        
        mut j := 0 as i64
        while j < arg_count as i64:
            let arg_reg = f.extras.data[arg_start + 1 + j]
            fprintf(self.file, "        (local.get $r%d)\n", arg_reg as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            j = j + 1
        
        mut callee := ""
        if inst.src1 == 0 as u32:
            let sym_idx = inst.type_id as u32
            if sym_idx != 0 as u32 and (sym_idx as i64) < self.symtable.symbols.len:
                let sym = self.symtable.symbols.data[sym_idx as i64]
                callee = self.resolve_sym_name(sym_idx, sym.name_id)
            else:
                callee = self.resolve_sym_name(0 as u32, 0 as u32)
        else:
            callee = self.resolve_sym_name(0 as u32, 0 as u32)
        
        fprintf(self.file, "        (call $%s)\n", (callee as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        if inst.dest != 0 as u32:
            fprintf(self.file, "        (local.set $r%d)\n", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        @free(callee as ptr[u8])
    elif op == OP_CAST or op == OP_ZEXT or op == OP_SEXT or op == OP_TRUNC:
        let dst_t = map_wasm_type(self.typetable, inst.type_id as u32)
        mut src_t := "i32"
        if inst.src1 > 0 as u32 and self.reg_types != null as ptr[u32]:
            let src_type = self.reg_types[inst.src1]
            src_t = map_wasm_type(self.typetable, src_type)
        
        fprintf(self.file, "        (local.get $r%d)\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        if src_t == "i64" and dst_t == "i32":
            fputs("        i32.wrap_i64\n", self.file)
        elif src_t == "i32" and dst_t == "i64":
            if op == OP_ZEXT:
                fputs("        i64.extend_i32_u\n", self.file)
            else:
                fputs("        i64.extend_i32_s\n", self.file)
        
        fprintf(self.file, "        (local.set $r%d)\n", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_JUMP:
        fprintf(self.file, "        (local.set $state (i32.const %d))\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fputs("        (br $loop)\n", self.file)
    elif op == OP_BRANCH:
        fprintf(self.file, "        (local.get $r%d)\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fputs("        (if\n", self.file)
        fputs("          (then\n", self.file)
        fprintf(self.file, "            (local.set $state (i32.const %d))\n", inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fputs("          )\n", self.file)
        fputs("          (else\n", self.file)
        fprintf(self.file, "            (local.set $state (i32.const %d))\n", inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fputs("          )\n", self.file)
        fputs("        )\n", self.file)
        fputs("        (br $loop)\n", self.file)
    elif op == OP_RETURN:
        if inst.src1 != 0 as u32:
            fprintf(self.file, "        (local.get $r%d)\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        fputs("        return\n", self.file)
    else:
        fputs("        nop\n", self.file)
// bootstrap/stage1/main_air.ax
// Test harness entry point for AXIOM self-hosted compiler & driver


extern "C" fn fopen(filename: ptr[void], mode: str) -> ptr[void]
extern "C" fn fclose(stream: ptr[void]) -> i32
extern "C" fn fseek(stream: ptr[void], offset: i64, origin: i32) -> i32
extern "C" fn ftell(stream: ptr[void]) -> i64
extern "C" fn rewind(stream: ptr[void])
extern "C" fn fread(buffer: ptr[void], size: i64, count: i64, stream: ptr[void]) -> i64
extern "C" fn printf(fmt: str, a1: i64, a2: i64, a3: i64, a4: i64, a5: i64, a6: i64, a7: i64, a8: i64) -> i32
extern "C" fn puts(s: str) -> i32
extern "C" fn system(command: ptr[void]) -> i32
extern "C" fn snprintf(buf: ptr[void], size: i64, format: str, a1: ptr[void], a2: ptr[void]) -> i32
extern "C" fn remove(filename: ptr[void]) -> i32

fn print_inst(inst: AirInst):
    let op = inst.opcode
    if op == OP_NOP:
        return

    if op == OP_RETURN:
        if inst.src1 != 0 as u32:
            printf("    ret %%%d\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        else:
            puts("    ret")
    elif op == OP_JUMP:
        printf("    jump block_%d\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    elif op == OP_BRANCH:
        printf("    branch %%%d block_%d block_%d\n", inst.src1 as i64, inst.src2 as i64, inst.dest as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    else:
        let mnemonic = opcode_mnemonic(op)
        let has_dest = (inst.dest != 0 as u32)
        let has_src1 = (inst.src1 != 0 as u32)
        let has_src2 = (inst.src2 != 0 as u32)
        let is_binary = opcode_is_binary_alu(op)

        if has_dest:
            mut type_id := inst.type_id
            if op == OP_CALL or op == OP_INDEX or op == OP_DEREF or op == OP_CAST or op == OP_AWAIT:
                type_id = 0 as u16

            if type_id != 0 as u16:
                printf("    %%%d: t%d = %s", inst.dest as i64, type_id as i64, (mnemonic as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
            else:
                printf("    %%%d = %s", inst.dest as i64, (mnemonic as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        else:
            printf("    %s", (mnemonic as ptr[u8]) as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)

        if is_binary and has_src1 and has_src2:
            printf(" %%%d, %%%d\n", inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        elif has_src1 and has_src2:
            printf(" %%%d, %%%d\n", inst.src1 as i64, inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        elif has_src1:
            printf(" %%%d\n", inst.src1 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        elif has_src2:
            printf(" %%%d\n", inst.src2 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        else:
            puts("")

fn print_block(f: AirFunc, mut bb: BasicBlock):
    printf("  block_%d:", bb.id as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    if bb.is_entry and bb.is_exit:
        puts("  ; entry exit")
    elif bb.is_entry:
        puts("  ; entry")
    elif bb.is_exit:
        puts("  ; exit")
    else:
        puts("")

    mut i := 0 as i64
    while i < bb.instrs_len as i64:
        let inst_idx = f.block_instrs.data[bb.instrs_start as i64 + i]
        if inst_idx < f.insts.len as u32:
            let inst = f.insts.data[inst_idx as i64]
            print_inst(inst)
        i = i + 1

fn print_func(f: AirFunc):
    printf("fn @%d(", f.name as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    mut i := 0 as i64
    while i < f.params.len:
        if i > 0:
            printf(", ", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        printf("t%d", f.params.data[i] as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
        i = i + 1
    printf(")", 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    if f.ret_type != 0 as u32:
        printf(" -> t%d", f.ret_type as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64, 0 as i64)
    puts(":")

    mut bi := 0 as i64
    while bi < f.blocks.len:
        let bb = f.blocks.data[bi]
        print_block(f, bb)
        bi = bi + 1

fn print_module(mod: AirModule):
    mut i := 0 as i64
    while i < mod.funcs.len:
        if i > 0:
            puts("")
        print_func(mod.funcs.data[i])
        i = i + 1

pub fn main(argc: i32, argv: ptr[ptr[u8]]) -> i32:
    if argc < 2:
        puts("Usage: axc <command> [args]")
        puts("Commands:")
        puts("  dump-air <file.ax>")
        puts("  emit-c <file.ax> [-o <out.c>]")
        puts("  build <file.ax> [-o <out.exe>] [--target <wasm32|wasm32-unknown-unknown>]")
        return 1

    mut is_dump_air := false
    mut is_emit_c := false
    mut is_build := false
    mut file_arg_idx := 1
    mut output_file := ""
    mut target_wasm32 := false

    let arg1 = argv[1] as str
    if arg1 == "dump-air":
        if argc < 3:
            puts("Error: missing filename for dump-air")
            return 1
        is_dump_air = true
        file_arg_idx = 2
    elif arg1 == "emit-c":
        if argc < 3:
            puts("Error: missing filename for emit-c")
            return 1
        is_emit_c = true
        file_arg_idx = 2
    elif arg1 == "build":
        if argc < 3:
            puts("Error: missing filename for build")
            return 1
        is_build = true
        file_arg_idx = 2
    else:
        // Compatibility mode (backward-compatible with triple_build.ps1 verification loop)
        is_dump_air = true
        file_arg_idx = 1

    // Parse options starting after the file argument
    mut opt_idx := file_arg_idx + 1
    while opt_idx < argc:
        let opt = argv[opt_idx] as str
        if opt == "-o" or opt == "--output":
            if opt_idx + 1 < argc:
                output_file = argv[opt_idx + 1] as str
                opt_idx = opt_idx + 1
            else:
                puts("Error: missing value for -o option")
                return 1
        elif opt == "--target" or opt == "-target":
            if opt_idx + 1 < argc:
                let target_triple = argv[opt_idx + 1] as str
                if target_triple == "wasm32" or target_triple == "wasm32-unknown-unknown" or target_triple == "wasm":
                    target_wasm32 = true
                opt_idx = opt_idx + 1
            else:
                puts("Error: missing value for --target option")
                return 1
        opt_idx = opt_idx + 1

    let filename_ptr = argv[file_arg_idx]
    let file = fopen(filename_ptr as ptr[void], "rb")
    if file == null as ptr[void]:
        puts("Error: could not open file")
        return 1

    fseek(file, 0, 2) // SEEK_END = 2
    let size = ftell(file)
    rewind(file)

    if size < 0:
        puts("Error: could not get file size")
        fclose(file)
        return 1

    let buffer = @alloc(size + 1) as ptr[u8]
    if buffer == null as ptr[u8]:
        puts("Error: memory allocation failed")
        fclose(file)
        return 1

    let bytes_read = fread(buffer as ptr[void], 1, size, file)
    fclose(file)

    buffer[bytes_read] = 0 as u8

    let src = buffer as str

    // 1. Lex
    mut lexer := new_lexer(src)
    let tokens = lexer.tokenize()

    // 2. Parse
    mut pool := new_intern_pool()
    mut parser := new_parser(tokens, src, pool)
    parser.parse_program()

    // 3. Resolve
    mut symtable := new_symbol_table(parser.pool)
    mut resolver := new_name_resolver(parser.tree, parser.pool, symtable)
    resolver.resolve()

    // 4. Typecheck
    mut typetable := new_type_table()
    mut checker := new_type_checker(parser.tree, parser.pool, resolver.symtable, typetable)
    checker.run_type_checker()
    typetable = checker.types

    // 5. Memory Safety & Ownership pipeline (only if NOT in dump-air/compatibility mode!)
    if not is_dump_air:
        mut ownership_chk := new_ownership_checker(parser.tree, parser.pool, resolver.symtable, typetable)
        ownership_chk.check()

        mut escape_an := new_escape_analyser(parser.tree, parser.pool, resolver.symtable, typetable)
        escape_an.run()

        mut ctgc_inj := new_ctgc_injector(parser.tree, parser.pool, resolver.symtable, typetable)
        ctgc_inj.run()

        mut alias_opt := new_alias_reuse_optimizer(parser.tree, parser.pool, resolver.symtable, typetable)
        alias_opt.run()

    // 6. Build AIR
    mut air_builder_val := new_air_module_builder(parser.tree, resolver.symtable, typetable, parser.pool, checker.node_types)
    mut air_builder := &air_builder_val
    air_builder.build_module()

    // 7. Handle output phase
    if is_dump_air:
        print_module(air_builder.module)
    elif is_emit_c:
        mut cgen := new_c_generator(air_builder.module, parser.tree, air_builder.pool, resolver.symtable, typetable)
        if std.string.len(output_file) == 0:
            output_file = "output.c"
        let success = cgen.generate(output_file)
        if not success:
            puts("Error: could not generate C code")
            return 1
    elif is_build:
        if target_wasm32:
            mut wasm_gen := new_wasm_generator(air_builder.module, parser.tree, air_builder.pool, resolver.symtable, typetable)
            if std.string.len(output_file) == 0:
                output_file = "output.wat"
            let success = wasm_gen.generate(output_file)
            if not success:
                puts("Error: could not generate Wasm Text code")
                return 1
            
            @free(buffer)
            if tokens.data != null as ptr[Token]:
                @free(tokens.data as ptr[u8])
            if lexer.tokens.data != null as ptr[Token]:
                @free(lexer.tokens.data as ptr[u8])
            if lexer.indent_stack.data != null as ptr[i32]:
                @free(lexer.indent_stack.data as ptr[u8])
            if lexer.newline_offsets.data != null as ptr[i32]:
                @free(lexer.newline_offsets.data as ptr[u8])

            if parser.tree.nodes.data != null as ptr[AstNode]:
                @free(parser.tree.nodes.data as ptr[u8])
            if parser.tree.extras.data != null as ptr[i32]:
                @free(parser.tree.extras.data as ptr[u8])

            free_air_module_builder(air_builder)
            free_type_checker(checker)
            free_typetable(typetable)
            free_symtable(resolver.symtable)
            free_pool(parser.pool)
            return 0

        mut cgen := new_c_generator(air_builder.module, parser.tree, air_builder.pool, resolver.symtable, typetable)
        let temp_c = "axiom_temp.c"
        let success = cgen.generate(temp_c)
        if not success:
            puts("Error: could not generate C code")
            return 1

        if std.string.len(output_file) == 0:
            output_file = "output.exe"

        // Compile using gcc
        let cmd_buf = @alloc(2048) as ptr[u8]
        let output_file_nt = str_to_null_terminated(output_file)
        let temp_c_nt = str_to_null_terminated(temp_c)

        snprintf(cmd_buf as ptr[void], 2048, "gcc -O2 -o %s %s -Iruntime runtime/axalloc/axalloc.c runtime/panic/panic.c runtime/ax_assert.c runtime/ax_collections.c runtime/ax_math.c runtime/ax_print.c runtime/ax_string_ops.c", output_file_nt as ptr[void], temp_c_nt as ptr[void])

        let status = system(cmd_buf as ptr[void])

        // Clean up
        // remove(temp_c_nt as ptr[void])
        @free(output_file_nt)
        @free(temp_c_nt)
        @free(cmd_buf)

        if status != 0:
            puts("Error: C compilation failed")
            return status

    // Free resources
    @free(buffer)
    if tokens.data != null as ptr[Token]:
        @free(tokens.data as ptr[u8])
    if lexer.tokens.data != null as ptr[Token]:
        @free(lexer.tokens.data as ptr[u8])
    if lexer.indent_stack.data != null as ptr[i32]:
        @free(lexer.indent_stack.data as ptr[u8])
    if lexer.newline_offsets.data != null as ptr[i32]:
        @free(lexer.newline_offsets.data as ptr[u8])

    if parser.tree.nodes.data != null as ptr[AstNode]:
        @free(parser.tree.nodes.data as ptr[u8])
    if parser.tree.extras.data != null as ptr[i32]:
        @free(parser.tree.extras.data as ptr[u8])

    free_air_module_builder(air_builder)
    free_type_checker(checker)
    free_typetable(typetable)
    free_symtable(resolver.symtable)
    free_pool(parser.pool)

    return 0