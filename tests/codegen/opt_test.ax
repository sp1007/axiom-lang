// tests/codegen/opt_test.ax
// Direct test for O1 SSA optimizations (constant folding, copy propagation, DCE).

pub fn test_fold() -> i32:
    let a = 10 + 20
    let b = a * 2
    return b

pub fn test_copy_prop() -> i32:
    let x = 42
    let y = x
    let z = y
    return z

pub fn test_dce() -> i32:
    let dead_var = 100 * 200
    return 1

pub fn main() -> i32:
    let r1 = test_fold()
    let r2 = test_copy_prop()
    let r3 = test_dce()
    return r1 + r2 + r3
