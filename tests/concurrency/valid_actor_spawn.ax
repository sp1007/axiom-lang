extern "C" fn putchar(c: i32) -> i32

fn my_actor_handler(self: ptr[void], payload: ptr[void], msg_type: u32):
    putchar(72) // 'H'
    putchar(10) // '\n'

fn main() -> i32:
    let actor_id = spawn my_actor_handler(0 as ptr[void], 0 as ptr[void], 0 as u32)
    putchar(83) // 'S'
    putchar(10) // '\n'
    return 0
