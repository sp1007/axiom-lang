// Đây là comment tiếng Việt chứa các ký tự UTF-8 đặc biệt: á, à, ả, ã, ạ, đ, ê, ô, ư
fn main():
    // 1. Kiểm tra String chứa UTF-8
    let test_str = "Xin chào thế giới AXIOM! Tiếng Việt có các ký tự: áàảãạđêôư"
    println(test_str)

    // 2. Kiểm tra Char Literal chứa UTF-8
    // Mặc dù kiểu primitive là char8 (lấy byte đầu tiên), lexer và parser vẫn phải parse thành công không lỗi.
    let c1 = 'đ'
    let c2 = 'á'
    let c3 = 'A' // ASCII tiêu chuẩn

    println("Đã parse thành công các ký tự UTF-8!")
