fn ops_040_ci_cd_task_runner():
    // Axiom dùng làm ngôn ngữ viết script CI/CD do compile siêu nhanh
    fn build_task():
        assert(process.exec("axc", ["build", "main.ax"]).exit_code == 0)
    build_task()