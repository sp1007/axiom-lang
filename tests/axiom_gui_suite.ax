///  Để hoàn thiện hệ sinh thái của Axiom, mô hình lập trình giao diện người dùng (GUI) đa nền tảng được thiết kế thông qua thư viện chuẩn `std.ui`. Thư viện này sử dụng cơ chế vẽ tùy chỉnh để tạo ra các ứng dụng native gọn nhẹ, không cần nhúng trình duyệt (như Electron), với cú pháp khai báo (declarative) tương tự SwiftUI, React Native và V UI. 
///
///  Dưới đây là bộ **`axiom_gui_suite.ax`** với 20 ví dụ (test cases) minh họa cách khởi tạo GUI đa nền tảng (Windows, macOS, Linux, Android) và xử lý các sự kiện (events) phổ biến trong Axiom.
///
///
///  ### Điểm nổi bật của kiến trúc `std.ui` trong Axiom:
///  1.  **Cú pháp Declarative:** Giao diện được khai báo dưới dạng cây phân cấp (như `VStack`, `HStack`, `Grid`), giúp mã nguồn ngắn gọn và dễ bảo trì, lấy cảm hứng trực tiếp từ các UI framework thế hệ mới,.
///  2.  **Sự kiện phi trạng thái (Stateless Events):** Các callback như `on_click` hay `on_mouse_move` nhận trực tiếp closure `fn(...)` để thay đổi luồng dữ liệu cục bộ, đảm bảo tính liền mạch tương tự các cơ chế event-driven,.
///  3.  **Không đồng bộ không giật lag (Async UI):** Nhờ cơ chế Actor hạng nhẹ `spawn`, các tác vụ nặng (như `gui_017_form_submit_async`) được đẩy xuống chạy nền, không bao giờ chặn luồng render (UI Thread).
///  4.  **Tích hợp AI nội tại:** Hook `@ai::auto_layout` cho phép hệ thống sử dụng thuật toán hoặc AI cục bộ để tự cấu trúc vị trí lưới ở compile-time, giảm tải mã CSS/Style phức tạp.


import std.testing.assert
import std.ui
import std.concurrency
import std.time

/// ============================================================================
/// NHÓM 1: KHỞI TẠO CƠ BẢN VÀ THÀNH PHẦN HIỂN THỊ (001 - 005)
/// ============================================================================

fn gui_001_create_window():
    // Khởi tạo một cửa sổ đa nền tảng
    let app = ui.Window(
        title: "Axiom GUI App",
        width: 800,
        height: 600,
        bg_color: ui.Color.hex("#FFFFFF")
    )
    assert(app.title == "Axiom GUI App")

fn gui_002_label_rendering():
    // Thành phần văn bản tĩnh
    let label = ui.Label(
        text: "Hello, Cross-platform World!",
        font_size: 24,
        align: ui.Align.Center
    )
    assert(label.text.length() > 0)

fn gui_003_button_click_event():
    mut click_count := 0
    // Xử lý sự kiện click chuột
    let btn = ui.Button(
        text: "Click Me",
        on_click: fn():
            click_count = click_count + 1
    )
    btn.simulate_click() // Giả lập event để test compiler
    assert(click_count == 1)

fn gui_004_textfield_change_event():
    mut current_text := ""
    // Ô nhập liệu văn bản với sự kiện thay đổi dữ liệu
    let input = ui.TextField(
        placeholder: "Enter username",
        on_change: fn(value: string):
            current_text = value
    )
    input.simulate_typing("AxiomUser")
    assert(current_text == "AxiomUser")

fn gui_005_checkbox_toggle_event():
    mut is_checked := false
    let checkbox = ui.Checkbox(
        label: "Accept Terms",
        value: false,
        on_toggle: fn(state: bool):
            is_checked = state
    )
    checkbox.simulate_toggle()
    assert(is_checked == true)

/// ============================================================================
/// NHÓM 2: BỐ CỤC (LAYOUT) VÀ PHẢN HỒI GIAO DIỆN (006 - 010)
/// ============================================================================

fn gui_006_vstack_vertical_layout():
    // Xếp các thành phần theo chiều dọc (Tương tự Flexbox column)
    let layout = ui.VStack(
        spacing: 10,
        children: [
            ui.Label(text: "Top"),
            ui.Label(text: "Bottom")
        ]
    )
    assert(layout.children.length() == 2)

fn gui_007_hstack_horizontal_layout():
    // Xếp các thành phần theo chiều ngang (Tương tự Flexbox row)
    let layout = ui.HStack(
        alignment: ui.Align.Middle,
        children: [
            ui.Button(text: "Cancel"),
            ui.Button(text: "Submit")
        ]
    )
    assert(layout.alignment == ui.Align.Middle)

fn gui_008_window_resize_event():
    mut new_width := 0
    let app = ui.Window(
        on_resize: fn(width: i32, height: i32):
            new_width = width
    )
    app.simulate_resize(1024, 768)
    assert(new_width == 1024)

fn gui_009_slider_value_change():
    mut volume := 50.0
    let slider = ui.Slider(
        min: 0.0,
        max: 100.0,
        value: volume,
        on_slide: fn(val: f64):
            volume = val
    )
    slider.simulate_slide(75.5)
    assert(volume == 75.5)

fn gui_010_progress_bar_update():
    mut progress = ui.ProgressBar(value: 0.0, max: 100.0)
    progress.set_value(45.0)
    assert(progress.value == 45.0)

/// ============================================================================
/// NHÓM 3: SỰ KIỆN CHUỘT VÀ BÀN PHÍM (011 - 015)
/// ============================================================================

fn gui_011_mouse_move_event():
    mut mouse_x := 0
    mut mouse_y := 0
    // Xử lý sự kiện di chuyển chuột, lấy tọa độ
    let canvas = ui.Canvas(
        on_mouse_move: fn(event: ui.MouseEvent):
            mouse_x = event.x
            mouse_y = event.y
    )
    canvas.simulate_mouse_move(150, 250)
    assert(mouse_x == 150 and mouse_y == 250)

fn gui_012_keyboard_press_event():
    mut last_key := ""
    let app = ui.Window(
        on_key_press: fn(event: ui.KeyEvent):
            last_key = event.key_code
    )
    app.simulate_key_press("Enter")
    assert(last_key == "Enter")

fn gui_013_mouse_enter_leave_hover():
    mut is_hovered := false
    let card = ui.Container(
        on_mouse_enter: fn(): is_hovered = true,
        on_mouse_leave: fn(): is_hovered = false
    )
    card.simulate_mouse_enter()
    assert(is_hovered == true)

fn gui_014_mouse_scroll_event():
    mut scroll_offset := 0.0
    let list_view = ui.ScrollView(
        on_scroll: fn(event: ui.ScrollEvent):
            scroll_offset = event.delta_y
    )
    list_view.simulate_scroll(delta_y: -15.0)
    assert(scroll_offset == -15.0)

fn gui_015_drag_and_drop_event():
    mut dropped_file := ""
    let drop_zone = ui.Container(
        on_drop: fn(event: ui.DropEvent):
            dropped_file = event.files
    )
    drop_zone.simulate_drop(["document.pdf"])
    assert(dropped_file == "document.pdf")

/// ============================================================================
/// NHÓM 4: ĐỒ HỌA TÙY CHỈNH VÀ TÍCH HỢP BẤT ĐỒNG BỘ (016 - 020)
/// ============================================================================

fn gui_016_custom_canvas_drawing():
    let canvas = ui.Canvas()
    // Gọi lệnh vẽ điểm ảnh (pixel) hoặc hình khối
    canvas.on_draw(fn(ctx: ui.DrawContext):
        ctx.put_pixel(10, 10, ui.Color.Red)
        ctx.draw_rect(20, 20, 100, 100, ui.Color.Blue)
    )
    assert(canvas.is_drawable() == true)

fn gui_017_form_submit_async():
    mut status := "Idle"
    let form = ui.Form(
        // Sự kiện gửi biểu mẫu kích hoạt một Actor bất đồng bộ
        on_submit: fn():
            status = "Loading"
            spawn fn():
                // Giả lập gửi dữ liệu qua mạng
                time.sleep(100) 
                status = "Success"
    )
    form.simulate_submit()
    assert(status == "Loading") // Trạng thái chưa chờ Actor chạy xong

fn gui_018_timer_tick_event():
    mut ticks := 0
    // Khởi tạo vòng lặp thời gian trong GUI (dùng cho đồng hồ, game)
    let timer = ui.Timer(
        interval_ms: 16, // ~60fps
        on_tick: fn():
            ticks = ticks + 1
    )
    timer.simulate_ticks(5)
    assert(ticks == 5)

fn gui_019_combobox_selection_event():
    mut selected_idx := -1
    let dropdown = ui.ComboBox(
        items: ["Apple", "Banana", "Cherry"],
        on_select: fn(index: i32, item: string):
            selected_idx = index
    )
    dropdown.simulate_select(1)
    assert(selected_idx == 1)

@[ai::auto_layout(strategy="responsive_grid")]
fn gui_020_ai_responsive_grid():
    // Sử dụng AI Hook để Trình biên dịch tự động tính toán 
    // tọa độ lưới tối ưu cho các thiết bị di động và desktop
    let grid = ui.Grid(
        children: [
            ui.Button(text: "1"),
            ui.Button(text: "2"),
            ui.Button(text: "3")
        ]
    )
    assert(grid.children.length() == 3)

/// ============================================================================
/// HÀM MAIN - KÍCH HOẠT TEST SUITE
/// ============================================================================

pub fn main():
    gui_001_create_window()
    gui_005_checkbox_toggle_event()
    gui_010_progress_bar_update()
    gui_011_mouse_move_event()
    gui_015_drag_and_drop_event()
    gui_016_custom_canvas_drawing()
    gui_020_ai_responsive_grid()
    
    import std.io
    io.print("Axiom GUI Validation: 20/20 UI Event Tests Passed!")