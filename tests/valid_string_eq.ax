fn main() -> i32:
    let a = "hello"
    let b = "hello"
    let c = "world"
    
    if a == b:
        println("a == b holds (PASS)")
    else:
        println("a == b failed (FAIL)")
        
    if a != c:
        println("a != c holds (PASS)")
    else:
        println("a != c failed (FAIL)")
        
