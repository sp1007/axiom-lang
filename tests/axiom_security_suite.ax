import std.testing.assert
import std.crypto
// Yêu cầu quyền đọc hệ thống tệp tại Compile-time
import std.fs { read, write } 

fn sec_051_capability_based_permissions():
    // Hàm này chỉ chạy được nếu module xin cấp quyền `read` ở trên.
    // Nếu dùng `fs.delete` sẽ bị compiler chặn (do chưa xin quyền).
    let data = fs.read_string("axiom.toml")
    assert(data.length() > 0)

fn sec_052_password_hashing_argon2():
    let pwd = "SuperSecretPassword"
    let salt = crypto.random_bytes(16)
    let hash = crypto.argon2(pwd, salt)
    assert(hash.length() > 0)

fn sec_053_aes_gcm_encryption():
    let key = crypto.random_bytes(32) // AES-256
    let nonce = crypto.random_bytes(12)
    let (ciphertext, tag) = crypto.aes_gcm_encrypt("Secret Data", key, nonce)
    assert(ciphertext.length() > 0)

fn sec_054_aes_gcm_decryption():
    // Giả lập từ test case trên
    assert(true)

fn sec_055_secure_memory_wipe():
    mut sensitive_key := "DoNotLeakThis12345"
    // C23 memset_explicit tương đương: Đảm bảo compiler không tối ưu hóa lệnh xóa này
    crypto.secure_wipe(sensitive_key)
    assert(sensitive_key != "DoNotLeakThis12345")

fn sec_056_rsa_key_generation():
    // let (pub_key, priv_key) = crypto.rsa_generate_keys(2048)
    assert(true)

fn sec_057_digital_signature_verification():
    // let signature = crypto.sign(data, priv_key)
    // assert(crypto.verify(data, signature, pub_key) == true)
    assert(true)

fn sec_058_timing_attack_safe_compare():
    let hash_a = "abcdef123456"
    let hash_b = "abcdef123456"
    // So sánh thời gian hằng số (Constant-time compare), chống Hacker đo đạc độ trễ
    assert(crypto.constant_time_eq(hash_a, hash_b) == true)

fn sec_059_csprng_random_generation():
    // Sinh số ngẫu nhiên an toàn mật mã thay vì rand() chuẩn
    let token = crypto.secure_random_hex(32)
    assert(token.length() == 64)

fn sec_060_jwt_creation():
    import std.net.jwt
    let secret = "secret_key"
    let payload = {"user_id": "100"}
    let token = jwt.sign(payload, secret, alg: jwt.Alg.HS256)
    assert(token.starts_with("eyJ"))